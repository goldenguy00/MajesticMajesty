///////////////////////////////////////////////////////////////////////////////
function Palace_Death(agent ThisAgent)

declare
	integer gold;
	list flags;
	agent AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	gold = $getplayerdata(thisagent,"gold");
	$adjustplayerdata(thisagent,"gold",0 - gold);
	$dropgoldeveryone(thisagent,gold);

	// clear all flags of this player
	$listobjects(thisagent,"rewardFlag",-1,flags,#rewardflags,#Myplayer,#NoHiddenMap);

	while ($listsize(flags) > 0) do
		$removelistmember(flags,1);

  	thisagent's "type" = "Dead";

	$release_occupants(thisagent);

	$performaction( thisagent,"Become_Rubble",thisagent );

	if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
		if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
			$Player_Dead_Cleanup ( thisagent );

	$declareloss(thisagent);

	$deleteagent(thisagent);

end

///////////////////////////////////////////////////////////////////////////////
function Player_Dead_Cleanup ( agent thisagent )
// This function removes flags and destroys all buildings belonging to the player.
declare
	agent unit, palace;
	list units;

begin

	$listobjects ( thisagent, "rewardFlag", -1, units, #rewardflags, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			$deletegamepiece ( unit );
		end

	$ListObjects ( thisagent, "building", -1, units, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			if ( $IsDead ( unit ) == FALSE )
				$SetAttribute ( unit, #ATTRIB_HP, -1 );
		end

	$ListObjects ( thisagent, "lair", -1, units, #Myplayer, #NoHiddenMap );
	foreach unit in units do
		begin
			if ( $IsDead ( unit ) == FALSE )
				( unit's "IGDeathScript" )( unit );
		end
end

///////////////////////////////////////////////////////////////////////////////
function dropgoldeveryone(agent thisagent, integer amount)

// this is for when a palace dies, it gives out all the treasury gold to nearby
// heroes and monsters

declare
	list guysnearby,newguys,monstersnearby;
	agent guy;
	integer num_guys,goldper;

begin
	$ListObjects(thisagent,"hero",#gold_drop_radius * 2, guysnearby );

	foreach guy in guysnearby do
		begin
			//if (($getsubtype(guy) != "henchman"))
			  //	if ($GetSubtype (Guy) != "Controlled")
			If (Guy's "Subtype" == "Hero")
				begin
					newguys << guy;
				end
		end

	guysnearby = newguys;

	$listobjects(thisagent,"monster",#gold_drop_radius * 2,monstersnearby);

	guysnearby = $addlists(guysnearby,monstersnearby);

	num_guys = $listsize(guysnearby);

	if (num_guys > 0)
		begin
			goldper = (amount / num_guys);
			foreach guy in guysnearby do
				$give_gold(guy,goldper);
		end

end

///////////////////////////////////////////////////////////////////////////////
function gnome_camp_destroyed(agent thisagent)

declare
	agent palace;
	list	hovels;

begin
	palace = $getpalace(thisagent);

	If ($NotValid (Palace) == False)
		begin

			$ListObjects (ThisAgent, "Building", -1, Hovels, #MyPlayer);

			Hovels = $ListTitles (Hovels, "Gnome_Hovel");

			//If this is the last Hovel, then kill the Hovel spawn script, and don't spawn another one.
			If ($ListSize (Hovels) == 0)
				begin
					If ($IsRunning (Palace's "Gnome_Camp_Spawner"))
						begin

							$KillThread (Palace's "Gnome_Camp_Spawner");

						end
				end

			//Otherwise, see if we want to run it again.
			Else
				begin
					If ($isrunning(palace's "gnome_camp_spawner") == FALSE)
						$runthread(palace's "gnome_camp_spawner",#gnome_camp_delay,palace);

				end
		end

	$guild_destroyed_2(thisagent);
end


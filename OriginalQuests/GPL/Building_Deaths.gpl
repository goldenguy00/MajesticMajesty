///////////////////////////////////////////////////////////////////////////////
function release_occupants(agent thisagent)

declare
	list guys;
	agent guy;

begin
	// release anyone inside the building
	if ($hasattribute("occupants",thisagent))
		if ($listsize(thisagent's "occupants") > 0)
			begin
				guys = thisagent's "occupants";
				foreach guy in guys do
					begin
						if ($isvalidgamepiece(guy))
							$exit_building(guy,thisagent);
		//					$debugout("occupant left building in a paniced state.");
					end
				$clearlist(thisagent's "occupants");
			end
end

///////////////////////////////////////////////////////////////////////////////
function guild_destroyed_common(agent thisagent,function no_where_script)

declare
	agent member,guild,guy;
	list other_guilds,new_list,guys,homeless_members,other_players,op_new_list,working_list;

begin
	// inform guild members of their guild's death

	$release_occupants(thisagent);

	$ListObjects(thisagent,"building",-1,other_guilds,#MyPlayer);
	other_guilds = $listtitles(other_guilds,thisagent's "title");

	$listObjects(thisagent,"Building",-1,other_players,#NotMyPlayer);
	other_players = $listtitles(other_players,thisagent's "title");

	$clearlist(op_new_list);

	$clearlist(new_list);

	// try to give all members a home with the same player
	// if they don't get a home - put them on a list to check for
	// possible homes with another player

	// remove all 'full' guilds from consideration
	if ($listsize(other_guilds) > 0)
		begin
			foreach guild in other_guilds do
				begin
					// check to see if the guild has any free slots
					if ($GuildHasOpenSlots( guild ))
						new_list << guild;
				end
		end

	foreach guild in other_players do
		begin
			if ($GuildHasOpenSlots( guild ))
				op_new_list << guild;
		end


	// remove dead guild members from thisagent
	// just so we avoid potential errors
	Foreach Member in ThisAgent's "Members" do
		begin
			If ($IsDead (Member) == False)
				Working_List << Member;
		end

	ThisAgent's "Members" = Working_list;


	// check each member to see what they should do.
	foreach member in working_list do
		begin
//			if (member != $nullagent())

//				if ($isdead(member))
//					begin
//						$deletegamepiece(member);
//					end
//				else
					if ($listsize(new_list) == 0)
						begin
							// no where else to go on this player's team!
							if ($listsize(op_new_list) > 0)
								begin
									if ($randomnumber(100) > member's "loyalty")
										begin
											guild = $listmember(op_new_list,1);
											$adopt(guild,member);

											if ($listsize(guild's "members") == guild's "max_members")
												$removelistmember(op_new_list,1);
										end
									else
										homeless_members << member;
								end
							else
								homeless_members << member;
						end
					else
						begin
							// add the guy to the other guild
							guild = $listmember(new_list,1);
							$adopt(guild,member);

							// is this guild is full
							if ($GuildHasOpenSlots( guild ) == FALSE)
								$removelistmember(new_list,1);
						end
		end

	foreach member in homeless_members do
		begin
			member's "BasicScript" = no_where_script;
			member's "ActiveScript" = no_where_script;
			member's "Home" = $nullagent();
		end

   $building_death( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
function GuardHouse_Death (agent ThisAgent)
Declare
	agent	Guard;
	agent Solarus;

Begin
	thisagent's "type" = "Dead";

	Foreach Guard in ThisAgent's "Guards" do
		begin
			If ($IsHidden (Guard))
				begin
					Guard's "Type" = "Hero";
					$UnHide (Guard);
				end

			Guard's "ActiveScript" = $Guard_Goto_Palace;
			Guard's "BasicScript" = $Guard_Goto_Palace;
			Guard's "BackScript" = $Guard_Goto_Palace;
			$ResumeThread (Guard's "ActiveScript");
		end

	Foreach Solarus in ThisAgent's "Occupants" do
		begin
			$Exit_Building (Solarus, ThisAgent);

		end

        $building_death( thisagent );
End

///////////////////////////////////////////////////////////////////////////////
// Death function for "Slay the Mighty Dragon" quest's building, Hidden_Sword_Site
Function Hidden_Sword_Death (agent ThisAgent)
declare
	agent RootAgent;

begin
	//$DebugOut (911, "In Hidden sword death");

	RootAgent = $RetrieveAgent("GplAIRoot");

	thisagent's "type" = "Dead";

	//$DebugOut (911, "Killing spawn function");
	$killthread(thisagent's "Spawn_function");

	//$DebugOut (911,"Seeing if special spawn type is valid. If so, spawning");
	If (ThisAgent's "Special_Spawn_Type" != "xx")
		$SpawnUnit (ThisAgent, ThisAgent's "Special_Spawn_Type", $LocationOf (ThisAgent), "Override");

	//$DebugOut (911, "Dropping gold...");
	$dropgoldinradius(thisagent,$getattribute(thisagent,#ATTRIB_gold));

	//Drop the magic sword
	//ThisAgent's "Epic_Quest_Item" = #QItem_Magic_Sword;
	$CreateNewInventoryItem (#QItem_Magic_Sword, ThisAgent);

	$Drop_Qitems (ThisAgent);

	$MessageFlag ($LocationOf(ThisAgent), #message_slay_dragon_sword_site_dead);

	//Enable the Dwarven Settlement, so that the player can build it in order to give the magic sword to each of the
	//Heroes (The Dwarven Settlement will automatically clone the sword)
	$Enableunittype("Dwarven_Settlement");

	//$DebugOut (911, "Hidden sword death: abouth to Building_Death");

	$building_death( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
// Death function for "Quest for the Magic Ring" quest's building, Hidden_Ring_Site
Function Hidden_Ring_Death (agent ThisAgent)
declare
	agent 	RootAgent;
	integer  Counter;

begin
	RootAgent = $RetrieveAgent("GplAIRoot");

	thisagent's "type" = "Dead";

	//$DebugOut (911, "Killing spawn function");
	$killthread(thisagent's "Spawn_function");

	//$DebugOut (911, "Dropping gold...");
	$dropgoldinradius(thisagent,$getattribute(thisagent,#ATTRIB_gold));

	//If this is false, then this is the first magic ring site, and it has to drop the ring.
	If (RootAgent's "Quest_Flag_1" == False)

		begin
			//Drop the Magic Ring, and make it so Player 1 and 2 are now at war

			$Drop_Qitems (ThisAgent);

			Counter = 1;

			While (Counter <= #Blk_Phants_Spawned_In_Magic_Ring) do
				begin
					$SpawnUnit (ThisAgent, "Black_Phantom", "override");
	      		Counter ++;
	   		end

			RootAgent's "Quest_Flag_1" = True;

			$MessageFlag ($LocationOf (ThisAgent), #Message_Magic_Ring_Found_Ring);

		end

	$building_death( thisagent );
end


///////////////////////////////////////////////////////////////////////////////
// This function cleans up the Palace's Constuction Lists, to make sure their aren't invalid agents on it
// when a building dies.
Function Clean_Palace_Construction_Lists (agent ThisAgent)
Declare
	agent Palace;

Begin
	 Palace = $GetPalace (ThisAgent);

	 If ($IsValidGamePiece (Palace))
		begin
			If ($AgentInList (ThisAgent, Palace's "Buildings_Waiting"))
				Palace's "buildings_waiting" -= ThisAgent;

			If ($AgentInList (ThisAgent, Palace's "Buildings_Under_Construction"))
				Palace's "buildings_under_construction" -= ThisAgent;
		end
End

///////////////////////////////////////////////////////////////////////////////
// Death function for "Free the Slaves" quest's building, Slave_Pits
function slave_pits_death(agent thisagent)

declare
	list crosses,palaces,pits;
	agent cross,palace,pit;
	integer i,edge;

begin
	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	// release the slaves from the slave crosses
	$listobjects(thisagent,"Mystery",400,crosses);
	foreach cross in crosses do
		begin
			$setattribute(cross,#ATTRIB_ForceBuildingState,#building_force_active);
			$killthread(cross's "activescript");
			$killthread(cross's "spawn_function");

			//Take the cross off the minimap
			$ShowMinimap (cross, False);

			//Make it so the slave cross no longer plays its selection sound
			$SetAttribute (Cross, #ATTRIB_InhibitSelectionSound, 1);

			$spawnunit(cross,$random_hero(),$getunitplayernumber(palace));
		end

	$messageflag($LocationOf (thisagent),#message_slaves_freed);

	$listobjects(thisagent,"lair",-1,pits,#NoHiddenMap);
	pits = $listtitles(pits,"Slave_pits");

	i = $listsize(pits);
	if ( i == 2 )
		begin
			// send out a wave of raiders if 2 pits are left
			edge = $randomnumber(4);
			i = 7;
			while (i > 0) do
				begin
					// the main invasion force
					$spawnunit(palace,"ratman",$RandomedgeCoord(edge),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
					$spawnunit(palace,"Giant_rat",$RandomedgeCoord(edge),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
					$spawnunit(palace,"Giant_rat",$RandomedgeCoord(edge),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));

					// extra ratmen and rats at random spots
					$spawnunit(palace,"ratman",$randomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
					$spawnunit(palace,"Giant_rat",$randomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
					i -= 1;
				end
		end
	else
	if ( i == 1 )
		begin
			// do something special when only one pit is left.
			pit = $listmember(pits,1);
			$spawnunit(pit,"minotaur",#monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian),"override");
			$spawnunit(pit,"minotaur",#monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian),"override");
			$spawnunit(pit,"medusa",#monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian),"override");
			$spawnunit(pit,"medusa",#monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian),"override");
			$spawnunit(pit,"minotaur",#monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian),"override");
		end

	$lair_death(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function random_hero() is string

declare
	string what_hero;
	integer x;

begin
	x = $randomnumber(10);

	what_hero = "gnome";

	if (x == 0)
		what_hero = "paladin";
	else
	if (x == 1)
		what_hero = "warrior_of_discord";
	else
	if (x == 2)
		what_hero = "Priestess";
	else
	if (x == 3)
		what_hero = "healer";
	else
	if (x == 4)
		what_hero = "warrior";
	else
	if (x == 5)
		what_hero = "ranger";

	return what_hero;
end

///////////////////////////////////////////////////////////////////////////////
Function Respawning_Lair_Death (agent ThisAgent)
declare
	agent hero;
	list heroes;

begin
  	thisagent's "type" = "Dead";

	//This Lair can't be flagged or cast on till it respawns, and it doessn't show up on the minimap
	$SetAttribute (ThisAgent, #ATTRIB_NotFlaggable, 1);
	$SetAttribute (ThisAgent, #ATTRIB_NotSpellTarget, 1);
	$ShowMinimap (ThisAgent, False);


	$killthread (thisagent's "spawn_function");

	$killthread(thisagent's "activescript");

	If (ThisAgent's "Special_Spawn_Type" != "xx")
		$SpawnUnit (ThisAgent, ThisAgent's "Special_Spawn_Type", $LocationOf (ThisAgent), "Override");

	$dropgoldinradius(thisagent,$getattribute(thisagent,#ATTRIB_gold));

	$SetAttribute (ThisAgent, #Attrib_Gold, 0);

	// check for special weapons and armor to be dropped
	$ListObjects(thisagent,"hero",#GOLD_drop_radius, heroes );

	foreach hero in heroes do
		begin
			//if (($getsubtype(hero) != "henchman"))
			  //	if ($GetSubtype (hero) != "Controlled")

			//Make sure this is a real Hero
			If (Hero's "SubType" == "Hero")
			 	begin
					$chance_weapon(thisagent,hero);
					$chance_armor(thisagent,hero);
				end
		end

	$Drop_QItems (ThisAgent);

	ThisAgent's "Type" = "Dead";

	//Have the Lair wake up in X ms
	ThisAgent's "ActiveScript" = $Respawn_Lair;

	$RunThread (ThisAgent's "ActiveScript", $RandomNumber (30000) + 400000 , ThisAgent);
end

///////////////////////////////////////////////////////////////////////////////
// This deathscript just makes a lair specific message and then calls Lair Death
// for Brashnard's Sphere
Function Sphere_Death (agent ThisAgent)
Declare
	list	Spheres;
	agent	AIRootAgent;

Begin
	$ListObjects (ThisAgent, "Lair", -1, Spheres, #NoHiddenMap);

	Spheres = $ListTitles (Spheres, "Brashnards_Sphere");

	If ($ListSize (Spheres) == 6)
		$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_1);

	Else if ($ListSize (Spheres) == 5)
		$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_2);

	Else if ($ListSize (Spheres) == 4)
		$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_3);

	Else if ($ListSize (Spheres) == 3)
		$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_4);

	Else if ($ListSize (Spheres) == 2)
		begin

			$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_5);

			//Spawn a slew of baddies on one of the map edges
			$spawnunit(ThisAgent,"Zombie",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Zombie",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Zombie",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Zombie",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Zombie",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Rust_Spitter",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Rust_Spitter",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Rust_Spitter",$RandomedgeCoord(#North),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Rust_Spitter",$RandomedgeCoord(#North),"Override",#Monster_player);


			$spawnunit(ThisAgent,"Skeleton",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Skeleton",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Skeleton",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Skeleton",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Skeleton",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Giant_Spider",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Giant_Spider",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Giant_Spider",$RandomedgeCoord(#South),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Giant_Spider",$RandomedgeCoord(#South),"Override",#Monster_player);

		end

	Else if ($ListSize (Spheres) == 1)
		begin
			AIRootAgent = $RetrieveAgent ("GPLAIRoot");

			//Stop playing current music, and play the last music track
			$Play_Endgame_Music (AIRootAgent);

			$MessageFlag ($LocationOf (ThisAgent), #message_brash_sphere_6);

			//Spawn a slew of baddies on one of the map edges
			//Spawn a slew of baddies on one of the map edges
			$spawnunit(ThisAgent,"Troll",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Troll",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Troll",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Troll",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Troll",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#West),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#West),"Override",#Monster_player);

			$spawnunit(ThisAgent,"Minotaur",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Minotaur",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Minotaur",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Minotaur",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Minotaur",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#East),"Override",#Monster_player);
			$spawnunit(ThisAgent,"Ratman",$RandomedgeCoord(#East),"Override",#Monster_player);


			//Also spawn 2 Guardian Rock_Golems around the last sphere site.
			$spawnunit(ThisAgent,"Rock_Golem",$LocationOf ($ListMember (Spheres,1)) ,"Override",#Monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian));
			$spawnunit(ThisAgent,"Rock_Golem",$LocationOf ($ListMember (Spheres,1)) ,"Override",#Monster_player,$concatenate(#ATTRIB_Artifice,#force_guardian));



		end

	//Have the lair do a Multispawn
	ThisAgent's "Multi_Spawn_Num" = 5;
	$Lair_Multispawn_Death (ThisAgent);

End
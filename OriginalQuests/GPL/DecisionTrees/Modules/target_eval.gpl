///////////////////////////////////////////////////////////////////////////////
function target_eval( agent attacker, agent defender) is integer
/// this function
/// evaluates the desire of 'attacker' to
/// engage in combat with 'defender'
//

declare

	integer score;
	list thislist;
//	integer hitstokill;
//	integer hitstildead;

begin
	// first get a rough time estimate of how long it will take
	// attacker to kill defender

	// then modify it by distance
	// and attacker's combat variables, + intelligence

	thislist << defender;

	score = $list_eval(attacker,thislist);

	// modify scores by distance between agents
	score -= ($distancebetweenagents(attacker,defender) / 250);

	return score;
end


///////////////////////////////////////////////////////////////////////////////
function eval_enemies_nearby(agent thisagent) is Boolean

declare
	agent new_target,target;
	boolean flaggie;

begin

	$list_enemies(thisagent,1);

	if ($listsize(thisagent's "Hostiles") == 0) return FALSE;

	// add thisagent's target back onto the list, if neccessary????

	// decide whether to run or not
	if ($should_I_Run(thisagent,thisagent's "Hostiles") == FALSE)
		begin
			flaggie = FALSE; // thisagent does not have a new target

			target = thisagent's "target";
			new_target = $pick_closest(thisagent,thisagent's "Hostiles");

			// if thisagent's target is a building or lair,
			// they should just pick the closest enemy

			// if there is a target closer than thisagent's
			// current target - pick a new target
			if (($isvalidgamepiece(Target) == FALSE) || (Target == ThisAgent))
				flaggie = TRUE;
			else
				begin
					if ((target's "type" == "lair") || (target's "type" == "building"))
						flaggie = TRUE;
					if (($distanceBetweenAgents(thisagent,new_target) <
					$distanceBetweenAgents(thisagent,Target)))
						flaggie = TRUE;
				end

			if (flaggie)
				begin
					$stopmoving(thisagent);
					thisagent's "Target" = new_target;

					//Say See Hostile voice line if Target's "Type" is monster
					If (New_Target's "Type" == "Monster")
						$Say (ThisAgent, "VFX_See_Hostile");

					$SpecifyIntent (ThisAgent, #intent_fighting);
					thisagent's "ActiveScript" = $attack_object;
				end

			return Flaggie;
		end
	else
		begin
			// hero has decided to run!

			// empty thisagent's Hostiles list
			$clearlist(thisagent's "Hostiles");
			return TRUE;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Healer_Eval_Nearby (agent ThisAgent) is Boolean
Declare
	agent Healing_Target;
//	list	Friendlies;
//	agent Friendly;
//	agent Hostile;
//	agent target;

begin
	// first check if there is anyone nearby who needs healing
	// then see if anyone has attacked me. I only run if I am swung at!

	Healing_Target = $Eval_For_Healing (ThisAgent, thisagent's "castingrange");

	If (Healing_Target != $NullAgent ())
		if ($isspellavailable(thisagent,"healer_heal"))
			$Cast (ThisAgent, "Healer_heal", Healing_Target, "");


//	$list_enemies (ThisAgent,1);
	If ($listsize(thisagent's "Hostiles") == 0)
		 return FALSE;

//	Foreach Hostile in ThisAgent's "Hostiles" do
//		If (Hostile's "Subtype" == "Undead")
//			begin
//				//Turn Undead HERE!
//			end

	$flee(thisagent,#intent_flee_scared);

	// empty thisagent's Hostiles list
	$clearlist(thisagent's "Hostiles");

	return True;
end

///////////////////////////////////////////////////////////////////////////////
function support_eval_nearby(agent thisagent) is boolean

declare
	boolean flag;
	agent new_target;

begin
	$cleanse_hostiles(thisagent);

	if (thisagent's "basicscript" == $follow_support)
		begin
			If ($listsize(thisagent's "Hostiles") == 0)
		 		return FALSE;
			else
				begin
					new_target = $pick_closest(thisagent,thisagent's "Hostiles");

					thisagent's "activescript" = $attack_object;
					thisagent's "backscript" = $attack_object;
					thisagent's "target" = new_target;

					$clearlist(thisagent's "hostiles");
					return TRUE;
				end
		end
	else
		begin
			flag = $eval_enemies_nearby(thisagent);
			return flag;
		end
end

///////////////////////////////////////////////////////////////////////////////
function wizard_eval_nearby(agent thisagent) is boolean

declare
	boolean danger_danger_flag,mirror_flag,flag;
	agent dude;


begin
	// check for targets with a high magic resistance
	// if there are none, go to regular eval, otherwise flee!
	$list_enemies(thisagent,1);

	foreach dude in thisagent's "hostiles" do
		begin
			if (($getattribute(dude,#ATTRIB_magicresistance) > 60))
				danger_danger_flag = TRUE;

			if (($getattribute(dude, #ATTRIB_HasEffectMagicMirror) == 1))
				begin
					mirror_flag = TRUE;
					danger_danger_flag = TRUE;
				end
		end

	if (danger_danger_flag == FALSE)
		begin
			flag = $eval_enemies_nearby(thisagent);
			return flag;
		end
	else
		begin
			if (mirror_flag)
				$flee_absolute(thisagent,#intent_flee_scared);
			else
				$flee(thisagent,#intent_flee_scared);

			// empty thisagent's Hostiles list
			$clearlist(thisagent's "Hostiles");
			return TRUE;
		end
end

///////////////////////////////////////////////////////////////////////////////
function cultist_eval_nearby(agent thisagent) is boolean

declare
	agent charm_target;
	integer monster_limit;
	boolean flag;
	list animals;

begin
	monster_limit = (($getattribute(thisagent,#ATTRIB_experienceLevel) - 1) / 3) + 1;

	If (ThisAgent's "Num_Followers" < monster_limit)
		begin
			$listobjects(thisagent,"monster",thisagent's "castingrange",animals,#NotMyTeam);
			animals = $listsubtypes(animals,"animal");

			if ($listsize(animals) > 0)
				charm_Target = $listmember(animals,1);

			If (charm_Target != $NullAgent ())
					if ($isspellavailable(thisagent,"charm_monster"))
						begin
							$Cast (ThisAgent, "charm_monster", charm_Target, "");
							return TRUE;
						end
		end

	flag = $eval_enemies_nearby(thisagent);
	return flag;
end

///////////////////////////////////////////////////////////////////////////////
function gnome_eval(agent thisagent) is boolean

declare

begin
	If ($listsize(thisagent's "Hostiles") == 0)
		 return FALSE;

	$flee(thisagent,#intent_flee_scared);

	// empty thisagent's Hostiles list
	$clearlist(thisagent's "Hostiles");

	return True;
end

///////////////////////////////////////////////////////////////////////////////
function list_enemies(agent thisagent,integer mult)

// this function lists all dangerous enemies near thisagent,
// and exits the function with that list in thisagent's "hostiles"
declare
	list in_sight,in_sight2,newl,units,buildings,btowers,ghouses,wtowers,towers;
	list settlements;
	string Enemy;
	integer sightrange;
	agent unit;


begin
	//first add all enemies in sight of thisagent to thisagent's hostiles list
	enemy = thisagent's "EnemyType";

	sightrange = $getattribute(thisagent,#ATTRIB_sightrange) * mult;

	$ListObjects(thisagent,enemy,sightrange,in_sight );
	$ListObjects(thisagent,"hero",sightrange,in_sight2,#NotMyTeam);
	$listobjects(thisagent,"building",sightrange,buildings,#NotMyTeam);
	buildings = $listcompleted(buildings);
	btowers = $listtitles(buildings,"ballista_Tower");
	settlements = $listtitles(buildings,"Dwarven_settlement");
	btowers = $addlists(btowers,settlements);

	//Enchanted wizard's towers
	wtowers = $listtitles(buildings,"wizards_tower");
	wtowers = $listenchanted(wtowers);

	//Guardhouses with arrows
	ghouses = $listtitles(buildings,"guardhouse");
	ghouses = $listarrowed(ghouses);

	towers = $addlists(btowers,ghouses);
	towers = $addlists(towers,wtowers);

	in_sight = $addlists(in_sight,in_sight2);

	in_sight = $addlists(in_sight,towers);

	//This takes all Friends off of In_Sight
	If (ThisAgent's "Friend" != "xx")
		$Cull_Subtypes (In_sight, ThisAgent's "Friend");

	// make sure that there are no duplicates in hostiles and sight range

	$debugout(in_sight,thisagent's "hostiles");
	newl = $addlists(in_sight,thisagent's "hostiles");
//	thisagent's "Hostiles" = in_sight; // add hostiles later
	thisagent's "hostiles" = newl;

	$Debugout("=",newl);
//	// remove thisagent's target from the list, if neccesary
//	// if the target is not a coord and is valid
//	// then if the target is out of sight, or the only one around, remove it
//	// from the list
//	if ((thisagent's "target" != thisagent) && ($isvalidgamepiece(thisagent's "target"))) // != $Nullagent()))
//		if ($distanceBetweenAgents(thisagent,thisagent's "target") > $getattribute(thisagent,#ATTRIB_Sightrange))
//			thisagent's "hostiles" -= thisagent's "target";
//		else
//			if ($listsize(thisagent's "hostiles") == 1)
//				$clearlist(thisagent's "hostiles");
	thisagent's "hostiles" = $possibly_remove_target(thisagent,thisagent's "hostiles");

	if ($listsize(thisagent's "hostiles") > 0)
		foreach unit in thisagent's "hostiles" do
			begin
				if ($notvalid(unit) == FALSE)
					units << unit;
			end

	thisagent's "hostiles" = units;
end

///////////////////////////////////////////////////////////////////////////////
function Possibly_remove_target(agent thisagent,list hostiles) is list

declare

begin
	// remove thisagent's target from the list
	// if the target is not a coord and is valid
	// then if the target is out of sight, or the only one around, remove it
	// from the list
	if ((thisagent's "target" != thisagent) && ($isvalidgamepiece(thisagent's "target"))) // != $Nullagent()))
		// possibly put in : remove target from the list
		if ($distanceBetweenAgents(thisagent,thisagent's "target") > $getattribute(thisagent,#ATTRIB_Sightrange))
			hostiles -= thisagent's "target";
		else
			if (($listsize(hostiles) == 1) && ($agentinlist(thisagent's "target",hostiles)))
				$clearlist(hostiles);

	return hostiles;
end

///////////////////////////////////////////////////////////////////////////////
Function List_Heroes (agent ThisAgent) is List
Declare
	list	Heroes,newheroes;
	agent hero;

Begin
	$ListObjects (ThisAgent, "Hero", $getattribute (ThisAgent,#ATTRIB_SightRange),Heroes, #MyTeam );

	foreach hero in heroes do
		begin
			//we only want true "heroes" here, so check their subtype
			if (Hero's "subtype" == "Hero")// != "Henchman" && $GetSubtype(Hero) != "Controlled")
				newheroes << hero;
		end
	Return newHeroes;
End

///////////////////////////////////////////////////////////////////////////////
function should_I_run(agent thisagent, list thislist) is Boolean

// returns true if the guy wants to run, false if not

declare
	agent Speedy,hero;
	integer killorbekilled,friend_mod,t;
	list heroes;

begin
	// get the "numbers" for the list
	killorbekilled = $list_eval(thisagent, thislist);

	// count friendlies
	heroes = $list_heroes(thisagent);

	if ($listsize(heroes) > 0)
		begin
		foreach hero in heroes do
			begin
				t = $getattribute(hero,#ATTRIB_experienceLevel);
				friend_mod += t;
			end
		$debugout(friend_mod," friends");
	end

	killorbekilled += friend_mod;

	// see if the total of the targets is too dangerous
	if (killorbekilled < 1)
		begin
			// thisagent thinks it would be dead before it killed these guys
			// can thisagent outrun the fastest enemy?
			speedy = $pick_fastest(thisagent,thislist);

			if ($getattribute(thisagent,#ATTRIB_speed) > $getspeed(speedy))
				begin
					// flight
//					$debugout("I must flee!");
					$flee(thisagent,#intent_flee_scared);
					return TRUE;

				end
			else
				begin
//					$debugout("I can't flee. Oh Well!");
					$last_stand(thisagent,#intent_flee_scared);
					return TRUE;
				end
		end
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function monster_eval_enemies(agent thisagent)

declare
	string enemy;
	list in_sight,newl;
	agent tempagent;

begin
	enemy = thisagent's "EnemyType";

	$cleanse_hostiles(thisagent);

	$ListObjects(thisagent,enemy,$getattribute(thisagent,#ATTRIB_Sightrange),in_sight );

	$debugout("monster_eval:",in_sight);

	If (ThisAgent's "Friend" != "xx")
		$Cull_Titles (In_Sight, ThisAgent's "Friend");

	// add hostiles to in_sight;
//	in_sight = in_sight + (thisagent's "Hostiles");
	newl = $addlists(in_sight,thisagent's "Hostiles");
	in_sight = newl;
	$debugout("monster_eval,after addlists:",in_sight);

	in_sight = $possibly_remove_target(thisagent,in_sight);
	$debugout("monster_eval, after possibly remove:",in_sight);

//	$debugout($listsize(in_sight));
 	if ($listsize(in_sight) > 0)
		begin
			// pick the closest guy to attack
			tempagent = $pick_closest(thisagent,in_sight);
			if (tempagent != thisagent's "target")
				begin
					thisagent's "Target" = tempagent; //$pick_closest(thisagent,in_sight);
					thisagent's "ActiveScript" = $Monster_Attack_object;
				end
			$Clearlist (ThisAgent's "Hostiles");
		end
end

///////////////////////////////////////////////////////////////////////////////
function list_eval(agent thisagent, list thislist) is integer

// this function should only ever be used by the unit type "hero"
// when they are evulating nearby hostiles of any type

declare
	agent hostile;
	float hmod_tohit;
	float ta_tohit_f,ta_avoid_f,htohit_f,havoid_f;
	float ta_mod_tohit;
	float enemy_total_strength,enemy_total_HP,enemy_HP,enemy_strength;
	integer distance,total_distance;
	integer hitstildead,hitstokill;
	integer total_range_difference,sum,dist1,hostile_range,attack_range,extra_shots;
	integer hostile_extra_range,thisagent_extra_range;
	integer spell_mod;

	// to make this work with towers:
	// make functions: $getattackrange, $getstrength, $getarmor
begin
	if ($listsize(thislist) == 0)
		begin
			return 0;
		end

	total_range_difference = 0;
	thisagent_extra_range = $getattribute(thisagent,#ATTRIB_maxattackrange);
	hostile_extra_range = 0;

	foreach hostile in thislist do
		begin
			// first determine if anyone has a range advantage

			dist1 = $distancebetweenagents(thisagent,hostile);
			hostile_range = $Egetattackrange(hostile); //$getattribute(hostile,#ATTRIB_maxattackrange);
			attack_range = $getattribute(thisagent,#ATTRIB_maxattackrange);

			// if thisagent is in range of hostile, but hostile is not in range of
			// thisagent then thisagent has a range bonus
			// if any enemy is in range of thisagent, thisagent has no extra range
			if (dist1 < thisagent_extra_range)
				begin
					if (dist1 > hostile_range)
						if (dist1 <= attack_range)
							thisagent_extra_range = dist1;
						else
							thisagent_extra_range = 0;
				end

			// if hostile is in range of thisagent, but thisagent is not in range of
			// hostile then the hostiles have an advantage in range
			if (dist1 > attack_range)
				if (dist1 <= hostile_range)
//					if (dist1 > hostile_extra_range)
						hostile_extra_range += dist1;


			htohit_f = $gettohit(hostile);
			ta_avoid_f = $gettoavoid(hostile,thisagent);
			ta_tohit_f = $gettohit(thisagent);
			havoid_f = $gettoavoid(thisagent,hostile);

			// these mods are the percentage below 1 (1/hmod..)
			// to modify the strength and HP by in order to estimate them
			// they are the fraction which represents how often a creature hits another
			// based on the first creatures to hit and the second creatures dodge/parry

			hmod_tohit = htohit_f * ((100.0 - ta_avoid_f) / 100.0);
			if (hmod_tohit == 0)
				begin
					hmod_tohit = 1;
					$debugout(911,"hmod_tohit is 0!",htohit_f);
				end

			ta_mod_tohit = ta_tohit_f * ((100.0 - havoid_f) / 100.0);
			if (ta_mod_tohit == 0)
				begin
					ta_mod_tohit = 1;
					$debugout(911,"ta_mod_tohit is 0!",ta_tohit_f);
				end

			// a creature's actual damage is underestimated to account for
			// the chance of them missing the hero
			// it is also underestimated by the hero's armor

			enemy_strength = $getstrength(hostile); //$getattribute(hostile,#ATTRIB_Strength);
			enemy_strength	-= $hero_armor_value(thisagent);
			if (enemy_strength < 1) enemy_strength = 1;

			enemy_total_strength += (enemy_strength / (100.0 / (hmod_tohit)) );

			// a creature's actual HP is exaggerated to account for the
			// hero's chance of missing them
			// it is also exaggerated by the number of swings it would take the hero
			// to kill them times the hostiles armor value

			enemy_HP = $getattribute(hostile,#ATTRIB_HP);
			// adjust for enemy armor
			enemy_HP = enemy_HP + ($getArmor(hostile) * (enemy_HP / $hero_damage(thisagent))); //($getattribute(hostile,#ATTRIB_armor_basic_damage);
			// adjust enemy HP upward for the chance of the hero missing them
			enemy_total_HP += (enemy_HP * (100.0 / (ta_mod_tohit)) );

  //		$debugout("hostile to hit -",hmod_tohit,"agent to hit -",ta_mod_tohit,"enemy total strength -",enemy_total_strength,"enemy total HP -",enemy_total_HP);
		end

	total_range_difference = thisagent_extra_range - hostile_extra_range;

	extra_shots = total_range_difference / #extra_shot_mod;

	if (enemy_total_strength < 1) enemy_total_strength = 1;

	hitstokill = enemy_total_HP / $hero_damage(thisagent);
	hitstildead = $getattribute(thisagent,#ATTRIB_HP) / enemy_total_strength;

	hitstokill -= extra_shots;

//	$debugout(911,"kill enemies in -",hitstokill," : dead in -",hitstildead,"TRD",total_range_difference,"ES",extra_shots);

	// modify scores by thisagent's estimations
	hitstokill = (thisagent's "enemy_estimation") * hitstokill;

	hitstildead = (thisagent's "self_estimation") * hitstildead;

	spell_mod = $spell_extra_value(thisagent);

//	$debugout(911,"Mod, kill enemies in -",hitstokill," : dead in -",hitstildead," spell mod:",spell_mod);
//  	$traceoff();
	return hitstildead - hitstokill + spell_mod;
end

///////////////////////////////////////////////////////////////////////////////
function Egetattackrange(agent thisagent) is integer

declare

begin
	if ((thisagent's "type" == "hero") || (thisagent's "type" == "monster"))
		return $getattribute(thisagent,#ATTRIB_maxattackrange);
	else
		if (thisagent's "title" == "guardhouse")
			return #guardhouse_arrow_range;
		else
			return $getattribute(thisagent,#ATTRIB_sightrange);//thisagent's "sightrange";
end

///////////////////////////////////////////////////////////////////////////////
function getstrength(agent thisagent) is integer

declare

begin
	if ((thisagent's "type" == "hero"))
		return $hero_damage(thisagent);
	else
		if (thisagent's "type" == "monster")
			return $getattribute(thisagent,#ATTRIB_strength);
		else
			if (thisagent's "title" == "wizards_tower")
				return 10;
			else
				if (thisagent's "type" == "pet")
					return $getattribute(thisagent,#ATTRIB_strength);
				else
					begin
						if ($hasattribute("strength",thisagent))
							return thisagent's "strength";
						else
							return 1;
					end
end

///////////////////////////////////////////////////////////////////////////////
function getarmor(agent thisagent) is integer

declare

begin
	if ((thisagent's "type" == "hero"))
		return $hero_armor_value(thisagent);
	else
		if (thisagent's "type" == "monster")
			return $getattribute(thisagent,#ATTRIB_armor_basic_damage);
		else
			return 0;
end

///////////////////////////////////////////////////////////////////////////////
function spell_extra_value(agent thisagent) is integer

declare
	integer value;

begin
	if ($isspellavailable(thisagent,"energy_blast",1))
		value += 10;

	if ($isspellavailable(thisagent,"fire_blast",1))
		value += 30;

	if ($isspellavailable(thisagent,"fire_ball",1))
		value += 30;

	if ($isspellavailable(thisagent,"teleport",1))
		value += 5;

	if ($isspellavailable(thisagent,"resist_magic",1))
		value += 5;

	if ($isspellavailable(thisagent,"meteor_storm",1))
		value += 30;

	if ($isspellavailable(thisagent,"drain_life",1))
		value += 30;

	if ($isspellavailable(thisagent,"sun_scorch",1))
		value += 30;

	return value;
end

///////////////////////////////////////////////////////////////////////////////
function hero_armor_value(agent thisagent) is integer

declare
	integer value;

begin
	value = $getattribute(thisagent,#ATTRIB_armor_basic_damage);
	value += $getattribute(thisagent,#ATTRIB_armor_struct_bonus);
	value += $getattribute(thisagent,#ATTRIB_armor_magic_bonus);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function hero_weapon_value(agent thisagent) is integer

declare
	integer value;

begin
	value = $getattribute(thisagent,#ATTRIB_weapon_basic_damage);
	value += $getattribute(thisagent,#ATTRIB_weapon_struct_bonus);
	value += $getattribute(thisagent,#ATTRIB_weapon_magic_bonus);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function hero_damage(agent thisagent) is integer

declare
	integer value;

begin
	value = $hero_weapon_value(thisagent);
	value += ($getattribute(thisagent,#ATTRIB_Strength) / #strength_div);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function pick_toughest(agent thisagent,list thislist) is agent

declare
	agent enemy;
	agent toughest_enemy;
	integer toughest_score;
	integer temp_score;
begin
	toughest_score = 30000;
		foreach enemy in thislist do
			begin
				temp_score = $target_eval(thisagent,enemy);
				if (temp_score < toughest_score)
					begin
						toughest_score = temp_score;
						toughest_enemy = enemy;
					end
			end

		return toughest_enemy;
end

///////////////////////////////////////////////////////////////////////////////
function pick_fastest(agent thisagent,list thislist) is agent

declare
	agent enemy;
	agent fastest_enemy;
	integer fastest_speed;
	integer speed;
	integer e_speed;

begin
	fastest_speed = -1;
//	fastest_enemy = thislist << 1;

	speed = $getattribute(thisagent,#ATTRIB_Speed);

	foreach enemy in thislist do
		begin
			e_speed = $getspeed(enemy);

			if (e_speed > fastest_speed)
				begin
					fastest_speed = e_speed;
					fastest_enemy = enemy;
				end
		end

	return fastest_enemy;
end

///////////////////////////////////////////////////////////////////////////////
function getspeed(agent thisagent) is integer

declare

begin
	if (thisagent's "type" != "building")
		return $getattribute(thisagent,#ATTRIB_speed);
	else
		return 0;
end

///////////////////////////////////////////////////////////////////////////////
function pick_closest(agent thisagent,list thislist) is agent

declare
	agent enemy;
	agent closest_enemy;
	integer closest_dist;
	integer e_dist;

begin
	closest_dist = 100000;

	foreach enemy in thislist do
		begin
//			if (!$isdead(enemy))
//				begin
					e_dist = $distancebetweenAgents(thisagent,enemy);
					if (e_dist < closest_dist)
						begin
							closest_dist = e_dist;
							closest_enemy = enemy;
						end
//				end
		end

	return closest_enemy;
end

///////////////////////////////////////////////////////////////////////////////
Function Pick_Farthest (agent ThisAgent, list ThisList) is Agent
Declare
	agent enemy;
	agent furthest_enemy;
	integer furthest_dist;
	integer e_dist;

begin
	furthest_dist = 0;

	foreach enemy in thislist do
		begin
			e_dist = $distancebetweenAgents(thisagent,enemy);
			if (e_dist > furthest_dist)
				begin
					furthest_dist = e_dist;
					furthest_enemy = enemy;
				end
		end

	return furthest_enemy;
end

///////////////////////////////////////////////////////////////////////////////
Function Pick_Richest (agent ThisAgent, list ThisList) is Agent
Declare
	agent	dude;
	agent	richest_dude;
	integer temp_gold;
	integer most_gold;

Begin
	Most_Gold = 0;
	Foreach Dude in ThisList do
		begin
			Temp_Gold = $getattribute (Dude, #ATTRIB_Gold);
			if (Temp_Gold >= Most_Gold)
				begin
					Most_Gold = Temp_Gold;
					Richest_Dude = Dude;
				end
		end

	If ($getattribute (Richest_Dude, #ATTRIB_Gold) > 0)
		return Richest_Dude;

	return $NullAgent ();
end


///////////////////////////////////////////////////////////////////////////////
// This is to tell whether or not a Guardhouse has arrows.
function ListArrowed (list thislist) is list

declare
	list newlist;
	agent entry;

begin
	foreach entry in thislist do
		begin
			If ($GetAttribute (Entry, #ATTRIB_ResearchArrows) != 0)
				newlist << entry;
		end

	return NewList;
end

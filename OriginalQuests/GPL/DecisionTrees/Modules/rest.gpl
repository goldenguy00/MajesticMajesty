function rest(agent thisagent) is Boolean

declare
	integer HP;
	integer maxHP;

begin
	HP = $getattribute(thisagent,#ATTRIB_HP);
	maxHP = $getattribute(thisagent,#ATTRIB_MaxHP);

	if (((HP * 100) / maxHP) <= thisagent's "PercentageHPretreat")
		begin
			// heal self task
			$heal_self(thisagent);
			return TRUE;
		end

	return FALSE;

end
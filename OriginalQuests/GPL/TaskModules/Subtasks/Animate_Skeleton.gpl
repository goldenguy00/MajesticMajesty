Function Animate_Skeleton (agent ThisAgent)
Declare

Begin
	$DebugOut ("Priestess animates a Skeleton!!");
	$SpawnUnit (ThisAgent, "Skeleton");
	(ThisAgent's "Num_Followers") ++;
End
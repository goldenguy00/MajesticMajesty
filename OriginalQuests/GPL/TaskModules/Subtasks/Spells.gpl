/////////////////////////////////////////////////////////////////////////////////////////////////
function Anti_Magic_Shield_Begin( agent thisagent )
// player cast spell - from temple to krypta
// not allowed on buildings.
declare

begin
	$createeffector( thisagent, "antimagic_shield_effector", 0 );
	$createeffector( thisagent, "anitmagic_shield_icon", 20000 );
	$SetAttribute( thisagent, #ATTRIB_HasEffectAntiMagic, 1 );

	// increase the units magic resistance
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Magicresistance,90);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Anti_Magic_Shield_End( agent thisagent )
// player cast spell - from temple to krypta
// - callback from "anitmagic_shield_icon" effector
declare

begin
	// revert the units magic resistance
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Magicresistance,-90);
	$SetAttribute( thisagent, #ATTRIB_HasEffectAntiMagic, 0 );
end


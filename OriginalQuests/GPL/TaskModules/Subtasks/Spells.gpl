/////////////////////////////////////////////////////////////////////////////////////////////////
function Wind_Storm_Target( agent thisagent ) is boolean
// return TRUE if the target is affected by wind storms
declare
begin
	// everything except strangleweeds and daemonwoods
	return (thisagent's "title" != "Daemonwood" &&
			thisagent's "title" != "Strangleweed");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Wind_Storm_Active(agent thisagent)
// player cast spell - from temple to lunord
// - activescript for helia_sun_scorch unit
declare
	list targets;
	agent target;

begin
//	$ListObjects(thisagent,"monster",115, targets );
	targets = $list_enemies_seen(thisagent,115);
	foreach target in targets do
		if ( $Wind_Storm_Target( target ) )
			begin
				$createeffector( target, "wind_storm_effector2", 0 );
				$TeleportToPoint( target, #Teleport_Windstorm_Range, $RandomCoord (thisagent, 5000) );
				$player_spell_attack( target, 24, 10 );
			end
end


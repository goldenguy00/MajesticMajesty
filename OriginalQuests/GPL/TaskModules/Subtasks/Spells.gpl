/////////////////////////////////////////////////////////////////////////////////////////////////
function Exploding_Aura_Cast(agent thisagent, agent target)
// monster spell
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3;

begin
	// list all enemies nearby -
	//$ListObjects(thisagent,"hero",thisagent's "castingrange",targets,#NotMyPlayer);
	targets = $list_enemies_seen(thisagent,$getattribute(thisagent,#ATTRIB_sightrange));

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// fire 3 projectiles at the closest ones
	$createmissile("exploding_aura_missile",thisagent,target1);
	$createmissile("exploding_aura_missile",thisagent,target2);
	$createmissile("exploding_aura_missile",thisagent,target3);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Exploding_Aura_Hit( agent thisagent, agent target )
// monster spell
// - callback from missile hit
declare
	list targets;
	agent targetD;

begin
	// CBT note: as of Majesty Alpha the effector duration below is 0
	$createeffector(target,"exploding_aura_effector1",$getspellattribute("exploding_aura","effector_duration"));
	$spell_attack( thisagent, target, 35 );

	$ListObjects(target ,"hero",40, targets );

	foreach targetD in targets do
		begin
			$spell_attack(thisagent, targetD, 15 );
		end

end


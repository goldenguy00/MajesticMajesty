function Inferno_Hit( agent thisagent, agent target )
declare
	list Targets, t1, t2;
	agent dude;

begin
	$ListObjects(thisagent,"building",ThisAgent's "CastingRange",t1,#NotMyPlayer);
	$ListObjects(thisagent,"hero",ThisAgent's "CastingRange",t2,#NotMyPlayer);
	targets = $addlists(t1,t2);

	foreach dude in targets do
		begin
			$createeffector( dude, "inferno_effector2", 0 );
			$spell_attack( thisagent, dude, 40 );
		end
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function Lightning_Storm_Hit( agent thisagent, agent target )
// player cast spell - from wizard's guild
// - birthscript for lightning_storm unit
declare

begin
	// run a test to see who gets nailed every 1/2 second
	$NewThread( thisagent's "activeScript", 500, thisagent ); // 1000

	// have the spell last for X seconds
	$SetSpellUnitTimeout( thisagent, 2300 ); // 5500

	// run the damage code once, so in case of lag there is never no damage
	$lightning_storm_active(thisagent);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Lightning_Storm_Active ( agent thisagent )
// player cast spell - from wizard's guild
// - activescript for lightning_storm unit
declare
	list targets;
	agent target, AIRootAgent;
	integer min, max;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	targets = $compile_enemies ( thisagent, 150 );

	if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
		begin
			if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
				begin
					min = #Deathmatch_Lightning_Storm_Min_Damage;
					max = #Deathmatch_Lightning_Storm_Max_Damage;
				end
			else
				begin
					min = #Lightning_Storm_Min_Damage;
					max = #Lightning_Storm_Max_Damage;
				end
		end
	else
		begin
			min = #Lightning_Storm_Min_Damage;
			max = #Lightning_Storm_Max_Damage;
		end

	foreach target in targets do
		begin
			$createeffector ( target, "lightening_storm_effector2", 0 );
			$player_spell_attack ( target, Max, Min );
		end
end


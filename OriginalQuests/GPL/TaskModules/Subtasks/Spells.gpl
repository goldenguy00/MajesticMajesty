/////////////////////////////////////////////////////////////////////////////////////////////////
function Healer_Heal_Effect( agent thisagent, agent target )
// healer spell - lvl 1
// - callback from cast action
declare
	agent AIRootAgent;
	integer Healing;
begin
	if ( $isdead ( target ))
		return;

	if ( $isdead ( thisagent ) == FALSE )
		begin
			$createeffector( target, "healer_healing_effector", 0 );

			AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
  			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				begin
					if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
						begin
							healing = ( #Deathmatch_Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
							if ( healing > #Deathmatch_Agrella_Healing_Cap )
								healing = #Deathmatch_Agrella_Healing_Cap;
						end
					else
						begin
							healing = ( #Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
						end
				end
			else
				begin
					healing = ( #Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
				end

			$Heal ( ThisAgent, Target, healing );
			if ( target's "backscript" == $use_building_safe )
				begin
					if ( $haslowHP ( target ) == False )
						$reset_tasks ( target );
				end
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Agrela_Heal_Effect( agent thisagent )
// player cast spell - from temple to agrela
declare
	agent AIRootAgent;
	integer healing;

begin
	if ($isdead(thisagent))
		return;

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	$createeffector( thisagent, "agrela_healing_effector", 0 );

	if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
		if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
			begin
				healing = $RandomNumber ( #Deathmatch_Temple_Heal ) + #Deathmatch_Temple_Heal;
				$Player_Heal ( thisagent, healing );
			end
		else
			$Player_Heal ( thisagent, 100 );

	if (thisagent's "backscript" == $use_building_safe)
		begin
			if ($haslowHP(thisagent) == False)
				$reset_tasks(thisagent);
		end

end


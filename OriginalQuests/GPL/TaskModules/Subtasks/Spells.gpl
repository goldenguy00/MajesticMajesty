/////////////////////////////////////////////////////////////////////////////////////////////////
function summon_skeleton_check(agent thisagent) is integer
// is it a good idea for the liche queen to summon a skeleton?
// if there are more than a certain # near her, then no
// otherwise, yes.
declare
	list skeletons;

begin
	$listobjects(thisagent,"monster",500,skeletons,#MyPLayer);
	skeletons = $listtitles(skeletons,"skeleton");

	if ($listsize(skeletons) > 20)
		return 0;
	else
		return 1;
end


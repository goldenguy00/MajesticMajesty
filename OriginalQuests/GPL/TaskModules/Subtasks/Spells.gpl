// $ListObjects(thisagent,"monster",55, targets );

	targets = $compile_enemies(thisagent,80);
	foreach target in targets do
		begin
			$createeffector( target, "fireball_effector2", 500 );
			$player_spell_attack( target, 15,2 );
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function compile_enemies(agent thisagent,integer range) is list

declare
	list targets,t2,t3;

begin
	$ListObjects(thisagent,"monster",range,targets,#NotMyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#NotMyTeam);
	t3 = $addlists(targets,t2);
	return t3;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Fire_Blast_Cast(agent thisagent, agent target)
// wizard spell - lvl 3
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3;

begin
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,thisagent's "castingrange");

//	$ListObjects(thisagent,"monster",thisagent's "castingrange",targets,#NotMyPlayer);

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// fire 3 projectiles at the closest ones
	$createmissile("Fire_blast_missile",thisagent,target1);
	$createmissile("Fire_blast_missile",thisagent,target2);
	$createmissile("Fire_blast_missile",thisagent,target3);
end


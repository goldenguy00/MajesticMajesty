end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Force_End( agent thisagent )
// monster spell
// - callback from force_effector1 effector
declare
	list targets;
	agent dude;

begin
	$ListObjects(thisagent,"hero",#Teleport_Forced_Range, targets );

	foreach dude in targets do
		begin
			$createeffector( dude, "force_effector2", 0 );
			$TeleportToPoint( dude, #Teleport_Forced_Range, $RandomCoord (thisagent, 5000) );
			$player_spell_attack( dude, 10,2 );
		end


end

/////////////////////////////////////////////////////////////////////////////////////////////////
function teleport_check(agent thisagent) is integer

declare

begin
	return $main_teleport_check(thisagent,#Teleport_range);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function teleport_short_check(agent thisagent) is integer

declare

begin
	return $main_teleport_check(thisagent,#Teleport_short_range);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function main_teleport_check(agent thisagent,integer therange) is integer
// check to see if someone who wants to teleport is
// too close to their destination to use the teleport well enough.
declare
	coordinate coord;

begin
	if (thisagent's "Target" == thisagent)
		coord = thisagent's "destination";
	else
		if ($isvalidgamepiece(thisagent's "target"))
			coord = $locationof(thisagent's "target");
		else
			return 0;

	if ($distancebetweencoords(coord,$locationof(thisagent)) > therange / 5)
		return 1;
	else
		return 0;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Teleport_Effect( agent thisagent, agent target )
// wizard spell - lvl 4
// - callback from cast action
declare

	integer theTimePeriod;

begin
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	theTimePeriod = $GetSpellAttribute( "teleport", "effector_duration" );
	$createeffector( thisagent, "teleport_effector", theTimePeriod );

//	$Teleport_DoMove( thisagent, #Teleport_Range );

	// do the movement later
	thisagent's "teleportScript" = $Teleport_DoMove;
	$RunThread( thisagent's "teleportScript", theTimePeriod/2, thisagent, #Teleport_Range );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Teleport_Short_Effect( agent thisagent, agent target )
// adept spell - lvl 4
// - callback from cast action
declare

	integer theTimePeriod;

begin
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	theTimePeriod = $GetSpellAttribute( "teleport_short", "effector_duration" );
	$createeffector( thisagent, "teleport_short_effector", theTimePeriod );

	// do the movement later
	thisagent's "teleportScript" = $Teleport_DoMove;
	$RunThread( thisagent's "teleportScript", theTimePeriod/2, thisagent, #Teleport_Short_Range );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Teleport_DoMove( agent thisagent, integer theRange )
// shared teleport code, does the actual teleportation
declare

begin
	If ($IsDead (ThisAgent))
		return;

	// if the target is themselves, it is a point
	if (thisagent's "Target" == thisagent)
		$TeleportToPoint( thisagent, theRange, thisagent's "destination" );
	else
		if ($isvalidgamepiece(thisagent's "target"))
			$TeleportToUnit( thisagent, theRange, thisagent's "Target", thisagent's "castingrange" );
end


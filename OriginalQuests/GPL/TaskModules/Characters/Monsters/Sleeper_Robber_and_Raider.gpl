///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Robber (agent ThisAgent)
Declare
	list		Buildings;

Begin
	$DebugOut (thisagent's "title","is picking a target.");
	$ListObjects (ThisAgent, "Building", -1, Buildings );
	If ($ListSize (Buildings) > 0)
		begin
			ThisAgent's "Target" = $Pick_Richest (ThisAgent, Buildings);
			If (ThisAgent's "Target" == $NullAgent ())
				begin
					ThisAgent's "ActiveScript" = $Sleeper_Raider;
					ThisAgent's "BackScript" = $Sleeper_Raider;
					ThisAgent's "BasicScript" = $Sleeper_Raider;
					$DebugOut ("No Buildings to Steal from, so",thisagent's "title","becomes a Raider!!");
				end
			Else
				begin
					$DebugOut ("Target Picked!");
					ThisAgent's "ActiveScript" = $Sleeper_Go_Steal;
				end
		end
	Else
		begin
			$DebugOut ("No buildings at all!",thisagent's "title","is going home!");
			ThisAgent's "ActiveScript" = $Sleeper_Go_Home;
		end
End

///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Raider (agent ThisAgent)
Declare
	list		Buildings;

Begin
	$DebugOut (thisagent's "title","is picking a target.");
	$ListObjects (ThisAgent, "Building", -1, Buildings );
	If ($ListSize (Buildings) > 0)
		begin
			ThisAgent's "Target" = $ListMember (Buildings, 1);
			//ThisAgent's "Target" = $Pick_Closest (ThisAgent, Buildings);
			$DebugOut ("Target Picked!");
			ThisAgent's "ActiveScript" = $Sleeper_Attack_Building;
		end
	Else
		begin
			$DebugOut ("No Buildings to Attack!!");
			ThisAgent's "ActiveScript" = $Sleeper_Go_Home;
		end
End


///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Go_Home (agent ThisAgent)
Declare

Begin
	If ($Is_Valid_Sleeper_Home (ThisAgent's "Sleeper_Home"))
		begin
			//If ThisAgent isn't @ Sleeper_Home, send them there
			If ($IsAdjacent (ThisAgent, ThisAgent's "Sleeper_Home") == FALSE)
				begin
					If ($IsMoving (ThisAgent) == FALSE)
						begin
							ThisAgent's "Destination" = $LocationOf (ThisAgent's "Sleeper_Home");
							$Move (ThisAgent, thisagent's "sleeper_home");
						end
				end
			Else
				begin
				   thisagent's "type" = "Waiting_to_die";
					$killthread(thisagent's "activescript");
					$DeleteGamePiece (ThisAgent);
				end
		end
	Else
		begin
			$DebugOut (thisagent's "title","doesn't have a home or their home is offmap, so they become a Raider!");
			//if ($validfunction(ThisAgent's "SleeperScript"))
				//begin
					//If ($IsRunning (ThisAgent's "SleeperScript"))
						//$KillThread (ThisAgent's "SleeperScript");
				//end
			$make_raider(thisagent);
//			ThisAgent's "ActiveScript" = $Raider;
//			ThisAgent's "BasicScript" = $Raider;
//			ThisAgent's "BackScript" = $Raider;
		end
End

///////////////////////////////////////////////////////////////////////////////
Function Offmap_Sleeper_Go_Home (agent ThisAgent)
Declare

Begin
	If ($isnearmapedge(thisagent))
		begin
			thisagent's "type" = "Waiting_to_die";
			$killthread(thisagent's "activescript");
			$DeleteGamePiece (ThisAgent);
		end
	Else
		begin
			If ($IsMoving (ThisAgent) == False)
				begin
					ThisAgent's "Target" = ThisAgent;
					$Move (ThisAgent, ThisAgent's "Coord_Home");
				end
		end
End

///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Callback (agent ThisAgent)
Declare


Begin
	//$DebugOut (ThisAgent's "ActiveScript");

	ThisAgent's "Target" = $NullAgent ();
	$StopMoving (ThisAgent);
	$DebugOut (thisagent's "title","is going home.");
	ThisAgent's "ActiveScript" = $Sleeper_Go_Home;
End

//THis sends offmap sleepers back home
Function Offmap_Sleeper_Callback (agent ThisAgent)
Declare

Begin

	ThisAgent's "Target" = $NullAgent ();
	$StopMoving (ThisAgent);
	ThisAgent's "ActiveScript" = $Offmap_Sleeper_Go_Home;
	$say(thisagent,"taunt");

End

///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Robber_Eval_Enemies (agent ThisAgent)
Declare
	string enemy;
	list	 Henchmen;
	agent  Hench;

begin
	//First, see if anybody is attacking ThisAgent

	thisagent's "hostiles" = $possibly_remove_target(thisagent,thisagent's "hostiles");

	If ($ListSize (ThisAgent's "Hostiles") > 0)
		begin
			//$DebugOut ("Sleeper is in the Hostiles loop.");
			ThisAgent's "Target" = $Pick_Closest (ThisAgent, ThisAgent's "Hostiles");

			//If so, attack them
			ThisAgent's "ActiveScript" = $Sleeper_Attack_Hero;
			$ClearList (ThisAgent's "Hostiles");
		end

	//Then, constantly look around for Caravans and Tax Collectors (by listing Henchmen in
	//their sightrange) If ThisAgent finds them, compare them to ThisAgent's current target,
	//and attack the one with the most gold.
	Else
		begin
			Henchmen = $ListSubTypesInRadius (ThisAgent, "hero", "henchman", $getattribute (ThisAgent, #ATTRIB_SightRange));
			If ($ListSize (Henchmen) > 0)
				begin
					Foreach Hench in Henchmen do
						If ($getattribute (Hench, #ATTRIB_Gold) > $Getattribute (ThisAgent's "Target", #ATTRIB_Gold))
							begin
								ThisAgent's "Target" = Hench;
								ThisAgent's "ActiveScript" = $Sleeper_Attack_Hero;
							end
				end
		end
end



///////////////////////////////////////////////////////////////////////////////
function Sleeper_Attack_Building(agent ThisAgent)

declare
	integer HP,maxHP,targetrange,Speed,targetspeed;
	agent target;
	boolean do_attack;

begin
	target = thisagent's "target";

// is target alive?
	if ($notvalid(Target))
		begin
			$reset_tasks(thisagent);
		end
	else
		begin
			targetrange = $DistanceBetweenAgents (ThisAgent, Target);
			if (targetrange > $getattribute(thisagent,#ATTRIB_maxattackrange))
				begin
					// move towards target
					thisagent's "destination" = $locationof(target);
					thisagent's "activeScript" = $monster_travel_to;
					thisagent's "backScript" = $Sleeper_Attack_Building;
					$move(thisagent,target);
				end

			else
				begin
					if ($ListSize (ThisAgent's "Hostiles") > 0)
						begin
							ThisAgent's "Target" = $Pick_Closest (ThisAgent, ThisAgent's "Hostiles");
							ThisAgent's "ActiveScript" = $Sleeper_Attack_Hero;
						end
					else
						begin
							// is target within min attack range?
								begin
									// make attack on object
									do_attack = TRUE;

									if (target's "type" == "building")
										if ($peasants_near(thisagent) == TRUE)
											do_attack = FALSE;

									if (do_attack)
										$PerformAction (ThisAgent, ThisAgent's "Attack_Action", Target);

								end
						end
				end
		end
end


///////////////////////////////////////////////////////////////////////////////
function Sleeper_Attack_Hero (agent ThisAgent)
declare
	integer targetrange;
	agent target,leader;
	integer	SightRange,attackrange;
	boolean casting;
	string spell_name;

begin
	target = thisagent's "target";

	// is target alive?
	if ($notvalid(target))
		begin
			$reset_tasks(thisagent);
		end
	else
		begin
			// is target out of pursuit range?
			targetrange = $distanceBetweenAgents(thisagent,target);

			if ($target_out_of_range(thisagent,target))
				begin
					// go back to regular functioning
					$reset_tasks(thisagent);
				end
			else
				begin
					// pick weapon or spell
					spell_name = $getbestspell(thisagent,#list_attack);
					$debugout("Monster attack spell:",spell_name);

					if (spell_name == "nothing")
						begin
							attackrange = $getattribute(thisagent,#ATTRIB_maxattackrange);
							casting = FALSE;
						end
					else
						begin
							attackrange = thisagent's "castingrange";
							casting = TRUE;
						end

					// is thisagent in attackrange of target
					if (targetrange > attackrange)
						begin
							// move towards target
							thisagent's "destination" = $locationof(target);
							thisagent's "activeScript" = $monster_travel_to;
							thisagent's "backScript" = $sleeper_attack_Hero;
							$move(thisagent,target);
							$debugout("Monster starting move to target.");
						end
					else
						begin
							// make attack on object
							if (casting)
								$castspell(thisagent,spell_name,target, "");
							else
								$performAction(thisagent,(thisagent's "attack_action"),target);
						end
				end
		end
end


///////////////////////////////////////////////////////////////////////////////
function Sleeper_Robber_Travel_To (agent ThisAgent)
Declare

Begin
	if ($has_arrived(thisagent,false) == FALSE)
		$Sleeper_Robber_Eval_Enemies (ThisAgent);
end


///////////////////////////////////////////////////////////////////////////////
function Sleeper_Birth	(agent ThisAgent)
Declare

Begin
	//Check to see if my parent is annoyed (if I have a parent)
	If ($IsValidGamePiece ($Parent (ThisAgent)))
		begin
			ThisAgent's "Sleeper_Home" = $Parent (ThisAgent);
		end


	$Shared_Sleeper_Birth (ThisAgent);

End

///////////////////////////////////////////////////////////////////////////////
Function Offmap_Sleeper_Birth (agent ThisAgent)
Declare


Begin

	ThisAgent's "Coord_Home" = $FarthestMapEdge (ThisAgent);

	ThisAgent's "SleeperScript" = $Offmap_Sleeper_Callback;

	$Shared_Sleeper_Birth (ThisAgent);

End

///////////////////////////////////////////////////////////////////////////////
Function Shared_Sleeper_Birth (agent ThisAgent)
Declare
	integer	Sleeper_Callback_Time;
	list		Buildings;
	integer	Distance;
	agent 	AIRootAgent;

Begin
	ThisAgent's "Target" = $NullAgent ();

	$ListObjects (ThisAgent, "Building", -1, Buildings );

	if ($listsize(buildings) > 0)
		Distance = $DistanceBetweenAgents (ThisAgent, $ListMember (Buildings, 1));
	else
		Distance = 1500;

	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	//If ThisAgent is Vendral and we are in Slay Dragon, then hardcode the sleeper callback time
	If (ThisAgent's "Title" == "Vendral" && AIRootAgent's "Quest_Number" == #QNumber_Slay_Dragon)
		begin

			Sleeper_Callback_Time = (120000 + $RandomNumber (120000) + 1);

		end

	Else
		begin

			Sleeper_Callback_Time = #Sleeper_Base_Callback + (Distance * #Sleeper_Callback_Mod);

		end
	$NewThread (ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent);

	$RunThread (ThisAgent's "SleeperScript", Sleeper_Callback_Time, ThisAgent);

	thisagent's "startingScript" = thisagent's "basicScript";
End

///////////////////////////////////////////////////////////////////////////////
Function Sleeper_Death (agent ThisAgent)
Declare

Begin
	If ($IsRunning (ThisAgent's "SleeperScript"))
		$KillThread (ThisAgent's "SleeperScript");

	$monster_gravestone(thisagent);
End

///////////////////////////////////////////////////////////////////////////////
// This returns True if the Sleeper Home is valid,
// False if it is offmap or dead
Function Is_Valid_Sleeper_Home (agent ThisAgent) is boolean
Declare

Begin
	If ($IsDead (ThisAgent))
		return False;


	If ($UnitIsOffmapLair (ThisAgent))
		return False;


	if (thisagent's "type" != "Lair")
		return FALSE;

		return True;
End
///////////////////////////////////////////////////////////////////////////////
function raider(agent thisagent)

declare

	list buildings;
	agent target;
	boolean casting;
	integer attackrange;
	string spell_name;

begin
	target = thisagent's "target";

	if ($notvalid(thisagent's "target"))
		begin
			$debugout(thisagent's "title"," picking a target.");
			$ListObjects(thisagent,"building",50000, buildings );
			if ($listsize(buildings) > 0)
				begin
					ThisAgent's "Target" = $ListMember (Buildings, 1);
					//thisagent's "target" = $pick_closest(thisagent,buildings);
				end
			else
				begin
					// raider wanders because it has no targets
					thisagent's "activescript" = $wandering;
				end
		end
	else
		begin
			// pick weapon or spell
			spell_name = $getbestspell(thisagent,#list_attack);
			$debugout("raider spell:",spell_name);

			if (spell_name == "nothing")
				begin
					attackrange = $getattribute(thisagent,#ATTRIB_maxattackrange);
					casting = FALSE;
				end
			else
				begin
					attackrange = thisagent's "castingrange";
					casting = TRUE;
				end

			$cleanse_hostiles(thisagent);

			if (($listsize(thisagent's "hostiles") > 0) && (thisagent's "raider_respond" == TRUE))
//			if ((thisagent's "raider_respond" == TRUE))
				begin
					$monster_eval_enemies(thisagent);
				end
//			else
				if ($distancebetweenagents(thisagent,thisagent's "target") < attackrange)
					begin
						// check for peasants nearby who are repairing buildings
						if ($peasants_near(thisagent) == FALSE)
							begin
								if (casting)
									$castspell(thisagent,spell_name,target, "");
								else
									if ($randomnumber(1000) <= 995)
										$PerformAction (ThisAgent, ThisAgent's "Attack_Action", ThisAgent's "Target");
									else
										$PerformAction (ThisAgent, thisAgent's "Idle_action", ThisAgent's "Target");
							end
					end
				else
					begin
						thisagent's "destination" = $locationof(thisagent's "target");
 						thisagent's "activescript" = $monster_travel_to;
						thisagent's "backscript" = $raider;
						//$move(thisagent,$locationof(thisagent's "target"));
						$move(thisagent,thisagent's "target");
					end
		end

end

///////////////////////////////////////////////////////////////////////////////
function cleanse_hostiles(agent thisagent)

declare
	agent enemy;
	list newlist;

begin
	if ($listsize(thisagent's "hostiles") > 0)
		begin
			foreach enemy in thisagent's "hostiles" do
				begin
					if ($isvalidgamepiece(enemy))
						newlist << enemy;
				end

			thisagent's "hostiles" = newlist;
		end
end

///////////////////////////////////////////////////////////////////////////////
function peasants_near(agent thisagent) is boolean

declare
	list peasants,helpers;
	agent peasant,helper;
	boolean do_it;

begin
	$listobjects(thisagent's "target","hero",$getattribute(thisagent,#ATTRIB_sightrange),peasants,#myplayer);
	peasants = $listtitles(peasants,"peasant");

	// remove peasants who some one else is closer to

	if ($listsize(peasants) > 0)
		begin
			peasant = $listmember(peasants,1);

			$listobjects(peasant,"monster",$getattribute(thisagent,#ATTRIB_sightrange),helpers,#Notmyplayer);
			//$debugout(911,helpers);

			do_it = TRUE;

			if ($listsize(helpers) > 0)
				begin
					helper = $listmember(helpers,1);
					if (helper != thisagent)
//						do_it = FALSE;
//					else
						if ($distancebetweenagents(helper,peasant) < $distancebetweenagents(thisagent,peasant))
							do_it = FALSE;
				end

			if (do_it)
				begin
					thisagent's "target" = peasant;
					thisagent's "ActiveScript" = $Monster_Attack_object;
					return TRUE;
				end
			else
				return FALSE;
		end

	return False;
end
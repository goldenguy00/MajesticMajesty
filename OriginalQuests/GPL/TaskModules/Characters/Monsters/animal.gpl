///////////////////////////////////////////////////////////////////////////////
Function Animal (agent ThisAgent)
Declare

begin
	if ($ismoving(thisagent) == False)
		begin
			$Move(thisagent,$RandomCoord(ThisAgent,$getattribute (ThisAgent, #ATTRIB_SightRange)),"avoid_buildings");
		end
	else
		$Monster_eval_enemies(thisagent);
end
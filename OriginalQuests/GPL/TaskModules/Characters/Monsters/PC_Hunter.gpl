Function PC_Hunter_Eval_Hostiles (agent ThisAgent)
// this function is the PC hunter evaluation while 'travelling_to'
Declare

begin
	$cleanse_hostiles(thisagent);

	If ($ListSize (ThisAgent's "Hostiles") > 0)
		begin
			ThisAgent's "Target" = $Pick_Closest (ThisAgent, ThisAgent's "Hostiles");
//			ThisAgent's "ActiveScript" = $PC_Hunter_Attack_Object;
			thisagent's "activeScript" = $monster_attack_object;
			$ClearList (ThisAgent's "Hostiles");
		end
end


Function Pc_Hunter_Eval_Enemies (agent ThisAgent)

// this function is only called by the basic PC hunter code and Item Hunter code
Declare
	string enemy;
	list in_sight,newl;

begin
	enemy = thisagent's "EnemyType";
	$ListObjects(thisagent,enemy,$getattribute(thisagent,#ATTRIB_Sightrange), in_sight );

	// add hostiles to in_sight;
//	in_sight = in_sight + (thisagent's "Hostiles");
	newl = $addlists(in_sight,thisagent's "Hostiles");
	in_sight = newl;

//	$debugout($listsize(in_sight));
 	if ($listsize(in_sight) > 0)
		begin
			// pick the closest guy to attack
			thisagent's "Target" = $pick_closest(thisagent,in_sight);
//			thisagent's "ActiveScript" = $PC_Hunter_Attack_object;
			thisagent's "activeScript" = $monster_attack_object;
			$Clearlist (ThisAgent's "Hostiles");
		end
end
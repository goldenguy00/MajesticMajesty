Function PC_Hunter (agent ThisAgent)

Declare
	agent		Best_Target;
	agent 	Hero;
	list		Heroes;
	list		Henchmen;
	integer	Temp_Score,Best_Score,distance;
	integer	HP,Ranged;
	boolean	Flag;
  //	integer	Intelligence,Speed,Dodge,Artifice,Willpower,Parry,Luck,Strength,HtoH;


Begin
	Flag = False;

	if ((thisagent's "title" != "Url_shekk") && (thisagent's "title" != "Black_phantom"))
		distance = $getattribute (ThisAgent, #ATTRIB_sightrange) * #PCHunter_Find_Target_Mod;
	else
		distance = -1;

	Heroes = $ListSubTypesInRadius (ThisAgent, ThisAgent's "EnemyType", "hero", distance);
	Best_Score = 0;

	If ($ListSize (Heroes) > 0)
		begin
			Foreach Hero in Heroes do
				begin
					Temp_Score = $GetAttribute (Hero, #ATTRIB_ExperienceLevel);
					If (Temp_Score >= Best_Score)
						begin
							ThisAgent's "Target" = Hero;
							Best_Score = Temp_Score;
							Flag = True;
						end
				end
		end

	Else
		begin
			if ((thisagent's "title" != "Url_shekk") && (thisagent's "title" != "Black_phantom"))
				distance = $GetAttribute (ThisAgent, #ATTRIB_SightRange) * #PCHunter_Find_Hench_Mod;
			else
				distance = -1;

			Henchmen = $ListSubtypesInRadius (ThisAgent, ThisAgent's "EnemyType", "henchman", distance);
			If ($ListSize (Henchmen) > 0)
				begin
					ThisAgent's "Target" = $ListMember (Henchmen, 1);
					Flag = True;
				end
		end

	If (Flag)
		begin
			$performaction(thisagent,thisAgent's "Idle_action",ThisAgent's "Target");

//			ThisAgent's "ActiveScript" = $PC_Hunter_Attack_Object;
			thisagent's "activescript" = $monster_attack_Object;
			$DebugOut (thisagent's "title","has acquired a PC target! Beginning the hunt.");
		end
	Else
		begin
			If ($IsMoving (ThisAgent) == FALSE)
				$Move (ThisAgent, $RandomCoord (ThisAgent, $getattribute (ThisAgent, #ATTRIB_SightRange)));
			Else
				$PC_Hunter_Eval_Enemies (ThisAgent);
		end
End




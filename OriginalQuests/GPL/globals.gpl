// end-game pause delay
expression #EndGameFadeDelay 1500

// message box scrolling
expression #MessageBoxScrollSpeed 3000

// supercharge time
expression #SuperChargeDuration 30000

expression #followBored 20

expression #palace_revenue_cap 300

expression #max_tohit 95
expression #max_toavoid 95

expression #Deathmatch_max_toavoid 85
expression #Deathmatch_Hero_Magic_Resist 30

expression #level_div 1

expression #Lightning_Storm_Min_Damage 8
expression #Lightning_Storm_Max_Damage 25

expression #Deathmatch_Lightning_Storm_Min_Damage 5
expression #Deathmatch_Lightning_Storm_Max_Damage 14

expression #Agrella_Healing_Multiplier 8

expression #Deathmatch_Agrella_Healing_Multiplier 4
expression #Deathmatch_Agrella_Healing_Cap 24

expression #Deathmatch_Temple_Heal 30

// This expression controls the reducing rate of returns on marketplaces and
// trading posts in deathmatch mode.  The higher it is set, the better the
// rate of returns on additional markets/tradeposts.
// IT SHOULD NEVER BE SET TO A VALUE OF LESS THAN 2!!!
expression #Deathmatch_income_modifier 3


// special case: "Last Palace Standing" increases the cost multiplier for some buildings
// UPDATE 1.3 THIS IS NEW CODE FOR THIS PATCH RELEASE --CBT
// Note: because we need fractional multipliers and there is no C-interface
//		 for floating point GPL expressions, the below values are divided
//		 by 10 when used (e.g. 12 is actually 1.2, or 4 is actually 0.4)
expression #LPS_BallistaMultiplier	25
expression #LPS_WizTowerMultiplier	18
expression #LPS_GuardhseMultiplier	15
expression #LPS_RylGardnMultiplier	12
expression #LPS_InnMultiplier		12

expression #Deathmatch_Building_Damage_Multiplier 1.5
expression #Deathmatch_Sewer_Limit 3
expression #Deathmatch_Graveyard_Limit 2
expression #Deathmatch_Housing_Limit 6
expression #Deathmatch_Small_Trade_Radius 1700
expression #Deathmatch_Large_Trade_Radius 2800

expression #freestyle_Required_Time_Increment 5
expression #freestyle_Required_Time_Minimum 15
expression #freestyle_Required_Time_Maximum 365


//Expressions for modifiying freestyle difficulty
//Starting gold is divided by this number and then subtracted form the total diff rating
expression #Starting_Gold_Diff_Divider 1000
//This is subtracted from Starting gold/The gold diff divider, so we have a threshold
expression #Starting_Gold_Diff_Threshold 20

expression #starting_gold_very_easy 30000
expression #starting_gold_easy 20000
expression #starting_gold_normal 15000
expression #starting_gold_hard 10000

expression #required_gold_easy 40000
expression #required_gold_normal 80000
expression #required_gold_hard 160000

expression #required_time_easy 15
expression #required_time_normal 30
expression #required_time_hard 60



expression #sewer_close_chance 80


//Default distance from palace that random treasure gets spawned
expression #default_spawn_treasure_dist 500

//Radius around a lait revealed by a Solarii when they "Find a Lair"
expression #reveal_found_lair_dist 300


//Range people use for Is_Free_Task to look for others with the same intentions
expression #Is_Free_Task_Range 2000

expression #is_free_task_max_heroes 2

// Played if (now - last_timeout) > timeout && (conditions met)
// timeout in milli-seconds
expression #advisor_timeout_low_treasury 180000
expression #advisor_trigger_amount_low_treasury 1000

expression #advisor_timeout_need_heroes  60000

// How often to poll looking for when Elves and Dwarves Buildings are available to play the advisor sound.
// Referenced in: game_level.c
expression #advisor_timeout_elves_available   20000
expression #advisor_timeout_dwarves_available 20000

// The minimum percent of building tiles that must be revealed to allow a construction.
// Referenced in: construct.c
expression #construction_minpercent_notblocked 85

expression #force_raider 1
expression #force_overlay 2
expression #force_guardian 3
expression #force_bomber 4


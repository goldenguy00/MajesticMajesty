// how much each statue boosts loyalty of heroes in town
expression #statue_loyalty_boost 5
expression #gardens_loyalty_boost 15

// how close is too close for the purposes of fleeing to?
expression #Near_home_dist 125

expression #near_inn_dist 150

// how much a hero's maxattackrange is reduced for following for bow support
expression #follow_support_buffer 65

// a hero starts with #hero_start_gold + randomnumber(#hero_start_gold) gold
expression #hero_start_gold 50

// override a buildings state
expression #building_force_active 2
expression #building_force_inactive 1
expression #building_normal_state 0


expression #Player_1 0 //This is the Human Player in epic quest/single-player freestyle games
expression #Player_2 1 //Call this expression for access to Player 2
expression #Player_3 2
expression #Player_4 3
expression #Monster_Player 7 //use this expression when spawning onto the Monster Player

//Distance within which Guardhouse will fire arrows at bad guys
expression #guardhouse_arrow_range 150

// The hero level required to allow you to edit their name
expression #HeroNameEditingLevel 10


// mod much any extra range a character has is divided by in order
// to give them an extra shot. was 45 but uppded to 65 to try to get rangers
// more accurate
expression #extra_shot_mod 65

//General spawn cap for monsters (they won't spawn if this many monsters are already on the map) Overriden in some special
//cases in EQuests
expression #Monster_Spawn_Cap 85

//Largest discrepancy between a unit's destination and the location of their moving target that a unit will
//tolerate before they decide to issue another more accurate move order.
expression #Destination_Target_Discrepency_Tolerance 75

//Max number of followers the Priestess can have at a time
expression #Max_Number_Priestess_Followers 3

//Max number of followers the Cultist can have at a time
expression #Max_Number_Cultist_Followers 3

// how close a charcter needs to be to the edge of the screen before they think
// they can leave the map
expression #edge_buffer 64

//Number of heroes that have to die before a Graveyard is created
expression #Graveyard_limit 15

// how long gravestones wait before disappearing
expression #Gravestone_lifespan 10000
expression #Gravestone_lifespan_max 90000
// how long rubble waits before disappearing
expression #RubbleCleanupPeriod 60000

// period to check for recruiting a hero
// will be recruited if individual recruitment delay is up
expression #DelayRecruitCheckPeriod 1000

// healing and poison values:
// time interval that hitpoint deltas are checked
expression #PeriodicHPDeltaPeriod 1000
// frequency for poisoning and healing
expression #PoisonInterval 1
expression #HealingInterval 5

//Duration that a Wizard's Tower enchantment lasts for
expression #Wiz_Tower_Enchantment_Duration 90000

// cost in crystals for a wizard's tower
expression #WizTowerCrystalCost 100

// cost in gold to upgrade a wizard's tower
expression #WizTowerUpgradeCost 400

// cost for guild skills
expression #RageOfKrolmCost 1500
expression #AssemblyCost 500
expression #MoveCampCost 800

// initial and delta values for reward flags
expression #RewardInitial 0
expression #RewardDelta 100

// limits for auto spawned buildings in your kingdom
// number of heroes that need to live in town before a general house is created
expression #Population_waiting_limit 4

// number of buildings built in a town before sewers need building
expression #Sewer_building_limit 9

// amout of gold that is 'vaporized' before spawning a troll in town
expression #Troll_gold_limit 1000

// amount of markets, blacksmiths and inns needed for a fountain to be build
expression #fountain_building_limit 5

// number of trips to the blacksmith before a minotaur autospawns
expression #minotaur_blacksmith_limit 25


//This is for Global Random Coord. Controls how close to the edge of the map
//the function will allow the RandomCoord it returns to be
expression #Edge_Tolerance 200

//Execution time for 'normal' activescripts/threads (Hero's activescripts, for instance)
expression #Normal_Cycle 300
expression #Henchmen_Cycle 500
expression #Flag_Cycle 500
expression #Lair_cycle 1200
expression #Fairgrounds_Cycle 1100

//Amount of time Fairgrounds run Dump_Contestants for before they return to normal polling/running tourneys
//used to make sure Heroes get reset properly when Tourney changes
expression #Fairgrounds_Reset_Time 10000

expression #palace_revenue_cycle 20000
expression #palace_revenue_amount 5

expression #Housing_revenue 8
expression #housing_random 8

// fairgrounds globals

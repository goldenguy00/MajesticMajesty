//Max speed that lairs will spawn monsters
expression #Max_Lair_Spawn_Time 15000

//Millisecond rate at which "Annoyed" Lairs spawn
//expression #Lair_Annoyed_Spawn_Rate 5000

//Subtacted from a Lair's Spawn Rate every time a creature is spawned, so the longer the game, the faster the Spawn Rate

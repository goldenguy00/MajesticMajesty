///////////////////////////////////////////////////////////////////////////////
// Birth script for "Quest for the Magic Ring" quest specific building, Hidden_Ring_Site
// This checks to see if Quest Flag 1 is true. If it is, that means that the first Hidden Ring Site is gone,
// and this one needs to spawn w/o a magic ring in it
Function Hidden_Ring_Birth (agent ThisAgent)
Declare
	agent	RootAgent;
	agent	Palace, Temp_Palace;
	list	Palaces;

Begin
	RootAgent = $RetrieveAgent ("GplAIRoot");

	//If true, then this is the second ring site.
	If (RootAgent's "Quest_Flag_1" == True)
		begin

			//This unit is not flaggable and not targettable by spells
			$SetAttribute (ThisAgent, #ATTRIB_NotFlaggable, 1);
			$SetAttribute (ThisAgent, #ATTRIB_NotSpellTarget, 2);

			Palaces = $ListPalaces ();

			//Get the Player 1 palace
			Foreach Temp_Palace in Palaces do
				begin
					If ($GetUnitPlayerNumber (Temp_Palace) == #Player_1)
		   			Palace = Temp_Palace;
				end

			$MessageFlag (ThisAgent, #Message_Magic_Ring_Show_Site_2);

			//reveal the area
			$revealArea(Palace,$LocationOf (ThisAgent),400);

			//Spawn at full HP
			$SetAttribute (ThisAgent, #ATTRIB_HP, $GetAttribute (ThisAgent, #ATTRIB_MaxHP));

			//This is to set it apart from the first ring site
			ThisAgent's "Title" = "Hidden_Ring_Site2";

			ThisAgent's "Type" = "Special";
		end

	$Lair_Birth (ThisAgent);
End


///////////////////////////////////////////////////////////////////////////////
// Birth script for "Quest for the Holy Chalice" quest specific building, Hidden_Chalice_Site
// This just spawns Rrongol so that he know this is his parent, and when he runs Guardian_Birth, he will
// patrol it
Function Hidden_Chalice_Birth (agent ThisAgent)

Declare

Begin
	$SpawnUnit (ThisAgent, "Rrongol", "Override");

	$Lair_Birth (ThisAgent);
End


///////////////////////////////////////////////////////////////////////////////
function Broken_sewer_Birth(agent thisagent)

declare
	integer team;
	agent AIRootAgent;

begin
	AIRootAgent = $retrieveAgent("GplAIRoot");
	if (AIRootAgent's "quest_number" == #qnumber_clash_empires)
		team = #player_3;
	else
		team = #monster_player;

	$setunitplayernumber(thisagent,team);
	$rat_spawn(thisagent);
	$lair_birth(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
Function lair_birth(agent thisagent)

Declare

begin
	//Set up attribs with GPL values if they are initialalized to 0
	If ($GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate) == 0)
		$SetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate, ThisAgent's "Base_Spawn_Rate");

	If ($GetAttribute (ThisAgent, #ATTRIB_Lair_History_Mod) == 0)
		$SetAttribute (ThisAgent, #ATTRIB_Lair_History_Mod, #Lair_History_Modifier);

	$NewThread (ThisAgent's "Spawn_Function", $GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate), ThisAgent);

	$NewThread (thisagent's "activeScript", #Lair_Cycle, thisagent);
end


///////////////////////////////////////////////////////////////////////////////
function city_lair_birth(agent thisagent)

declare
	integer time_to_spawn;

begin
	$auto_birth(thisagent);
	$lair_birth(thisagent);

	Time_To_Spawn = $GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate);
	time_to_spawn = $random_time(time_to_spawn);
	$SetThreadInterval (ThisAgent's "Spawn_Function", Time_To_Spawn);

	// set the built flag so that the sound isn't "under construction"
	$setattribute(thisagent,#ATTRIB_FirstStageBuilt,1);

	if (thisagent's "title" == "graveyard")
		begin
			// set up a random number of spawns this graveyard has before it
			// decays and leaves the map
			// store it in difficulty
			thisagent's "difficulty" = $randomnumber(5) + 10;
		end

end

///////////////////////////////////////////////////////////////////////////////
function guardhouse_birth(agent thisagent)
declare
//	agent	AIRootAgent;

begin
//	$NewThread (ThisAgent's "RevenueScript", ThisAgent's "revenue_time", ThisAgent);

	//$count_building(thisagent);

	$NewThread (ThisAgent's "Guard_Function", #Normal_Cycle, ThisAgent);
	$RunThread (ThisAgent's "Guard_Spawn_Function", 1, ThisAgent);

	$Building_Birth (ThisAgent);
end

///////////////////////////////////////////////////////////////////////////////
// This function is called before the first frame of the game
// it is needed to force the palace's upgrade button to be correct
// IT ALSO  sets thisagent to title palace if it is an outpost

// This is run AFTER all the birthscripts for units have run

function Palace_Pre_Birth( agent thisagent )
declare
begin

	//If ThisAgent is an outpost, then change its title to Palace
	If (ThisAgent's "Title" == "Outpost")
		begin

			ThisAgent's "Title" = "Palace";

		end

	Else
		$setattribute(thisagent,#ATTRIB_Upgrade_herosNeeded,thisagent's "heroes_to_upgrade");

end

///////////////////////////////////////////////////////////////////////////////
Function Palace_Birth (agent ThisAgent)
Declare

Begin

	thisagent's "in_danger" = FALSE;
	$clearlist(thisagent's "tax_route");
	$clearlist(thisagent's "tax_targets");
	$NewThread( thisagent's "activeScript", #palace_revenue_cycle, thisagent );
	$NewThread( ThisAgent's "Guard_Function",#Normal_Cycle, ThisAgent);
	$RunThread (ThisAgent's "Guard_Spawn_Function", #initial_Palace_guard_delay, ThisAgent);
	$runThread( ThisAgent's "Tax_spawn",#initial_tax_collector_delay, thisagent);
	$runThread(thisagent's "peasant_spawn",#initial_peasant_delay, thisagent);
End

///////////////////////////////////////////////////////////////////////////////
Function Tower_Birth	(agent ThisAgent)
Declare


Begin
	//$count_building(thisagent);

//	If ($ValidFunction (ThisAgent's "RevenueScript"))
//		$NewThread (ThisAgent's "RevenueScript", ThisAgent's "revenue_time", ThisAgent);

	// if it is a ballista tower (or guardhouse?) run an activescript

	If ((ThisAgent's "Title" == "Ballista_Tower") || (ThisAgent's "Title" == "Guardhouse"))
		$NewThread (ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent);

	if (thisagent's "Title" == "wizards_tower")
		$setattribute(thisagent,#ATTRIB_enchantmentLevel,0);

	$Building_Birth (ThisAgent);
End


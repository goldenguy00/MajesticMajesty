///////////////////////////////////////////////////////////////////////////////
Function Goblin_Watchtower_Birth ( agent thisagent )
Declare


begin
	//Set up attribs with GPL values if they are initialalized to 0
	$NewThread ( ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent );
end


Function Outpost_Birth ( agent ThisAgent )
Declare

Begin

	thisagent's "in_danger" = FALSE;
	$clearlist ( thisagent's "tax_route" );
	$clearlist ( thisagent's "tax_targets" );
	if ( $getunitplayernumber ( thisagent ) != #monster_player )
		begin
			$NewThread ( thisagent's "activeScript", #palace_revenue_cycle, thisagent );
			$NewThread ( ThisAgent's "Guard_Function",#Normal_Cycle, ThisAgent );
			$RunThread ( ThisAgent's "Guard_Spawn_Function", #initial_Palace_guard_delay, ThisAgent );
			$runThread ( ThisAgent's "Tax_spawn",#initial_tax_collector_delay, thisagent );
			$runThread ( thisagent's "peasant_spawn", #initial_peasant_delay, thisagent );
		end

	//Check stray heroes - pass "hero" as it is a special case
	// the player number check is so that if you want this to be
	// 'rescuable' it needs to not adopt right away!
	if ( $getunitplayernumber ( thisagent ) != #monster_player )
		begin
			$check_strays ( thisagent, "hero", #MyPlayer );
			$check_strays ( thisagent, "hero", #NotMyPlayer );
		end

End

///////////////////////////////////////////////////////////////////////////////
Function Embassy_Birth ( agent ThisAgent )
Declare


Begin

	$NewThread ( ThisAgent's "ActiveScript", #Embassy_Min_Spawn_Hero_Time +
	$RandomNumber ( #Embassy_Max_Spawn_Hero_Time - #Embassy_Min_Spawn_Hero_Time ), ThisAgent );

	$Building_Birth ( ThisAgent );

	//Embassy allows the player to see everything that their allied team-member can see
	$SetShareReveal ( $GetUnitPlayerNumber ( ThisAgent ), True );

	//Check stray heroes - pass "hero" as it is a special case
	// the player number check is so that if you want this to be
	// 'rescuable' it needs to not adopt right away!
	if ( $getunitplayernumber ( thisagent ) != #monster_player )
		begin
			$check_strays ( thisagent, "hero", #MyPlayer );
			$check_strays ( thisagent, "hero", #NotMyPlayer );
		end

End

///////////////////////////////////////////////////////////////////////////////
// This function is called by the in-game code when a building is upgraded
function building_upgraded ( agent thisagent )

declare

begin

	$runthread ( thisagent's "upgradescript", 1, thisagent );

end


///////////////////////////////////////////////////////////////////////////////
// This function is called by the in-game code to determine the number
// of henchmen a palace supports
function GetSupportedHenchmen ( agent thisagent, integer index ) is integer

declare
	integer retval,num_fount;
	list fountains;

begin
	retval = 0;

	if ( index == 0 )
		retval = thisagent's "max_peasants";
	else if ( index == 1 )
		begin
			$listobjects ( thisagent, "building", -1, fountains, #CheckTitles, "Fountain", #Myplayer );
			//fountains = $listtitles(fountains,"fountain");

			num_fount = $listsize ( fountains );

			retval = thisagent's "max_tax_collectors" + num_fount;
		end
	else if ( index == 2 )
		retval = thisagent's "Max_guards";

	return retval;
end


///////////////////////////////////////////////////////////////////////////////
// Common code used by heroes, henchmen, and cheats for finishing up
// a building's upgrade or construction process
function BuildingReachedMaxHP ( agent theBuilding )

declare
	agent AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	//$DebugOut(911, "BuildingReachedMaxHP() for ", theBuilding);

	if ( $getattribute ( theBuilding, #ATTRIB_FirstStageBuilt ) != 1 )
	begin
		if ( $hasattribute ( "birthscript2", theBuilding ))
			begin
				//Have advisor say that a building has been upgraded
				$PlaySound ( TheBuilding, "Advisor_Building_Complete", "VFX_ADVISOR" );
				$LocalChatMessage ( $GetUnitPlayerNumber ( TheBuilding  ), #chat_building_complete, TheBuilding );

				$runthread ( theBuilding's "birthscript2", 1, theBuilding );

				//$DebugOut(911, " ran 'birthscript2'.");
			end
		//else
			//$DebugOut(911, " COULDN'T run 'birthscript2'.");
	end
	else
		// is being repaired or upgraded?
		if ( $getattribute ( theBuilding, #ATTRIB_currentstagebuilt ) != 1 )
			begin
				$UpgradeAgentAttributes ( theBuilding );

				If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
					begin
						$SetAttribute ( theBuilding, #ATTRIB_MaxGuildMembers, 1 );

						If (TheBuilding's "Subtype" == "Palace")
							If (TheBuilding's "Level" == 2)
								TheBuilding's "heroes_to_upgrade" = 4;

					end

				If ( TheBuilding's "Title" == "Palace" )
					begin

						//Play the special Palace voice line
						$PlaySound ( TheBuilding, "Advisor_Palace_Upgrade", "VFX_ADVISOR" );

						// special case for palace
						$setattribute ( TheBuilding, #ATTRIB_Upgrade_herosNeeded, TheBuilding's "heroes_to_upgrade" );
					end

				Else
					begin
						//Have advisor say that a building has been upgraded
						$PlaySound ( TheBuilding, "Advisor_Building_Upgraded", "VFX_ADVISOR" );
						$LocalChatMessage ( $GetUnitPlayerNumber ( TheBuilding ), #chat_building_upgraded, TheBuilding );
						
						If (TheBuilding's "Title" == "Guardhouse")
							begin
								// Max_Guards might have changed when the attributes were updated.
								$RestartGuardSpawnThread(TheBuilding, 1);
							end						
					end

				//$DebugOut(911, " ran $UpgradeAgentAttributes.");
			end
		else
			begin
				// done repairing
				if ( $getattribute ( thebuilding, #ATTRIB_quickRepair ) == 1 )
					$setattribute ( thebuilding, #ATTRIB_quickRepair, 0 );
			end

	$setattribute ( theBuilding, #ATTRIB_HP, $getattribute ( theBuilding, #ATTRIB_MaxHP ));
	$setattribute ( theBuilding, #ATTRIB_currentstagebuilt, 1 );
	$setattribute ( theBuilding, #ATTRIB_FirstStageBuilt, 1 );
end

///////////////////////////////////////////////////////////////////////////////
function basic_upgrade ( agent thisagent )

declare
	agent	AIRootAgent;
	agent palace;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
		begin
			$SetAttribute ( ThisAgent, #ATTRIB_MaxGuildMembers, 1 );
		end

	palace = $gettruepalace ( thisagent );
	palace's "buildings_waiting" << thisagent;
end

///////////////////////////////////////////////////////////////////////////////
function magical_upgrade ( agent thisagent )

declare
	agent palace, AIRootAgent;
	integer HP, Maxhp, build_rate;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
		begin
			$SetAttribute ( ThisAgent, #ATTRIB_MaxGuildMembers, 1 );
		end

	HP = $getattribute ( thisagent, #ATTRIB_HP );
	MaxHP = $getattribute ( thisagent, #ATTRIB_MAXHP );
	build_rate = thisagent's "magical_build_rate";

	if (HP != MAXHP)
		begin
  			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				begin
					if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
						HP += #Deathmatch_magical_build_amount;
					else
						HP += build_rate;
				end
			else
				HP += build_rate;

			if ( HP > MAXHP )
				HP = MAXHP;

			$setattribute ( thisagent, #ATTRIB_HP, HP );
			$runthread ( thisagent's "upgradescript", #magical_build_delay, thisagent );
		end
	else
		begin
			$UpgradeAgentAttributes ( thisagent );

			If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
				begin
					$SetAttribute ( ThisAgent, #ATTRIB_MaxGuildMembers, 1 );
				end

			$setattribute ( thisagent, #ATTRIB_currentstageBuilt, 1 );
			//$setattribute(thisagent,#ATTRIB_firststageBuilt,1);
			$playsound ( thisagent, "Advisor_Building_Upgraded", "VFX_ADVISOR" );

			//Chat to the message area
			$LocalChatMessage ( $GetUnitPlayerNumber ( ThisAgent ), #chat_building_upgraded, ThisAgent );
		end
end

///////////////////////////////////////////////////////////////////////////////
function palace_upgrade ( agent thisagent )

declare

begin
	$basic_upgrade ( thisagent );
	$runthread ( thisagent's "upgradescript2", #palace_upgrade_check, thisagent );

	// these following are so that we insure the new limits are enacted, even if the player
	// upgrades the palace again right away
	$RunThread ( ThisAgent's "Guard_Spawn_Function", #initial_Palace_guard_delay, ThisAgent );
	$runThread ( ThisAgent's "Tax_spawn", #initial_tax_collector_delay, thisagent );
	$runThread ( thisagent's "peasant_spawn", #initial_peasant_delay, thisagent );
end

///////////////////////////////////////////////////////////////////////////////
function palace_upgrade2 ( agent thisagent )

declare

begin
	if ( $getattribute ( thisagent, #ATTRIB_currentStageBuilt ) != 1 )
		$runthread ( thisagent's "upgradescript2", #palace_upgrade_check, thisagent );
	else
		begin
			// run the spawners so the new henchman limits are enacted
			$RunThread ( ThisAgent's "Guard_Spawn_Function", #initial_Palace_guard_delay, ThisAgent );
			$runThread ( ThisAgent's "Tax_spawn", #initial_tax_collector_delay, thisagent );
			$runThread ( thisagent's "peasant_spawn", #initial_peasant_delay, thisagent );
//			$setattribute(thisagent,#ATTRIB_Upgrade_herosNeeded,thisagent's "heroes_to_upgrade");
		end
end

///////////////////////////////////////////////////////////////////////////////
function basic_birth ( agent thisagent )

declare
	agent palace;
	integer HP,Maxhp;

begin
	HP = $getattribute ( thisagent, #ATTRIB_HP );
	MaxHP = $getattribute ( thisagent, #ATTRIB_MAXHP );

	thisagent's "in_danger" = FALSE;

	if ( HP != MAXHP )
	// if (thisagent is not completed)
		begin
		//put thisagent on the palace's list of buildings needing
			palace = $gettruepalace ( thisagent );
			palace's "buildings_waiting" << thisagent;
		end
	else
		$runthread ( thisagent's "birthscript2", 1, thisagent );
end

///////////////////////////////////////////////////////////////////////////////
function magical_birth ( agent thisagent )

declare
	agent palace, AIRootAgent;
	integer HP, Maxhp, build_rate;

begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	HP = $getattribute ( thisagent, #ATTRIB_HP );
	MaxHP = $getattribute ( thisagent, #ATTRIB_MAXHP );
	build_rate = thisagent's "Magical_Build_Rate";

	if ( HP != MAXHP )
		begin
  			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				begin
					if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
						HP += #Deathmatch_magical_build_amount;
					else
						HP += build_rate;
				end
			else
				HP += build_rate;

			if ( HP > MAXHP ) HP = MAXHP;
			$setattribute ( thisagent, #ATTRIB_HP, HP );

			if (HP > 0)
				$runthread ( thisagent's "birthscript", #magical_build_delay, thisagent );
		end
	else
		begin
			if ( $getattribute ( thisagent, #ATTRIB_firststageBuilt ) == 0 )
				begin
					$playsound ( thisagent, "Advisor_Building_Complete", "VFX_ADVISOR" );

					//Chat to the message area
					$LocalChatMessage ( $GetUnitPlayerNumber( ThisAgent ), #chat_building_complete, ThisAgent);
				end

			$setattribute ( thisagent, #ATTRIB_currentstageBuilt, 1 );
			$setattribute ( thisagent, #ATTRIB_firststageBuilt, 1 );
			$runthread ( thisagent's "birthscript2", 1, thisagent );
		end
end

///////////////////////////////////////////////////////////////////////////////
function auto_birth ( agent thisagent )

declare

begin
	$count_building ( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
// Add the building to the owner's Palace building count.
// This can cause other units to be auto-created, such as sewers.
function count_building ( agent thisagent )

declare
	agent palace, bldg, AIRootAgent;
	list bldgs;
	integer i;
	boolean flag;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $gettruepalace ( thisagent );
	flag = TRUE;

	if ( $isvalidgamepiece ( palace ))
		begin
			palace's "total_buildings" ++;
			palace's "buildings_lately" ++;

			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
					begin
						$listobjects ( palace, "AutoBuilding", -1, bldgs, #CheckTitles, "Sewers", #MyPlayer );
						if ( $ListSize ( bldgs ) >= #Deathmatch_Sewer_Limit )
							flag = FALSE;
					end

			//If this is Valley of the Serpents, then no infrastructure
			Else if ( AIRootAgent's "Quest_Number" == #QNumber_Vale_Serpents )
				begin

					Flag = False;

				end


			if ( Flag == TRUE )
				if ( palace's "buildings_lately" >= #sewer_building_limit )
					begin
						palace's "buildings_lately" = 0;

						$listobjects ( palace, "building", -1, bldgs, #MyPlayer, #ATTRIB_FirstStageBuilt, 1 );

						bldgs << palace;

						i = $listsize ( bldgs );

						bldg = $listmember ( bldgs, $randomnumber ( i ) + 1 );

						$spawnunit ( bldg, "sewers", "maxhp" );
					end

			if (( thisagent's "title" == "marketplace" ) || ( thisagent's "title" == "blacksmith" ) ||
				( thisagent's "title" == "inn" ))
				begin
					palace's "fountain_buildings" ++;
					if ( palace's "fountain_buildings" == #fountain_building_limit )
						begin
							palace's "fountain_buildings" = 0;
							$spawnunit ( palace, "fountain", "maxhp" );
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
// Changed for outpost functionality, so that if "hero" is passed, then check_strays does a global search
// for heroes.
function check_strays ( agent thisagent, string what_hero, integer player )

declare
	list new_strays,strays;
	agent stray;

begin
	// check map for strays
	//
	$ListObjects ( thisagent, "hero", -1, strays, player, #insideOtherUnits );

	//If What_hero == "hero", then check by subtype (this is for the outpost)
	//otherwise, check by the title that is passed as what_hero
	If ( what_hero == "hero" )
		strays = $ListSubtypes ( strays, what_hero );

	Else
		strays = $listtitles ( strays, what_hero );

	foreach stray in strays do
		begin
			if (( stray's "home" ) == $nullagent ())
				new_strays << stray;
		end

	while (( $listsize ( new_strays ) > 0 ) && $GuildHasOpenSlots ( thisagent )) do
		begin

			stray = $pick_closest ( thisagent, new_strays );
			new_strays -= stray;

			if ( player == #Notmyplayer )
				begin
					if ( $randomnumber ( 100 ) > stray's "loyalty" )
						$adopt ( thisagent, stray );
				end
			else
				$adopt ( thisagent, stray );
		end
end

///////////////////////////////////////////////////////////////////////////////
function adopt( agent thisguild, agent stray )

declare

begin
	//If the hero has Rage of Krolm on them, then turn it off...otherwise the call back will call the wrong palace,
	//as $GetPalace will return a different palace when Rage_End gets called by the effector
	If ( $CheckEffector ( Stray, "Rage_Icon" ))
		begin

			$DeleteEffector ( Stray, "Rage_Icon" );

		end

	thisguild's "members" << stray;
	stray's "home" = thisguild;
	$setparent ( stray, thisguild );
	stray's "basicScript" = stray's "startingScript";
	$setunitplayernumber ( stray, $getunitplayernumber ( thisguild ));

	if ( $IsDead ( stray ) == FALSE ) // If the unit is dead, it doesn't need or want its tasks reset.
		$reset_tasks ( stray );
end

///////////////////////////////////////////////////////////////////////////////
function guild_birth ( agent thisagent )

declare
	agent	AIRootAgent;
	list 	strays,new_strays;
	agent stray;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
		begin


			$SetAttribute ( ThisAgent, #ATTRIB_MaxGuildMembers, 1 );

		end

	thisagent's "in_danger" = FALSE;

	//$count_building(thisagent);

	// the player number check is so that if you want this to be
	// 'rescuable' it needs to not adopt right away!
	if ( $getunitplayernumber ( thisagent ) != #monster_player )
		begin
			$check_strays ( thisagent, thisagent's "member_title", #MyPlayer );
			$check_strays ( thisagent, thisagent's "member_title", #NotMyPlayer );
		end

	$setattribute ( thisagent, #ATTRIB_gold, 0 );

	// start the guild's activescript if it has one
	If ( $HasAttribute ( "ActiveScript", ThisAgent ))
		$NewThread ( ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent );

	$Building_Birth ( ThisAgent );

end

///////////////////////////////////////////////////////////////////////////////
function warriors_guild_birth(agent thisagent)

declare
	list strays,strays2,strays3,total_strays,new_strays;
	agent stray, AIRootAgent;
	string title;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	If (AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
		begin
		
			$SetAttribute (ThisAgent, #ATTRIB_MaxGuildMembers, 1);

		end

	thisagent's "in_danger" = FALSE;

	//$count_building(thisagent);
	// check map for strays
	//
	$check_strays(thisagent,"Warrior",#myplayer);
	$check_strays(thisagent,"Paladin",#myplayer);
	$check_strays(thisagent,"Warrior_of_discord",#myplayer);
	$check_strays(thisagent,"Warrior",#Notmyplayer);
	$check_strays(thisagent,"Paladin",#Notmyplayer);
	$check_strays(thisagent,"Warrior_of_Discord",#Notmyplayer);

	$setattribute(thisagent,#ATTRIB_gold,0);

	$Building_Birth (ThisAgent);
end

///////////////////////////////////////////////////////////////////////////////
function built_or_auto_birth(agent thisagent)

declare
	list list1;

begin
	//$ListObjects(thisagent,"building",-1,list1,#CheckTitles, ThisAgent's "Title",#MyPlayer);
	//list1 = $listtitles(list1,thisagent's "title");

	if ($ListObjects(thisagent,"building",-1,list1,#CheckTitles, ThisAgent's "Title",#MyPlayer) < 1)
		$basic_birth(thisagent);
	else
		begin
			$auto_birth(thisagent);
			$runthread(thisagent's "birthscript2",1,thisagent);
		end
end


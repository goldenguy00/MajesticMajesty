Function Fairgrounds_Birth (agent ThisAgent)
Declare

Begin
//	$count_building(thisagent);

	$NewThread (ThisAgent's "ActiveScript", #Fairgrounds_Cycle, ThisAgent);

	$Building_Birth (ThisAgent);
End

///////////////////////////////////////////////////////////////////////////////
Function Trading_Post_Birth (agent ThisAgent)
Declare

Begin
	$RunThread (ThisAgent's "ActiveScript", #Henchmen_Cycle, ThisAgent);

	$Building_Birth (ThisAgent);
End

///////////////////////////////////////////////////////////////////////////////
function statue_birth(agent thisagent)

declare
	list guys;
	agent guy;

begin
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);

	$debugout(911,"Guys seen by statue",$listsize(guys));
	foreach guy in guys do
		if (guy's "subtype" == "hero")
			guy's "loyalty" += #statue_loyalty_boost;

	$building_birth(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function gardens_birth(agent thisagent)

declare
	list guys;
	agent guy;

begin
	//$count_building(thisagent);
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);

	foreach guy in guys do
		if (guy's "subtype" == "hero")
			guy's "loyalty" += #gardens_loyalty_boost;

	$Building_Birth (ThisAgent);

	$runthread(thisagent's "spawn_1",#gazebo_delay,thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function gazebo_timer(agent thisagent)

declare
	agent palace;

begin
	palace = $gettruepalace(thisagent);

	if ($isvalidgamepiece(palace))
		$spawnunit(palace,"gazebo","maxhp");
end

///////////////////////////////////////////////////////////////////////////////
function fountain_birth(agent thisagent)

declare
	agent palace;

begin
//	$building_birth(thisagent);
	$count_building(thisagent);
	palace = $gettruepalace(thisagent);

	// run the tax spawn function to get a new tax collector
	if ($isvalidgamepiece(palace))
		if ($isrunning (palace's "tax_spawn") == False)
			$runthread(palace's "tax_spawn",#tax_collector_delay,palace);
end

///////////////////////////////////////////////////////////////////////////////
function gazebo_birth(agent thisagent)

declare

begin
	$building_birth(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
// This has a Lair Become Reborn if it was destroyed (run from a special DeathScript)
Function Respawn_Lair (agent ThisAgent)
Declare

Begin
	//Refill HP's and become active again
	$SetAttribute (ThisAgent, #ATTRIB_HP, $GetAttribute (ThisAgent, #ATTRIB_MaxHP));
	ThisAgent's "Type" = "Lair";

	//This Lair can be flagged and cast on again, and re-appears on the minimap
	$SetAttribute (ThisAgent, #ATTRIB_NotFlaggable, 0);
	$SetAttribute (ThisAgent, #ATTRIB_NotSpellTarget, 0);
	$ShowMinimap  (ThisAgent, True);

	//Give the agent some gold again
	$SetAttribute (ThisAgent, #Attrib_Gold, $RandomNumber (500) + 250);

	//Set up attribs with GPL values if they are initialalized to 0
	If ($GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate) == 0)
		$SetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate, ThisAgent's "Base_Spawn_Rate");

	If ($GetAttribute (ThisAgent, #ATTRIB_Lair_History_Mod) == 0)
		$SetAttribute (ThisAgent, #ATTRIB_Lair_History_Mod, #Lair_History_Modifier);

	//Reset ThisAgent's "History_Modifier"
	ThisAgent's "History_Modifier" = 0;

	$NewThread (ThisAgent's "Spawn_Function", $GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate), ThisAgent);

	ThisAgent's "Type" = "Lair";

	ThisAgent's "ActiveScript" = $Lair_Brains;

	$NewThread (thisagent's "activeScript", #Lair_Cycle, thisagent);
End

///////////////////////////////////////////////////////////////////////////////
// Birth script for "Tomb of the Dragon King" quest specific building, Dragon_Tomb
function tomb_birth(agent thisagent)

declare
	agent AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ("GplAIRoot");
	AIRootAgent's "quest_flag_2" = FALSE; // this tells the victory script
														// it is okay to check for victory!!!

	$setattribute(thisagent,#ATTRIB_HP,$getattribute(thisagent,#ATTRIB_MaxHP));

	$lair_birth(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function GuildHasOpenSlots(agent guild) is Boolean
// used to check if a hero can join a guild

declare
	integer list_size, list_capacity;

begin

	// check to see if the guild has any free slots
	list_size = $listsize(guild's "members");
	list_capacity = $getattribute(guild,#ATTRIB_MaxGuildMembers);

	// either has an 2 or more open slots, or isn't recruiting
	return (	(( list_size < list_capacity ) && ($BuildingIsRecruiting(guild) == FALSE) )
			 ||	( list_size < (list_capacity -1) ));

end
declare
	agent palace;
	list 	list1;
	agent AIRootAgent;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	If (AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
		begin

			$SetAttribute (ThisAgent, #ATTRIB_MaxGuildMembers, 1);

		end

	palace = $gettruepalace(thisagent);

	$ListObjects(thisagent,"building",-1,list1,#CheckTitles,"Gnome_Hovel",#MyPlayer);
	//list1 = $listtitles(list1,"gnome_hovel");

	if ($isvalidgamepiece(palace))
		if ($listsize(list1) < #max_gnome_camps)
			if ($isrunning(palace's "gnome_camp_spawner") != TRUE)
				$runthread(palace's "gnome_camp_spawner",#gnome_camp_delay,palace);

	$guild_birth(thisagent);
end


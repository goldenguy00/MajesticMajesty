///////////////////////////////////////////////////////////////////////////////
function bungalow_birth(agent thisagent)

declare
	agent palace, AIRootAgent;
	list list1;

begin
	//TODO: PERHAPS FIND A BETTER PLACE FOR THE FOLLOWING QUEST-SPECIFIC CHECK
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	If (AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
		begin

			$SetAttribute (ThisAgent, #ATTRIB_MaxGuildMembers, 1);

		end

	palace = $gettruepalace(thisagent);

	if ($isvalidgamepiece(palace))
		begin
			// start the brothel timer
			$runthread(thisagent's "spawn_1",#brothel_delay,thisagent);

			//$ListObjects(thisagent,"building",-1,list1,#CheckTitles,"rogues_guild",#MyPlayer);
			//list1 = $listtitles(list1,"rogues_guild");

			if ($ListObjects(thisagent,"building",-1,list1,#CheckTitles,"rogues_guild",#MyPlayer) > 0)
				begin
					if (palace's "gambling_hall_building" == FALSE)
						begin
							$runthread(thisagent's "spawn_2",#gambling_hall_delay,thisagent);
							palace's "gambling_hall_building" = TRUE;
						end
				end
		end

	$guild_birth(thisagent);
end


// Initialize a newly spawned unit
function UnitDelete(integer agentID)
declare
	agent theAgent;
begin
	theAgent = $AgentNumber( agentID );
 	// Run the death script here::
	if ( $ValidFunction( theAgent's "DeathScript" ) )
		( theAgent's "deathScript" )( theAgent );
end

///////////////////////////////////////////////////////////////////////////////
// Initialize a newly spawned unit
function NewUnitInit(agent newAgent)
declare
	agent AIRootAgent;
begin
	// The birth script is set to run:
	if ( $ValidFunction( NewAgent's "BirthScript" ) )
		begin
			//$RunThread( newAgent's "birthScript", 1, newAgent );

			//THIS IS DONE NOW BECAUSE ALL UNITS ARE GUARANTEED TO BE PLACED ON THE MAP
			//BEFORE THEY CALL NEWUNITINIT, SO WE DON'T HAVE TO RUN BIRTHSCRIPTS A FRAME LATER
			(NewAgent's "BirthScript")(NewAgent);

	//		$DebugOut( 911, newAgent's "title", " set ", newAgent's "birthScript", " to run." );
		end
	else
		begin
//			$DebugOut( 911, newAgent's "title", " didn't have a birthscript." );
		end
end

///////////////////////////////////////////////////////////////////////////////
// This function will be called once, before any objects have
// been loaded into the map.  It should set up any agents
// and functions that need to be in place before the game
// pieces are loaded onto the map;
function InitializeGpl()
declare
	agent AIRootAgent;
begin
	AIRootAgent = $RetrieveAgent("GplAIRoot");
	if ( AIRootAgent == $NullAgent() )
	begin
		// Set the script-calling function executing every 1/2 second;
		// Create the container agent for the agents to be loaded onto the map;
		$CreateAgent( "GplAIRoot", "GplAIRoot" );
		// Retrieve the agent we just created
		AIRootAgent = $RetrieveAgent("GplAIRoot");
		// The following function will be run once, after map objects are loaded:
		$RunThread( AIRootAgent's "KickoffFunction", 1 );
	end
end


///////////////////////////////////////////////////////////////////////////////
function isdead(agent thisagent) is Boolean

declare

begin

	if ($IsValidGamePiece (ThisAgent) == FALSE)
		begin
			$debugout("isdead: isvalidgamepiece is FALSE.");
			return TRUE;
		end

// Commenting out the null check.  The assumption is that $IsValidGamePiece encompasses this check
//	if (thisagent == $nullagent())
//		begin
//			$debugout("isdead: thisagent == $nullagent()");
//			return TRUE;
//		end

	if (ThisAgent's "Type" == "Dead")
		begin
			$debugout("isdead: thisagent's type == dead");
			return TRUE;
		end

	if ($getattribute(thisagent,#ATTRIB_HP) > 0)
		begin
			return False;
		end

	$debugout("isdead: true for unknown reason.");
	return True;
end

///////////////////////////////////////////////////////////////////////////////
function notValid(agent thisagent) is boolean

declare

begin
	if ($isdead(thisagent)) return TRUE;

	if ($insidebuilding(thisagent)) return TRUE;

	if (thisagent's "type" == "Hidden") return TRUE;

  	if ($GetAttribute( thisagent, #ATTRIB_HasEffectInvisibility) != 0) return TRUE;

  	if ($GetAttribute( thisagent, #ATTRIB_HasEffectCamouflage) != 0) return TRUE;

//	if (thisagent's "type" == "invisible") return TRUE;

//	if (thisagent's "type" == "camouflaged") return TRUE;

	return FALSE;

end

///////////////////////////////////////////////////////////////////////////////
function notValid_attacker(agent thisagent) is boolean

declare

begin
	if ($isdead(thisagent)) return TRUE;

	if ($insidebuilding(thisagent)) return TRUE;

	if (thisagent's "type" == "Hidden") return TRUE;

	return FALSE;

end

///////////////////////////////////////////////////////////////////////////////
Function IsFrozen (agent ThisAgent) is boolean
Declare

Begin

	If ($CheckEffector (thisagent,"petrify_icon"))
		return True;

	If ($CheckEffector (thisagent,"vines_effector"))
		return True;

	If ($CheckEffector (thisagent,"Level_Leach_Effector"))
		return True;

	If ($CheckEffector (ThisAgent, "paralytic_gaze_icon"))
		return True;

	return False;

End

///////////////////////////////////////////////////////////////////////////////
function isnearMapEdge(agent thisagent) is Boolean

declare
	coordinate board_size;
	coordinate agent_loc;
	integer x_size;
	integer y_size;
	integer x2;
	integer y2;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size);
	y_size = $getY(board_size);
	agent_loc = $locationof(thisagent);

	x2 = $getX(agent_loc);
	y2 = $getY(agent_loc);


	if (x2 >= (x_size - #edge_buffer)) return TRUE;

	if (x2 <= #edge_buffer) return TRUE;

	if (y2 >= (y_size - #edge_buffer)) return TRUE;

	if (y2 <= #edge_buffer) return TRUE;

	return FALSE;

end

///////////////////////////////////////////////////////////////////////////////
function farthestmapedge(agent thisagent) is Coordinate

declare
	coordinate board_size;
	coordinate agent_loc;
	coordinate go_here,tcoord;
	integer x_size;
	integer y_size;
	integer x2;
	integer y2;
	integer toleft,toright,totop,tobottom;
	list values;
	list coords;
	integer bignum,num;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size) - 1;
	y_size = $getY(board_size) - 1;

	agent_loc = $locationof(thisagent);
	x2 = $getX(agent_loc);
	y2 = $getY(agent_loc);

	toright = x_size - x2;
	toleft = x2;

	totop = y2;
	tobottom = y_size - y2;

	values << toright;
	values << toleft;
	values << totop;
	values << tobottom;

	coords << $makecoord(x_size + 250,y2);
	coords << $makecoord(-250,y2);
	coords << $makecoord(x2,-250);
	coords << $makecoord(x2,y_size + 250);

	bignum = -1;

	foreach num in values do
		begin
			tcoord = $listmember(coords,1);
			$removelistmember(coords,1);
			if (num > bignum)
				begin
					bignum = num;
					go_here = tcoord;
				end
		end

	return go_here;
end

///////////////////////////////////////////////////////////////////////////////
function farthestmapedge_onmap(agent thisagent) is Coordinate

declare
	coordinate board_size;
	coordinate agent_loc;
	coordinate go_here,tcoord;
	integer x_size;
	integer y_size;
	integer x2;
	integer y2;
	integer toleft,toright,totop,tobottom;
	list values;
	list coords;
	integer bignum,num;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size) - 1;
	y_size = $getY(board_size) - 1;

	agent_loc = $locationof(thisagent);
	x2 = $getX(agent_loc);
	y2 = $getY(agent_loc);

	toright = x_size - x2;
	toleft = x2;

	totop = y2;
	tobottom = y_size - y2;

	values << toright;
	values << toleft;
	values << totop;
	values << tobottom;

	coords << $makecoord(x_size,y2);
	coords << $makecoord(1,y2);
	coords << $makecoord(x2,1);
	coords << $makecoord(x2,y_size);

	bignum = -1;

	foreach num in values do
		begin
			tcoord = $listmember(coords,1);
			$removelistmember(coords,1);
			if (num > bignum)
				begin
					bignum = num;
					go_here = tcoord;
				end
		end

	return go_here;
end

///////////////////////////////////////////////////////////////////////////////
// Returns the farthest map corner from this agent in a coordinate
function farthestmapcorner(agent thisagent) is coordinate
declare
	coordinate coord,agent_loc,go_here,board_size;
	list coords;
	integer x_size,y_size,bigdist,dist;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size) - 1;
	y_size = $getY(board_size) - 1;

	coords << $makecoord(0,0);
	coords << $makecoord(0,y_size);
	coords << $makecoord(x_size,0);
	coords << $makecoord(x_size,y_size);

	bigdist = -1;

	agent_loc = $locationof(thisagent);

	foreach coord in coords do
		begin
			dist = $distancebetweencoords(agent_loc,coord);
			if (dist > bigdist)
				begin
					bigdist = dist;
					go_here = coord;
				end
		end

	return go_here;
end

///////////////////////////////////////////////////////////////////////////////
function closestmapedge(agent thisagent) is coordinate

declare
	coordinate board_size;
	coordinate agent_loc;
	coordinate go_here,tcoord;
	integer x_size;
	integer y_size;
	integer x2;
	integer y2;
	integer toleft,toright,totop,tobottom;
	list values;
	list coords;
	integer bignum,num;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size) - 1;
	y_size = $getY(board_size) - 1;

	agent_loc = $locationof(thisagent);

	x2 = $getX(agent_loc);
	y2 = $getY(agent_loc);
	toright = x_size - x2;
	toleft = x2;

	totop = y2;
	tobottom = y_size - y2;

	values << toright;
	values << toleft;
	values << totop;
	values << tobottom;

	coords << $makecoord(x_size,y2);
	coords << $makecoord(5,y2);
	coords << $makecoord(x2,5);
	coords << $makecoord(x2,y_size);

	bignum = 100000;

	$debugout("bignum",bignum);

	foreach num in values do
		begin
			tcoord = $listmember(coords,1);
			$removelistmember(coords,1);
			if (num < bignum)
				begin
					bignum = num;
					go_here = tcoord;
					$debugout("set bignum to",num," set go_here to",go_here,"(",tcoord,")");

				end
			$debugout(num,tcoord);
		end

	$debugout(x_size,y_size,"-",go_here);

	return go_here;
end

///////////////////////////////////////////////////////////////////////////////
expression #North 0
expression #south 1
expression #East 2
expression #West 3

///////////////////////////////////////////////////////////////////////////////
function randomedgeCoord(integer whichside) is coordinate

declare
	coordinate board_size,coord;
	integer x_size;
	integer y_size;
	integer x2;
	integer y2;

begin
	board_size = $getboardextents();
	x_size = $getX(board_size);
	y_size = $getY(board_size);

	if (whichside == #North)
		begin
			x2 = $randomnumber(x_size - 60) + 30;
			y2 = 30;
		end
	else
	if (whichside == #South)
		begin
			x2 = $randomnumber(x_size - 60) + 30;
			y2 = y_size - 30;
		end
	else
	if (whichside == #East)
		begin
			x2 = x_size - 30;
			y2 = $randomnumber(y_size - 60) + 30;
		end
	else
	if (whichside == #West)
		begin
			x2 = 30;
			y2 = $randomnumber(y_size - 60) + 30;
		end

	coord = $makecoord(x2,y2);
	return coord;
end

///////////////////////////////////////////////////////////////////////////////
function agentinlist(agent thisagent,list thislist) is Boolean

declare
	agent joe_smith;
	boolean is_it_here;

begin
	is_it_here = FALSE;

	foreach joe_smith in thislist do
		if (joe_smith == thisagent) is_it_here = TRUE;

	return is_it_here;

end

///////////////////////////////////////////////////////////////////////////////
function ListEnchanted(list thislist) is list

declare
	list newlist;
	agent entry;

begin
	foreach entry in thislist do
		begin
			if ($getattribute(entry,#ATTRIB_enchantmentlevel) > 0)
				newlist << entry;
		end

	return NewList;
end

///////////////////////////////////////////////////////////////////////////////
// This function find all SUBTYPES the passed list, and then returns a list that is only those titles
Function ListSubtypes (list ThisList, string Subtype) is list
Declare
	agent	Dude;
	list	NewList;

Begin
	Foreach Dude in ThisList do
		begin
			If (Dude's "Subtype" == Subtype)
				NewList << Dude;
		end

	return NewList;
End

///////////////////////////////////////////////////////////////////////////////
function reset_tasks(agent thisagent)

declare

begin
	// TODO: Why doesn't reset_tasks stop the unit's movement or clear its order stack in some
	// fashion?  It could complete an existing hide order and end up doing very wierd stuff
	// inside a building or other strangeness as it currently stands.
	$StopMoving (ThisAgent);
	
	thisagent's "target" = $Nullagent();
	thisagent's "activescript" = thisagent's "basicscript";
	thisagent's "backscript" = thisagent's "basicscript";
	$clearlist(thisagent's "hostiles");
end

///////////////////////////////////////////////////////////////////////////////
function haslowHP(agent thisagent) is boolean

declare
	integer HP,maxHP;

begin
	HP = $getattribute(thisagent,#ATTRIB_HP);
	maxHP = $getattribute(thisagent,#ATTRIB_MAXHP);

 	if (((HP * 100) / maxHP) <= thisagent's "PercentageHPretreat") return TRUE;
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function addlists(list list1,list list2) is list

declare
	list new_list;

begin
	while ($listsize(list1) > 0) do
		begin
	 		new_list << $listmember(list1,1);
			$removelistmember(list1,1);
		end

	while ($listsize(list2) > 0) do
		begin
	 		new_list << $listmember(list2,1);
			$removelistmember(list2,1);
		end

	return new_list;
end

///////////////////////////////////////////////////////////////////////////////
// This is for Units transfering to Buildings -- it DOESN'T TAX BY ITSELF
Function Transfer_Gold (agent ThisAgent, agent Target, integer Gold)
Declare

Begin

	$AdjustAttribute (ThisAgent, #ATTRIB_Gold, -Gold);

	$AdjustAttribute (Target, #ATTRIB_Gold, Gold);

	$CreateEffector (Target, "got_gold_bldg", 0, Gold);

End

///////////////////////////////////////////////////////////////////////////////
Function Spend_Gold (agent ThisAgent, agent ThisBuilding, integer Gold)
Declare
	integer	Stored_Gold;
	integer	Gold_Owed;
	integer	Spent_Gold;
	integer	Vaporized_Gold;

Begin
	Stored_Gold = $GetAttribute (ThisAgent, #ATTRIB_StoredGold);

	//Amount of gold that goes to the Building
	Spent_Gold = (Gold * $GetAttribute (ThisBuilding, #ATTRIB_TaxRate)) / 100;

	//Amount of gold that is vaporized
	Vaporized_Gold = Gold - Spent_Gold;

	//Where the gold comes from - Stored before Regular
	If (Stored_Gold >= Gold)
		begin
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Gold);
		end

	Else
		begin
			Gold_Owed = Gold - Stored_Gold;
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Stored_Gold);
			$AdjustAttribute (ThisAgent, #ATTRIB_Gold, -Gold_Owed);
		end

	//Give Spent_Gold to building
	$AdjustAttribute (ThisBuilding, #ATTRIB_Gold, Spent_Gold);

	//Perform Action or Create Effector
	//$PerformAction (ThisBuilding, "Got_Gold_Bldg", ThisBuilding);
	$CreateEffector (ThisBuilding, "Got_Gold_Bldg", 0, Spent_Gold);

	//Vaporize the Ramainder of the gold
	$Vaporize_Gold (ThisAgent, Vaporized_Gold);
End

///////////////////////////////////////////////////////////////////////////////
// This is for Hero Distractors like the Gambling Hall and Brothel.  They have taxrate 0, but still
// need to have the overlays above their heads show that they got gold. This function DOES
// subtract gold from ThisAgent.
Function Hero_Pay_Distractor (agent ThisAgent, agent ThisBuilding, integer Gold)
Declare
	integer	Stored_Gold;
	integer	Gold_Owed;

Begin
	Stored_Gold = $GetAttribute (ThisAgent, #ATTRIB_StoredGold);

	//Where the gold comes from - Stored before Regular
	If (Stored_Gold >= Gold)
		begin
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Gold);
		end

	Else
		begin
			Gold_Owed = Gold - Stored_Gold;
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Stored_Gold);
			$AdjustAttribute (ThisAgent, #ATTRIB_Gold, -Gold_Owed);
		end

	//Perform Action or Create Effector using GOLD (even though the building actually didn't
	//get anything
	$CreateEffector (ThisBuilding, "Got_Gold_Bldg", 0, Gold);

	//Vaporize ALL of the gold
	$Vaporize_Gold (ThisAgent, Gold);
End

///////////////////////////////////////////////////////////////////////////////
// This returns a Hero's Total_Gold (Stored + Regular)
Function Total_Gold (agent ThisAgent) is integer
Declare
	integer	Total_Gold;

Begin
	Total_Gold = $GetAttribute (ThisAgent, #ATTRIB_Gold) + $GetAttribute (ThisAgent, #ATTRIB_StoredGold);
	return Total_Gold;
End

///////////////////////////////////////////////////////////////////////////////
// ThisAgent is only passed so that GetPalace works
Function Vaporize_Gold (agent ThisAgent, integer Gold)
Declare
	agent	Palace,spawn_target;
	list buildings;
	integer i;

Begin
	Palace = $GetTruePalace (ThisAgent);

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	Palace's "Vaporized_Gold" += Gold;

	Palace's "troll_gold" += gold;

	if (Palace's "troll_gold" > #troll_gold_limit)
		begin
			Palace's "troll_gold" -= #troll_gold_limit;
//			// spawn a troll from the farthest
//			$ListObjects(palace,"building",-1, buildings );
//			if ($listsize(buildings) > 0)
//				spawn_target = $ListMember (Buildings, $ListSize (Buildings));
//				//spawn_target =	$pick_farthest(thisagent,buildings);
//			else
//				spawn_target = Palace;

			// spawn a troll from a random complete building
			$listobjects(palace,"building",-1,buildings,#MyPlayer, #ATTRIB_FirstStageBuilt, 1);
			//buildings = $listcompleted(buildings);

			buildings << palace;

			i = $listsize(buildings);

			spawn_target = $listmember(buildings,$randomnumber(i) + 1);

			$spawnUnit(spawn_target,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay));
		end
End

///////////////////////////////////////////////////////////////////////////////
// This will give the inn the full Price of staying there, if the Hero has it, otherwise it will give what they can afford
Function Pay_Inn (agent ThisAgent, agent ThisBuilding, integer Gold)
Declare
	integer	Total_Gold;
	integer	Stored_Gold;
	integer	Gold_Owed;
	integer	Spent_Gold;
	integer	Vaporized_Gold;

Begin
	Total_Gold = $Total_Gold (ThisAgent);

	//This makes sure the Agent deosn't spend more than they have
	If (Gold > Total_Gold)
		Gold = Total_Gold;

	Stored_Gold = $GetAttribute (ThisAgent, #ATTRIB_StoredGold);

	//Amount of gold that goes to the Building
	Spent_Gold = (Gold * $GetAttribute (ThisBuilding, #ATTRIB_TaxRate)) / 100;

	//Amount of gold that is vaporized
	Vaporized_Gold = Gold - Spent_Gold;

	//Where the gold comes from - Stored before Regular
	If (Stored_Gold >= Gold)
		begin
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Gold);
		end

	Else
		begin
			Gold_Owed = Gold - Stored_Gold;
			$AdjustAttribute (ThisAgent, #ATTRIB_StoredGold, -Stored_Gold);
			$AdjustAttribute (ThisAgent, #ATTRIB_Gold, -Gold_Owed);
		end

	//Give Spent_Gold to building
	$AdjustAttribute (ThisBuilding, #ATTRIB_Gold, Spent_Gold);

	//Perform Action
	if (spent_gold > 0)
		$CreateEffector (ThisBuilding, "Got_Gold_Bldg", 0, Spent_Gold);
		//$PerformAction (ThisBuilding, "Got_Gold_Bldg", ThisBuilding);

	//Vaporize the Ramainder of the gold
	$Vaporize_Gold (ThisAgent, Vaporized_Gold);
End

///////////////////////////////////////////////////////////////////////////////
Function Is_Free_Task (agent ThisAgent, function Intention, agent Target) is boolean

Declare
	list	others;
	agent	other;
	list	potentials;
	integer i;
	boolean free;

Begin

	free = true;

	If ($ListObjects (ThisAgent, "hero", #Is_Free_Task_Range, others, #MyPlayer) > 0)
		Foreach Other in Others do
			begin
				If ((Other's "ActiveScript" == Intention) || (Other's "BackScript" == Intention))
					begin
						If (Other's "Target" == Target)
							begin
								//If I am further from the target than the other, then return False
								If ($DistanceBetweenAgents (ThisAgent, Target) > $DistanceBetweenAgents (Other, Target))
									free = False;
							  	else
									i += 1;
							end
					end
			end

	//no other people with this intention around - so return true
	if (free)
		begin
			if (i <= #is_free_task_max_heroes)
  				return True;
			else
				return false;
		end
	else
		return false;
End


///////////////////////////////////////////////////////////////////////////////
// This function looks at the passed list and cull out all units that have Attribute set as true.
// Then it returns that list
Function List_Attribs (list ThisList, integer Attribute) is list
Declare
	agent Entry;
	list 	NewList;

Begin
	Foreach Entry in ThisList do
		begin
			If ($GetAttribute (Entry, Attribute) != 0)
				begin

					NewList << Entry;

				end

		end

	return NewList;

End

///////////////////////////////////////////////////////////////////////////////
// Returns the absolute value of an integer passed to it.
function AbsoluteValue ( integer number ) is integer
declare
begin
	if ( number < 0 )
		number = ( number * ( - 1 ));

	return number;
end


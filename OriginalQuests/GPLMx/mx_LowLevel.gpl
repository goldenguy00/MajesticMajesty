	If ($ListSize (Monsters) <= #Monster_Spawn_Cap)
		begin
			$SpawnUnit (Palace, "Giant_Spider", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Giant_Spider", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Giant_Spider", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Giant_Spider", $RandomCoord (Palace, -1), #Monster_Player);

			$SpawnUnit (Palace, "Werewolf", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Werewolf", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Werewolf", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Werewolf", $RandomCoord (Palace, -1), #Monster_Player);

			$SpawnUnit (Palace, "Medusa", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Medusa", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Medusa", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Medusa", $RandomCoord (Palace, -1), #Monster_Player);

			$SpawnUnit (Palace, "Evil_Oculus", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Evil_Oculus", $RandomCoord (Palace, -1), #Monster_Player);

			$SpawnUnit (Palace, "Rust_spitter", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Rust_spitter", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Rust_spitter", $RandomCoord (Palace, -1), #Monster_Player);
			$SpawnUnit (Palace, "Rust_spitter", $RandomCoord (Palace, -1), #Monster_Player);
		end
end


///////////////////////////////////////////////////////////////////////////////
// Return the Palace ThisAgent belongs to, this can return an Outpost if
// an Outpost is ThisAgent's "Parent"
function GetPalace (Agent ThisAgent) is agent
Declare
	list	Palaces;
	agent	Closest_Palace;
	agent Parent;

Begin

	 Parent = $Parent (ThisAgent);

	If ($IsDead (Parent) == False)
		begin
			If (Parent's "SubType" == "Outpost")
				return Parent;
		end

	$ListObjects (ThisAgent, "Building", -1, Palaces, #CheckTitles, "Palace", #MyPlayer, #NoHiddenMap);

	If (ThisAgent's "Title" == "Palace")
		Palaces << ThisAgent;

	If ($ListSize (Palaces) > 0)
		return $ListMember (Palaces, 1);

	return $NullAgent ();
End

///////////////////////////////////////////////////////////////////////////////
// Returns the Palace of the player ThisAgent belongs to, even if ThisAgent
// is owned by an Outpost of the player.
Function GetTruePalace (agent ThisAgent) is agent
Declare
	list	Palaces;
	agent Palace;

Begin

	$ListObjects (ThisAgent, "Building", -1, Palaces, #CheckTitles, "Palace", #MyPlayer, #NoHiddenMap);

	If (ThisAgent's "Title" == "Palace")
		Palaces << ThisAgent;

	If ($ListSize (Palaces) > 0)
		return $ListMember (Palaces, 1);

	return $NullAgent ();
End

///////////////////////////////////////////////////////////////////////////////
// This function finds all FAMILY in the passed list, and then returns a list that is only those units
Function ListFamily (list ThisList, string Family) is list
Declare
	agent	Dude;
	list	NewList;

Begin
	Foreach Dude in ThisList do
		begin
			If (Dude's "family" == family)
				NewList << Dude;
		end

	return NewList;
End

///////////////////////////////////////////////////////////////////////////////
// This function determines the string entry that describes why a given player lost.
// Unused?
function GameOverReason( integer playerNum ) is integer
declare
	integer index ;
	agent AIRootAgent;

begin
	$DebugOut( 911, "GameOverReason() called for player number ", playerNum );

	AIRootAgent = $RetrieveAgent ("GplAIRoot");
	index = AIRootAgent's "Quest_Number";

	//If this is the DEMO, then return a hard-coded index number
	If (AIRootAgent's "Quest_Number" == #QNumber_Demo)
		index = 20;


	//If this is MX, then all QNumbers start out 9 higher than their actual
	//string table entry, so we have to subtract 9 to make them match.
	If (index > 20 && index < 500)
		begin

			index -= 9;

		end

	//If index > 500, that means it is a freestyle quest, in which case set it to
	//the index 0, which is the generic loss. All freestyle victory conditions are 500 or greater
	If (index > 500)
		index = 0;


	return index;
end

///////////////////////////////////////////////////////////////////////////////
// This function calculates a gamble from the gamling hall
function Gamble(agent thisAgent, integer color, integer bet) is integer
declare
	integer Winnings,roll,newcolor;

begin
	$DebugOut( 911, "Gamble" );

	roll = $randomnumber(20) + 1;
// VERY IMPORTANT need to set the attrib GambleWinner to 0-3 (red,black,gold,skulls)

	if (roll <= 10)
		begin
			newcolor = 1; // black wins
			winnings = bet * 2;
		end
	else
	if (roll <= 15)
		begin
			newcolor = 3; // skulls
			winnings = 0;
		end
	else
	if (roll <= 19)
		begin
			newcolor = 0; // red wins
			winnings = bet * 5;
		end
	else
		begin
			newcolor = 2; // gold wins
			winnings = bet * 20;
		end

	if (newcolor != color)
		begin
			winnings = 0; // ha ha they chose a loser color this time.
		end

	$setattribute(thisagent,#ATTRIB_gamblewinner,newcolor);
	return Winnings;
end

///////////////////////////////////////////////////////////////////////////////
// This function calculates the number to put in the difficulty field in Freestyle games
function CalculateDifficulty (integer StartingGold, integer playerdiff, integer monsterDiff,integer wanderingDIff,integer event1Diff,integer event2Diff) is integer
declare
	integer Diff, DiffMod1, DiffMod2;

begin
	//$DebugOut (911,"---------------------------------------------------------------------------------------");

	//$DebugOut (911, "Event1Diff:", Event1Diff);
	//$DebugOut (911, "Event2Diff:", Event2Diff);

	//Take the average of the 3 difficulty ratings
	Diff = (PlayerDiff + (MonsterDiff * 3) + (WanderingDiff * 2) ) / 6;

	StartingGold = ( StartingGold / #Starting_Gold_Diff_Divider ) - #Starting_Gold_Diff_Threshold;

	//$DebugOut (911, "DIFF:", Diff);

	//$DebugOut (911, "STARTING GOLD:", StartingGold);

	//Modify difficulty by the EventDiffs levels

	//Only if the EventDiff is higher than the currently computed diff do we modifiy it
	If (Event1Diff > Diff)
		DiffMod1 = ( Diff + Event1Diff ) / 2;


	If (Event2Diff > Diff)
		DiffMod2 = ( Diff + Event2Diff ) / 2;

	If (DiffMod1 == 0)
		DiffMod1 = Diff;

	If (DiffMod2 == 0)
		DiffMod2 = Diff;


	//$DebugOut (911, "Difficulty Modifier ONE:", DiffMod1);
	//$DebugOut (911, "Difficulty Modifier TWO:", DiffMod1);


	//Take the average of the two DiffMods.
	Diff = ( DiffMod1 + DiffMod2 ) / 2;

	//$DebugOut (911, "EVENT-Modified difficulty:", DIff);

	//Modify average difficulty by Starting Gold
	Diff = Diff - StartingGold;

	//$DebugOut (911, "RETURN VALUE:", Diff);

	return Diff;
end

///////////////////////////////////////////////////////////////////////////////
// This function recieves the diffrating that was passed back to the engine (see CalculateDifficulty) and passes back
// a string index that corresponds to an entry in ingametxt. This is the adjective that is printed in the window along
// with the diff rating.
function CalculateDifficultyString(integer diffRating) is integer
declare
begin
	if (diffRating < 20)
		return 0 ;
	else if (diffRating < 40)
		return 1 ;
	else if (diffRating < 60)
		return 2 ;
	else if(diffrating < 80)
		return 3 ;
	else
		return 4 ;
end


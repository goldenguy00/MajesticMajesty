// then the old camp is destroyed and the new one becomes active.
function KickoutRangers(agent thisAgent)
declare
begin
//	$DebugOut( 911, "Kicking out rangers" );
	$release_occupants(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
// Have members activescript's reset to their basicscripts - maybe only of they are going home?
// this is so they move to the right location - old loc is invalid
function MoveCamp(agent ThisAgent)

declare
	agent member;
begin
//	$DebugOut( 911, "Moving camp" );
	foreach member in thisagent's "members" do
		begin
			if ($isdead(member) == FALSE)
				if ($ishidden(member) == False)
				if ((member's "activescript" != $journey_offmap) &&
				 	(member's "activescript" != $return_to_map) &&
				  	(member's "backscript" != $hide_off_map))
					begin
						$stopmoving(member);
						$reset_tasks(member);
					end
		end
end


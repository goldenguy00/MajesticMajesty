///////////////////////////////////////////////////////////////////////////////
function ListBuildLevelsinRadius (agent ThisAgent, string type, string title, integer Level, integer Dist) is list
Declare
	list	new_list;
	list	working_list;
	list	final_list;
	agent Diddly;

Begin
	$ListObjects (ThisAgent, Type, Dist, New_List );
	foreach Diddly in New_List do
		begin
			If (Diddly's "title" == Title)
				Working_list << Diddly;
		end

	foreach Diddly in Working_List do
		begin
			If (Diddly's "Level" == Level)
				Final_List << Diddly;
		end

	return Final_List;
End

///////////////////////////////////////////////////////////////////////////////
Function PickHighestLevelBuilding (agent ThisAgent, list ThisList) is agent
Declare
	agent 	Dude;
	integer	Temp_Best_Level;
	agent		Temp_Best_Agent;
	integer	Temp_Best_Distance;
	integer	Distance;

Begin
	Temp_Best_Level = -1;

	Foreach Dude in ThisList do
		begin
			If (Dude's "Level" > Temp_Best_Level)
				begin
					Temp_Best_Level = Dude's "Level";
					Temp_Best_Agent = Dude;
					Temp_Best_Distance = $DistanceBetweenAgents (ThisAgent, Dude);
				end

			Else
				begin
					If (Dude's "Level" == Temp_Best_Level)
						begin
							Distance = $DistanceBetweenAgents (ThisAgent, Dude);
							If (Distance < Temp_Best_Distance)
								begin
									Temp_Best_Distance = Distance;
									Temp_Best_Agent = Dude;
								end
						end
				end
		end

	return Temp_Best_Agent;

End

///////////////////////////////////////////////////////////////////////////////
Function Loyalty_Mod_Pick_Closest (agent ThisAgent, list ThisList) is agent
declare
	agent Dude;
	agent closest_dude;
	integer closest_dist;
	integer temp_dist;
	integer	Loyalty;
	integer thisagent_team_number;

begin
	//$Debugout (911, "In Loyalty check!");
	Loyalty = ThisAgent's "Loyalty";
	closest_dist = 999999;
	thisagent_team_number = $getplayerTeamNumber(ThisAgent);

  	foreach Dude in Thislist do
	 	begin
			//$DebugOut (911, "In Foreach!");
			temp_dist = $distancebetweenAgents(thisagent,Dude);

			//See if the Dude is on a different team, if so then make it less attractive
//			If ($GetPlayerTeamNumber (ThisAgent) != $GetPlayerTeamNumber (Dude))
			If (thisagent_team_number != $GetPlayerTeamNumber (Dude))
				begin
			   	//If hero is loyal, then don't even consider this Dude
					If (Loyalty > (#Loyalty_Other_Team_Roll) + 1)
						begin
							ThisList -= Dude;
					   end
					Else
						//Crank up the temp_dist, so this building appears less attractive
						Temp_Dist = Temp_Dist * #Loyalty_Dist_Diff_Team_Mod;
				end

			Else
				begin
					//See if the Dude is owned by a different player, if so them make it less attractive
					If ( $UnitsAreSamePlayer (ThisAgent, Dude) == False )
			  			begin
							//Roll against my loyalty
				 			If (Loyalty > $RandomNumber (#Loyalty_Other_Player_Roll) + 1)
								//If I am loyal, make this building appear further away than it is
								temp_dist = temp_dist * #Loyalty_Dist_Diff_Player_Mod;
						end
				end

			if (temp_dist < closest_dist)
			 	begin
					closest_dist = temp_dist;
				  	closest_dude = dude;
			  	end
	  	end

	//$DebugOut (911, closest_Dude);
	return closest_dude;
end

///////////////////////////////////////////////////////////////////////////////
// This builds a list consisting of all types that a Looter finds attractive
//    --Note: It only requires an agent and a distance, as the types/titles are hardcoded in the function--
// Unfortunately, I couldn't use GetTitle for this, because it can't check several different titles at once.
Function ListLootablesInRadius (agent ThisAgent, integer Distance) is list
Declare
	list  Working_List_Of_Heroes;
	list  Working_List_Of_Buildings;
	list  Final_List;
	agent Diddly;

Begin
	$ListObjects (ThisAgent, "hero", Distance,Working_List_Of_Heroes );
	$ListObjects (ThisAgent, "building", Distance, Working_List_Of_Buildings, #ATTRIB_FirstStageBuilt, 1 );
	//WOrking_list_of_Buildings = $listcompleted(WOrking_list_of_Buildings);

	Foreach Diddly in Working_List_Of_Buildings do
		begin
			if (Diddly's "Title" == "Marketplace")
					Final_List << Diddly;
			Else
				begin
					if (Diddly's "Title" == "Trading_Post")
						Final_List << Diddly;
				end
		end

	Foreach Diddly in Working_List_Of_Heroes do
	  	begin
		 	if (Diddly's "Title" == "Caravan")
			  	Final_List << Diddly;
		 	Else
				if (Diddly's "Title" == "Tax_Collector")
				 	Final_List << Diddly;
		end


	Return Final_List;

End

///////////////////////////////////////////////////////////////////////////////
// This Function builds a list of Buildings of Title that have their FirstStageCompleted
Function ListCompletedTitles (agent thisagent,string type, string title, integer dist) is list
Declare
	list new_list;
	list final_list;
	agent diddly;

begin
	new_list = $ListTitlesInRadius(thisagent,type,title,dist);

	Foreach Diddly in New_List do
		begin
			If ($GetAttribute (Diddly, #ATTRIB_FirstStageBuilt) == 1)
				Final_List << Diddly;
		end

	return Final_List;
End


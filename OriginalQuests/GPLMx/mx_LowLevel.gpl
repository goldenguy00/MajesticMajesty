///////////////////////////////////////////////////////////////////////////////
// This function builds and culls a list by ThisAgent's "Friend"
Function Cull_Subtypes (list ThisList, string Friend)
Declare
	agent Potential;

Begin

	Foreach Potential in ThisList do
		begin
			If (Potential's "Subtype" == Friend)
				ThisList -= Potential;
		end

End


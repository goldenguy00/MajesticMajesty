		begin
			If (Potential's "Title" == Friend)
				ThisList -= Potential;
		end

End

///////////////////////////////////////////////////////////////////////////////
// This function builds a list if all first_stage built entries on the list it was passed, and returns it
Function ListCompleted (list ThisList) is list
Declare
	agent Dude;
	list 	Newlist;

Begin
	Foreach Dude in ThisList do
		begin
			If ($GetAttribute (Dude,#ATTRIB_FirstStageBuilt) == 1)
				NewList << Dude;
		end

	return NewList;

End


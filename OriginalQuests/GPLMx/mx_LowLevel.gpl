///////////////////////////////////////////////////////////////////////////////
// Called by the engine code to see if this unit should be tracked in the
// mini-view (for now, just heros)
//
// return value: non-zero if is a valid unit
function IsValidMiniViewTarget( agent thisagent ) is integer

declare

integer retval;

begin
	if (thisagent's "subtype" == "hero")
		retval = 1;
	else
		retval = 0;

	return retval;
end


///////////////////////////////////////////////////////////////////////////////
// Called by the engine code to determine the type of a GPL vehicle
//
// return value: the type of unit
expression #UNIT_TYPE_OTHER 0
expression #UNIT_TYPE_HERO 1
expression #UNIT_TYPE_HENCHMAN 2
expression #UNIT_TYPE_BUILDING 3

///////////////////////////////////////////////////////////////////////////////
function GetUnitType( agent thisagent ) is integer

declare

integer retval;

begin
	if (thisagent's "subtype" == "hero")
		retval = #UNIT_TYPE_HERO;
	else if (thisagent's "subtype" == "henchman")
		retval = #UNIT_TYPE_HENCHMAN;
	else if (thisagent's "type" == "building")
		retval = #UNIT_TYPE_BUILDING;
	else
		retval = #UNIT_TYPE_OTHER;

	return retval;
end


///////////////////////////////////////////////////////////////////////////////
function caravan_raider ( agent thisagent )

declare

	list heroes;
	agent target;
	boolean casting;
	integer attackrange, search_dist;
	string spell_name;

begin
	target = thisagent's "target";

	if ( $notvalid ( thisagent's "target" ))
		begin
			$debugout ( thisagent's "title", " picking a target." );

			search_dist = 1000;

//			if ($hasattribute("relentless",thisagent))
//				begin
//					If (ThisAgent's "Relentless")
//						search_dist = -1;
//				end

			//$ListObjects ( thisagent, "hero", search_dist, heroes, #CheckTitles, "Caravan", #NotMyteam );
			//heroes = $listtitles ( heroes, "caravan" );

			if ( $ListObjects ( thisagent, "hero", search_dist, heroes, #CheckTitles, "Caravan", #NotMyteam ) > 0 )
				begin
					ThisAgent's "Target" = $ListMember ( heroes, 1 );
				end
			else
				begin
					// Caravan raider wanders because it has no targets
					thisagent's "activescript" = $wandering;
				end
		end
	else
		begin
			// pick weapon or spell
			spell_name = $GetBestSpell ( thisagent, #list_attack );
			$debugout ( "raider spell:", spell_name );

			if ( spell_name == "nothing" )
				begin
					attackrange = $GetAttribute ( thisagent, #ATTRIB_maxattackrange );
					casting = FALSE;
				end
			else
				begin
					attackrange = thisagent's "castingrange";
					casting = TRUE;
				end

			$raider_eval_enemies ( thisagent );

			if ( $distancebetweenagents ( thisagent, thisagent's "target" ) < attackrange )
				begin
					if ( casting )
						$castspell ( thisagent, spell_name, target, "" );
				end
			else
				begin
					thisagent's "destination" = $locationof ( thisagent's "target" );
 					thisagent's "activescript" = $monster_travel_to;
					thisagent's "backscript" = $caravan_raider;
					$move ( thisagent, thisagent's "target" );
				end
		end
end
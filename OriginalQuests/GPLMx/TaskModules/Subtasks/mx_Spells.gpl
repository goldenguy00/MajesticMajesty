declare

begin
	// CBT note: as of Majesty Alpha the effector duration below is 0
	$createeffector( target, "frost_Field_hit_effector", 0 );

	//This uses player spell attack because the targetting agent may not have
	//attack attributes
	$player_spell_attack( target, 12, 5 );
end

///////////////////////////////////////////////////////////////////////////////
function ChangeOfHeart_Begin ( agent thisagent )
//This makes fleeing heroes go berserk, otherwise it makes them flee.
declare
	integer Intent;

begin
	If ( ThisAgent's "Subtype" == "Hero" )
		begin
			If ( $IsDead ( ThisAgent ))
				return;


			$createeffector( thisagent, "ChangeHeart", 0 );

			Intent = $GetAttribute ( ThisAgent, #ATTRIB_AIIntentionString );

			//If the unit is currently leaving Ardania, then don't do anything
			//Also, if the unit is currently frozen don't do anthing
			If ( Intent == #intent_flee_Map || $IsFrozen ( ThisAgent ))
				return;


			//ThisAgent should go berserk if they are currently fleeing
			If ( Intent == #intent_flee_Scared || Intent == #intent_flee_lowHP )
				begin

					$Go_Berserk ( ThisAgent );

				end

			//Otherwise, if they aren't inside a building, they should flee
			Else
				begin
					If ( $InsideBuilding ( ThisAgent ) == False )
						begin

							$Flee_Absolute ( ThisAgent, #intent_flee_scared );

						end

					//Potentially kick unit out of the building if they are in it...
					Else
						begin

							$Exit_Building ( ThisAgent, ThisAgent's "Target" );

							$Go_Berserk ( ThisAgent );

						end

				end

		end
end

///////////////////////////////////////////////////////////////////////////////
Function Gate_Unit_Created (agent ThisAgent, agent Target)
Declare
	list		Abodes;
	integer  ListSize;

Begin
	//$DebugOut (911, "GATE UNIT CREATED!");

	//Find the closest abodes on the map, and setthe local player's as parent
	ListSize = $ListObjects (ThisAgent, "Building", -1, Abodes, #CheckTitles, "SorcerersAbode", #FindFirstMatchOnly, #NoHiddenMap, #MyPlayer);
	//Abodes = $ListTitles (Abodes, "SorcerersAbode");

	If (ListSize > 0)
		begin

			$SetParent (ThisAgent, $ListMember (Abodes, 1) );

			// destroy the unit after the duration period
			$SetSpellUnitTimeout( thisagent, 30000 );

			// run the active script periodically
			$NewThread( thisagent's "activeScript", 1000, thisagent );

		end

	Else
		$DeleteGamePiece (ThisAgent);

End

///////////////////////////////////////////////////////////////////////////////
// This continually scans for heroes around the Abode, and teleports them to the gate location
Function Gate_Active (agent ThisAgent)
Declare
	list 	Heroes;
	agent Hero, Parent;

Begin
	Parent = $Parent (ThisAgent);

	If ($IsDead (Parent) == False)

		begin

			$ListObjects (Parent, "Hero", 700, Heroes, #CheckSubtypes, "Hero", #MyPlayer);
			//Heroes = $ListSubtypes (Heroes, "Hero");

			Foreach Hero in Heroes do
				begin
					If ($IsDead (Hero) == False)
						begin

							//See if the hero is closer to the S. Abode than to the Gate
							If ( $DistanceBetweenAgents (Hero, Parent) < $DistanceBetweenAgents (Hero, ThisAgent) )
								begin

									//Create the missile that will teleport the heroes when it hits them
									$CreateMissile ("gate_P", Parent, Hero);

								end
						end
				end

		end

	Else
		$DeleteGamePiece (ThisAgent);

End

///////////////////////////////////////////////////////////////////////////////
Function Gate_Hit (agent ThisAgent, agent Target)
Declare
	list	Gates;
	agent	Gate;

Begin
	//$ListObjects (ThisAgent, "spell", -1, Gates, #MyPlayer);
	//Gates = $ListTitles (Gates, "Gate");

	If ($ListObjects (ThisAgent, "spell", -1, Gates, #FindFirstMatchOnly, #MyPlayer) > 0)
		begin

			$CreateEffector (Target, "Gate_Effector", 0);

			$TeleportToUnit( Target, 80000, $ListMember( Gates, $RandomNumber( $ListSize ( Gates ) ) + 1 ), 0  );

			$Reset_Tasks ( Target );

		end

End



////////////////////////////////////////////////////////
// --- Chain Lightning Spell functions begin here --- //
////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////////////////////////
function ChainLightning_Begin ( agent thisagent )
/////////////////////////////////////////////////////////////////////////////////
// This initiates a chain lightning sequence on the vehicle targeted by the UI.
// This first step of the sequence 'cheats' an instantanious missile hit callback
// to kick the effect off.
/////////////////////////////////////////////////////////////////////////////////
declare
begin

	if ( $IsDead ( Thisagent ))
		return;

	If (ThisAgent's "Type" != "Lair" && ThisAgent's "Type" != "Building")
		begin
			// This SetAttrib sets the initial chain power on the starting target.
			$SetAttribute ( ThisAgent, #ATTRIB_StruckByChainLightning, #StartingChainPulses );
			$createeffector ( thisagent, "Chainlightning_Icon", 3000 );
			$Chainlightning_MissileHit ( thisagent );
		end
end

///////////////////////////////////////////////////////////////////////////////
Function ChainLightning_MissileHit ( agent victim )
//
Declare
	integer 	max_damage, min_damage, int_pulse;
	float 	pulse;
	agent 	target;
	list 		targets, Monsters, Heroes;
	boolean  fired;

Begin
	// First check to see if the target has a mirror up, if so, just jump
	// out of the effect.
	if ( $GetAttribute ( victim, #ATTRIB_HasEffectMagicMirror ) == 1 )
		return;
	if ( $IsDead ( victim ))
		return;

	$Debugout ( 911, victim, " hit by chain lightning bolt." );

	$createeffector ( victim, "Chainlightning_effector", 0 );

	// Set the damage based on the pulse strength of the chain attribute.
	Pulse = $GetAttribute ( victim, #ATTRIB_StruckByChainLightning );
	int_pulse = pulse; // Setattribute later in function needs an integer attribute.

	Max_Damage = ( pulse * #Chainlightning_DamageMultiplier );
	Min_Damage = ( Max_Damage / 1.5 );

	// If there's more than one pulse strength left, move into the propogation sequence.
	if (( Pulse ) > 1 )
		begin
			$ListObjects ( victim, "Hero", #ChainLightning_Radius, Heroes, #MyTeam, #NoHiddenMap );
			$ListObjects ( victim, "Monster", #ChainLightning_Radius, Monsters, #MyTeam, #NoHiddenMap );

			Targets = $AddLists (Heroes, Monsters);

			if ( $ListSize ( targets ) > 0 )
				begin
					Foreach target in Targets do
						begin
							if ( fired == false )
								begin
									if ( $IsDead ( target ) == FALSE )
										begin
											// Dont target anyone who's been hit by the chain already.
											if ( $GetAttribute ( target, #ATTRIB_StruckByChainLightning ) < 1 )
												begin
													// Setting the chain attrib on the target both allows the missile
													// to affect its target without a callback from the attacker,
													// and lets us properly decrement the effect as it propogates.
													$debugout ( 911, "Chain iterated from ", victim, " to ", target );
													$SetAttribute ( target, #ATTRIB_StruckByChainLightning, ( int_pulse - 1 ));
													$createeffector ( target, "Chainlightning_Icon", 3000 );
													$CreateMissile ( "chain_lightning_missile", victim, target );
													fired = TRUE;
												end
										end
								end
						end
				end
		end
	// Do your damage at the end of the entire sequence.
	$Player_Spell_Attack ( victim, Max_Damage, Min_Damage );
end


///////////////////////////////////////////////////////////////////////////////
function ChainLightning_End ( agent thisagent )
//
declare
begin
	// This zeroes the chain attribute, making the target legal for another chain
	// strike in the future.
	$debugout ( 911, "Chain effect cleared from ", thisagent );
	$SetAttribute ( thisagent, #ATTRIB_StruckByChainLightning, 0 );
end


///////////////////////////////////////////////////////////////////////////////
function Dismiss_Begin ( agent thisagent )
//This teleports the targetted unit to a random point somewhere on the map
//In multiplayer, it teleports the into the vicinity of another player's palace (randomly choosing which palace)
declare
	coordinate	Point;
	agent			Palace;
	list			Palaces;

begin

	If ( $IsDead ( ThisAgent ))
		return;


	$CreateEffector (ThisAgent, "Dismiss", 0);

	Palaces = $ListPalaces ();


	//If there is just one palace on the map, then teleport the unit randomly
	//Also, if the teleported unit is a "hero" then just teleport them randomly
	If ( ThisAgent's "Type" == "Hero" || $ListSize ( Palaces ) == 1 )
		begin
			// $Debugout ( 911, "Hero OR Single Palace Dismissal." );

			// Point = $RandomCoord ( ThisAgent, 3000, -1 );

			point = $farthestmapedge_onmap ( thisagent );

		end

	Else
		begin
			// $Debugout ( 911, "Monster AND Multiple Palace Dismissal." );

			Palace = $GetTruePalace (ThisAgent);

			//If the unit isn't associated with a valid palace,
			//then take the closest palace off of the list
			If ($IsDead (Palace) == False)
				begin

					Palace = $Pick_Closest (ThisAgent, Palaces);

				end


			//Take theagent's palaces off the list (if applicable);
			Palaces -= Palace;


			//Find a random entry on palaces list
			Palace = $ListMember ( Palaces, $RandomNumber ( $ListSize ( Palaces ) ) +1 );

			Point = $RandomCoord ( Palace, 500 );

		end

	// do the movement later
	thisagent's "teleportScript" = $Dismiss_DoMove;
	$RunThread( thisagent's "teleportScript", 1000, ThisAgent, Point);

end

///////////////////////////////////////////////////////////////////////////////
// This actually does the Dismiss teleportation. It is delayed so that the player
// has a chance to see the Disiss effector on the targeted unit before the unit teleports
function Dismiss_DoMove( agent thisagent, coordinate Point)
declare

begin

	If ($IsDead (ThisAgent))
		return;

	//Teleport to the point that was passed to this function from Dismiss_Begin
	//if (thisagent's "Target" == thisagent)
	$TeleportToPoint( thisagent, 100000, Point );

	$Reset_Tasks ( ThisAgent );

end



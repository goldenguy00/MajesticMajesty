function Summon_Medusae_Begin ( agent thisagent, agent target )
////////////////////////////////////////////////
// This just kicks off the spellcasting effector
// for the summon medusae spell.
////////////////////////////////////////////////
declare
	list	Medusae;

begin
	//Only cast if there aren't already Medusa around
	if ( $listobjects ( thisagent, "monster", 500, Medusae, #CheckTitles, "Medusa", #MyPlayer ) < 2 )
		$createeffector ( thisagent, "summon_medusae_effector", 2500, "after" );
end



	$MagicalAdjustAttribute ( thisagent, #ATTRIB_Strength, -40 );
	$SetAttribute ( thisagent, #ATTRIB_HasEffectStrength, 0 );

end

//--- Shapeshift Potion Spell ---//

///////////////////////////////////////////////////////////////////////////////
function Shapeshift_Potion_Effect ( agent thisagent, agent target )
//////////////////////////////////////////////////////////////////////////////////
// The shapeshift potion turns characters into various monsters, depending on what
// class of attack they use.  The statistics gained depend of the form taken.
//////////////////////////////////////////////////////////////////////////////////
// This is an item cast spell. The item is destroyed and the
// spell forgotten when it is used.
////////////////////////////////////////////////////////////
declare
	string title;

begin
	If ( $IsDead ( ThisAgent ))
		return;

	title = thisagent's "title";

	$createeffector ( thisagent, "shapeshift_potion_effector", 0 );
	$createeffector ( thisagent, "shapeshift_potion_icon", $GetSpellAttribute ( "Shapeshift_Potion", "effector_duration" ) );

	$DeleteInventoryItem ( #Bazaar_Item_Six, ThisAgent );
	$ForgetSpell ( ThisAgent, "Shapeshift_Potion" );

	if ( thisagent's "AttackType" == 2 )
		begin // Ranged attackers turn into Dryads.
			$ChangeUnitType ( thisagent, "Dryad" );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, 30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Dodge, 30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_MagicResistance, 30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Ranged, 20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Artifice, 20 );
		end
	else if ( title == "Priestess" || title == "Wizard" || title == "Healer" )
		begin // Spell attackers turn into Medusas.
			$ChangeUnitType ( thisagent, "Medusa" );
			$adjustattribute ( thisagent, #ATTRIB_Armor_Basic_Damage, 4 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Intelligence, 20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, 20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_MagicResistance, 50 );
			$adjustattribute ( thisagent, #ATTRIB_MaxHP, 30 );
			$adjustattribute ( thisagent, #ATTRIB_HP, 30 );
		end
	else
		begin // Anyone else (most melee attackers) turns into a minotaur.
			$ChangeUnitType ( thisagent, "Minotaur" );
			$adjustattribute ( thisagent, #ATTRIB_Armor_Basic_Damage, 5 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_HtoH, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Strength, 24 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Vitality, 20 );
			$adjustattribute ( thisagent, #ATTRIB_MaxHP, 40 );
			$adjustattribute ( thisagent, #ATTRIB_HP, 40 );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Shapeshift_Potion_End ( agent thisagent )
///////////////////////////////////////////////////////////////
// This function changes characters transformed by a shapeshift
// potion back into their proper form and stats.
///////////////////////////////////////////////////////////////
declare
	integer maxHP, current_hits;
	string title;

begin
	$RevertUnitType ( thisagent );

	title = thisagent's "title";

	if ( thisagent's "AttackType" == 2 )
		begin // Revert from Dryad.
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, -30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Dodge, -30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_MagicResistance, -30 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Ranged, -20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Artifice, -20 );
		end
	else if ( title == "Priestess" || title == "Wizard" || title == "Healer" )
		begin // Revert from Medusa.
			$adjustattribute (thisagent, #ATTRIB_Armor_Basic_Damage, -4 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Intelligence, -20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, -20 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_MagicResistance, -50 );
			$adjustattribute ( thisagent, #ATTRIB_MaxHP, -30 );
		end
	else
		begin // Revert from Minotaur.
			$adjustattribute (thisagent, #ATTRIB_Armor_Basic_Damage, -5 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_HtoH, -10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Strength, -24 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Vitality, -20 );
			$adjustattribute ( thisagent, #ATTRIB_MaxHP, -40 );
		end

	// revert HP to full, if are above max
	maxHP = $getattribute ( thisagent, #ATTRIB_MaxHP );
	if ( $getattribute ( thisagent, #ATTRIB_HP ) > maxHP )
		$SetAttribute ( thisagent, #ATTRIB_HP, maxHP );
end


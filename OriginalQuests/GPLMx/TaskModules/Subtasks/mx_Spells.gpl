///////////////////////////////////////////////////////////////////////////////
function fire_ball_unit_created(agent thisagent, agent target)
// wizard spell - lvl 5
// - birthscript for fire_ball unit
declare

begin
	// destroy the unit after the duration period
	// CBT note: as of Majesty Alpha the effector duration below is 0
	$SetSpellUnitTimeout( thisagent, $GetSpellAttribute( "fire_ball", "effector_duration" ) );

	// run the active script just once to target the area
//	$RunThread( thisagent's "activeScript", 0, thisagent );

	// do this now, instead of with runthread, in case of lag
	$fire_ball_active(thisagent);
end


///////////////////////////////////////////////////////////////////////////////
function Fire_Ball_Active(agent thisagent)
// wizard spell - lvl 5
// - activescript for fire_ball unit
declare
	list targets;
	agent target;

begin
// $ListObjects(thisagent,"monster",55, targets );

	targets = $compile_enemies(thisagent,80);
	foreach target in targets do
		begin
			If ($Does_Resist_Fire (Target) == False)
				begin

					$createeffector( target, "fireball_effector2", 500 );
					$player_spell_attack( target, 15,2 );

				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function compile_enemies(agent thisagent,integer range) is list

declare
	list targets,t2,t3;

begin
	$ListObjects(thisagent,"monster",range,targets,#NotMyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#NotMyTeam);
	t3 = $addlists(targets,t2);
	return t3;
end


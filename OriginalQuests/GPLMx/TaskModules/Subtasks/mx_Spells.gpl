// --- This section contains the Champions Vigor spell functions --- //

///////////////////////////////////////////////////////////////////////////////
function Champions_Vigor_Begin ( agent thisagent )
// GPL cast spell - from hall of champions
declare
begin
	if ( $IsDead ( ThisAgent ) )
		return;

	$createeffector( thisagent, "Champions_Vigor_effector", 0 );
	$createeffector( thisagent, "Champions_Vigor_icon", 90000 );

	$AdjustAttribute ( thisagent, #ATTRIB_MaxHP, 15 );
	$AdjustAttribute ( thisagent, #ATTRIB_HealingRateModifier, -3 );

	$setattribute ( thisagent, #ATTRIB_HP, $getattribute ( thisagent, #ATTRIB_MaxHP ));
end

///////////////////////////////////////////////////////////////////////////////
function Champions_Vigor_End ( agent thisagent )
// GPL cast spell - from hall of champions
// - callback from "Champions_Vigor_icon" effector
declare
	integer maxhp;
begin
	$AdjustAttribute ( thisagent, #ATTRIB_MaxHP, -15 );
	$AdjustAttribute ( thisagent, #ATTRIB_HealingRateModifier, 3 );

	maxhp = $getattribute ( thisagent, #ATTRIB_MaxHP );

	if ( $IsDead ( ThisAgent ))
		return;

	if ( $getattribute ( thisagent, #ATTRIB_HP ) > maxhp )
		$setattribute ( thisagent, #ATTRIB_HP, maxhp );
end

// --- This section contains the Earthquake spell functions --- //

///////////////////////////////////////////////////////////////////////////////
function Earthquake_Unit_Created ( agent thisagent, agent target )
/////////////////////////////////////////////////////////////
// player cast spell - from Sorcerer's Abode
// - birthscript for Earthquake unit
/////////////////////////////////////////////////////////////
// Sets the earthquake active script to call at set intervals
// over the duration of the spell.
/////////////////////////////////////////////////////////////
declare

begin
	//$DebugOut (911, "EARTHQUAKE CREATED!");

	// run a test to see what gets hit every second
	$NewThread ( thisagent's "activeScript", 1500, thisagent );

	// have the spell last for X seconds
	$SetSpellUnitTimeout ( thisagent, 6000 );

	// run the damage code once, so in case of lag there is never no damage
	$earthquake_active ( thisagent );

	$StartEarthquakeSpell ( ThisAgent, 5, 30, 6000 );

end

///////////////////////////////////////////////////////////////////////////////
function Earthquake_Active ( agent thisagent )
////////////////////////////////////////////////////////////////////
// player cast spell - from Sorcerer's Abode
// - activescript for Eartquake unit
////////////////////////////////////////////////////////////////////
// This function strikes all non-aligned buildings and lairs within
// its radius.  The damage drops off as the distance from the target
// center increases.
////////////////////////////////////////////////////////////////////
declare
	list targets;
	agent target;
	integer epicenter_distance, max_damage, min_damage;
	float damage_multiplyer, range_band;

begin
	//$DebugOut (911, "IN EARTHQUAKE ACTIVE");

	targets = $earthquake_targets ( thisagent, #Earthquake_Radius );
	range_band = ( #Earthquake_Radius / 8 );
	// The damage is reduced over 8 concentric range bands within the radius.

	foreach target in targets do
		begin
			if ( $IsDead ( Target ) == FALSE )
				begin
					//$DebugOut (911, "IN EARTHQUAKE ASSIGN DAMAGE CODE!");

					Epicenter_distance = $DistanceBetweenAgents ( ThisAgent, target );
					if ( epicenter_distance < range_band )
						damage_multiplyer = .75;
					else
						damage_multiplyer = ( range_band / epicenter_distance );

					max_damage = ( damage_multiplyer * #Earthquake_Damage );
					min_damage = ( damage_multiplyer * ( #Earthquake_Damage / 2 ));

					$debugout ( "max earthquake damage = ", max_damage,
									" : min earthquake damage = ", min_damage );

					$createeffector ( target, "Earthquake_p", 0 );
					$player_spell_attack ( target, max_damage, min_damage );
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function earthquake_targets ( agent thisagent, integer range ) is list

////////////////////////////////////////////////////////////////
// returns a list of all unfriendly buildings & lairs in radius.
////////////////////////////////////////////////////////////////

declare
	list targets, t2, t3;

begin
	$ListObjects ( thisagent, "building", range, targets, #NoHiddenMap );
	$ListObjects ( thisagent, "lair", range, t2, #NoHiddenMap );
	t3 = $addlists ( targets, t2 );
	return t3;
end



//--- Speed Tonic Spell ---//

///////////////////////////////////////////////////////////////////////////////
function Speed_tonic_effect ( agent thisagent, agent target )
////////////////////////////////////////////////////////////
// This is an item cast spell. The item is destroyed and the
// spell forgotten when it is used.
////////////////////////////////////////////////////////////
declare
begin
	If ( $IsDead ( ThisAgent ))
		return;

	$createeffector ( thisagent, "speed_tonic_effector", 0 );
	$createeffector ( thisagent, "speed_tonic_icon", $GetSpellAttribute ( "Speed_Tonic", "effector_duration" ) );
	$adjustattribute ( thisagent, #ATTRIB_MovementRateModifier, -200 );
	$adjustattribute ( thisagent, #ATTRIB_ActionRateModifier, -50 );
	$SetAttribute ( thisagent, #ATTRIB_HasEffectWingedFeet, 1 );

	$DeleteInventoryItem ( #Bazaar_Item_One, ThisAgent );
	$ForgetSpell ( ThisAgent, "Speed_Tonic" );

	$TurnOnSpeedTrail ( thisagent, 4 );
end

///////////////////////////////////////////////////////////////////////////////
function Speed_Tonic_End ( agent thisagent )
// Item cast spell
// - callback from "speed_tonic_icon" effector
declare

begin
	$adjustattribute ( thisagent, #ATTRIB_MovementRateModifier, 200 );
	$adjustattribute ( thisagent, #ATTRIB_ActionRateModifier, 50 );
	$SetAttribute ( thisagent, #ATTRIB_HasEffectWingedFeet, 0 );

	$turnoffSpeedTrail ( thisagent );
end


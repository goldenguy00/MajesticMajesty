function Summon_Medusae_Callback ( agent thisagent )
///////////////////////////////////////////////////////////////////////////////////
// This summons in a Medusa.
///////////////////////////////////////////////////////////////////////////////////
declare
	coordinate agent_loc;

begin

	agent_loc = $locationof ( thisagent );
	$SpawnUnit ( thisagent, "Medusa" );

end


///////////////////////////////////////////////////////////////////////////////
function Shared_Begin_Resurrect( agent thisagent )
// helper function for resurrection shared code
declare

begin
	// MUST SET THIS HERE - because of the replacement script system
	//thisagent's "activescript" = thisagent's "startingscript";
	thisagent's "activescript" = thisagent's "basicscript";

	//Kill existing activescript (which is paused)
	//Reason: Otherwise it may call back and delete itself (because the activescript is be_dead)
	$Killthread (ThisAgent's "ActiveScript");

	$ClearEngineDeathFlags( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
function Shared_End_Resurrect( agent thisagent )
// helper function for resurrection shared code
declare

begin
	//$SetThreadInterval ( thisagent's "activescript", #Normal_Cycle );

	//New thread - not set thread interval

	$NewThread (ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent);

	$SetAttribute( thisagent, #ATTRIB_HP, $getattribute(thisagent,#ATTRIB_MaxHP));
	thisagent's "type" = thisagent's "original_type";
	$performaction(thisagent,"do_nothing",thisagent);

	$Reset_Tasks (ThisAgent);
end


///////////////////////////////////////////////////////////////////////////////
function Reanimate_Begin( agent thisagent )
// player cast spell - from temple to krypta
declare

begin
	$SpecifyIntent (ThisAgent, #intent_reanimating);
	$createeffector( thisagent, "reanimate_effector", 1700 );

	$Shared_Begin_Resurrect( thisagent );
end


///////////////////////////////////////////////////////////////////////////////
function Reanimate_End( agent thisagent )
// player cast spell - from temple to krypta
// - callback from "reanimate_effector" effector
declare

begin
	$NewThread (ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent);

	$SetAttribute( thisagent, #ATTRIB_HP, ( $getattribute ( thisagent, #ATTRIB_MaxHP ) / 2 ));
	thisagent's "type" = thisagent's "original_type";
	$performaction(thisagent,"do_nothing",thisagent);
end


///////////////////////////////////////////////////////////////////////////////
function Resurrection_Begin( agent thisagent )
// player cast spell - from temple to agrela
declare

begin
	$SpecifyIntent (ThisAgent, #intent_resurrecting);
	$createeffector( thisagent, "resurrection_effector", 1500 );

	$Shared_Begin_Resurrect( thisagent );
end


///////////////////////////////////////////////////////////////////////////////
function Resurrection_End( agent thisagent )
// player cast spell - from temple to agrela
// - callback from "resurrection_effector" effector
declare
	integer rebirths;
begin
	rebirths = 0;

	if ( $HasAttribute ( "reborn_counter", thisagent ))
		rebirths = thisagent's "reborn_counter";

	If (ThisAgent's "SubType" == "Hero")
		begin
			// If you have a >0 rebirth counter, we assume you are a healer coming home
			// to be reborn, and do not teleport you (because it looks stupid).
			if ( rebirths < 1 )
				if ( $IsValidGamePiece ( thisagent's "home" ))
					$TeleportToUnit ( thisagent, 100000, thisagent's "home", 0 );
		end

	// The healer rebirth counter is now decremented here, due to timing issues.
	if (( thisagent's "title" == "healer" ) && ( rebirths > 0 ))
		ThisAgent's "Reborn_Counter" --;

	$Shared_End_Resurrect( thisagent );
end


///////////////////////////////////////////////////////////////////////////////
function SuperCharge_Begin(agent thePalace)
// player cast spell - from wizard's guild
// thePalace is the casting player's palace
declare
	list bldgs,bldgs2;
	agent bldg;

begin
	// flag is stored on the palace, since it is global to the kingdom
	$setattribute( thePalace, #ATTRIB_SuperChargeActive, 1 );

	// note the following was done in the calling "c" code
	// thePalace->AlterAttribute( ATTRIB_SuperChargeBeginTime, gGameSyncTick );

	// put effectors on all wizards towers and guilds
	$listobjects( thePalace,"building",-1,bldgs,#MyPlayer);

	bldgs2 = $removetitles(bldgs,"wizards_guild");
	bldgs = $listtitles(bldgs,"wizards_tower");
	bldgs = $addlists(bldgs2,bldgs);

	foreach bldg in bldgs do
		begin
			$createeffector( bldg,"Super_charge_effector", #SuperChargeDuration );
		end

	// end after 30 seconds (#SuperChargeDuration is 30000)
	thePalace's "spell_callback" = $SuperCharge_End;
	$RunThread( thePalace's "spell_callback", #SuperChargeDuration, thePalace );
end


///////////////////////////////////////////////////////////////////////////////
function SuperCharge_End(agent thePalace)
// player cast spell - from wizard's guild
// script run by "SuperCharge_Begin" after timeout period
declare

begin
	$setattribute( thePalace, #ATTRIB_SuperChargeActive, 0 );
end


///////////////////////////////////////////////////////////////////////////////
expression #ThePoisonAmount 10

function Poison_begin(agent thisagent, agent target)
// not a spell: called from attacking with a poisoned weapon
declare

//	integer current_poison;
	integer duration;

begin

//	current_poison = $getattribute(target,#ATTRIB_poisoncounter);

//	duration = #PeriodicHPDeltaPeriod * #PoisonInterval * (current_poison + #ThePoisonAmount);
	duration = #PeriodicHPDeltaPeriod * #PoisonInterval * #ThePoisonAmount;

	// create effector if even if already there
	$createeffector( target,"Poison_icon",duration );

	$setattribute( target,#ATTRIB_poisonCounter, #ThePoisonAmount );
end

///////////////////////////////////////////////////////////////////////////////
// This is called when a unit is suspended by a suspension/freezing - type spell
Function Freeze_Unit (agent ThisAgent)
Declare


Begin
	$StopMoving (ThisAgent);

	$SuspendThread (ThisAgent's "ActiveScript");

	// NLS: set this attribute to keep the unit from being moved
	$SetAttribute( thisagent, #ATTRIB_IsFrozen, 1 );
End

///////////////////////////////////////////////////////////////////////////////
// This is called when a suspension-type spell times-out
Function UnFreeze_Unit (agent ThisAgent)
Declare

Begin
	// check to make sure that there aren't any freeze locks in place
	if ( ($GetAttribute(ThisAgent,#ATTRIB_HasEffectPetrify) == 0) &&
		 ($GetAttribute(ThisAgent,#ATTRIB_HasEffectVines) == 0) &&
		 ($GetAttribute(ThisAgent,#ATTRIB_HasEffectParalyticGaze) == 0) &&
		 ($GetAttribute(ThisAgent,#ATTRIB_HasEffectLevelLeach) == 0) )
		begin
			//If the unit isn't dead, then it should reset tasks
			If ($IsDead (ThisAgent) == False)
				begin

					$Reset_Tasks (ThisAgent);
					$ResumeThread (ThisAgent's "ActiveScript");

					// NLS: release this attribute to allow the unit to be moved
					$SetAttribute( thisagent, #ATTRIB_IsFrozen, 0 );
				end

	// NLS BUGFIX2
	// I'm doing the $ResumeThread in $gravestone instead
//			Else If (ThisAgent's "Subtype" != "Henchman")
//				begin
//
//					$ResumeThread (ThisAgent's "ActiveScript");
//
//				end
		end

End

///////////////////////////////////////////////////////////////////////////////
function GetProperUnitArt(agent thisagent)
// resolve which art is correct for drawing a unit
declare
	string theColor;
	integer theTransparency;

begin
	// get rid of old effects
	$ClearDrawEffects( thisagent );

	// set the color
	if ($getattribute(thisagent,#ATTRIB_HasEffectPetrify) == 1)
		theColor = "gray";
	else if ($getattribute(thisagent,#ATTRIB_HasEffectCamouflage) == 1)
		theColor = "green";
	else
		theColor = "none";

	if ($getattribute(thisagent,#ATTRIB_HasEffectInvisibility) == 1)
		theTransparency = 9;
	else if ($getattribute(thisagent,#ATTRIB_HasEffectIllusionaryHero) == 1)
		theTransparency = 5;
	else
		theTransparency = 0;

	$SetDrawEffects( thisagent, theColor, theTransparency );
end


///////////////////////////////////////////////////////////////////////////////
expression #Multiple_Unit_Attack_Range 24

///////////////////////////////////////////////////////////////////////////////
function multiple_enemy_attack(agent thisagent, agent target)
// Warrior of Discord level 3
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3;

begin
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,#Multiple_unit_Attack_range);

//	$ListObjects(thisagent,"monster",thisagent's "castingrange",targets,#NotMyPlayer);

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// fire 3 projectiles at the closest ones
	$make_attack(thisagent,target1);
	$make_attack(thisagent,target2);
	$make_attack(thisagent,target3);
end

///////////////////////////////////////////////////////////////////////////////
function get_healer_begin(agent thisagent, agent target)

declare
	list heroes;

begin
	// first look for healers
	//$listobjects(thisagent,"hero",thisagent's "castingRange" * 2,heroes, #CheckTitles, "Healer", #NotMyTeam);
	//heroes = $listtitles(heroes,"healer");

	if ($listobjects(thisagent,"hero",thisagent's "castingRange" * 2,heroes, #CheckTitles, "Healer", #NotMyTeam) > 0)
		begin
			if ($randomnumber(100) < 35)
				begin
					// then see if you cast a missle at the nearest one
					$createmissile("energy_blast_missile",thisagent,$listmember(heroes,1));
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
// Returns TRUE if ThisAgent's resist fire is TRUE, AND they make a random roll
Function Does_Resist_Fire (agent ThisAgent) is boolean
Declare

Begin
	If ($HasAttribute ("Resists_Fire", ThisAgent) )
		begin

			If (ThisAgent's "Resists_Fire")

				If ( ( ( $GetAttribute (ThisAgent, #ATTRIB_ExperienceLevel) * 5) + 30) > $RandomNumber (100) + 1)
					return True;

		end

	return False;

End


///////////////////////////////////////////////////////////////////////////////
function Critical_Hit_Unit_Created(agent thisagent, agent target)
//Callback for the Critical_hit vehicle that is instantiated when a unit is
//critically hit
declare

begin
	// destroy the unit after the duration period

	$SetSpellUnitTimeout( thisagent, 2000 );

end
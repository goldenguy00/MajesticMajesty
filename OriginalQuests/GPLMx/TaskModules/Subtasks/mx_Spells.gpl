///////////////////////////////////////////////////////////////////////////////
// This only returns TRUE if there are undead within ThisAgent's Sightrange
function turn_undead_check (agent thisagent) is integer

declare
	list targets;

begin
	targets = $compile_enemies(thisagent,200);
	targets = $ListSubtypes (Targets, "undead");


	if ($listsize(targets) > 0)
		return 1;

	else
		return 0;
end


///////////////////////////////////////////////////////////////////////////////
// Damage all undead in thisagent's "sightrange"
function turn_undead (agent ThisAgent, agent Target)
Declare

Begin
	If ($IsDead (ThisAgent) == False)
		$createeffector( thisagent, "turn_undead_eff", 1000 );

End


///////////////////////////////////////////////////////////////////////////////
// Damage all undead in thisagent's "sightrange"
function turn_undead_hit (agent ThisAgent)
Declare
	list	Targets;
	agent	Dude;

Begin
	If ($IsDead (thisAgent) == False)
		begin

			targets = $compile_enemies(thisagent, 200);
			targets = $ListSubtypes (targets, "undead");

			foreach dude in targets do
				begin
					$createeffector( dude, "turn_undead_hit", 0 );

					//Use player spell attacks as this won't instantiate ThisAgent on the target's
					//hostiles list - which makes the spell not strategic for the Healers
					$player_spell_attack( dude, 10 + $getattribute( thisagent,#ATTRIB_experienceLevel ) / 2, 8 );
				end

		end
End


///////////////////////////////////////////////////////////////////////////////
// This is the new check that WoD make when they want to use their Multiple Unit Attack
Function Multiple_Attack_Check (agent ThisAgent)
Declare
	agent Target;

Begin
	Target = ThisAgent's "Target";

	If ($IsDead (Target) == False)
		begin

			//If target is not a building or lair
			If (Target's "Type" != "Lair" && Target's "Type" != "Building")
				begin

					//and they are within damage range
					If ($DistanceBetweenAgents (ThisAgent, Target) <= #Multiple_unit_Attack_range)
						return 1;

				end

		end

	return 0;

End




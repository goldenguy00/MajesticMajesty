end


///////////////////////////////////////////////////////////////////////////////
function Frost_Field_Active (agent thisagent)
//Run as a unit's "ShieldScript" when they have FrostField
declare
	list  targets;
	agent target;

begin
	// list all enemies nearby - as long as the agent isn't in a building

	If ($InsideBuilding (ThisAgent) == False)
		begin

			targets = $compile_enemies(thisagent,200);

		//	$ListObjects(thisagent,"monster",thisagent's "castingrange",targets,#NotMyPlayer);

			if ($listsize(targets) == 0)
				return;

			Foreach Target in Targets do
				begin

					$createmissile("Frost_Field_Missile",thisagent,target);

				end

		end
end


//--- Fire Balm Spell ---//

///////////////////////////////////////////////////////////////////////////////
function Fire_balm_effect ( agent thisagent, agent target )
////////////////////////////////////////////////////////////
// This is an item cast spell. The item is destroyed and the
// spell forgotten when it is used.
////////////////////////////////////////////////////////////
declare
	string	action;

begin
	If ( $IsDead ( ThisAgent ))
		return;

	$createeffector ( thisagent, "fire_balm_effector", 0 );
	$createeffector ( thisagent, "fire_balm_icon", $GetSpellAttribute ( "Fire_balm", "effector_duration" ) );
	$SetAttribute ( thisagent, #ATTRIB_HasEffectFireBalm, 1 );
	$GetProperUnitArt ( thisagent );

	//Swap attack actions, so the unit uses fiery projectiles
	action = ThisAgent's "Attack_Action";
	ThisAgent's "Attack_Action" = ThisAgent's "Special_Attack_Action";
	ThisAgent's "Special_Attack_Action" = Action;

	//The hero also temporarily gets a "special splat"
	ThisAgent's "special_splat" = "fire_balm_hit";

	$DeleteInventoryItem ( #Bazaar_Item_Two, ThisAgent );
	$ForgetSpell ( ThisAgent, "Fire_Balm" );

end

///////////////////////////////////////////////////////////////////////////////
function Fire_Balm_End ( agent thisagent )
// Item cast spell
// callback from "fire_balm_icon" effector
declare
	string	action;

begin

	$SetAttribute ( thisagent, #ATTRIB_HasEffectFireBalm, 0 );
	$GetProperUnitArt ( thisagent );

	//Swap attack actions back again
	action = ThisAgent's "Attack_Action";
	ThisAgent's "Attack_Action" = ThisAgent's "Special_Attack_Action";
	ThisAgent's "Special_Attack_Action" = Action;

	//No more special splay
	ThisAgent's "special_splat" = "";

end


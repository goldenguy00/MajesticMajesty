function Change_Shape_Begin( agent thisagent, agent target )
// cultist spell - lvl 7
// - callback from cast action
declare

begin
	$createeffector( thisagent, "change_shape_effector", 0 );
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	$createeffector( thisagent, "change_shape_icon", $GetSpellAttribute( "change_shape", "effector_duration" ) );

	$ChangeUnitType( thisagent, "Red_Bear" );

	// increase various attributes
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage,6);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Strength,10);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Vitality,15);
	$adjustattribute(thisagent,#ATTRIB_MaxHP,35);
	$adjustattribute(thisagent,#ATTRIB_HP,35);
end


///////////////////////////////////////////////////////////////////////////////
function Change_Shape_End( agent thisagent )
// cultist spell - lvl 7
// - callback from "change_shape_icon" effector
declare

	integer maxHP;

begin
	$RevertUnitType( thisagent );

	// revert the attributes
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage,-6);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Strength,-10);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Vitality,-15);
	$adjustattribute(thisagent,#ATTRIB_MaxHP,-35);

	// revert HP to full, if are above max
	maxHP = $getattribute(thisagent,#ATTRIB_MaxHP);
	if ($getattribute(thisagent,#ATTRIB_HP) > maxHP)
		$SetAttribute( thisagent, #ATTRIB_HP, maxHP );
end



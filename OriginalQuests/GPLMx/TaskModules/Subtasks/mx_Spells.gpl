// --- Gorgon's Petrify Spell --- //

///////////////////////////////////////////////////////////////////////////////
function Gorgon_Petrify_Begin ( agent ThisAgent, agent target )
////////////////////////////////////////////////////////////////////////////
// The Gorgon_Petrify effect is basically identical to the player cast spell
// 'petrify', save that it has an internal check to ensure that it
// is not recast onto a currently petrified unit.
////////////////////////////////////////////////////////////////////////////
declare
	integer Time;
begin


	If ( $IsDead ( target ))
		return;

	//Buildings, Lairs, and Dwarves don't get petrified.
	If (Target's "Type" != "Building" && Target's "Type" != "Lair" && Target's "Title" != "Dwarf")
		begin

			if ( $GetAttribute ( target, #ATTRIB_HasEffectPetrify ) == 1 )
				return;

				time = 19000; // TODO: When majesty is unfrozen, this time should be
					  			// rebuilt as a global expression for both this spell

				if ( $randomnumber ( 100 ) <= $getattribute ( target, #ATTRIB_MagicResistance ))
					time = time / 2;

				$createeffector ( target, "petrify_effector", 0 );
				$createeffector ( target, "petrify_icon", time );

				$SetAttribute ( target, #ATTRIB_HasEffectPetrify, 1 );
				$GetProperUnitArt ( target );
				$Freeze_Unit ( target );
				$SpecifyIntent ( target, #intent_petrified );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Gorgon_Petrify_End ( agent ThisAgent )
declare
begin
	$SetAttribute ( ThisAgent, #ATTRIB_HasEffectPetrify, 0 );
	$GetProperUnitArt ( thisagent );
	$UnFreeze_Unit ( ThisAgent );
end


// --- Gorgon's Enhance Medusa Spell --- //

///////////////////////////////////////////////////////////////////////////////
function Enhance_Medusa_Begin ( agent ThisAgent, agent target )
//////////////////////////////////////////////////////////////////////////
// This effect will grant the target the 'Medusa_Slow' spell, which it can
// then cast on enemies.  This ability itself is refered to as the
// 'Medusa_Stare' ability. Be careful not to confuse the two.
//////////////////////////////////////////////////////////////////////////
declare
begin
	If ( $IsDead ( target ))
		return;
	if ( $GetAttribute ( target, #ATTRIB_HasEffectMedusa_Stare ) == 1 )
		return;

	$CreateEffector ( target, "Medusa_Stare", $GetSpellAttribute ( "Medusa_Stare", "effector_duration" ));
	$SetAttribute ( target, #ATTRIB_HasEffectMedusa_Stare, 1 );

	$LearnSpell ( target, "Medusa_Slow" );
end

///////////////////////////////////////////////////////////////////////////////
function Enhance_Medusa_End ( agent ThisAgent )
declare
begin
	$SetAttribute ( ThisAgent, #ATTRIB_HasEffectMedusa_Stare, 0 );

	$Forgetspell ( ThisAgent, "Medusa_Slow" );
end

// --- Medusae's Slow Spell --- //

///////////////////////////////////////////////////////////////////////////////
function Medusa_Slow_Begin ( agent ThisAgent, agent target )
/////////////////////////////////////////////////////////
// This spell hinders the target's movement, action rate,
// parry and dodge abilities substantially.
/////////////////////////////////////////////////////////
declare
begin
	If ( $IsDead ( target ))
		return;

	If (Target's "Type" != "Building" && Target's "Type" != "Lair" && Target's "Title" != "Adept")
		begin

			if ( $GetAttribute ( target, #ATTRIB_HasEffectMedusa_Slow ) == 1 )
				return;


			$CreateEffector ( target, "Medusa_Slow_Icon", $GetSpellAttribute ( "Medusa_Slow", "effector_duration" ));
			$SetAttribute ( target, #ATTRIB_HasEffectMedusa_Slow, 1 );

			$MagicalAdjustAttribute ( target, #ATTRIB_Parry, -10 );
			$MagicalAdjustAttribute ( target, #ATTRIB_Dodge, -10 );
			$AdjustAttribute ( target, #ATTRIB_MovementRateModifier, 200 );
			$AdjustAttribute ( target, #ATTRIB_ActionRateModifier, 500 );

		end

end

///////////////////////////////////////////////////////////////////////////////
function Medusa_Slow_End ( agent ThisAgent )
declare
begin
	$SetAttribute ( ThisAgent, #ATTRIB_HasEffectMedusa_Slow, 0 );
	$MagicalAdjustAttribute ( ThisAgent, #ATTRIB_Parry, 10 );
	$MagicalAdjustAttribute ( ThisAgent, #ATTRIB_Dodge, 10 );
	$AdjustAttribute ( ThisAgent, #ATTRIB_MovementRateModifier, -200 );
	$AdjustAttribute ( ThisAgent, #ATTRIB_ActionRateModifier, -500 );
end

// --- Gorgon's Summon Medusae Spell --- //


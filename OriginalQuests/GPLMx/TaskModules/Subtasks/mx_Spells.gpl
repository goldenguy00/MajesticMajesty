end

///////////////////////////////////////////////////////////////////////////////
function Teleport_DoMove( agent thisagent, integer theRange )
// shared teleport code, does the actual teleportation
declare

begin
	If ($IsDead (ThisAgent))
		return;

	// if the target is themselves, it is a point
	if (thisagent's "Target" == thisagent)
		$TeleportToPoint( thisagent, theRange, thisagent's "destination" );
	else
		if ($isvalidgamepiece(thisagent's "target"))
			$TeleportToUnit( thisagent, theRange, thisagent's "Target", thisagent's "castingrange" );
end

///////////////////////////////////////////////////////////////////////////////
function double_attack_effect(agent thisagent, agent target)

declare

begin
	if ($isdead(thisagent's "target") == FALSE)
		begin
			$make_attack(thisagent,thisagent's "target");
			$make_attack(thisagent,thisagent's "target");
		end
end

///////////////////////////////////////////////////////////////////////////////
function double_attack_check(agent thisagent) is integer

declare
	list targets;

begin
	targets = $compile_enemies(thisagent,$getattribute(thisagent,#ATTRIB_maxattackrange));
	if ($listsize(targets) > 0)
		return 1;
	else
		return 0;
end


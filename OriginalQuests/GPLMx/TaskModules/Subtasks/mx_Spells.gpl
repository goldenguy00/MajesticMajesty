///////////////////////////////////////////////////////////////////////////////
function mind_warp_check(agent thisagent) is integer

declare
	list guys;

begin
	// make sure there are more than one hero nearby
	guys = $list_enemies_seen(thisagent,$getattribute(thisagent,#ATTRIB_sightrange));
	guys = $listsubtypes(guys,"hero");
	if ($listsize(guys) > 1)
		return 1;
	else
		return 0;
end

///////////////////////////////////////////////////////////////////////////////
function mind_warp_effect(agent thisagent,agent target)

// make nearby heroes have a percent chance to change sides
// temporarily
declare
	list guys;
	agent guy,guy2;

begin
	if ($isdead(thisagent))
		return;

	guys = $list_enemies_seen(thisagent,$getattribute(thisagent,#ATTRIB_sightrange));
	guys = $listsubtypes(guys,"hero");
	if ($listsize(guys) > 1)
		begin
			// pick 1 guy to be warped, pick another guy to be attacked
			guy = $pick_closest(thisagent,guys);
			guys -= guy;
			guy2 = $pick_closest(guy,guys);
			guy's "activescript" = $attack_object;
			guy's "backscript" = $attack_object;
			$specifyintent(guy,#intent_fighting);
			guy's "Target" = guy2;
			// play an effector on the guys
			$createeffector(guy,"Mindwarp",5000);
//			$createeffector(guy2,"Electrical_fury_effector",5000);
		end
end

///////////////////////////////////////////////////////////////////////////////
function Terrify_effect(agent thisagent,agent target)

// make nearby heroes run!
declare
	list guys;
	agent guy;

begin
	if ($isdead(thisagent))
		return;

	guys = $list_enemies_seen(thisagent,$getattribute(thisagent,#ATTRIB_sightrange));
	foreach guy in guys do
		begin
			if (guy's "subtype" == "hero")
				if ($randomnumber(100) < 75)
					begin
						// play effector
//						If ( $InsideBuilding ( guy ))
//							$Exit_Building ( ThisAgent, ThisAgent's "Target" );

						$Flee ( guy, #intent_flee_scared );
						$createeffector(guy,"Terrify_effector",0);

					end
		end
end



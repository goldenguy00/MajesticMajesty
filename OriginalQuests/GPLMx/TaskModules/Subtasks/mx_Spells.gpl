///////////////////////////////////////////////////////////////////////////////
function meteor_storm_unit_created(agent thisagent, agent target)
// wizard spell - lvl 7
// - birthscript for meteor_storm unit
declare

begin
	// destroy the unit after the duration period
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	$SetSpellUnitTimeout( thisagent, $GetSpellAttribute( "meteor_storm", "effector_duration" ) );

	// run the active script periodically
	$NewThread( thisagent's "activeScript", 1600, thisagent );

	// run the damage once so in case of lag, there is never no damage at all.
	$meteor_storm_active(thisagent);
end



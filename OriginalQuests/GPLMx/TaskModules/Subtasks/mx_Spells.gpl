///////////////////////////////////////////////////////////////////////////////
function SuperBuff ( agent thisagent )
// Permanently buffs a unit with a number of the better spells.  Only really for use on monsters.
declare

begin
	if ( $isdead ( thisagent ))
		return;

	if ( $getattribute ( thisagent, #ATTRIB_HasEffectStoneSkin ) == 0 )
		begin
			$createeffector ( thisagent,"dauros_stone_skin_icon", -1 );
			$SetAttribute ( thisagent, #ATTRIB_HasEffectStoneSkin, 1 );
			$adjustattribute ( thisagent, #ATTRIB_armor_basic_damage, 6 );
		end

	if ( $GetAttribute ( thisagent, #ATTRIB_HasEffectAntiMagic ) == 0 )
		begin
			$createeffector ( thisagent, "antimagic_shield_icon", -1 );
			$SetAttribute ( thisagent, #ATTRIB_HasEffectAntiMagic, 1 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Magicresistance, 60 );
		end

	if ( $GetAttribute ( thisagent, #ATTRIB_HasEffectBlessing ) == 0 )
		begin
			$createeffector ( thisagent, "blessing_icon", -1 );
			$SetAttribute ( thisagent, #ATTRIB_HasEffectBlessing, 1 );

			$MagicalAdjustAttribute ( thisagent, #ATTRIB_HtoH, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_dodge, 15 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_parry, 15 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_ranged, 10 );
		end

	if ( $GetAttribute ( thisagent, #ATTRIB_HasEffectVigilance ) == 0 )
		begin
			$createeffector ( thisagent, "vigilance_icon", -1 );

			$MagicalAdjustAttribute ( thisagent, #ATTRIB_WillPower, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_HtoH, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Ranged, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, 10 );
			$MagicalAdjustAttribute ( thisagent, #ATTRIB_Dodge, 10 );
			$adjustattribute ( thisagent, #ATTRIB_Weapon_Basic_Damage, 6 );
			$adjustattribute ( thisagent, #ATTRIB_MovementRateModifier, -50 );
			$adjustattribute ( thisagent, #ATTRIB_ActionRateModifier, -500 );
			$SetAttribute ( thisagent, #ATTRIB_HasEffectVigilance, 1 );

			$turnonSPeedTrail ( thisagent, 2 );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Pestilence_begin(agent thisagent, agent target)
// RHoden spell
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3,target4;

begin
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,thisagent's "castingrange");

//	$ListObjects(thisagent,"monster",thisagent's "castingrange",targets,#NotMyPlayer);

	$createeffector( thisagent, "ratman_pest_eff", $GetSpellAttribute( "Pestilence", "effector_duration" ) );

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target4 = $listmember(targets,1);

	// fire 4 projectiles at the closest ones
	$createmissile("ratman_pest_proj",thisagent,target1);
	$createmissile("ratman_pest_proj",thisagent,target2);
	$createmissile("ratman_pest_proj",thisagent,target3);
	$createmissile("ratman_pest_proj",thisagent,target4);
end

///////////////////////////////////////////////////////////////////////////////
function Pestilence_missile_Hit( agent thisagent, agent target )
// - callback from pestilence missile hit
declare

begin
	if ($isdead(target))
		return;

	// CBT note: as of Majesty Alpha the effector duration below is 0

	$createeffector( target, "ratman_pest_hit", $GetSpellAttribute( "Pestilence", "effector_duration" ) );
	$spell_attack( thisagent, target, 15 );

	if ( $hasattribute ( "Immune_to_poison", target ))
		if ( target's "immune_to_poison" == FALSE )
			$poison_begin ( thisagent, target );

end


// --- Stonebacks Shield Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Stonebacks_Shield_Begin ( agent thisagent, agent target )
// This starts the effector that callsback to Stonebacks_Hit
declare
	list heroes;
	agent hero;

begin
	if ( $isdead ( thisagent ))
		return;

	$CreateEffector ( thisagent, "Stonebacks_Shield_Effector", 0 );

end

///////////////////////////////////////////////////////////////////////////////
function Stonebacks_Hit ( agent thisagent )
// This item simultaniously casts stoneskin and anti-magic on the hero using it,
// as well as all heroes within a nearby radius.
declare
	list heroes;
	agent hero;

begin
	if ( $isdead ( thisagent ))
		return;

	$ListObjects (ThisAgent, "hero", 160, Heroes, #MyPlayer, #CheckSubtypes, "Hero");
	heroes << thisagent;

	foreach hero in heroes do
		begin
			if ( $isdead ( hero ) == FALSE )
				begin
					$CreateEffector ( hero, "Stonebacks_Hit_Effector", 0 );

					if ( $getattribute ( hero, #ATTRIB_HasEffectStoneSkin ) == 0 )
						begin
							$createeffector ( hero,"dauros_stone_skin_icon", 15000 );
							$SetAttribute ( hero, #ATTRIB_HasEffectStoneSkin, 1 );
							$adjustattribute ( hero, #ATTRIB_armor_basic_damage, 6 );
						end

					if ( $GetAttribute ( hero, #ATTRIB_HasEffectAntiMagic ) == 0 )
						begin
							$createeffector ( hero, "antimagic_shield_icon", 15000 );
							$SetAttribute ( hero, #ATTRIB_HasEffectAntiMagic, 1 );
							$MagicalAdjustAttribute ( hero, #ATTRIB_Magicresistance, 90 );
						end
				end
		end
end






// --- Solarii Fire Hammer Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Fire_Hammer_Hit ( agent thisagent, agent target )
// This is the hit callback for the fire hammer spell used by solarii.

declare
begin
	if ( $isdead ( target ))
		return;

	// Hit the target.
	$CreateEffector ( target, "Fire_Hammer_Effector", 0 );

	If ($Does_Resist_Fire (Target) == False)
		begin

			$Spell_Attack ( thisagent, target, 20 + ( $getattribute ( thisagent, #ATTRIB_experienceLevel ) * 2 ));

		end

	// Return the missile to me.
	if ( $IsDead ( thisagent ) == FALSE )
		if ( $IsDead ( target ) == FALSE )
			$CreateMissile ( "Fire_Hammer_False_Projectile", target, Thisagent );
end

///////////////////////////////////////////////////////////////////////////////
function Fire_Hammer_Dud ( agent thisagent, agent target )
// This function does nothing, but is needed for the missile callback,
// or the missile doesn't get deleted properly.
declare
begin
end

// --- Solarii Supernova Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Supernova_Blast ( agent thisagent, agent target )
// This spell is called directly when high level Solarii die. The standard 'target'
// that the blast is centered on is themselves.

declare
	list targets;
	agent unit;

begin
	$createeffector ( target, "Supernova_Blast_Effector", 0 );

	targets = $compile_enemies ( target, #Supernova_Radius );

	foreach unit in targets do
		begin
				If ($Does_Resist_Fire (Unit) == False)
					begin

						$createeffector ( unit, "Supernova_Hit_Effector", 0 );
						$spell_attack ( thisagent, unit, #Supernova_Damage + ( $getattribute ( thisagent, #ATTRIB_experienceLevel ) * 2 ));

					end
		end
end

// --- Howl of Discord Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Howl_of_Discord_Begin ( agent thisagent, agent target )
declare
	list heroes, monsters, all_targets;
	agent hero, victim;
	integer level, fear_mod, min_damage, max_damage;

begin
	$CreateEffector ( thisagent, "Howl_of_Discord_Effector", 0 );

	All_Targets = $compile_enemies (ThisAgent, #Howl_of_Discord_Radius);

	level = $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel );
	fear_mod = ( level * 5 );
	min_damage = ( #Howl_of_Discord_Damage + level );
	max_damage = ( min_damage * 1.5 );

	foreach victim in all_targets do
		begin
			if ( $isdead ( victim ) == FALSE )
				begin
					// All valid targets get the effector.
					$CreateEffector ( victim, "Howl_of_Discord_Hit", 0 );
					$Spell_Attack ( thisagent, victim, max_damage );

					// Only actual heroes can be affected by the fear.
					if ( victim's "subtype" == "hero" )
						begin
							if (( $randomnumber ( 100 ) + fear_mod ) > ( #Howl_of_Discord_Resist * victim's "self_estimation" ))
								begin
									// Must check the if the unit is dead here, as it may have been killed
									// by the howl damage called earlier
									if ( $isdead ( victim ) == FALSE )
										$Flee_Absolute ( victim, #intent_flee_scared );
								end
						end
				end
		end
end


///////////////////////////////////////////////////////////////////////////////
//Returns 1 if there are valid enemies nearby
function howl_check ( agent thisagent ) is integer

declare
	list targets;

begin
	targets = $compile_enemies ( thisagent, #Howl_of_Discord_Radius );

	//Only cast if there is more than one enemy nearby
	if ( $listsize ( targets ) > 1 )
		return 1;
	else
		return 0;
end




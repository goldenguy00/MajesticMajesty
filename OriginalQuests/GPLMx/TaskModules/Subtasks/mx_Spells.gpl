///////////////////////////////////////////////////////////////////////////////
function Strength_potion_effect ( agent thisagent, agent target )
////////////////////////////////////////////////////////////
// This is an item cast spell. The item is destroyed and the
// spell forgotten when it is used.
////////////////////////////////////////////////////////////
declare
begin
	If ( $IsDead ( ThisAgent ))
		return;

	$createeffector ( thisagent, "Strength_potion_effector", 0 );
	$createeffector ( thisagent, "Strength_potion_icon", $GetSpellAttribute ( "Strength_Potion", "effector_duration" ) );
	$MagicalAdjustAttribute ( thisagent, #ATTRIB_Strength, 40 );

	$DeleteInventoryItem ( #Bazaar_Item_Three, ThisAgent );
	$ForgetSpell ( ThisAgent, "Strength_Potion" );

	$SetAttribute ( thisagent, #ATTRIB_HasEffectStrength, 1 );

end

///////////////////////////////////////////////////////////////////////////////
function Strength_Potion_End ( agent thisagent )
// Item cast spell
// - callback from "speed_tonic_icon" effector
declare


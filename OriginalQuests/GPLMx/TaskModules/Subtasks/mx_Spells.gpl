///////////////////////////////////////////////////////////////////////////////
function Drain_Life_Hit( agent thisagent, agent target )
// priestess spell - lvl 1
// - callback from missile hit
declare
	integer	Effector_Duration;
	list		My_Skeletons;
	agent		Skeleton, Best_Skeleton;
	integer  Healing_Needed, Temp_Healing_Needed, HP, MaxHP;

begin
	if ( $isdead ( target ))
		return;

	if ( $isdead ( thisagent ))
		return;

	// CBT note: as of Majesty Alpha the effector duration below is 0
	Effector_Duration = $GetSpellAttribute ("Drain_Life", "effector_duration");

	If (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			//If I am hurt, then heal me
			If ($GetAttribute (ThisAgent, #ATTRIB_HP) < $GetAttribute (ThisAgent, #ATTRIB_MaxHP))
				begin
					$createeffector( ThisAgent, "life_drain_effector2", Effector_Duration );
					$heal(thisagent,thisagent,5);
	   		end

			Else
				//Heal a controlled skeleton nearby
				begin
					//init Healing_Needed and Temp_Healing_Needed to 0, in order to eval for SKele needing it the most
					Temp_Healing_Needed = 0;
		   		Healing_Needed = 0;

					$ListObjects (ThisAgent, "Hero", $GetAttribute (ThisAgent, #ATTRIB_SightRange), My_Skeletons, #CheckSubtypes, "Controlled");
					//My_Skeletons = $ListSubtypesInRadius (ThisAgent, "hero", "controlled", $GetAttribute (ThisAgent, #ATTRIB_SightRange));

					My_Skeletons = $ListTitles (My_Skeletons, "Skeleton");
		   		Foreach Skeleton in My_Skeletons do
						begin
							HP = $GetAttribute (Skeleton, #ATTRIB_HP);
							MaxHP = $GetAttribute (Skeleton, #ATTRIB_MaxHP);

							//pick the Skele that needs it the most
							If (HP < MaxHP)
								begin
									Temp_Healing_Needed = MaxHP - HP;
									If (Temp_Healing_Needed > Healing_Needed)
										begin
											Healing_Needed = Temp_Healing_Needed;
											Best_Skeleton = Skeleton;
										end
								end
		      		end
					If ($IsValidGamePiece (Best_Skeleton))
						begin
							$createeffector( Best_Skeleton, "life_drain_effector2", Effector_Duration );
							$Heal (ThisAgent, Best_Skeleton, 5);
		      		end
				end
		end

	$createeffector( target, "life_drain_effector", Effector_Duration);
	$spell_attack( thisagent, target, 15 );
end


///////////////////////////////////////////////////////////////////////////////
function Life_Leach_Hit( agent thisagent, agent target )
// monster spell
// - callback from missile hit
declare
	integer	Effector_Duration;

begin
	if ($isvalidgamepiece(target) == FALSE)
		return;

	// CBT note: as of Majesty Alpha the effector duration below is 0
	Effector_Duration = $GetSpellAttribute ("life_leach", "effector_duration");


	if ((target's "type" != "building") && (target's "type" != "lair"))
		begin
			$CreateEffector (ThisAgent, "life_leech_effector2", Effector_Duration);
			$heal(thisagent,thisagent,8);
		end


	$PlaySound (Target, "Life_Leech", "Attack");

	$createeffector(target,"life_leech_effector1", Effector_Duration);

	$spell_attack( thisagent, target, 15 );
end


///////////////////////////////////////////////////////////////////////////////
function Level_Leach_Hit (agent ThisAgent, agent Target)
Declare
	integer	Effector_Duration;

Begin

	If ($IsDead (Target))
		return;

	Effector_Duration = $GetSpellAttribute ("level_leach", "effector_duration");

	$createeffector(target,"Level_Leach_Effector", Effector_Duration, "after");

	// set attrib for freeze locking (see UnFreeze_Unit)
	$SetAttribute( target, #ATTRIB_HasEffectLevelLeach, 1 );

	// pause action
	$Freeze_Unit (Target);

	$SpecifyIntent (Target, #intent_level_being_leeched);

	//Drain level
	$Drain_Level (Target, $RandomNumber (2) + 1);
End


///////////////////////////////////////////////////////////////////////////////
Function Level_Leach_End (agent ThisAgent)
Declare

Begin
	// release attrib for freeze locking (see UnFreeze_Unit)
	$SetAttribute( thisagent, #ATTRIB_HasEffectLevelLeach, 0 );

	$UnFreeze_Unit (ThisAgent);
End



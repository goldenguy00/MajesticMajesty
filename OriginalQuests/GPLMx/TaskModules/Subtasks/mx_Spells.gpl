// --- Ratman Fester Spell --- //

///////////////////////////////////////////////////////////////////////////////
function Infectious_Cloud_Hit ( agent thisagent, agent target )
// monster spell
// - callback from missile hit
declare

begin
	$createeffector ( target, "Infectious_Cloud_Effector", 0 );
	$spell_attack ( thisagent, target, 10 );

	if ( $isdead ( target ) == FALSE )
		if ( $GetAttribute ( target, #ATTRIB_HasEffectRatmanPlague ) < 1 )
			if (( $RandomNumber ( 100 ) + 1 ) < #Plague_Chance )
				if ( Target's "Type" != "Building" && Target's "Type" != "Lair" )
					if ( Target's "subtype" != "undead" )
						begin
							$SetAttribute ( target, #ATTRIB_HasEffectRatmanPlague, #Ratman_Plague_Generations );
							$Ratman_Plague_Begin ( thisagent, target );
						end
end

// --- Ratman Plague Spell --- //
///////////////////////////////////////////////////////////////////////////////
function Ratman_Plague_Begin ( agent thisagent, agent target )
declare
begin
	If ( $IsDead ( target ))
		return;

	If (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			$CreateEffector ( target, "Ratman_Plague_Icon", 1, "infinite" );
			target's "PlagueScript" = $Ratman_Plague_Active;
			$NewThread ( target's "PlagueScript", #Ratman_Plague_Callback_Time, target );

			$MagicalAdjustAttribute ( target, #ATTRIB_Strength, -10 );
			$MagicalAdjustAttribute ( target, #ATTRIB_Parry, -10 );
			$MagicalAdjustAttribute ( target, #ATTRIB_Dodge, -10 );
			$AdjustAttribute ( target, #ATTRIB_MovementRateModifier, 100 );
			$AdjustAttribute ( target, #ATTRIB_ActionRateModifier, 200 );
			$Adjustattribute ( target, #ATTRIB_HealingRateModifier, 5 );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Ratman_Plague_Active ( agent thisagent )
declare
	integer plague_generation, HP;
	list plague_targets;
	agent target;
	boolean valid;

begin
	If ( $IsDead ( thisagent ))
		return;

	// Get my plague generation and iterate it down by one.
	plague_generation = $GetAttribute ( thisagent, #ATTRIB_HasEffectRatmanPlague );
	plague_generation -= 1;

	// If the plague generation has run out, end the plague here.
	if ( plague_generation < 1 )
		begin
			$DeleteEffector ( thisagent, "Ratman_Plague_Icon" );
			return;
		end

	// Iterate the plague to all heroes nearby.
	$ListObjects ( thisagent, "hero", #Plague_Radius, plague_targets, #NoHiddenMap );
	foreach target in plague_targets do
		begin
			valid = TRUE;
			If ( $IsDead ( target ))
				valid = FALSE;
			if ( $GetAttribute ( target, #ATTRIB_HasEffectRatmanPlague ) > 0 )
				valid = FALSE;

			if ( valid )
				if ( Target's "subtype" != "undead" )
					// You get a vitality check to see if you resist the plague. It's difficult though.
	 				if (( $RandomNumber ( 40 ) + 5 ) > $GetAttribute ( target, #ATTRIB_Vitality ))
						begin
							$Ratman_Plague_Begin ( thisagent, target );
							$SetAttribute ( target, #ATTRIB_HasEffectRatmanPlague, #Ratman_Plague_Generations );
						end
		end

	// Damage the hero a little bit from the plague.
	HP = $GetAttribute ( thisagent, #ATTRIB_HP );
	HP -= ( $RandomNumber ( 6 ) + 1 );
	if ( HP < 1 )
		HP = 1; // Note - You can't actually die from the rat plague directly.

	$SetAttribute ( thisagent, #ATTRIB_HP, HP );

	// Vitality check is made. If successful the duration of the plague is shortened.
	if (( $RandomNumber ( 40 ) + 5 ) > $GetAttribute ( thisagent, #ATTRIB_Vitality ))
		plague_generation -= 1;

	// Dont set the plague attribute below 1 yet, or the character could be re-infected unfairly.
	if ( plague_generation < 1 )
		plague_generation = 1;

	// Set the new generation value on the infected agent.
	$SetAttribute ( thisagent, #ATTRIB_HasEffectRatmanPlague, plague_generation );
end

///////////////////////////////////////////////////////////////////////////////
function Ratman_Plague_End ( agent thisagent )
declare
begin
	$SetAttribute ( thisagent, #ATTRIB_HasEffectRatmanPlague, 0 );

	$MagicalAdjustAttribute ( thisagent, #ATTRIB_Strength, 10 );
	$MagicalAdjustAttribute ( thisagent, #ATTRIB_Parry, 10 );
	$MagicalAdjustAttribute ( thisagent, #ATTRIB_Dodge, 10 );
	$AdjustAttribute ( thisagent, #ATTRIB_MovementRateModifier, -100 );
	$AdjustAttribute ( thisagent, #ATTRIB_ActionRateModifier, -200 );
	$Adjustattribute ( thisagent, #ATTRIB_HealingRateModifier, -5 );

	$KillThread ( thisagent's "PlagueScript" );
end


// -- Shadowbeast Speed spells begin here -- //

///////////////////////////////////////////////////////////////////////////////
// This function makes the Shadow Beast speed up for a couple seconds, so that
// they can quickly close with enemies...
Function SBeast_Speed_Begin ( agent ThisAgent, agent Target )
Declare

Begin
	If ( $IsDead ( thisagent ))
		return;

	$adjustattribute ( ThisAgent,#ATTRIB_MovementRateModifier, -300 );
	$turnonSPeedTrail ( ThisAgent, 4 );

	$CreateEffector (ThisAgent, "SBeast_Speed_Icon", $GetSpellAttribute ("SBeast_Speed", "Effector_duration"));

End

///////////////////////////////////////////////////////////////////////////////
// This function end the Shadow Beast short-lived speed boost. Callback from invisible effector icon.
Function SBeast_Speed_End (agent ThisAgent)
Declare

Begin

	$AdjustAttribute (ThisAgent, #ATTRIB_MovementRateModifier, 300);
	$Turnoffspeedtrail (ThisAgent);

End


///////////////////////////////////////////////////////////////////////////////
// This function checks to see whether the Shadow Beast should cast its speed spell or not
// if they are far from the target, they won't, and if they are already within maxattackrange they won't
Function SBeast_Speed_Check (agent ThisAgent) is integer
Declare
	agent		Target;
	integer	Distance;

Begin
	Target = ThisAgent's "Target";

	If (Target != ThisAgent)
		begin

			If ($NotValid (Target) == False)
				begin

					Distance = $DistanceBetweenAgents (ThisAgent, Target);

					If (Distance <= 10)
						begin

							return 0;

						end

					If (Distance <= 500)
						begin

							return 1;

						end

				end
		end

	return 0;

End



// -- Wendigo blink begin here -- //

///////////////////////////////////////////////////////////////////////////////
// This function makes the Wendigo fade out, then teleport briefly after the fade
Function Wendigo_Blink_Begin ( agent ThisAgent, agent Target )
Declare

Begin

	If ( $IsDead ( thisagent ))
		return;

	$FadeOut (ThisAgent, 500);

	// do the movement later
	thisagent's "teleportScript" = $Blink_DoMove;
	$RunThread( thisagent's "teleportScript", 1000, thisagent);
End

///////////////////////////////////////////////////////////////////////////////
// This is run as the Wendigo's teleportscript. It makes them teleport to their target, and then fade in.
Function Blink_DoMove (agent ThisAgent)
Declare

Begin
	If ($IsValidGamePiece (ThisAgent) == False)
		return;

	If ($IsDead (ThisAgent) == False)
		begin

			if ($isvalidgamepiece(thisagent's "target"))
				$TeleportToUnit( thisagent, 10000, thisagent's "Target", 0);

		end


	$FadeIn (ThisAgent, 500);
End


///////////////////////////////////////////////////////////////////////////////
// This function checks to see whether the Wendigo should cast its blink spell or not
// if they are far from the target, they won't, and if they are close, they won't
Function Wendigo_Blink_Check (agent ThisAgent) is integer
Declare
	agent		Target;
	integer	Distance;

Begin
	Target = ThisAgent's "Target";

	If (Target != ThisAgent)
		begin

			If ($NotValid (Target) == False)
				begin

					Distance = $DistanceBetweenAgents (ThisAgent, Target);

					If (Distance <= 100)
						begin

							return 0;

						end

					If (Distance <= 600)
						begin

							return 1;

						end

				end
		end

	return 0;

End




///////////////////////////////////////////////////////////////////////////////
// Stones' summoning spell
Function Summon_Sbeast_Effect (agent ThisAgent, agent Target)
Declare
	list	Monsters;

Begin


	If ($ListObjects (ThisAgent, "monster", -1, Monsters) < #Monster_Spawn_Cap)
		begin

			$SpawnUnit (ThisAgent, "ShadowBeast");
			$SpawnUnit (ThisAgent, "ShadowBeast");

		end

End


///////////////////////////////////////////////////////////////////////////////
// Styx and Stones spell that allows them to aid eachother.
Function Recall_Effect (agent ThisAgent, agent Target)
Declare
	list		Monsters;
	agent 	Friend;
	string	Title;

Begin
	If (ThisAgent's "Title" == "Stones")
		Title = "Styx";

	Else
		Title = "Stones";

	//$ListObjects (ThisAgent, "monster", -1, Monsters, #CheckTitles, Title);
	//Monsters = $ListTitles (Monsters, Title);

	if ($ListObjects (ThisAgent, "monster", -1, Monsters, #CheckTitles, Title) > 0)
		begin
			Friend = $ListMember (Monsters, 1);

			If ($IsDead (Friend) == False)
				begin

					//have the friend say their voice line
					//TODO: SAY SUMMON ALLY VOICE LINE
					$Say (Friend, "VFX_Special1");

					$TeleportToUnit (ThisAgent, 80000, Friend, 0);

					$Reset_Tasks (ThisAgent);

				end

		end
End

///////////////////////////////////////////////////////////////////////////////
Function Recall_Check (agent ThisAgent)
Declare
	list		Monsters;
	agent 	Friend;
	string	Title;

Begin
	//Only enter the logic if ThisAgent doesn't have an enemy target
	//If (ThisAgent's "Target" == $NullAgent () || ThisAgent's "Target" == ThisAgent)

	If (ThisAgent's "ActiveScript" != $Monster_Attack_Object && ThisAgent's "BackScript" != $Monster_Attack_Object)
		begin
			If (ThisAgent's "Title" == "Stones")
				Title = "Styx";

			Else
				Title = "Stones";

			//$ListObjects (ThisAgent, "monster", -1, Monsters, #CheckTitles, Title);
			//Monsters = $ListTitles (Monsters, Title);

			if ($ListObjects (ThisAgent, "monster", -1, Monsters, #CheckTitles, Title) > 0)
				begin
					Friend = $ListMember (Monsters, 1);

					If ($IsDead (Friend) == False)
						begin

							If ($DistanceBetweenAgents (ThisAgent, Friend) > 400)
								begin

									//See if the ally has a target (meaning are they fighting)
									//If ( ( Friend's "Target" != $NullAgent () ) && (Friend's "Target" != Friend ) )
									If (Friend's "ActiveScript" == $Monster_Attack_Object || Friend's "BackScript" == $Monster_Attack_Object)
										begin

											//Friend is in trouble and they are far enough away. Return true;
											return 1;


										end

								end
						end
				end
		end

	//Not worth casting right now
	return 0;

end


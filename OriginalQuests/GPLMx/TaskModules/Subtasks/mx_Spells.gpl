///////////////////////////////////////////////////////////////////////////////
function W_K_Teleport( agent thisagent, agent target )
//
// - callback from cast action
declare

	integer theTimePeriod;

begin
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	theTimePeriod = $GetSpellAttribute( "teleport", "effector_duration" );
	$createeffector( thisagent, "teleport_effector", theTimePeriod );

	// do the movement later
	thisagent's "teleportScript" = $W_K_teleport_move;
	$RunThread( thisagent's "teleportScript", theTimePeriod / 2, thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function W_K_teleport_move(agent thisagent)

declare
	coordinate coord;
	list	Palaces;
	agent	Palace;

begin
	If ($IsDead (ThisAgent))
		return;

	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	coord = $randomcoord(palace,1700,-1);
	$TeleportToPoint( thisagent, 15000, coord );
	thisagent's "coord_home" = coord;
	$playsound(thisagent,"witch_king","taunt");
end


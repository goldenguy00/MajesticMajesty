///////////////////////////////////////////////////////////////////////////////
function teleport_check(agent thisagent) is integer

declare

begin
	return $main_teleport_check(thisagent,#Teleport_range);
end

///////////////////////////////////////////////////////////////////////////////
function teleport_short_check(agent thisagent) is integer

declare

begin
	return $main_teleport_check(thisagent,#Teleport_short_range);
end

///////////////////////////////////////////////////////////////////////////////
function teleport_long_check(agent thisagent) is integer

declare

begin
	return $main_teleport_check(thisagent,#Teleport_long_range);
end

///////////////////////////////////////////////////////////////////////////////
function main_teleport_check(agent thisagent,integer therange) is integer
// check to see if someone who wants to teleport is
// too close to their destination to use the teleport well enough.
declare
	coordinate coord;

begin
	if (thisagent's "Target" == thisagent)
		coord = thisagent's "destination";
	else
		if ($isvalidgamepiece(thisagent's "target"))
			coord = $locationof(thisagent's "target");
		else
			return 0;

	if ($distancebetweencoords(coord,$locationof(thisagent)) > therange / 5)
		return 1;
	else
		return 0;
end

///////////////////////////////////////////////////////////////////////////////
function Teleport_Effect( agent thisagent, agent target )
// wizard spell - lvl 4
// - callback from cast action
declare

	integer theTimePeriod;

begin
	// CBT note: as of Majesty Alpha the effector duration below is NON-ZERO
	theTimePeriod = $GetSpellAttribute( "teleport", "effector_duration" );
	$createeffector( thisagent, "teleport_effector", theTimePeriod );

//	$Teleport_DoMove( thisagent, #Teleport_Range );

	// do the movement later
	thisagent's "teleportScript" = $Teleport_DoMove;
	$RunThread( thisagent's "teleportScript", theTimePeriod/2, thisagent, #Teleport_Range );
end



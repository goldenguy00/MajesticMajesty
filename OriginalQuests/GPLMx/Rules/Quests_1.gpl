///////////////////////////////////////////////////////////////////////////////
function clash_post_victory()

declare
	agent	AIRootAgent, Palace;
	list	Palaces;
	coordinate	Loc;

Begin
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	Palaces = $ListPalaces ();
	Palace = $ListMember ( Palaces, 1 );

	Loc = $RandomCoord (Palace, 400, 1200);
	//Reveal the area around the loc

	$RevealArea (Palace, Loc, 200);

	$SpawnUnit ( Palace, "Ratman", Loc, #player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "RatmanShaman", Loc, #player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "RatmanChampion", Loc, #player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "RatmanChampion", Loc, #player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "RatmanChampion", Loc, #player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));

	$SpawnUnit ( Palace, "Goblin_Champion", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "Goblin_Priest", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
	$SpawnUnit ( Palace, "GoblinOverlord", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));

	//TODO: Add message flag
	$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $Random_Time (300000) );
end

//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
// Darkness Falls Quest entry point
function DARKNESS_FALLS ()
declare
	agent 	AIRootAgent, Palace, Tomb1, Tomb2;
	list		Palaces, Tombs;
	integer	Random;

begin
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	AIRootAgent's "Quest_number" = #Qnumber_Darkness_falls;

	palaces = $ListPalaces();
	palace = $listmember ( palaces, 1 );

	//Start playing music
	$Setup_Quest_Music ( AiRootAgent );

	// what can't be used in this quest?
	$disableunittype("dwarven_Settlement");

	// setup starting messages

	//setup starting treasure
	$setup_random_treasure ( 20, #default_spawn_treasure_dist );


	//Put Styx and Stones in their tombs
	$ListObjects ( Palace, "Lair", -1, Tombs, #NoHiddenMap );
	Tombs = $RemoveTitles ( Tombs, "WightsTomb" );

	//Pick random entries off of the Tombs list
	//Get the first tomb
	Random = $RandomNumber ( $ListSize ( Tombs ) ) + 1 ;
	Tomb1 = ( $ListMember ( Tombs, Random ));

	//Take Tomb1 off the list, so it isn't chosen twice
	Tombs -= Tomb1;

	//Get the second tomb
	Tomb2 = ( $ListMember ( Tombs, 1 ));

	//Remember that there are more than 2 WightsTombs
	Tomb1's "Special_Spawn_Type" = "Styx";
	//Set Has_Special_spawn to True, so lair data is overriden in Lair_Death
	Tomb1's "Has_Special_Spawn" = True;

	Tomb2's "Special_Spawn_Type" = "Stones";
	Tomb2's "Has_Special_Spawn" = True;


	// start all scripts that need to be run
	AIRootAgent's "VictoryCondition" = $Darkness_Victory;
	$NewThread ( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	AIRootAgent's "VictoryCondition2" = $Darkness_Events;
	$NewThread ( AIRootAgent's "VictoryCondition2", $Random_Time ( 300000 ));


	//Whether or not the Tombs have been destroyed
	AIRootAgent's "Quest_Flag_1" = False;

	//This is for the first wave of raider shadowbeasts in the events script
	AIRootAgent's "Quest_Flag_2" = False;

	//This is for giving the player some Goblin Watchtowers after a certain amount of time
	AIRootAgent's "Quest_Flag_3" = False;

	//This is for the first wave of raider shadowbeasts in the events script
	AIRootAgent's "Quest_Flag_4" = False;

	//This is for giving the player a couple Goblin Fortresses
	AIRootAgent's "Quest_Flag_5" = False;

	//This is for the third wave of Shadow Beasts. These are PC_Hunters and raiders
	AIRootAgent's "Quest_Flag_6" = False;

	//This is for the third wave of Shadow Beasts. These are PC_Hunters and raiders
	AIRootAgent's "Quest_Flag_7" = False;
end

///////////////////////////////////////////////////////////////////////////////
function DARKNESS_VICTORY ()
declare
	list	Monsters, Wights, Palaces, Lairs;
	agent	Palace, Monster, Lair, AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	palaces = $ListPalaces ();
	palace = $listmember ( palaces, 1 );

	If ( AIRootAgent's "Quest_Flag_1" == False )
		begin

			//Search for Wightstomb
			$ListObjects ( Palace, "Lair", -1, Lairs, #NoHiddenMap );
			Lairs = $RemoveTitles ( Lairs, "WightsTomb" );

			If ( $ListSize ( Lairs ) == 0 )
				begin

					//The Tombs have all been destroyed
					AIRootAgent's "Quest_Flag_1" = True;

				end

		end


	//Quest flag one is true if we enter this else - the wights tombs have been destroyed
	Else
		begin

			//If both Styx and Stones are gravestones (or gone), then the player wins
			If ( $IsTitleAlive ( Palace, "Styx" ) == False && $IsTitleAlive ( Palace, "Stones" ) == False )
				begin

					$declarevictory ( palace, AIRootAgent's "End_Coord" );
					$KillThread ( AIRootAgent's "VictoryCondition" );

				end

		end
end

///////////////////////////////////////////////////////////////////////////////
Function Darkness_Events ()
Declare
	agent		AIRootAgent, Palace;
	list		Palaces;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	//Spawn a bunch of raider Shadowbeasts
	If (AIRootAgent's "Quest_Flag_2" == False)
		begin

			//Taunt
			$playsound(palace,"Stones","Taunt");

			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));

			$SetThreadInterval (AIRootAgent's "VictoryCondition2", $Random_Time (300000) );

			AIRootAgent's "Quest_Flag_2" = True;

		end


	//Goblins say they will help the player!
	Else If (AIRootAgent's "Quest_Flag_3" == False)
		begin

			//Message Flag
			$MessageFlag (Palace, #Message_DFalls_GWatchtower);

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 400, 800), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 300, 600), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 200, 400), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 400, 800), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 250, 450), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 350, 650), "MaxHP");

			AIRootAgent's "Quest_Flag_3" = True;

			$SetThreadInterval (AIRootAgent's "VictoryCondition2", $Random_Time (200000) );

		end


	//Spawn a bunch of raider Shadowbeasts
	Else If (AIRootAgent's "Quest_Flag_4" == False)
		begin

			//Taunt
			$playsound(palace,"Styx","Taunt");

			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));
			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));


			$SetThreadInterval (AIRootAgent's "VictoryCondition2", $Random_Time (100000) );

			AIRootAgent's "Quest_Flag_4" = True;
		end

	Else If (AIRootAgent's "Quest_Flag_5" == False)
		begin

			//Message Flag
			$MessageFlag (Palace, #Message_DFalls_GFortress);

			$SpawnUnit (Palace, "GoblinFortress", $RandomCoord (Palace, 200, 300), "MaxHP");

			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 400, 800), "MaxHP");
			$SpawnUnit (Palace, "Goblin_WatchTower", $RandomCoord (Palace, 400, 800), "MaxHP");

			//$SpawnUnit (Palace, "GoblinFortress", $RandomCoord (Palace, 300, 400), "MaxHP");

			//$SpawnUnit (Palace, "GoblinFortress", $RandomCoord (Palace, 400, 500), "MaxHP");

			$SetThreadInterval (AIRootAgent's "VictoryCondition2", $Random_Time (300000) );

			AIRootAgent's "Quest_Flag_5" = True;
		end

	Else if (AIRootAgent's "Quest_Flag_6" = True)
		begin

			//Taunt
			$playsound(palace,"Stones","Taunt");

			$spawnunit(palace,"ShadowBeast",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_raider));

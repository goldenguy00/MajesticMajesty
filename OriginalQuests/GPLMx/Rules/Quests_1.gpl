			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));

			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(200000) );

		 end

End

///////////////////////////////////////////////////////////////////////////////
// This spawns some high-level Gnomes near the Palace
Function Spawn_Gnomes (agent ThisAgent)
Declare
	agent 		SpawnUnit;
	coordinate  Coord;

Begin

	Coord = $ClosestMapEdge (ThisAgent);

	$minimapanimation ( Coord, "Event_beacon" );

	SpawnUnit = $SpawnUnit (ThisAgent, "Gnome", Coord);
	$Advance_To_Level (SpawnUnit, $RandomNumber (5) + 8);
	SpawnUnit's "Self_Estimation" = 3.0;
	SpawnUnit's "Enemy_Estimation" = .5;

	SpawnUnit = $SpawnUnit (ThisAgent, "Gnome", Coord);
	$Advance_To_Level (SpawnUnit, $RandomNumber (5) + 8);
	SpawnUnit's "Self_Estimation" = 3.0;
	SpawnUnit's "Enemy_Estimation" = .5;

	SpawnUnit = $SpawnUnit (ThisAgent, "Gnome", Coord);
	$Advance_To_Level (SpawnUnit, $RandomNumber (5) + 8);
	SpawnUnit's "Self_Estimation" = 3.0;
	SpawnUnit's "Enemy_Estimation" = .5;

	SpawnUnit = $SpawnUnit (ThisAgent, "Gnome", Coord);
	$Advance_To_Level (SpawnUnit, $RandomNumber (5) + 8);
	SpawnUnit's "Self_Estimation" = 3.0;
	SpawnUnit's "Enemy_Estimation" = .5;

	//This one is an MU!
	SpawnUnit = $SpawnUnit (ThisAgent, "Gnome", Coord);
	$Advance_To_Level (SpawnUnit, $RandomNumber (5) + 8);
	SpawnUnit's "Self_Estimation" = 3.0;
	SpawnUnit's "Enemy_Estimation" = .5;
	SpawnUnit's "Attack_Action" = "Do_Nothing";
	SpawnUnit's "CastingRange" = 200;
	$SetAttribute (SpawnUnit, #ATTRIB_MaxAttackRange, 200);
	$LearnSpell (SpawnUnit, "Fire_blast");
	$LearnSpell (SpawnUnit, "Fire_shield");
	$LearnSpell (SpawnUnit, "Fire_ball");
	$LearnSpell (SpawnUnit, "Meteor_Storm");
	$LearnSpell (SpawnUnit, "Energy_Blast");
	$LearnSpell (SpawnUnit, "Teleport");
	$MessageFlag (SpawnUnit, #Message_VSerpents_Gnomish_Army_Arrive);

End



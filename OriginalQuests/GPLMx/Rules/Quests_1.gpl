//////////////////////////////////////////////////////////////////////////////////////////
// Legendary Heroes Quest entry point
function LEGENDARY_HEROES ()
declare
	agent 	Lair, Barrow, Palace, AIRootAgent;
	list		Barrows, Palaces;
	integer	Random;

begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	AIRootAgent's "Quest_Number" = #QNumber_Legendary_Heroes;

	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	//Palace is easy to upgrade to level 2
	Palace's "heroes_to_upgrade" = 2;

	//Start playing music
	$Setup_Quest_Music (AiRootAgent);

	// what can't be used in this quest?

	// setup starting messages

	// setup barrow items
	$ListObjects (Palace, "lair", -1, Barrows, #NoHiddenMap);

	//Spawn some wandering monsters right away
	Foreach Lair in Barrows do
		begin

			//Roll random to see whether the lair spawns right away
			If ($RandomNumber (100) +1 > 50 )
				begin

					//This will be overriden by lair data
					$SpawnUnit (Lair, Lair's "Spawn_Type");


				end

		end


	//Find all lairs that are title AncientBarrow
	Barrows = $ListTitles (Barrows, "AncientBarrow");


	//Lairs in this realm respawn after a certain duration
	$SetUp_Respawning_Lairs (Palace);

	//Have the Barrows use normal deathscripts
	//They also need to recieve random items;
	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#QItem_LH_Wand_Immolation, Lair );
	Lair's "IGDeathScript" = $LH_Barrows_Death;
	Barrows -= Lair;

	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#QItem_LH_Belt_Reflection, Lair);
	Lair's "IGDeathScript" = $LH_Barrows_Death;
	Barrows -= Lair;

	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#QItem_LH_Teevus_Wand, Lair);
	Lair's "IGDeathScript" = $LH_Barrows_Death;
	Barrows -= Lair;

	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#QItem_LH_Rune_Healing, Lair);
	Lair's "IGDeathScript" = $LH_Barrows_Death;
	Barrows -= Lair;

	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#Qitem_LH_Helm_Displacement, Lair);
	Lair's "IGDeathScript" = $LH_Barrows_Death;
	Barrows -= Lair;

	Lair = $ListMember (Barrows, $RandomNumber ($ListSize (Barrows)  ) + 1 );
	$CreateNewInventoryItem (#Qitem_LH_Stonebacks_Shield, Lair);
	Lair's "IGDeathScript" = $LH_Barrows_Death;


	// start all scripts that need to be run
	AIRootAgent's "VictoryCondition" = $Legendary_Heroes_victory;
	$NewThread( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	AIRootAgent's "VictoryCondition2" = $Legendary_Heroes_Events;
	$NewThread( AIRootAgent's "VictoryCondition2", $random_time(300000));

	AIRootAgent's "UtilityScript" = $Legendary_Heroes_Time_Limit;
	$RunThread (AIRootAgent's "UtilityScript", 1800000);

	//This is used by the Events Script to make monsters randomly become Raiders
	//AIRootAgent's "Quest_Flag_1" = False;

	//This is used by the Events Script to make monsters randomly become PC_Hunters
	//AIRootAgent's "Quest_Flag_2" = False;

	//This triggers the first wave of wimpy little PC Hunters that attack the player's heroes
	//When the player gets 2 heroes
	AIRootAgent's "Quest_Flag_3" = False;

	//This triggers the second wave of wimpy little PC Hunters that attack the player's heroes
	//When the player gets 4 heroes
	AIRootAgent's "Quest_Flag_4" = False;


	//This is flipped to true if the player takes too long to win the quest.
	//It makes continuous earthquakes around the palace.
	AIRootAgent's "Quest_Flag_10" = False;

end

//////////////////////////////////////////////////////////////////////////////////////////
Function LEGENDARY_HEROES_VICTORY ()
Declare
	list		Palaces, Barrows, Heroes, Buildings;
	agent		Palace, AIRootAgent, Hero, SpawnAgent, Building;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	//See if all the Barrows have been destroyed
	//$ListObjects (Palace, "lair", -1, Barrows, #NoHiddenMap, #CheckTitles, "AncientBarrow");
	//Barrows = $ListTitles (Barrows, "AncientBarrow");

	If ($ListObjects (Palace, "lair", -1, Barrows, #NoHiddenMap, #CheckTitles, "AncientBarrow") == 0)
		begin

			//Set quest music back to bounce between early and mid game tracks
			$Reset_Quest_Music (AIRootAgent);

			$declarevictory(palace,AIRootAgent's "End_coord");

			//Kill BOTH victory condition scripts
			$KillThread( AIRootAgent's "VictoryCondition");

			//Kill BOTH victory condition scripts
			//$KillThread( AIRootAgent's "VictoryCondition2");

			//Kill the utilityscript as well
			$KillThread( AIRootAgent's "UtilityScript");

		end

	If (AIRootAgent's "Quest_Flag_3" == False)
		begin

			If ($ListObjects (Palace, "Hero", -1, Heroes, #CheckSubtypes, "Hero", #InSideOtherUnits) > 1)
				begin

					Foreach Hero in Heroes do
						begin

							If ($IsDead (Hero) == False)
								begin

									//Spawn some wimpy PC_Hunters
									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;
								end
						end


					AIRootAgent's "Quest_Flag_3" = True;

				end

		end

	Else if (AIRootAgent's "Quest_Flag_4" == False)
		begin

			If ($ListObjects (Palace, "Hero", -1, Heroes, #CheckSubtypes, "Hero", #InSideOtherUnits) > 3)
				begin

					Foreach Hero in Heroes do
						begin

							If ($IsDead (Hero) == False)
								begin

									//Spawn some wimpy PC_Hunters
									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;

									SpawnAgent = $SpawnUnit (Palace, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
									SpawnAgent's "Target" = Hero;
									SpawnAgent's "Relentless" = True;
									SpawnAgent's "ActiveScript" = $Monster_Attack_Object;
								end
						end


					AIRootAgent's "Quest_Flag_4" = True;

				end

		end

	//If this is true, then the player has taken too long, and it is time to start making earthquakes like crazy
	If (AIRootAgent's "Quest_Flag_10")
		begin

			$ListObjects ( Palace, "building", -1, Buildings );

			Buildings += Palace;

			If ($ListSize (Buildings) > 0)
				begin

					Building = $ListMember (Buildings, $RandomNumber ($ListSize (Buildings)  ) + 1 );

					Buildings -= Building;

					$CreateSpellUnit ( Building, "Earthquake", Building );


				end

			If ($ListSize (Buildings) > 0)
				begin

					Building = $ListMember (Buildings, $RandomNumber ($ListSize (Buildings)  ) + 1 );

					Buildings -= Building;

					$CreateSpellUnit ( Building, "Earthquake", Building );


				end

		end


End

//////////////////////////////////////////////////////////////////////////////////////////
Function Legendary_Heroes_Events ()
Declare
	list		Palaces, Monsters;
	agent		AIRootAgent, Palace, Monster;
	integer 	Random;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");
	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	//Make a random monster turn into a PC_Hunter
	If ($ListObjects (Palace, "Monster", -1, Monsters, #NoHiddenMap) > 0)
		begin

			Random = $RandomNumber ($ListSize (Monsters) ) + 1;

			Monster = $ListMember (Monsters, Random);

			$Make_PC_Hunter (Monster);

			$Reset_Tasks (Monster);

			Monsters -= Monster;

			//Next time make a Raider
			//AIRootAgent's "Quest_Flag_1" = False;

		end

	If ($ListSize (Monsters) > 0)
		begin

			Random = $RandomNumber ($ListSize (Monsters) ) + 1;

			Monster = $ListMember (Monsters, Random);

			$Make_PC_Hunter (Monster);

			$Reset_Tasks (Monster);

			Monsters -= Monster;


		end

	If ($ListSize (Monsters) > 0)
		begin

			Random = $RandomNumber ($ListSize (Monsters) ) + 1;

			Monster = $ListMember (Monsters, Random);

			$Make_PC_Hunter (Monster);

			$Reset_Tasks (Monster);

			Monsters -= Monster;

		end

	//Make this script execute again in a random amount of time
	$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $random_time(200000) );

End

//////////////////////////////////////////////////////////////////////////////////////////
// This awards a win if all the Barrows are gone, otherwise it declares loss
Function Legendary_Heroes_Time_Limit ()
Declare
	list 		Palaces, Barrows;
	agent		Palace, AIRootAgent;
	integer	ListSize;

Begin
	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	ListSize = $ListObjects (Palace, "lair", -1, Barrows, #NoHiddenMap, #CheckTitles, "AncientBarrow");

	If (ListSize == 0)
		begin

			//Set quest music back to bounce between early and mid game tracks
			$Reset_Quest_Music (AIRootAgent);

			$declarevictory(palace,AIRootAgent's "End_coord");

			//Kill BOTH victory condition scripts
			$KillThread( AIRootAgent's "VictoryCondition");

			//Kill BOTH victory condition scripts
			//$KillThread( AIRootAgent's "VictoryCondition2");

			//Kill the utilityscript as well
			$KillThread( AIRootAgent's "UtilityScript");

		end

	Else
		begin
			//Message Flag saying you took too long.
			$MessageFlag (Palace, #Message_LH_Earthquake_You_Lose);


			//This will continually make Earthquakes at various spots around the palace.
			AIRootAgent's "Quest_Flag_10" = True;


		end


End

//////////////////////////////////////////////////////////////////////////////////////////
// This function makes things happen when the player knocks over AncientBarrows
// Run as the IGDeathScript for the Barrow Mounds
Function LH_Barrows_Death (agent ThisAgent)
Declare
	list		Barrows, Heroes, Palaces;
	integer  ListSize;
	agent 	Hero, Palace;
	agent		AIRootAgent;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);


	ListSize = $ListObjects (ThisAgent, "lair", -1, Barrows, #NoHiddenMap, #CheckTitles, "AncientBarrow");

	If (ListSize == 5)
		begin

		 	$MessageFlag ($LocationOf (ThisAgent), #Message_LH_Barrow_One_Dead);

			//Earthquake!
			$CreateSpellUnit ( ThisAgent, "Earthquake", Palace );

			//Spawn some Trolls for each of the player's Heroes to fight
			$ListObjects (ThisAgent, "hero", -1, Heroes, #NoHiddenMap, #CheckSubtypes, "Hero");

			Foreach Hero in Heroes do
				begin

					$spawnUnit(ThisAgent,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");

				end

		end

	If (ListSize == 4)
		begin

		 	$MessageFlag ($LocationOf (ThisAgent), #Message_LH_Barrow_Two_Dead);

			//Earthquake!
			$CreateSpellUnit ( ThisAgent, "Earthquake", Palace );

			$ListObjects (ThisAgent, "hero", -1, Heroes, #NoHiddenMap, #CheckSubtypes, "Hero");

			Foreach Hero in Heroes do
				begin

					$spawnUnit(ThisAgent,"GreaterGorgon",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");

				end

		end

	If (ListSize == 3)
		begin

			$MessageFlag ($LocationOf (ThisAgent), #Message_LH_Barrow_Three_Dead);

			//Earthquake!
			$CreateSpellUnit ( ThisAgent, "Earthquake", Palace );

			//Spawn some Minotaurs for each of the player's Heroes to fight
			$ListObjects (ThisAgent, "hero", -1, Heroes, #NoHiddenMap, #CheckSubtypes, "Hero");

			Foreach Hero in Heroes do
				begin

					$spawnUnit(ThisAgent,"Minotaur",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Minotaur",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Minotaur",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");

				end

		end

	If (ListSize == 2)
		begin

		 	$MessageFlag ($LocationOf (ThisAgent), #Message_LH_Barrow_Four_Dead);

			//Earthquake!
			$CreateSpellUnit ( ThisAgent, "Earthquake", Palace );

			//Spawn a horde of PC_Hunting Goblins
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "GoblinOverlord", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Fighter", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Champion", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Archer", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );
			$SpawnUnit (ThisAgent, "Goblin_Priest", $RandomEdgeCoord ($RandomNumber (4)), #Monster_Player, $Concatenate (#ATTRIB_Artifice, #Force_PC_Hunter) );

		end

	If (ListSize == 1)
		begin

			//Endgame music
			$Play_Endgame_Music (AIRootAgent);

			$MessageFlag ($LocationOf (ThisAgent), #Message_LH_Barrow_Five_Dead);

			//Earthquake!
			$CreateSpellUnit ( ThisAgent, "Earthquake", Palace );

			$ListObjects (ThisAgent, "hero", -1, Heroes, #NoHiddenMap, #CheckSubtypes, "Hero");

			Foreach Hero in Heroes do
				begin

					$spawnUnit(ThisAgent,"Minotaur",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Minotaur",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");
					$spawnUnit(ThisAgent,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay), $LocationOf (Hero), "override");

				end

		end


	If (ListSize == 0)
		begin

			AIRootAgent's "End_Coord" = $LocationOf (ThisAgent);

		end

	//Then normal Lair Death
	$Lair_Death (ThisAgent);

End


//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
//////////////////////////////////////////////////////////////////////////////////////////
// The Valley of the Serpents Quest entry point
function VALE_SERPENTS ()
declare
	agent	Palace, AIRootAgent;
	list 	Palaces;

begin

	AIRootAgent = $RetrieveAgent ("GPLAIRoot");
	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);


	AIRootAgent's "Quest_Number" = #QNumber_Vale_Serpents;

	//Start playing music
	$Setup_Quest_Music (AiRootAgent);

	// what can't be used in this quest?
	$DisableUnittype ("Elven_bungalow");

	// setup starting messages

	// setup special things

	// start all scripts that need to be run
	AIRootAgent's "VictoryCondition" = $Vale_Serpents_Victory;
	$NewThread( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	AIRootAgent's "VictoryCondition2" = $Vale_Serpents_Events;
	$NewThread( AIRootAgent's "VictoryCondition2", $random_time(200000) );

	//This controls the first influx of elves
	AIRootAgent's "Quest_Flag_1" = False;

	//This controls the first wave of Medusa
	AIRootAgent's "Quest_Flag_2" = False;

	//This controls the second population of Elves - they plant Elven Bungalows
	AIRootAgent's "Quest_Flag_3" = False;

	AIRootAgent's "Quest_Flag_4" = False;
	AIRootAgent's "Quest_Flag_5" = False;
	AIRootAgent's "Quest_Flag_6" = False;
	AIRootAgent's "Quest_Flag_7" = False;
	AIRootAgent's "Quest_Flag_8" = False;
	AIRootAgent's "Quest_Flag_9" = False;
	AIRootAgent's "Quest_Flag_10" = False;
	AIRootAgent's "Quest_Flag_11" = False;
	AIRootAgent's "Quest_Flag_12" = False;
	AIRootAgent's "Quest_Flag_13" = False;
	AIRootAgent's "Quest_Flag_14" = False;
	AIRootAgent's "Quest_Flag_15" = False;
	AIRootAgent's "Quest_Flag_16" = False;
	AIRootAgent's "Quest_Flag_17" = False;
	AIRootAgent's "Quest_Flag_18" = False;
end

///////////////////////////////////////////////////////////////////////////////
Function Vale_Serpents_Victory ()
Declare
	agent AIRootAgent, Palace;
	list	Palaces, Bungs;
	list	SnakePits;

Begin

	AIRootAgent = $RetrieveAgent ("GPLAIRoot");
	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	//If all the serpent's pits get destroyed, then the player loses
	//$ListObjects (Palace, "lair", -1, SnakePits, #CheckTitles, "SnakePit", #NoHiddenMap);

	//Lairs = $ListTitles (Lairs, "SnakePit");

	If ($ListObjects (Palace, "lair", -1, SnakePits, #CheckTitles, "SnakePit", #NoHiddenMap) == 0)
		begin

			//Set quest music back to bounce between early and mid game tracks
			$Reset_Quest_Music (AIRootAgent);

			$declarevictory(palace,AIRootAgent's "End_coord");

			//Kill BOTH victory condition scripts
			$KillThread( AIRootAgent's "VictoryCondition");

			//Kill BOTH victory condition scripts
			$KillThread( AIRootAgent's "VictoryCondition2");

			//Kill BOTH victory condition scripts
			$KillThread( AIRootAgent's "UtilityScript");

			//Start a script that will randomly spawn Medusa, Gorgons, and Ice Dragons from time to time
			AIRootAgent's "VictoryCondition2" = $Vale_Post_Victory_Events;
			$NewThread (AIRootAgent's "VictoryCondition2", $Random_Time (200000) );
		end

	//If the player ever loses all the Elven Bungalows, they lose the quest
	If ($ListObjects (Palace, "building", -1, Bungs, #CheckTitles, "Elven_Bungalow") == 0)
		begin

			$DeclareLoss (Palace);

		end

End

///////////////////////////////////////////////////////////////////////////////
Function Vale_Serpents_Events ()
Declare
	agent		AIRootAgent, Palace, SpawnAgent;
	list		Palaces;
	coordinate	Coord;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");
	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	Coord = $FarthestMapEdge_OnMap (Palace);

	//Spawn some elves.
	If (AIRootAgent's "Quest_Flag_1" == False)
		begin
			//Message flag
			$MessageFlag (Palace, #Message_VSerpents_Elven_Refugees);

			$RevealArea (Palace, Coord, 300);

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);


			//Spawn a couple snakepits as well
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);


			AIRootAgent's "Quest_Flag_1" = True;

			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(60000) );
		end


	//Spawn some elves with Medusa chasing them
	Else if (AIRootAgent's "Quest_Flag_2" == False)
		begin
			//Message flag
			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);


			AIRootAgent's "Quest_Flag_2" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", 3000 );
		end


	//Spawn some elves with Medusa chasing them
	Else if (AIRootAgent's "Quest_Flag_3" == False)
		begin
			//Message flag
			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "Medusa", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));

			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 800, 1000 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 900, 1400 ), "MaxHP", #Monster_Player);

			AIRootAgent's "Quest_Flag_3" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(150000) );
		end

	//Spawn a couple Elven Bungs at 1 hp.
	Else if (AIRootAgent's "Quest_Flag_4" == False)
		begin

			SpawnAgent = $SpawnUnit (Palace, "Elven_Bungalow", $RandomCoord (Palace, 500, 1000) );
			//Message flag
			$MessageFlag (SpawnAgent, #Message_VSerpents_Elven_Bungalows);

			SpawnAgent = $SpawnUnit (Palace, "Elven_Bungalow", $RandomCoord (Palace, 500, 1000) );
			$MessageFlag (SpawnAgent, #Message_VSerpents_Elven_Bungalows);


			AIRootAgent's "Quest_Flag_4" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(40000) );
		end


	//Gnomes are on their way
	Else if (AIRootAgent's "Quest_Flag_5" == False)
		begin
			//Message flag
			$MessageFlag (Palace, #Message_VSerpents_Gnomish_Army_Move);

			AIRootAgent's "Quest_Flag_5" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(40000) );
		end



	Else if (AIRootAgent's "Quest_Flag_6" == False)
		begin

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);


			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);

			AIRootAgent's "Quest_Flag_6" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(60000) );
		end


	//The Gnome army is here!
	Else if (AIRootAgent's "Quest_Flag_7" == False)
		begin

			$Spawn_Gnomes (Palace);

			AIRootAgent's "Quest_Flag_7" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(60000) );

		end


	Else if (AIRootAgent's "Quest_Flag_8" == False)
		begin

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);

			AIRootAgent's "Quest_Flag_8" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(3000) );
		end


	Else if (AIRootAgent's "Quest_Flag_9" == False)
		begin

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "IceDragon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "IceDragon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));

			$SpawnUnit (Palace, "GreaterGorgon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "GreaterGorgon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "GreaterGorgon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));

			AIRootAgent's "Quest_Flag_9" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(120000) );
		end

  	Else if (AIRootAgent's "Quest_Flag_10" == False)
		begin

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "Elf", Coord);
			$SpawnUnit (Palace, "Elf", Coord);

			$SpawnUnit (Palace, "Elven_Bungalow", $RandomCoord (Palace, 1000, 1500) );

			AIRootAgent's "Quest_Flag_10" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", 3000 );
		end

	Else if (AIRootAgent's "Quest_Flag_11" == False)
		begin

			$minimapanimation ( Coord, "Event_beacon" );

			$SpawnUnit (Palace, "GreaterGorgon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));

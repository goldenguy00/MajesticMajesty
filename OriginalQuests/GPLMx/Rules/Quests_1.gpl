		end

	Else if (AIRootAgent's "Quest_Flag_18" == False)
		begin
			//ELVEN ARMY!!!
			$Play_Endgame_Music (AIRootAgent);

			$Spawn_Elves (Palace);

			AIRootAgent's "Quest_Flag_18" = True;
			$SetThreadInterval( AIRootAgent's "VictoryCondition2", $random_time(200000) );

		end

	//Otherwise spawn baddies forever
	Else
		 begin

			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player,$concatenate(#ATTRIB_Artifice,#force_elf_hunter));


///////////////////////////////////////////////////////////////////////////////
Function Snake_Pit_Spawn ( agent ThisAgent )
//This is the Spawn Function that SnakePits call.
//It spawns Gorgons and Medusae
Declare
	list		Monsters;
	integer  History_Mod;
	integer	Spawn_Num, Random2, Counter;

Begin

	$AutoSpawn_Lair (ThisAgent);

	//Adjust ThisAgent's "History_Modifier"
	ThisAgent's "History_Modifier" += $GetAttribute ( ThisAgent, #ATTRIB_Lair_History_Mod );

	//Give ThisAgent a little more gold
	$adjustattribute ( thisagent, #ATTRIB_gold, $randomnumber ( #lair_gold_regen ) + 1 );

	Counter = 0;

	$ListObjects ( ThisAgent, "Monster", -1, Monsters );

	//Make sure that there aren't already the maximum number of monsters on the map
	If ( $ListSize ( Monsters ) <= #Monster_Spawn_Cap )
		begin
			//Get a random number of Goblin units to spawn
			Spawn_Num = $RandomNumber (2) + 1;

			While ( Counter < Spawn_Num ) do
				begin
					If ($RandomNumber (100 + 1) > 80)
						begin

							$SpawnUnit (ThisAgent, "GreaterGorgon");

						end

					Else
						$SpawnUnit (ThisAgent, "Medusa");


					counter++;
				end

		end

End


///////////////////////////////////////////////////////////////////////////////
// This script continually spawns monsters after the Player wins Valley of the Serpents
Function Vale_Post_Victory_Events ()
Declare
	agent 	AIRootAgent, Palace;
	list		Palaces;
	integer  Random;

Begin
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	Palaces = $ListPalaces ();
	Palace = $ListMember (Palaces, 1);

	Random = $RandomNumber (5) + 1;


	If (Random == 1)
		begin

			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);

		end

	Else if (Random == 2)
		begin

			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);

		end

  	Else if (Random == 3)
		begin

			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"Medusa",$RandomedgeCoord($randomnumber(4)),#Monster_player);

		end

	Else if (Random == 4)
		begin

			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"IceDragon",$RandomedgeCoord($randomnumber(4)),#Monster_player);

		end

	Else if (Random == 5)
		begin

			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player);
			$spawnunit(palace,"GreaterGorgon",$RandomedgeCoord($randomnumber(4)),#Monster_player);


		end


	$SetThreadInterval (AIRootAgent's "VictoryCondition2", $Random_Time (300000) );

End


///////////////////////////////////////////////////////////////////////////////
// This is so monsters look for the Elvenbungalows on the map before they
// consider other buildings. Basically raider code.
function Elf_Hunter (agent thisagent)

declare

	list buildings, lairs, targets, Bungs, non_Bungs;
	agent target, closest_building, closest_lair, building;
	boolean casting;
	integer attackrange, search_dist;
	string spell_name;

begin
	target = thisagent's "target";

	if ($notvalid(thisagent's "target"))
		begin
			$debugout(thisagent's "title"," picking a target.");

			search_dist = -1;

			//Find the closest enemy building (if any)
			//Look for Elven Bungalows first
			If ($ListObjects( thisagent,"building",search_dist, buildings,#NotMyTeam ) > 0)
				begin

					//Only Elven Bungalows on this list
					Bungs = $RemoveTitles (Buildings, "Elven_Bungalow");

					//Everything else on this list
					Non_Bungs = Buildings;

					Targets = $Addlists (Bungs, non_Bungs);

				end


			if ($listsize(targets) > 0)
				begin

					ThisAgent's "Target" = $ListMember (Targets, 1);

				end
			else
				begin
					// raider wanders because it has no targets
					thisagent's "activescript" = $wandering;
				end
		end
	else
		begin
			// pick weapon or spell
			spell_name = $getbestspell(thisagent,#list_attack);
			$debugout("raider spell:",spell_name);

			if (spell_name == "nothing")
				begin
					attackrange = $getattribute(thisagent,#ATTRIB_maxattackrange);
					casting = FALSE;
				end
			else
				begin
					attackrange = thisagent's "castingrange";
					casting = TRUE;
				end

			$raider_eval_enemies(thisagent);

			if ($distancebetweenagents(thisagent,thisagent's "target") < attackrange)
				begin
					// check for peasants nearby who are repairing buildings
					if ($peasants_near(thisagent) == FALSE)
						begin
							if (casting)
								$castspell(thisagent,spell_name,target, "");
							else
								if ($randomnumber(1000) <= 995)
									$PerformAction (ThisAgent, ThisAgent's "Attack_Action", ThisAgent's "Target");
								else
									$PerformAction (ThisAgent, thisAgent's "Idle_action", ThisAgent's "Target");
						end
				end
			else
				begin
					thisagent's "destination" = $locationof(thisagent's "target");
 					thisagent's "activescript" = $monster_travel_to;
					thisagent's "backscript" = $elf_hunter;
					$move(thisagent,thisagent's "target");
				end
		end

end

///////////////////////////////////////////////////////////////////////////////
// The Clash of Empires Quest entry point
function CLASH_EMPIRES ()
declare
	agent AIRootAgent, Palace, Lair;
	list	Palaces, Lairs, Lairs2, Lairs3;

begin

	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	AIRootAgent's "Quest_number" = #QNumber_Clash_Empires;

	Palaces = $ListPalaces ();
	Palace = $ListMember ( Palaces, 1 );

	//Reveal the whole map to player_2
	$RevealWholeMap ( #Player_2 );   // the goblins
	$RevealWholeMap ( #Player_3 );  // the rats

	//Make it so the Player_2 (Goblin) side can see the whole map
	//Also make it so the Goblin Fort has lower max simul spawns, higher max stored spawns
	$ListObjects ( Palace, "Lair", -1, Lairs, #NoHiddenMap );
	Foreach Lair in Lairs do
		begin

			If ( $GetUnitPlayerNumber ( Lair ) == #Player_2 )
				Lairs2 << Lair;
			else
				lairs3 << lair;

			If (Lair's "Title" == "GoblinFortress")
				begin
					Lair's "Max_Simul_Spawns" = 1;
					Lair's "Max_Stored_Spawns" = 8;
				end

		end


	//Get a player 2 lair
	Lair = $ListMember ( Lairs2, 1 );

	//Make it so player2 is on a different team than player 1
	$SetPlayerTeamNumber ( Lair, $NewTeamNumber ());

	// make the rats on player 3 be on their own team
	lair = $listmember(lairs3, 1);

	$setplayerteamNumber( lair, $newTeamNumber());

	//Start playing music
	$Setup_Quest_Music ( AiRootAgent );

	// what can't be used in this quest?

	// setup starting messages

	// setup special things

	//This triggers a skirmish close to the palace between some rats and goblins
	AIRootAgent's "Quest_Flag_1" = False;
	//This spawns a couple Broken Sewer mains partway into the quest
	AIRootAgent's "Quest_Flag_2" = False;
	//This spawns some Wendigos onto any Cultists (if the player has any)
	AIRootAgent's "Quest_Flag_3" = False;
	//This spawns a couple Goblin Watchtowers partway into the quest
	AIRootAgent's "Quest_Flag_4" = False;
	//This triggers a skirmish close to the palace between some rats and goblins
	AIRootAgent's "Quest_Flag_5" = False;
	//This triggers a skirmish close to the palace between some rats and goblins
	AIRootAgent's "Quest_Flag_6" = False;
	//This triggers a skirmish close to the palace between some rats and goblins
	AIRootAgent's "Quest_Flag_7" = False;


	// start all scripts that need to be run
	AIRootAgent's "VictoryCondition" = $Clash_Empires_Victory;
	$NewThread ( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	AIRootAgent's "VictoryCondition2" = $Clash_Empires_Events;
	$NewThread ( AIRootAgent's "VictoryCondition2", $Random_Time ( 240000 ));

end

///////////////////////////////////////////////////////////////////////////////
function Clash_Empires_Victory ()
Declare
	agent 	AIRootAgent, Palace, Lair, Member;
	list		Palaces, Lairs, lairs2,Gobs, Rats, Monsters, Rat_Lairs, Gob_Lairs;
	integer	Rat_Diff, Gob_Diff, Counter, ListSize;


Begin

	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	Palaces = $ListPalaces ();
	Palace = $ListMember ( Palaces, 1 );

	//If all the lairs are gone, then the player wins
	$ListObjects ( Palace, "Lair", -1, Lairs, #NoHiddenMap );
	If ( $ListSize ( Lairs ) == 0)
		begin
			$declarevictory(palace);
			$KillThread ( AIRootAgent's "VictoryCondition" );
			$KillThread ( AIRootAgent's "VictoryCondition2" );
			AIRootAgent's "VictoryCondition2" = $clash_post_victory;
			$newthread(AIRootAgent's "VictoryCondition2", $random_time(300000));
		end

	If ( ($RandomNumber (100) + 1) < 35)
		begin
			// this code equalizes rat vs Goblin strengths on the map

			$ListObjects ( Palace, "Monster", -1, Monsters, #NoHiddenMap );

			Rats = $ListFamily (Monsters, "Ratman");
			Gobs = $ListFamily (Monsters, "Goblin");

			//If there are less rats, then spawn some rats
			Rat_Diff = $ListSize (Gobs) - $ListSize (Rats);

			//If there are less goblins, then spawn some golbins
			Gob_Diff = $ListSize (Rats) - $ListSize (Gobs);

			//Get all the Rats Nests on the map
			Rat_Lairs = $RemoveTitles (Lairs, "RatsNest");
			lairs2 = $removeTitles (lairs, "brokensewermain");
			rat_lairs = $addlists(rat_lairs,lairs2);

			//Towers don't spawn anything, so remove them
			$RemoveTitles (Lairs, "Goblin_Watchtower");

			//Everything else must be a Goblin Lair
			Gob_Lairs = Lairs;

			If (Rat_Diff > 0) // the rats are 1 or more behind the goblins
				begin
					ListSize = $ListSize (Rat_Lairs);
					$debugout(911,"rat selected...");

					if (listsize > 0)
						begin
							//Get a random lair to do the spawning
							Member = $ListMember (Rat_Lairs, $RandomNumber (ListSize) + 1);
							$SpawnUnit (Member, Member's "Spawn_Type" );
							$debugout(911,"...Rat for equalizer!");
						end
				end
			Else if (Gob_Diff > 0) // the goblins are 1 or more behind the rats
				begin
					ListSize = $ListSize (Gob_Lairs);
					$debugout(911,"goblin selected...");
					if (listsize > 0)
						begin
							// Get a random lair to do the spawning
							Member = $ListMember (Gob_Lairs, $RandomNumber (ListSize) + 1);
							$SpawnUnit (Member, Member's "Spawn_Type" );
							$debugout(911,"...goblin for equalizer!");
						end
				end
		end

End

///////////////////////////////////////////////////////////////////////////////
function Clash_Empires_Events ()

Declare
	agent	AIRootAgent, Palace, Cultist;
	list	Palaces, Cultists;
	coordinate	Loc;

Begin
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	Palaces = $ListPalaces ();
	Palace = $ListMember ( Palaces, 1 );

	//Spawn some Goblins and Rats on the same spot - but on different teams
	If ( AIRootAgent's "Quest_Flag_1" == False )
		begin
			Loc = $RandomCoord ( Palace, 400, 1200 );
			//Reveal the area around the loc

			$RevealArea ( Palace, Loc, 200 );

			$SpawnUnit ( Palace, "Ratman", Loc, #Player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "Ratman", Loc, #Player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "RatmanShaman", Loc, #Player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "RatmanChampion", Loc, #Player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));

			$SpawnUnit ( Palace, "Goblin_Fighter", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "Goblin_Champion", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "Goblin_Priest", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));
			$SpawnUnit ( Palace, "Goblin_Priest", Loc, #Player_2, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));

			$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $Random_Time ( 240000 ));

			AIRootAgent's "Quest_Flag_1" = True;
		end

	//Spawn a couple broken sewer mains
	Else if ( AIRootAgent's "Quest_Flag_2" == False )
		begin

			$MessageFlag ( Palace, #Message_CEmpires_Broken_Sewers );

			$SpawnUnit ( Palace, "BrokenSewerMain",$RandomCoord ( Palace, 300, 1000 ), #Player_3, "MaxHP" );
			$SpawnUnit ( Palace, "BrokenSewerMain",$RandomCoord ( Palace, 300, 1000 ), #Player_3, "MaxHP" );

			AIRootAgent's "Quest_Flag_2" = True;

			$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $Random_Time ( 60000 ));

		end

	//Spawn some wendigos
	Else if ( AIRootAgent's "Quest_Flag_3" == False )
		begin

			If ($ListObjects (Palace, "Hero", -1, Cultists, #InsideOtherUnits, #CheckTitles, "Cultist") > 0)
				begin

					$MessageFlag (Palace, #CEmpires_Displaced_Wendigo );

					Foreach Cultist in Cultists do
						begin

//							$SpawnUnit (Cultist, "Wendigo", $ClosestMapEdge (Palace) );
							$SpawnUnit (Cultist, "Wendigo", $ClosestMapEdge (Palace) );

						end

				end


			AIRootAgent's "Quest_Flag_3" = True;

			$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $Random_Time ( 120000 ));

		end

	//Spawn a couple watchtowers
	Else if ( AIRootAgent's "Quest_Flag_4" == False )
		begin

			$MessageFlag ( Palace, #Message_CEmpires_Goblin_Watchtowers );

			$SpawnUnit ( Palace, "Goblin_WatchTower", $RandomCoord ( Palace, 300, 1000 ), #Player_2, "MaxHP" );
			$SpawnUnit ( Palace, "Goblin_WatchTower", $RandomCoord ( Palace, 300, 1000 ), #Player_2, "MaxHP" );

			AIRootAgent's "Quest_Flag_4" = True;

			$SetThreadInterval ( AIRootAgent's "VictoryCondition2", $Random_Time ( 240000 ));

		end

	//Spawn some Goblins and Rats on the same spot - but on different teams
	Else if ( AIRootAgent's "Quest_Flag_5" == False )
		begin
			Loc = $RandomCoord ( Palace, 400, 1200 );
			//Reveal the area around the loc

			$RevealArea ( Palace, Loc, 200 );

			$SpawnUnit ( Palace, "Ratman", Loc, #Player_3, $concatenate ( #ATTRIB_Artifice, #force_Monster_Hunter ));

			$SpawnUnit (Palace, "IceDragon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));
			$SpawnUnit (Palace, "IceDragon", Coord, #Monster_Player, $concatenate(#ATTRIB_Artifice,#force_elf_hunter));

			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);
			$SpawnUnit (Palace, "SnakePit" ,$RandomCoord (Palace, 1000, 1500 ), "MaxHP", #Monster_Player);


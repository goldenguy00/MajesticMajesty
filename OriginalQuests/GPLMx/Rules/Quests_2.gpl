///////////////////////////////////////////////////////////////////////////////
// Rise of the Ratmen Quest entry point
function RISE_RATMEN ()

declare
	agent AIRootAgent;
	agent palace;
	list palaces;

begin
	AIRootAgent = $RetrieveAgent("GplAIRoot");

	AIRootAgent's "Quest_Number" = #QNumber_rise_ratmen;

	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	$Setup_Quest_Music (AiRootAgent);

// what can't be used in this quest?

// setup starting messages

// setup special things

// start all scripts that need to be run
	AIRootAgent's "VictoryCondition" = $ratmen_victory;
	$NewThread( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );
	AIRootAgent's "VictoryCondition2" = $ratmen_Events;
	$NewThread( AIRootAgent's "VictoryCondition2", $random_time(210000) );
end

///////////////////////////////////////////////////////////////////////////////
Function Ratmen_victory()

declare
	agent AIRootAgent,palace;
	list palaces,sewers;

begin
	AIRootAgent = $RetrieveAgent("GplAIRoot");

	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	if (AIRootAgent's "Quest_flag_7" == TRUE)
		begin
			// check for the death of Rhoden and all broken sewer mains
//			if (AIRootAgent's "Quest_flag_8" == TRUE) // rhoden is dead if flag 8 is true
			if ($IsTitleAlive(palace,"RhodenKingRat") == FALSE)

				begin
					$listobjects(palace,"Lair",-1,sewers, #CheckTitles, "BrokenSewerMain");
					//sewers = $listtitles(sewers,"BrokenSewerMain");

					if ($listsize(sewers) == 0)
						begin
							$declarevictory(palace);
							$Reset_Quest_Music (AIRootAgent);
							$killthread(AIRootAgent's "VictoryCondition");
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
Function Ratmen_Events()

declare
	agent AIRootAgent,palace,place,bldg;
	list palaces,sewers,stuff,bldgs;
	integer i,i2;

begin
	AIRootAgent = $RetrieveAgent("GplAIRoot");

	palaces = $ListPalaces();
	palace = $listmember(palaces,1);

	$listobjects(palace,"Lair",-1,sewers);
	$listobjects(palace,"AutoBuilding",-1,stuff);
	stuff = $listtitles(stuff,"Sewers");
	sewers = $listtitles(sewers,"BrokenSewerMain");

	sewers = $addlists(stuff,sewers);


	if (AIRootAgent's "Quest_flag_1" == FALSE)
		begin
			// small rat gang from a sewer entrance
			$playsound(palace,"Ratman_king","taunt2");
			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;

			$rat_gang1(place);

			AIRootAgent's "Quest_flag_1" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",$random_time(220000));
		end
  	else
	if (AIRootAgent's "Quest_flag_2" == FALSE)
		begin
			// 2 rat gangs from 2 sewer entrances
			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;

			$rat_gang1(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;

			$rat_gang2(place);

			AIRootAgent's "Quest_flag_2" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",$random_time(220000));
		end
  	else
	if (AIRootAgent's "Quest_flag_3" == FALSE)
		begin
			// 2 rat gangs
			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;

			$rat_gang2(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;

			$rat_gang3(place);

			AIRootAgent's "Quest_flag_3" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",$random_time(360000));
		end
  	else
	if (AIRootAgent's "Quest_flag_4" == FALSE)
		begin
			// ratapults + 3 rat gangs
			$playsound(palace,"Ratman_king","taunt");
			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang2(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang3(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang3(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang4(place);

			AIRootAgent's "Quest_flag_4" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",$random_time(200000));
		end
  	else
	if (AIRootAgent's "Quest_flag_5" == FALSE)
		begin
			// 3 rat gangs
			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang3(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang1(place);

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rat_gang2(place);

			AIRootAgent's "Quest_flag_5" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",$random_time(420000));
		end
  	else
	if (AIRootAgent's "Quest_flag_6" == FALSE)
		begin
//			$playsound(palace,"Ratman_king","VFX_GO_COMBAT");
//			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
//			sewers -= place;
//			$rhoden_gang(place);

			$listobjects(palace,"building",-1,bldgs, #MyPlayer, #ATTRIB_FirstStageBuilt, 1);
			//bldgs = $listcompleted(bldgs);

			bldgs << palace;

			i2 = $listsize(bldgs);

			i = 0;
			while (i < 7) do
				begin
					bldg = $listmember(bldgs,$randomnumber(i2) + 1);
					$minimapanimation(bldg,"Event_beacon");

					$spawnunit(bldg,"BrokensewerMain","maxhp");
					i += 1;
				end

			// rhoden appears with his ratly host (soon)! with extra gangs at other sewers
//			$messageFlag(palace,#message_Rise_ratmen_Rhoden);

			AIRootAgent's "Quest_flag_6" = TRUE;
			$setthreadInterval(AIRootAgent's "VictoryCondition2",5000);
		end
	  	else
	if (AIRootAgent's "Quest_flag_7" == FALSE)
		begin
			// rhoden appears a moment later to make his
			// entrance dramatic!
			$playsound(palace,"Ratman_king","VFX_GO_COMBAT");

			place = $listmember(sewers,$randomnumber($listsize(sewers)) + 1);
			sewers -= place;
			$rhoden_gang(place);

			$messageFlag(palace,#message_Rise_ratmen_Rhoden);
			AIRootAgent's "Quest_Flag_7" = TRUE;
			$killthread(AIRootAgent's "VictoryCondition2");
		end
end

///////////////////////////////////////////////////////////////////////////////
function rat_gang1(agent place)

declare

begin
	$minimapanimation(place,"Event_beacon");
	$SpawnUnit (place, "RatmanChampion", #Monster_player);
	$SpawnUnit (place, "RatmanChampion", #Monster_player);
	$SpawnUnit (place, "RatmanShaman", #Monster_player);
	$SpawnUnit (place, "Ratman", #Monster_player);
	$SpawnUnit (place, "Ratman", #Monster_player);
	$SpawnUnit (place, "Ratman", #Monster_player);
end


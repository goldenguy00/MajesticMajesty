	$spawnunit ( palace, "general_housing", palace ,"MaxHP" );
	$spawnunit ( palace, "general_housing", palace ,"MaxHP" );
	$spawnunit ( palace, "general_housing", palace ,"MaxHP" );
	$spawnunit ( palace, "general_housing", palace ,"MaxHP" );
	$spawnunit ( palace, "general_housing", palace ,"MaxHP" );

end
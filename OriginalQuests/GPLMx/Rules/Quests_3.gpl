///////////////////////////////////////////////////////////////////////////////
function Spire_Spawn_One ( agent ThisAgent )
// This is the first level spire spawn set.
// It generates a standard goblin fort spawn set.
declare
begin
	$Goblin_Spawn ( thisagent );

end

///////////////////////////////////////////////////////////////////////////////
function Spire_Spawn_Two ( agent ThisAgent )
// This is the second level spire spawn set.
// It generates 3-5 Giant spiders and Skeletons each.
declare
	integer spawns, count, rand;

begin
	spawns = ( $RandomNumber ( 3 ) + 3 );
	count = 0;

	while ( count < spawns ) do
	begin
		rand = $RandomNumber ( 3 );
		if ( rand < 2 )
			$SpawnUnit ( thisagent, "Giant_Spider", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Raider ), "override" );
		else
			$SpawnUnit ( thisagent, "Skeleton", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Raider ), "override" );

		count += 1;
	end
end

///////////////////////////////////////////////////////////////////////////////
function Spire_Spawn_Three ( agent thisagent )
// This is the third level spire spawn set.
// It generates 2-4 werewolves and vampires each.
declare
	integer spawns, count, rand;

begin
	spawns = ( $RandomNumber ( 3 ) + 2 );
	count = 0;

	while ( count < spawns ) do
	begin
		rand = $RandomNumber ( 3 );
		if ( rand < 2 )
			$SpawnUnit ( thisagent, "Werewolf", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Raider ), "override" );
		else
			$SpawnUnit ( thisagent, "Vampire", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_PC_Hunter ), "override" );

		count += 1;
	end
end

///////////////////////////////////////////////////////////////////////////////
function Spire_Spawn_Four ( agent thisagent )
// This is the fourth level spire spawn set.
// It generates 12 superbuffed Goblins of random types.

declare
	integer spawns, count, rand;
	agent spawn;

begin
//	spawns = ( $RandomNumber ( 3 ) + 5 );
	spawns = 12;
	count = 0;

	while ( count < spawns ) do
		begin
			rand = $RandomNumber ( 12 );
			if ( rand <= 1 )
				spawn = $SpawnUnit ( thisagent, "GoblinOverlord", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Bomber ), "override" );
			else if ( rand <= 3 )
				spawn = $SpawnUnit ( thisagent, "Goblin_Priest", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Bomber ), "override" );
			else if ( rand <= 5 )
				spawn = $SpawnUnit ( thisagent, "Goblin_Champion", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Bomber ), "override" );
			else if ( rand <= 8 )
				spawn = $SpawnUnit ( thisagent, "Goblin_Archer", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Bomber ), "override" );
			else
				spawn = $SpawnUnit ( thisagent, "Goblin_Fighter", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Bomber ), "override" );

			$SuperBuff ( spawn );
			count += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Spire_Spawn_Five ( agent thisagent )
// This is the fifth level spire spawn set.
// it generates FIVE Yeti & Ice Dragons!!!
declare
	integer spawns, count, rand;

begin
	spawns = 5;
	count = 0;

	while ( count < spawns ) do
		begin
			rand = $RandomNumber ( 3 );
			if ( rand < 2 )
				$SpawnUnit ( thisagent, "Yeti", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Raider ), "override" );
			else
				$SpawnUnit ( thisagent, "IceDragon", thisagent, $Concatenate ( #ATTRIB_Artifice, #Force_Raider ), "override" );

			count += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Set_Spire_Levels ()
// This function sets the spires to their appropriate attack spell and spawn levels.
declare
	agent palace, spire, hero;
	list spires, newspires, tempheroes, heroes;
	integer count, total_level;
	function spawn;
	string gun, prior_gun;

begin
	palace = $GetPlayerOnePalace ();

	// Build spire list.
	$ListObjects ( palace, "Lair", -1, spires, #CheckTitles, "SpireOfDeath", #NotMyPlayer, #NoHiddenMap );

	newspires = spires;

	// Get the total number of spires.
	foreach spire in spires do
		begin
			if ( $IsDead ( spire ))
				newspires -= spire;
		end
	count = $ListSize ( newspires );

	// Track player hero buildup in total levels.
	$ListObjects ( palace, "hero", -1, tempheroes, #MyPlayer, #InsideOtherUnits );

	foreach hero in tempheroes do
		if ( hero's "Subtype" == "hero" )
			begin
				heroes << hero;
				total_level += $GetAttribute ( hero, #ATTRIB_ExperienceLevel );
			end

	// Set the spire level count down by one or two depending on the player's buildup
	// and the current number of spires.
	if (( count == 5 ) || ( count == 4 ))
		begin
			if (( total_level > 40 ) && ( total_level < 70 ))
				count -= 1;
			else if ( total_level >= 70 )
				count -= 2;
		end
	else if (( count == 3 ) || ( count == 2 ))
		begin
			if ( total_level >= 70 )
				count -= 1;
		end

	// Dont set count to less than 0 :)
	if ( count < 1 )
		count = 1;

	$Debugout ( 911, "Total hero levels = ", total_level, " Adjusting spires to level ", count, " to compensate." );

	// Get the new spire values.
	if ( count == 5 )
		begin
			spawn = $Spire_Spawn_One;
			gun = "Spire_Blast_One";
		end
	else
	if ( count == 4 )
		begin
			spawn = $Spire_Spawn_Two;
			gun = "Spire_Blast_Two";
		end
	else
	if ( count == 3 )
		begin
			spawn = $Spire_Spawn_Three;
			gun = "Spire_Blast_Three";
		end
	else
	if ( count == 2 )
		begin
			spawn = $Spire_Spawn_Four;
			gun = "Spire_Blast_Four";
		end
	else
	if ( count == 1 )
		begin
			spawn = $Spire_Spawn_Five;
			gun = "Spire_Blast_Five";
		end
	else
		return;

	// Set the new values on all spires.
	foreach spire in newspires do
		begin
			spire's "Attack_Action" = gun;
			spire's "Spawn_Function" = spawn;
			$debugout ( 911, "Reseting lights NOW!" );
			$SetEffectorDirection ( spire, "Spire_Lights_Effector", ( count - 1 ));
		end
end

///////////////////////////////////////////////////////////////////////////////
Function Spire_Scan ( agent ThisAgent )
// Standard scan for targets.
Declare
	list	Enemies;

Begin
	// Compile list of enemies (if any).
	if ( thisagent's "enemytype" != "nothing" )
		begin
			Enemies = $list_enemies_seen ( thisagent, $getattribute ( ThisAgent, #ATTRIB_SightRange ));
			If ( $ListSize ( Enemies ) > 0 )
				ThisAgent's "ActiveScript" = $Spire_Attack;
		end
End


///////////////////////////////////////////////////////////////////////////////
Function Spire_Attack ( agent ThisAgent )
// Standard firing routine for spires.
Declare
	list	Enemies;

Begin
	// Compile target list.
	enemies = $list_enemies_seen ( thisagent, $getattribute ( ThisAgent, #ATTRIB_SightRange ));
	If ( $ListSize ( Enemies ) > 0 )
		begin
			// Target closest.
			ThisAgent's "Target" = $ListMember ( Enemies, 1 );

			// This calls a special effect to replace the towers attack animation.
			// this is a workaround to allow the tower to 'animate' in its damaged states.
			$CreateEffector ( Thisagent, "Spire_Attack_Effector", 0 );

			// Fire the bolt.
			$PerformAction ( ThisAgent, ThisAgent's "Attack_Action", THisAgent's "Target" );
		end
	Else
		// Switch back to scan if there are no targets.
		ThisAgent's "ActiveScript" = $Spire_Scan;
End

///////////////////////////////////////////////////////////////////////////////
function Spire_Birth ( agent thisagent )
// This is the standard birth script for spires of death.  It takes care of resetting
// their spawn and attack spell levels to ensure that they are always correct.
declare
begin
	$NewThread ( thisagent's "activeScript", #Normal_Cycle, thisagent );
	$CreateEffector ( thisagent, "Spire_Lights_Effector", 1, "infinite" );
	$setattribute ( thisagent, #ATTRIB_HealingRateModifier, 1 );
	$Set_Spire_Levels ();
end

///////////////////////////////////////////////////////////////////////////////
function Spire_Death ( agent thisagent )
// This is the standard deathscript for spires of death.  It forces the dying tower and
// all remaining towers to do an immediate spawn, then resets the towers to their new level.
// It also checks to see if ANY spires are still alive.  If NOT then it will declare victory.
declare
	list spires, newspires;
	agent palace, spire, AIRootAgent;
	integer count;

begin
	palace = $GetPlayerOnePalace ();
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "end_coord" = $LocationOf ( thisagent );

	// build spire list.
	$ListObjects ( palace, "Lair", -1, spires, #CheckTitles, "SpireOfDeath", #NotMyPlayer, #NoHiddenMap );
	newspires = spires;

	// Force all spires to spawn.
  	$Force_Spire_Spawns ();

	// Reset the levels of all spires.
	$Set_Spire_Levels ();

	// Kill this particular spire.
	$Lair_Death ( thisagent );

	foreach spire in spires do
		begin
			if ( $IsDead ( spire ))
				newspires -= spire;
		end

	count = $ListSize ( newspires );

	// If no spires remain, clean up and run victory.
	if ( count < 1 )
		begin
			$KillThread ( AIRootAgent's "SpecialSpawnScript" );
			$KillThread ( AIRootAgent's "SpecialSpawnScript2" );
			$DeclareVictory ( palace, AIRootAgent's "end_coord" );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Force_Spire_Spawns ()
// This is the standard mass spawn function for spires of death.  It forces all
// spires to simultaniously generate their currently set spawn type.
declare
	list spires;
	agent palace, spire;

begin
	palace = $GetPlayerOnePalace ();

	// List all spires.
	$ListObjects ( palace, "Lair", -1, spires, #CheckTitles, "SpireOfDeath", #NotMyPlayer, #NoHiddenMap );

	// Each spire launches its current spawn type.
	foreach spire in spires do
		begin
			spire's "Spawn_Function" ( spire );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Check_Spire_Regeneration ()
// When this script is called, it will spawn a new Spire of Death if there are
// currently less than five on the map.  It will also force ONLY the new spire
// to generate its currently set spawn immediately.
declare
	list spires;
	agent palace, spire;
	integer Spire_Count;

begin
	palace = $GetPlayerOnePalace ();

	$ListObjects ( palace, "Lair", -1, spires, #CheckTitles, "SpireOfDeath", #NotMyPlayer, #NoHiddenMap );

	Spire_Count = $ListSize ( spires );

	// If there are less than five spires, spawn a new one.
	if ( Spire_Count < 5 )
		begin
			spire = $SpawnUnit ( Palace, "SpireOfDeath", $RandomCoord ( Palace, 1000, 4000 ), #Monster_Player, "MAXHP" );

			// Reset the levels of all spires.
			$Set_Spire_Levels ();

			// This spire ONLY launches its own spawn.
			spire's "Spawn_Function" ( spire );
		end
	else
		$Set_Spire_Levels (); // Even if you don't regenerate a spire, reset the spires type anyway
									 // in case the player is doing massive hero buildup.
end



// The Siege Quest entry point
function SIEGE ()
declare
	agent AIRootAgent;
	agent palace, enemypalace;
	list palaces;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "Quest_Number" = #QNumber_Siege;

	palace = $GetPlayerOnePalace ();
	EnemyPalace = $GetPlayerTwoPalace ();

	$Setup_Quest_Music ( AiRootAgent );
	//Start playing music

	// what can't be used in this quest?
	$disableunittype("Wizards_guild1");

	// setup starting messages

	// setup special things

	$SetPlayerTeamNumber ( EnemyPalace, $NewTeamNumber () );
	AIRootAgent's "Permanent_Hostility" = TRUE;

	/////////////////////////////////////////////////////////////////////////
	// TODO: DO NOT LEAVE THIS DEATHMATCH FLAG ON!!! IT'S FOR TESTING ONLY!!!
	// AIRootAgent's "Deathmatch_Rules" = TRUE;
	/////////////////////////////////////////////////////////////////////////

	$Setup_Siege_Routes ();
	$SetEnemyResearch ();
	EnemyPalace's "IGDeathScript" = $Siege_Palace_Death;

	// start all scripts that need to be run

	// VictoryCondition is used to monitor the state of AI placed reward flags
	// and occasionally remove them.
	AIRootAgent's "VictoryCondition" = $Flag_Remover;
	$NewThread ( AIRootAgent's "VictoryCondition", ( $RandomNumber ( 60000 ) + 90000 ));

	// VictoryCondition2 handles the spawning of enemy AI caravans onto the map.
	AIRootAgent's "VictoryCondition2" = $Siege_Route_Spawn;
	$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 30000 ) + 50000 ));

	// SpecialSpawnScript handles the spawning of enemy AI heroes from their guilds.
	AIRootAgent's "SpecialSpawnScript" = $Enemy_Guild_Spawn;
	$NewThread ( AIRootAgent's "SpecialSpawnScript", ( 90000 ));

	// SpecialSpawnScript2 handles enemy AI spell and reward flag actions.
	AIRootAgent's "SpecialSpawnScript2" = $Enemy_Actions;
	$NewThread ( AIRootAgent's "SpecialSpawnScript2", ( 90000 ));

end

///////////////////////////////////////////////////////////////////////////////
function CheckSiegeMessage ()
////////////////////////////////////////////////////////////////////////////////////////
// CheckSiegeMessage resets the mission's victory/defeat counters and produces a message
// on the player's palace to cue them into the enemy's status and give tactical hints.
////////////////////////////////////////////////////////////////////////////////////////
declare
	agent AIRootAgent, palace, enemy_palace;
	integer victory, defeat, total, gold, dif;

begin
	palace = $GetPlayerOnePalace ();
	enemy_palace = $GetPlayerTwoPalace ();
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	victory = AIRootAgent's "Victory_Score"; 	// Number of caravans destroyed.
	defeat = AIRootAgent's "Defeat_Score";		// Number of caravans escaped.
	total = victory + defeat;						// Total number of caravans.
	dif = victory - defeat;							// Effective score.

	if ( $IsDead ( enemy_palace ))
		return;

	gold = $GetPlayerData ( enemy_palace, "gold" );

	$debugout ( 911, "Caravan Count = ", total, " Kill Score = ", dif, " Enemy Gold = ", gold );

	if ( total == 6 ) // Check every 6 caravans.
		begin
			AIRootAgent's "victory_score" = 0;
			AIRootAgent's "defeat_score" = 0;

			if ( dif <= -4 ) //Very poor intercept
				begin
					if ( gold > 40000 ) // Lots of resources
						$messageflag ( palace, #Siege_Status_1A );
					else if ( gold > 250000 ) // Substantial resources
						$messageflag ( palace, #Siege_Status_1B );
					else if ( gold > 10000 ) // Modest resources
						$messageflag ( palace, #Siege_Status_1C );
					else if ( gold <= 10000 ) // Poor resources
						$messageflag ( palace, #Siege_Status_1D );
				end
			else if ( dif <= -2 ) // Poor intercept
				begin
					if ( gold > 40000 ) // Lots of resources
						$messageflag ( palace, #Siege_Status_2A );
					else if ( gold > 25000 ) // Substantial resources
						$messageflag ( palace, #Siege_Status_2B );
					else if ( gold > 10000 ) // Modest resources
						$messageflag ( palace, #Siege_Status_2C );
					else if ( gold <= 10000 ) // Poor resources
						$messageflag ( palace, #Siege_Status_2D );
				end
			else if ( dif <= 0 ) // Modest intercept
				begin
					if ( gold > 40000 ) // Lots of resources
						$messageflag ( palace, #Siege_Status_3A );
					else if ( gold > 25000 ) // Substantial resources
						$messageflag ( palace, #Siege_Status_3B );
					else if ( gold > 10000 ) // Modest resources
						$messageflag ( palace, #Siege_Status_3C );
					else if ( gold <= 10000 ) // Poor resources
						$messageflag ( palace, #Siege_Status_3D );
				end
			else if ( dif <= 2 ) // Good intercept
				begin
					if ( gold > 40000 ) // Lots of resources
						$messageflag ( palace, #Siege_Status_4A );
					else if ( gold > 25000 ) // Substantial resources
						$messageflag ( palace, #Siege_Status_4B );
					else if ( gold > 10000 ) // Modest resources
						$messageflag ( palace, #Siege_Status_4C );
					else if ( gold <= 10000 ) // Poor resources
						$messageflag ( palace, #Siege_Status_4D );
				end
			else if ( dif <= 4 ) // Excellent intercept
				begin
					if ( gold > 40000 ) // Lots of resources
						$messageflag ( palace, #Siege_Status_5A );
					else if ( gold > 25000 ) // Substantial resources
						$messageflag ( palace, #Siege_Status_5B );
					else if ( gold > 10000 ) // Modest resources
						$messageflag ( palace, #Siege_Status_5C );
					else if ( gold <= 10000 ) // Poor resources
						$messageflag ( palace, #Siege_Status_5D );
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function GetPlayerOnePalace () is agent
// Always return's player one's palace.
declare
	list palaces;
	agent palace, temp_palace;

begin
	Palaces = $ListPalaces ();
	//Get the Player 1 palace
	Foreach Temp_Palace in Palaces do
		begin
			If ( $GetUnitPlayerNumber ( Temp_Palace ) == #Player_1 )
		   	Palace = Temp_Palace;
		end
	return palace;
end

///////////////////////////////////////////////////////////////////////////////
function GetPlayerTwoPalace () is agent
// Always return's player two's palace.
declare
	list palaces;
	agent palace, temp_palace;

begin
	Palaces = $ListPalaces ();
	//Get the Player 2 palace
	Foreach Temp_Palace in Palaces do
		begin
			If ( $GetUnitPlayerNumber ( Temp_Palace ) == #Player_2 )
		   	Palace = Temp_Palace;
		end
	return palace;
end

///////////////////////////////////////////////////////////////////////////////
function Flag_Remover ()
// Each time this function runs, it takes the first flag on the AIRootAgent's list
// (the oldest), and checks the status of the agent it is attached to. If that agent is
// in full repair it assumes that it has been unable to attack it effectively and
// removes the flag.
declare
	agent flag, palace, target, AIRootAgent;
	list flags;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	// In SIEGE, the enemy flags are stored on the AIRootAgent.
	flags = AIRootAgent's "AI_Reward_Flags";

	if ( $ListSize ( flags ) > 0 )
		begin
			flag = $ListMember ( flags, 1 );
			if ( $IsValidGamePiece ( flag ))
				begin
					target = $AgentNumber ( $GetAttribute ( flag, #ATTRIB_TargetID ));
					if ( $GetAttribute ( target, #ATTRIB_HP ) == $GetAttribute ( target, #ATTRIB_MaxHP ))
						begin
							$deletegamepiece ( flag );
							AIRootAgent's "AI_Reward_Flags" -= flag;
						end
				end
			else
				AIRootAgent's "AI_Reward_Flags" -= flag;
		end
end

///////////////////////////////////////////////////////////////////////////////
function End_Flag_Remover ()
// This function removes any and all flags active when the game ends.
declare
	agent flag, palace;
	list flags;

begin
	palace = $GetPlayerOnePalace ();

	$ListObjects ( palace, "RewardFlag", -1, flags, #RewardFlags );

	foreach flag in flags do
		begin
			$deletegamepiece ( flag );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Enemy_Guild_Spawn ()
declare
	agent palace, guild, AIRootAgent, enemy_hero;
	list guilds;
	integer members, max_members, gold;
	string type;

begin
	palace = $GetPlayerTwoPalace ();
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	$NewThread ( AIRootAgent's "SpecialSpawnScript", ( 30000 ));

	// build list of guilds.
	$ListObjects ( palace, "Building", -1, Guilds, #MyPlayer, #NoHiddenMap, #CheckSubtypes, "Guild" );

	foreach guild in guilds do // Generate a hero from each guild that needs one, if enough money is available.
		begin
			gold = $GetPlayerData ( palace, "gold" );
			if ( gold > 800 ) // Only spawn if you still have at least 800 gold.
				begin
					members = $ListSize ( guild's "members" );
					max_members = $getattribute ( guild, #ATTRIB_MaxGuildMembers );
					if ( members < max_members ) // Only spawn if there is room in guild.
						begin
							$AdjustPlayerData ( Guild, "gold", -600 ); // Charge 600 per hero spawned.
							Type = Guild's "Member_Title";
							enemy_hero = $SpawnUnit ( Guild, Type, $LocationOf ( guild ));

							$Generate_Character_Attributes ( enemy_hero ); 	// This is necessary for heroes that are not generated
																							// via an interface call.
							gold = $GetPlayerData ( palace, "gold" );
							$DebugOut ( 911, "AI Player #", $GetUnitPlayerNumber ( palace ), " Recruited ", type, ". ", gold, " gold remaining." );
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Enemy_Actions ()
declare
	agent palace, AIRootAgent, flag;
	list flags;
	integer gold;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $GetPlayerTwoPalace ();

	gold = $GetPlayerData ( palace, "gold" );
	$DebugOut ( 911, "Checking for action - AI Player #", $GetUnitPlayerNumber ( palace ), " has ", gold, " gold." );
	$NewThread ( AIRootAgent's "SpecialSpawnScript2", ( $RandomNumber ( 10000 ) + 5000 ));

	if ( gold > 2000 )
		begin // AI player still has money with which to kick your ass.
			if ( $Check_Lightning_Defense ( palace ) == FALSE )
				if ( $Check_Resurrect ( palace ) == FALSE )
					if ( $Check_Heal ( palace ) == FALSE )
						$Post_Enemy_Reward ();
		end
	else
		begin // AI player is out of money and surrenders!!!
			// Declare enemy surrender
			// $messageflag ( palace, #Message_Siege_Victory );
			$minimapanimation ( palace, "Event_beacon" );

			// Declare Peace between sides
			AIRootAgent's "Permanent_Hostility" = FALSE;
			$setplayerteamnumber ( palace, $neutralteamnumber() );

			// Kick off victory
			$SiegeOutOfMoney ();
		end
end

///////////////////////////////////////////////////////////////////////////////
function Check_Lightning_Defense () is boolean
// This function lets a non-player kindgom look for enemy heroes intruding within it's
// wizard's guild cast radius.  It checks the closest enemy, and if it detects a cluster
// of them within range, it will fry them all with a lightning storm. Otherwise it will
// smack the single target with a lightning bolt.

declare
	agent palace, hero, zaptarget, building, guild;
	list enemy_heroes, buildings;
	boolean flag;
	integer gold;

begin

	$Debugout ( 911, "Checking for Lightning Storm." );

	palace = $GetPlayerTwoPalace ();

	// build list of wizguilds.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Wizards_Guild", #MyPlayer, #NoHiddenMap );

	// Check to make sure if you have a valid guild of the level required.
	flag = FALSE;
	if ( $ListSize ( buildings ) > 0 )
		begin
			foreach building in buildings do
				begin
					if ( building's "level" >= 2 )
						begin
							flag = TRUE;
							guild = building;
						end
				end
		end

	// If no valid guild has been found, the function will cease here.
	if ( flag == FALSE )
		return FALSE;

	// Build a list of enemy heroes in range of guild.
	$ListObjects ( guild, "hero", 1200, enemy_heroes, #NotMyPlayer, #NoHiddenMap );

	// Target the closest hero, if any.
	if ( $ListSize ( enemy_heroes ) > 0 )
		begin
			ZapTarget = $ListMember ( enemy_heroes, 1 );
			$ListObjects ( ZapTarget, "hero", 150, enemy_heroes, #MyPlayer, #NoHiddenMap );
			// if there is MORE than one other hero (three total) within storm radius,
			// blast them with a lightning storm.
			if ( $ListSize ( enemy_heroes ) > 1 )
				begin
					$CreateSpellUnit ( guild, "Lightning_Storm", ZapTarget );
					$AdjustPlayerData ( palace, "gold", -1600 );

					gold = $GetPlayerData ( palace, "gold" );
					$DebugOut ( 911, "AI lightning stormed ", ZapTarget, ". ", gold, " gold remaining." );
					return TRUE; // AI may NOT consider another action after throwing storm.
				end
  			else // Otherwise hit the one guy with a lightning bolt instead.
				begin
					if (( $RandomNumber ( 4 ) + 1 ) > 2 )
						begin
							$AdjustPlayerData ( palace, "gold", -400 );
							$lightning_bolt_hit ( ZapTarget );

							gold = $GetPlayerData ( palace, "gold" );
							$DebugOut ( 911, "AI lightning bolted ", ZapTarget, ". ", gold, " gold remaining." );
							Return FALSE; // AI MAY consider another action after throwing a bolt.
						end
				end
		end
	// If the function falls through to here, no valid targets were found.
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function Check_Resurrect () is boolean
// This function lets a non-player kindgom look for friendly dead heroes and evaluate
// them as targets for an agrella resurrect spell.  It will not work if the player
// does not control a level 3 agrella temple. The function will return TRUE if
// it resurrects someone, FALSE otherwise.
declare
	agent palace, hero, restarget, building;
	list heroes, dead_heroes, buildings;
	boolean flag;
	integer gold;

begin

	$Debugout ( 911, "Checking for resurrection." );

	palace = $GetPlayerTwoPalace ();

	// build list of temples.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Temple_Krypta", #MyPlayer, #NoHiddenMap );

	// Make sure a valid level 3 temple is available.
	flag = FALSE;
	if ( $ListSize ( buildings ) > 0 )
		begin
			foreach building in buildings do
				begin
					if ( building's "level" == 3 )
						flag = TRUE;
				end
		end

	// If no valid temple has been found, the function will cease here.
	if ( flag == FALSE )
		return FALSE;

	// Build a list of dead heroes.
	$ListObjects ( palace, "dead", -1, dead_heroes, #MyPlayer, #NoHiddenMap );

	foreach hero in dead_heroes do
		begin
			if ( $IsDead ( hero ) == FALSE )
				dead_heroes -= hero;
		end

	// Sort through the list of dead heroes, choose the highest level dead hero.
	if ( $ListSize ( dead_heroes ) > 0 )
		begin
			ResTarget = $ListMember ( dead_heroes, 1 );
			foreach hero in dead_heroes do
				begin
					if ( $GetAttribute ( hero, #ATTRIB_ExperienceLevel ) > $GetAttribute ( ResTarget, #ATTRIB_ExperienceLevel ))
						ResTarget = hero;
				end
			// If that hero is > level 4, then resurrect him.
			if ( $GetAttribute ( ResTarget, #ATTRIB_ExperienceLevel ) > 4 )
				begin
					$Reanimate_Begin ( ResTarget );
					$AdjustPlayerData ( palace, "gold", -2000 );

					gold = $GetPlayerData ( palace, "gold" );
					$DebugOut ( 911, "AI Resurrected ", ResTarget, ". ", gold, " gold remaining." );
					return TRUE;
				end
		end
	// If the function falls through to here, no valid resurrection target was found.
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function Check_Heal () is boolean
// This function lets a non-player kindgom look for friendly heroes and evaluate
// them as targets for an agrella heal spell.  It will not work if the player
// does not control a level 1 or higher agrella temple. The function will return TRUE if
// it heals someone, FALSE otherwise.
declare
	agent palace, hero, HealTarget, building;
	list heroes, buildings;
	boolean flag;
	integer gold;

begin

	$Debugout ( 911, "Checking for heal." );

	palace = $GetPlayerTwoPalace ();

	// First build a list of temples and make sure at least one level three temple
	// is under the AI player's control.
	$ListObjects ( palace, "building", -1, buildings, #CheckTitles, "Temple_Fervus", #MyPlayer, #NoHiddenMap );

	// If no valid temple has been found, the function will cease here.
	if ( $ListSize ( buildings ) < 1 )
		Return FALSE;

	// Build a list of heroes.
	$ListObjects ( palace, "hero", -1, heroes, #MyPlayer, #NoHiddenMap );

	// Sort through the list of heroes, choose an injured hero.
	if ( $ListSize ( heroes ) > 0 )
		begin
			flag = FALSE;
			foreach hero in heroes do
				begin
					if ( $IsDead ( hero ) == FALSE )
						begin
							if ( $GetAttribute ( hero, #ATTRIB_HP ) < ( $GetAttribute ( hero, #ATTRIB_MaxHP ) * 0.5 ))
								begin
									HealTarget = hero;
									flag = TRUE;
								end
						end
				end
			// If a valid hero was found, heal him.
			if ( flag == TRUE )
				begin
					$Fervus_Heal_Effect ( HealTarget );
					$AdjustPlayerData ( palace, "gold", -400 );

					gold = $GetPlayerData ( palace, "gold" );
					$DebugOut ( 911, "AI Healed ", HealTarget, ". ", gold, " gold remaining." );
					return TRUE;
				end
		end
	// If the function falls through to here, no valid heal target was found.
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function Post_Enemy_Reward () is boolean
// Causes the AI player to decide whether or how to place a reward flag.
declare
	agent palace, target, hero;
	integer random, total_level, avg_level, num_heroes;
	list heroes, tempheroes;


begin
	$Debugout ( 911, "Checking for reward flag targets." );

	palace = $GetPlayerTwoPalace ();

	if ( $CountPlacedFlags ( palace ) < 1 ) // Only consider a flag if none are currently placed.
		begin
			$ListObjects ( palace, "hero", -1, heroes, #CheckSubtypes, "hero", #MyPlayer, #InsideOtherUnits );

			foreach hero in heroes do // Add up the total level of your heroes.
				begin
					total_level += $GetAttribute ( hero, #ATTRIB_ExperienceLevel );
				end

			num_heroes = $ListSize ( heroes );

			$Debugout ( 911, "AI Player has ", num_heroes, " heroes with total level of ", total_level );

			if (( $randomnumber ( 100 ) + 1 ) < total_level ) // Decide if you have enough levels to attack with.
				begin
					random = $RandomNumber ( 3 ) + 1; // Randomly choose a target type and flag it.
					if ( random == 1 )
						$FlagEconomicTarget ( total_level );
					else if ( random == 2 )
						$FlagGuildTarget ( total_level );
					else if ( random == 3 )
						$FlagClosestBuilding ( total_level );

					Return TRUE;
				end
		end
	Return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function CountPlacedFlags ( agent palace ) is integer
// Returns the number of reward flags currently in play belonging to the agent's player.
declare
	list flags;
	integer number;
begin
	$listobjects ( palace, "RewardFlag", -1, flags, #Rewardflags, #Myplayer, #NoHiddenMap );
	number = $ListSize ( flags );
	return number;
end

///////////////////////////////////////////////////////////////////////////////
function FlagEconomicTarget ( integer levels ) is agent
// This function will cause a computer player to place a reward flag on the closest enemy marketplace or trade post.
declare
	agent palace, target, flagtarget, flag, AIRootAgent;
	list t1, t2, targets, buildings;
	integer distance, newdistance, gold;

begin
	$Debugout ( 911, "Flagging Economic Target." );

	palace = $GetPlayerTwoPalace ();

	// Build  a list of all markets and tradeposts.
	$ListObjects ( palace, "building", -1, buildings, #NotMyPlayer );
	t1 = $RemoveTitles ( buildings, "marketplace" );
	t2 = $ListTitles ( buildings, "trading_post" );
	targets = $AddLists ( t1, t2 );

	// Select the closest item on the list.
	if ( $ListSize ( targets ) > 0 )
		begin
			flagtarget = $ListMember ( targets, 1 );
			distance = $DistanceBetweenAgents ( palace, flagtarget );

			foreach target in targets do
				begin
					newdistance = $DistanceBetweenAgents ( palace, target );
					if ( newdistance < distance )
						begin
							flagtarget = target;
							distance = newdistance;
						end
				end

			AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

			// Set the flag value based on the power of the computer player's heroes.
			if ( levels < 30 )
				gold = 100;
			else if ( levels < 45 )
				gold = 200;
			else if ( levels < 55 )
				gold = 300;
			else if ( levels < 65 )
				gold = 400;
			else if ( levels < 75 )
				gold = 500;
			else if ( levels >= 75 )
				gold = 1000;

			// Place the flag if the target is valid.
			if ( $IsValidGamePiece ( flagtarget ))
				flag = $PlaceRewardFlag ( flagtarget, #Player_2, gold );

			if ( flag != $nullagent ())
				AIRootAgent's "AI_Reward_Flags" << flag;

			gold = $GetPlayerData ( palace, "gold" );
			$DebugOut ( 911, "AI Flagged ", flagtarget, ". ", gold, " gold remaining." );
		end
	else
		$DebugOut ( 911, "AI unable to find appropriate flag target." );
end


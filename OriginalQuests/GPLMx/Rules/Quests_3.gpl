///////////////////////////////////////////////////////////////////////////////
// Trade Routes Quest entry point
function TRADE_ROUTES ()
declare
	agent AIRootAgent;
	agent palace;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "Quest_Number" = #QNumber_Trade_Routes;

	palace = $GetPlayerOnePalace ();

	//Start playing music
	$Setup_Quest_Music ( AiRootAgent );

	// what can't be used in this quest?
	$disableunittype ( "Marketplace1" );
	$disableunittype ( "Trading_Post" );

	// setup special things
	$Setup_Trade_Markers ();

	// setup starting messages

	AIRootAgent's "end_coord" = $LocationOf ( palace );

	// start all scripts that need to be run

	// VictoryCondition handles the detection of defeat through loss of the player's market.
	AIRootAgent's "VictoryCondition" = $Check_Market_Defeat;
	$NewThread ( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	// NOTE: VictoryScript2 is reserved for special victory detection attached to events.

	// SpecialSpawnScript handles the spawning of Caravans for this quest.
	AIRootAgent's "SpecialSpawnScript" = $Trade_Route_Spawn;
	$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $RandomNumber ( 30000 ) + 60000 ));

	// SpecialSpawnScript2 handles the standard (nonrandom) event string.
	AIRootAgent's "SpecialSpawnScript2" = $Trade_Route_Standard_Events;
	$NewThread ( AIRootAgent's "SpecialSpawnScript2", ( $RandomNumber ( 60000 ) + 210000 ));

	// NOTE: UtilityScript is reserved for the Strangleweed event spawn script.

end

///////////////////////////////////////////////////////////////////////////////
function Trade_Route_Standard_Events ()
// This function generates a standard string of events during the quest. It is non-random.
declare
	agent AIRootAgent, palace;
begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $GetPlayerOnePalace ();

	if ( AIRootAgent's "Quest_Flag_1" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_One );
			$Trade_Standard_One ();
			AIRootAgent's "Quest_Flag_1" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_2" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Three ); // NOTE: events two and three were swapped,
			$Trade_Standard_Three ();                       // So they appear out of order here.
			AIRootAgent's "Quest_Flag_2" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_3" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Two );
			$Trade_Standard_Two ();
			AIRootAgent's "Quest_Flag_3" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_4" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Four );
			$Trade_Standard_Four ();
			AIRootAgent's "Quest_Flag_4" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_5" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Five );
			$Trade_Standard_Five ();
			AIRootAgent's "Quest_Flag_5" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_6" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Six );
			$Trade_Standard_Six ();
			AIRootAgent's "Quest_Flag_6" = TRUE;
		end
	else if ( AIRootAgent's "Quest_Flag_7" == FALSE )
		begin
			$messageflag ( palace, #Trade_Standard_Seven );
			$Trade_Standard_Seven ();
			AIRootAgent's "Quest_Flag_7" = TRUE;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_One ()
// 8 Hostile rogues and a pair of guilds appear in a map corner.
declare
	agent Palace, guild1, guild2, rogue;
	integer num;

begin
	palace = $GetPlayerOnePalace ();

	// Spawn the guilds.
	guild1 = $SpawnUnit ( Palace, "Rogues_Guild2", $randomcoord ( $farthestmapcorner ( palace ), 1500 ), "MaxHP", #Monster_Player );
	guild2 = $SpawnUnit ( Palace, "Rogues_Guild2", $randomcoord ( $farthestmapcorner ( palace ), 1500 ), "MaxHP", #Monster_Player );

	// Spawn 8 rogues of varying levels near the guilds.
	num = 2;
	while ( num <= 5 ) do
		begin
			rogue = $SpawnUnit ( guild1, "Rogue", guild1, #Monster_Player );
			$advance_to_level ( rogue, num );

			rogue = $SpawnUnit ( guild2, "Rogue", guild2, #Monster_Player );
			$advance_to_level ( rogue, num );

			num += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Two ()
// Howling Hordes spawns a pack of 6 wolves and 2 werewolves.
declare
	coordinate spawnpoint;
	agent palace;
begin
	palace = $GetPlayerOnePalace ();
	spawnpoint = $RandomCoord ( palace, 2000, 2500 );

	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "White_Wolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "Werewolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));
	$SpawnUnit ( palace, "Werewolf", spawnpoint, #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Guardian ));

end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Three ()
// Strangleweed Infestation - This kicks off a continuous script that spawns a strangleweed
// every 8 seconds for the rest of the game.
declare
	agent AIRootAgent;
begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "UtilityScript" = $Spawn_Strangleweed;
	$NewThread ( AIRootAgent's "UtilityScript", 8000 );
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Four ()
// Barbarian Rush - 10 hostile barbarians enter the map and attack.
declare
	agent palace, barbarian;
begin
	palace = $GetPlayerOnePalace ();

	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
	$SpawnUnit ( Palace, "barbarian", $farthestmapedge_OnMap ( palace ), "MaxHP", #Monster_Player );
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Five ()
// Spawn three new Goblin Fort clusters.
declare
	agent palace, fort;
	coordinate coord;
	integer count;
begin
	palace = $GetPlayerOnePalace ();

	count = 1;
	while ( count <= 3 ) do
		begin
			coord = $RandomCoord ( palace, 2000, 3000 );
			fort = $SpawnUnit ( Palace, "GoblinFortress", coord, "MaxHP", #Monster_Player );
			$SpawnUnit ( Palace, "Goblin_Hovel", $RandomCoord ( fort, 200, 300 ), "MaxHP", #Monster_Player );
			$SpawnUnit ( Palace, "Goblin_Hovel", $RandomCoord ( fort, 200, 300 ), "MaxHP", #Monster_Player );
			$SpawnUnit ( Palace, "Goblin_Hovel", $RandomCoord ( fort, 200, 300 ), "MaxHP", #Monster_Player );
			count += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Six ()
// Spawn four daemonwood groves of three trees each.
declare
	agent palace, tree;
	integer count;
	coordinate coord;
begin
	palace = $GetPlayerOnePalace ();

	count = 1;
	while ( count <= 4 ) do
		begin
			coord = $RandomCoord ( palace, 1750, 2250 );
			tree = $SpawnUnit ( Palace, "Daemonwood", coord, #Monster_Player );
			$SpawnUnit ( Palace, "Daemonwood", $RandomCoord ( tree, 300, 500 ), #Monster_Player );
			$SpawnUnit ( Palace, "Daemonwood", $RandomCoord ( tree, 300, 500 ), #Monster_Player );
			count += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Standard_Seven ()
// 5 Rustspitters appear at the head of each trade route.
declare
	agent palace, marker, unit;
	integer count, spitter;

begin
	palace = $GetPlayerOnePalace ();

	count = 1;
	while ( count <= 4 ) do
		begin
			marker = $GetMarker ( count );
			$SpawnUnit ( Palace, "Rust_Spitter", $RandomCoord ( marker, 100, 300 ), #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Caravan_Raider ));
			$SpawnUnit ( Palace, "Rust_Spitter", $RandomCoord ( marker, 100, 300 ), #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Caravan_Raider ));
			$SpawnUnit ( Palace, "Rust_Spitter", $RandomCoord ( marker, 100, 300 ), #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Caravan_Raider ));
			$SpawnUnit ( Palace, "Rust_Spitter", $RandomCoord ( marker, 100, 300 ), #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Caravan_Raider ));
			$SpawnUnit ( Palace, "Rust_Spitter", $RandomCoord ( marker, 100, 300 ), #Monster_Player, $concatenate ( #ATTRIB_Artifice, #Force_Caravan_Raider ));
		  	count += 1;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Spawn_Strangleweed ()
// This places a strangleweed somewhere randomly in a radius around the player's palace.
declare
	coordinate coord;
	agent palace;
begin
	palace = $GetPlayerOnePalace ();
	coord = $RandomCoord ( palace, 1000, 3000 );
	$SpawnUnit ( palace, "Strangleweed", coord, #monster_player );
end

///////////////////////////////////////////////////////////////////////////////
function Check_Market_Defeat ()
// Checks to see if your market place is still standing. If not you lose.
declare
	agent palace;
	list buildings, b1, b2;

begin
	palace = $GetPlayerOnePalace ();

	$ListObjects ( palace, "Building", -1, buildings, #MyPlayer );
	b1 = $RemoveTitles ( buildings, "Marketplace" );
	b2 = $ListTitles ( buildings, "Closed" );
	buildings = $AddLists ( b1, b2 );

	if ( $ListSize ( buildings ) < 1 )
		$Trade_Routes_Defeat ();
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Routes_Victory ()
// Cleans up the event threads before closing out the game.
declare
	agent palace, AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	$KillThread ( AIRootAgent's "VictoryCondition" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );
	$KillThread ( AIRootAgent's "SpecialSpawnScript" );
	$KillThread ( AIRootAgent's "SpecialSpawnScript2" );
	// Note: The strangleweed script is NOT halted, it continues, just for the hell of it.

	palace = $GetPlayerOnePalace ();

	$DeclareVictory ( Palace, AIRootAgent's "end_coord" );
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Routes_Defeat ()
// Player loses.
declare
	agent palace;

begin
	palace = $GetPlayerOnePalace ();

	$DeclareLoss ( Palace );
end

///////////////////////////////////////////////////////////////////////////////
function CheckTradeVictory ()
// Called every time a caravan is lost or reaches market. It totals up the victory & defeat
// values and at certain points can call message or event scripts as a result.
// When you have reached enough caravans to declare victory or defeat, this function will call
// those routines as well.
declare
	agent AIRootAgent, palace;
	integer victory, defeat, total;

begin
	palace = $GetPlayerOnePalace ();
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	victory = AIRootAgent's "Victory_Score";	// How many caravans lived.
	defeat = AIRootAgent's "Defeat_Score";		// How many caravans died.
	total = victory + defeat; 						// How many caravans in all.

////////////////////////////// NOTICE NOTICE NOTICE //////////////////////////////////
// This section here forces certain event types up in order to test the random events.
// Comment it out when not being used for debugging!
//
//	if ( $Magical_Accident ())
//		$messageflag ( palace, #Message_Magical_Accident );
//
//	return;
//
////////////////////////////// NOTICE NOTICE NOTICE //////////////////////////////////

	// Check to make sure we haven't already lost or won.
	if (( AIRootAgent's "VictoryCondition2" == $Trade_Routes_Defeat ) || ( AIRootAgent's "VictoryCondition2" == $Trade_Routes_Victory ))
		return;

	if ( total == 5 ) // First progress check.
		begin
			if ( victory >= 5 )
				begin
					// Best result
					$messageflag ( palace, #Trade_Victory_1A );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Moderate_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 3 )
				begin
					// Good result
					$messageflag ( palace, #Trade_Victory_1B );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Moderate_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 1 )
				begin
					// Poor result
					$messageflag ( palace, #Trade_Victory_1C );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Minor_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else
				begin
					// Pathetic result
					$messageflag ( palace, #Trade_Victory_1D );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Helpful_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
		end
	else if ( total == 11 ) // Second progress check.
		begin
			if ( victory >= 10 )
				begin
					// Best result
					$messageflag ( palace, #Trade_Victory_2A );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Major_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 6 )
				begin
					// Good result
					$messageflag ( palace, #Trade_Victory_2B );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Moderate_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 4 )
				begin
					// Poor result
					$messageflag ( palace, #Trade_Victory_2C );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Minor_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else
				begin
					// Pathetic result
					$messageflag ( palace, #Trade_Victory_2D );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Helpful_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
		end
	else if ( total == 17 ) // Third progress check.
		begin
			if ( victory >= 15 )
				begin
					// Best result
					$messageflag ( palace, #Trade_Victory_3A );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Major_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 9 )
				begin
					// Good result
					$messageflag ( palace, #Trade_Victory_3B );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Major_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 5 )
				begin
					// Poor result
					$messageflag ( palace, #Trade_Victory_3C );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Minor_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else
				begin
					// Pathetic result
					$messageflag ( palace, #Trade_Victory_3D );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Helpful_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
		end
	else if ( total == 23 ) // Fourth progress check.
		begin
			if ( victory >= 20 )
				begin
					// Best result
					$messageflag ( palace, #Trade_Victory_4A );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Major_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 12 )
				begin
					// Good result
					$messageflag ( palace, #Trade_Victory_4B );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Moderate_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else if ( victory >= 6 )
				begin
					// Poor result
					$messageflag ( palace, #Trade_Victory_4C );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Helpful_Event;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 45000 ) + 15000 ));
				end
			else
				begin
					// Pathetic result & Defeat!
					$messageflag ( palace, #Trade_Victory_4D );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Defeat;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
		end
	else if ( total == 29 ) // Fifth and final progress check.
		begin
			if ( victory == 29 )
				begin
					// Perfect Victory!!!
					$messageflag ( palace, #Trade_Victory_5E );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Victory;
					$PlaySound (Palace, "Victory_Theme", "Begin");
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
			else if ( victory >= 25 )
				begin
					// Best result (victory)
					$messageflag ( palace, #Trade_Victory_5A );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Victory;
					$PlaySound (Palace, "Victory_Theme", "Begin");
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
			else if ( victory >= 15 )
				begin
					// Good result (victory)
					$messageflag ( palace, #Trade_Victory_5B );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Victory;
					$PlaySound (Palace, "Victory_Theme", "Begin");
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
			else if ( victory >= 8 )
				begin
					// Poor result (loss)
					$messageflag ( palace, #Trade_Victory_5C );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Defeat;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
			else
				begin
					// Pathetic result (loss)
					$messageflag ( palace, #Trade_Victory_5D );
					AIRootAgent's "VictoryCondition2" = $Trade_Routes_Defeat;
					$NewThread ( AIRootAgent's "VictoryCondition2", ( 15000 ));
				end
		end
	else
		return;
end

///////////////////////////////////////////////////////////////////////////////
Function Trade_Routes_Helpful_Event ()
// This is usually called if the player is doing poorly. It calls a random event that should
// be somewhat helpful to them.
declare
	agent AIRootAgent, palace;
	integer number;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );

	palace = $GetPlayerOnePalace ();

	number = $RandomNumber ( 3 ) + 1;
	$Debugout ( 911, "Doing Event Helpful: ", number );

	if ( number == 1 )
		begin // helpful event one
		 	$messageflag ( palace, #Message_Healing_Wind );
			$Healing_Wind ();
		end
	else if ( number == 2 )
		begin // helpful event two
		 	$messageflag ( palace, #Message_Found_Gold );
			$Found_Gold ();
		end
	else if ( number == 3 )
		begin // helpful event three
		 	$messageflag ( palace, #Message_Wandering_Heroes );
			$Wandering_Heroes ();
		end

//	else if ( number == 4 )
//		begin // helpful event four
//		end

end

///////////////////////////////////////////////////////////////////////////////
Function Trade_Routes_Minor_Event ()
// Creates a minor event, usually slightly deleterious.
declare
	agent AIRootAgent, palace;
	integer number;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );

	palace = $GetPlayerOnePalace ();

	number = $RandomNumber ( 3 ) + 1;
	$Debugout ( 911, "Doing Event Minor: ", number );

	if ( number == 1 )
		begin // minor event one
			$messageflag ( palace, #Message_Housing_Boom );
			$Housing_Boom ();
		end
	else if ( number == 2 )
		begin // minor event two
			$messageflag ( palace, #Message_Bandit_Event );
			$Bandit_Event ();
		end
	else if ( number == 3 )
		begin // minor event three
			$messageflag ( palace, #Message_Plague_Event );
			$Plague_Event ( palace );
		end

//	else if ( number == 4 )
//		begin // minor event four
//		end

end

///////////////////////////////////////////////////////////////////////////////
Function Trade_Routes_Moderate_Event ()
// Creates a moderately dangerous random event.
declare
	agent AIRootAgent, palace;
	integer number;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );

	palace = $GetPlayerOnePalace ();

	number = $RandomNumber ( 4 ) + 1;
	$Debugout ( 911, "Doing Event Moderate: ", number );

	if ( number == 1 )
		begin // moderate event one
			$messageflag ( palace, #Message_Krypta_Curse );
			$Krypta_Curse ( palace );
		end
	else if ( number == 2 )
		begin // moderate event two
			$messageflag ( palace, #Message_Undead_Horde );
			$Undead_Horde ();
		end
	else if ( number == 3 )
		begin // moderate event three
		 	$messageflag ( palace, #Message_Earthquake_Event );
			$Earthquake_Event ( palace );
		end
	else if ( number == 4 )
		begin // moderate event four
			if ( $Magical_Accident ( palace ))
			 	$messageflag ( palace, #Message_Magical_Accident );
		end
end


///////////////////////////////////////////////////////////////////////////////
Function Trade_Routes_Major_Event ()
// Creates a very dangerous random event.
declare
	agent AIRootAgent, palace, marker;
	integer number;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );

	palace = $GetPlayerOnePalace ();

	number = $RandomNumber ( 4 ) + 1;
	$Debugout ( 911, "Doing Event Major: ", number );

	if ( number == 1 )
		begin // major event one
			$messageflag ( palace, #Message_Goblin_Blockade );
			$Goblin_Blockade ();
		end
	else if ( number == 2 )
		begin // major event two
			$messageflag ( palace, #Message_Dragon_Raid );
			$Dragon_Raid ();
		end
	else if ( number == 3 )
		begin // major event three
			$messageflag ( palace, #Message_Treasury_Looted );
			$Treasury_Looted ( palace );
		end
	else if ( number == 4 )
		begin // major event four
			$messageflag ( palace, #Message_Gorgon_Raid );
			$Gorgon_Raid ();
		end
end


///////////////////////////////////////////////////////////////////////////////
Function Setup_Trade_Markers ()
///////////////////////////////////////////////////////////////////////////////////////////
// This function places the signposts that act as trade caravan origins during the mission.
// The caravans will appear from these markers and then proceed into your kingdom.
///////////////////////////////////////////////////////////////////////////////////////////
declare
	list signs;
	agent palace;
	agent sign, sign1, sign2, sign3, sign4;

begin
	palace = $GetPlayerOnePalace ();

	// Find and list each of the signs to be used as trade markers.
	$listobjects ( palace, "color", -1, signs, #NoHiddenMap );
	signs = $listtitles ( signs, "sign_fancy_iron" );
	sign1 = $listmember ( signs, 1 );
	sign2 = $listmember ( signs, 2 );
	sign3 = $listmember ( signs, 3 );
	sign4 = $listmember ( signs, 4 );

	// Set the text for each of the signs.
	$post_message ( sign1, #Sign_Trade_Marker_One );
	$post_message ( sign2, #Sign_Trade_Marker_Two );
	$post_message ( sign3, #Sign_Trade_Marker_Three );
	$post_message ( sign4, #Sign_Trade_Marker_Four );

	// Reveal the area around each of the signs.
	$RevealArea ( palace, $LocationOf ( sign1 ), 300 );
	$RevealArea ( palace, $LocationOf ( sign2 ), 300 );
	$RevealArea ( palace, $LocationOf ( sign3 ), 300 );
	$RevealArea ( palace, $LocationOf ( sign4 ), 300 );

	// Place a message flag on each sign.
	$messageflag ( sign1, #Message_Marker_One );
	$messageflag ( sign2, #Message_Marker_Two );
	$messageflag ( sign3, #Message_Marker_Three );
	$messageflag ( sign4, #Message_Marker_Four );

	// Set up a unique title for each of the trade markers so they can be quickly
	// found later on.
	sign1's "title" = "Trade_Marker_One";
	sign2's "title" = "Trade_Marker_Two";
	sign3's "title" = "Trade_Marker_Three";
	sign4's "title" = "Trade_Marker_Four";

end

///////////////////////////////////////////////////////////////////////////////
function GetMarker ( integer number ) is agent
// This function returns the appropriate trade marker for quick reference.
declare
	string title;
	list signs;
	agent marker, palace;

begin
	// Get the appropriate title string for the trade marker.
	if ( number == 1 )
		title = "Trade_Marker_One";
	else
	if ( number == 2 )
		title = "Trade_Marker_Two";
	else
	if ( number == 3 )
		title = "Trade_Marker_Three";
	else
	if ( number == 4 )
		title = "Trade_Marker_Four";
	else
		begin
			$Debugout ( 911, "GetMarkerTitle was passed an invalid value." );
			return;
		end

	palace = $GetPlayerOnePalace ();

	// Find and return the agent in question.
	$listobjects ( palace, "color", -1, signs, #checktitles, title, #NoHiddenMap );
	marker = $listmember ( signs, 1 );

	return marker;
end

///////////////////////////////////////////////////////////////////////////////
function Trade_Route_Spawn ()
// Launch a trade caravan every 1 to 1 1/2 days, with a 20% chance of
// launching 2 simultaniously.
declare
	integer number;
	agent AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $RandomNumber ( 30000 ) + 60000 ));

	$Create_Trade_Caravan ();

	number = $RandomNumber ( 5 ) + 1;
	if ( number == 5 )
		$Create_Trade_Caravan ();

end

///////////////////////////////////////////////////////////////////////////////
function Create_Trade_Caravan ()
// Generates a trade caravan randomly from one of the preset trade markers.
declare
	agent marker;
	coordinate spawnpoint;
	integer number, xcoord, ycoord;

begin
	// Choose which trade marker its coming from.
	number = $RandomNumber ( 4 ) + 1;
	marker = $GetMarker ( number );

	// Set its spawnpoint to the edge nearest the marker.
	spawnpoint = $ClosestMapEdge ( marker );
	xcoord = $GetX ( spawnpoint );
	ycoord = $GetY ( spawnpoint );

	// offset the caravan's spawnpoint somewhat to help randomize its route.
	if ( xcoord < 100 || xcoord > 8000 )
		ycoord = ycoord + ( $RandomNumber ( 640 ) - 320 );
	else
	if ( ycoord < 100 || ycoord > 8000 )
		xcoord = xcoord + ( $RandomNumber ( 640 ) - 320 );

	Spawnpoint = $MakeCoord ( xcoord, ycoord );

	// Generate the caravan.
	$SpawnUnit ( marker, "Caravan", spawnpoint );

	// Set off an event beacon to indicate its entrance to the player.
	$minimapanimation ( spawnpoint, "Event_beacon" );

end


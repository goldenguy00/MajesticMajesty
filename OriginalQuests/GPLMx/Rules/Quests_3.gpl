///////////////////////////////////////////////////////////////////////////////
function SetEnemyResearch ()
// This function sets the research levels for all of the enemy city buildings at startup.
declare
	list buildings, current;
	agent building, palace;

begin
	$Debugout ( 911, "Setting enemy research levels." );

	palace = $GetPlayerTwoPalace ();

	$ListObjects ( palace, "building", -1, buildings, #MyPlayer, #NoHiddenMap );

	// Set blacksmith research.
	current = $RemoveTitles ( buildings, "blacksmith" );

	foreach building in current do
		begin
			$SetAttribute ( building, #ATTRIB_ResearchArmorLevel_2, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchArmorLevel_3, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchArmorLevel_4, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchWeaponLevel_2, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchWeaponLevel_3, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchWeaponLevel_4, 1 );
		end

	// Set marketplace research.
	current = $RemoveTitles ( buildings, "marketplace" );

	foreach building in current do
		begin
			$SetAttribute ( building, #ATTRIB_ResearchHealingPotions, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchRingsOfProtection, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchPowerfulItem, 1 ); // this is the amulet. :P
		end


	// Set magic bazaar research.
	current = $RemoveTitles ( buildings, "Magic_Bazaar" );

	foreach building in current do
		begin
			$SetAttribute ( building, #ATTRIB_ResearchBazaar_Item_One, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchBazaar_Item_Two, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchBazaar_Item_Three, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchBazaar_Item_Four, 1 );
		end

	// Set guardhouse research.
	current = $RemoveTitles ( buildings, "guardhouse" );

	foreach building in current do
		begin
			$SetAttribute ( building, #ATTRIB_ResearchArrows, 1 );
			$SetAttribute ( building, #ATTRIB_ResearchGoodGuard, 1 );
		end

	// Set fairgrounds research and activate the building.
	current = $RemoveTitles ( buildings, "fairgrounds" );

	foreach building in current do
		begin
			$SetAttribute ( building, #ATTRIB_ResearchTournament, 1 );
			$SetAttribute ( building, #ATTRIB_CurrentEvent, 4 );
		end


	// Set library research
//	current = $ListTitles ( buildings, "library" );
//
//	foreach building in current do
//		begin
//			$SetAttribute ( building, #ATTRIB_ResearchTrainIntelligence, 1 );
//			$SetAttribute ( building, #ATTRIB_ResearchMagicResistance, 1 );
//			$SetAttribute ( building, #ATTRIB_ResearchWizardFireBlast_4, 1 );
//			$SetAttribute ( building, #ATTRIB_ResearchWizardMeteorStorm, 1 );
//			$SetAttribute ( building, #ATTRIB_ResearchEnergyBlast, 1 );
//			$SetAttribute ( building, #ATTRIB_ResearchFireShield, 1 );
//		end


end

///////////////////////////////////////////////////////////////////////////////
Function Setup_Siege_Routes ()
///////////////////////////////////////////////////////////////////////////////////////////
// This function places the signposts that act as trade caravan origins during the mission.
// The caravans will appear from these markers and then proceed into your kingdom.
///////////////////////////////////////////////////////////////////////////////////////////
declare
	list markers, targets;
	agent palace, player_palace, target;
	agent marker, marker1, marker2, marker3, marker4;

begin
	$Debugout ( 911, "Setting up siege routes." );

	palace = $GetPlayerTwoPalace ();
	player_palace = $GetPlayerOnePalace ();

	// Find and list each of the signs to be used as trade markers.
	$listobjects ( palace, "color", -1, markers, #NoHiddenMap );

	$Debugout ( 911, "Goblin markers: ", markers );

	markers = $listtitles ( markers, "Siege_Marker" );
	marker1 = $listmember ( markers, 1 );
	marker2 = $listmember ( markers, 2 );
	marker3 = $listmember ( markers, 3 );
	marker4 = $listmember ( markers, 4 );

	// Reveal the area around each of the markers to the computer player.

	$RevealArea ( palace, $LocationOf ( marker1 ), 300 );
	$RevealArea ( palace, $LocationOf ( marker2 ), 300 );
	$RevealArea ( palace, $LocationOf ( marker3 ), 300 );
	$RevealArea ( palace, $LocationOf ( marker4 ), 300 );

	// Set up a unique title for each of the trade markers so they can be quickly
	// found later on.
	marker1's "title" = "Siege_Marker_One";
	marker2's "title" = "Siege_Marker_Two";
	marker3's "title" = "Siege_Marker_Three";
	marker4's "title" = "Siege_Marker_Four";

	// Identify the closest player building to the computer so it can get things
	// moving early on.
	$ListObjects ( palace, "building", -1, targets, #NotMyPlayer, #NoHiddenMap );
	target = $ListMember ( targets, 1 );
   $RevealArea ( palace, $LocationOf( target ), 300 );

end

function GetSiegeMarker ( integer number ) is agent
// This function returns the appropriate trade marker for quick reference.
declare
	string title;
	list signs;
	agent marker, sign, palace;

begin
	if ( number == 1 )
		title = "Siege_Marker_One";
	else
	if ( number == 2 )
		title = "Siege_Marker_Two";
	else
	if ( number == 3 )
		title = "Siege_Marker_Three";
	else
	if ( number == 4 )
		title = "Siege_Marker_Four";
	else
		begin
			$Debugout ( 911, "GetMarkerTitle was passed an invalid value." );
			return;
		end

	palace = $GetPlayerTwoPalace ();

	$listobjects ( palace, "color", -1, signs, #NoHiddenMap );
	signs = $listtitles ( signs, title );
	marker = $listmember ( signs, 1 );

	return marker;
end

///////////////////////////////////////////////////////////////////////////////
function Siege_Route_Spawn ()
// Launch a trade caravan, with a 25% chance of launching 2 simultaniously.
declare
	integer number;
	agent AIRootAgent, palace;
	list markets;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	$NewThread ( AIRootAgent's "VictoryCondition2", ( $RandomNumber ( 30000 ) + 60000 ));

	palace = $GetPlayerTwoPalace ();

	$ListObjects ( palace, "building", -1, markets, #CheckTitles, "Marketplace", #MyPlayer );
	if ( $ListSize ( markets ) < 1 )
		begin
			$KillThread ( AIRootAgent's "VictoryCondition2" );
			return;
		end

	$Create_Siege_Caravan ();

	number = $RandomNumber ( 4 ) + 1;
	if ( number == 4 )
		$Create_Siege_Caravan ();

end

///////////////////////////////////////////////////////////////////////////////
function Create_Siege_Caravan ()
// Generates a trade caravan randomly from one of the preset trade markers.
declare
	agent marker, caravan, possible, palace;
	coordinate spawnpoint;
	integer number, xcoord, ycoord;
	list caravans;
	boolean flag;

begin
	palace = $GetPlayerOnePalace ();

	// Choose which trade marker its coming from.
	number = $RandomNumber ( 4 ) + 1;
	marker = $GetSiegeMarker ( number );

	// Set its spawnpoint to the edge nearest the marker.
	spawnpoint = $ClosestMapEdge ( marker );
	xcoord = $GetX ( spawnpoint );
	ycoord = $GetY ( spawnpoint );

	// offset the caravan's spawnpoint somewhat.
	if ( xcoord < 100 || xcoord > 8000 )
		ycoord = ycoord + ( $RandomNumber ( 640 ) - 320 );
	else
	if ( ycoord < 100 || ycoord > 8000 )
		xcoord = xcoord + ( $RandomNumber ( 640 ) - 320 );

	Spawnpoint = $MakeCoord ( xcoord, ycoord );

	Caravan = $SpawnUnit ( marker, "Caravan", spawnpoint );
	$SetAttribute ( caravan, #ATTRIB_MaxHP, ( $GetAttribute ( caravan, #ATTRIB_MaxHP ) * 2 ));
	$SetAttribute ( caravan, #ATTRIB_HP, $GetAttribute ( caravan, #ATTRIB_MaxHP ));

	// This section sets off an event beacon ONLY if the player can see the caravan at
	// its time of spawning.
	flag = FALSE;
	$ListObjects ( Palace, "hero", -1, caravans, #CheckTitles, "Caravan" );
	foreach possible in caravans do
		begin
			if ( possible == caravan )
				$minimapanimation ( $LocationOf ( caravan ), "Event_beacon" );
		end

end

///////////////////////////////////////////////////////////////////////////////
function Siege_Palace_Death ( agent ThisAgent )
// This function handles the special death routine for the evil palace in the siege mission.
// This is overwritten onto the evil palace at the start of the mission, to allow the normal data
// structure for the palace to be reusable later on if it becomes a full player building variant.
declare
	agent AIRootAgent;
	integer gold;
	list flags;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	AIRootAgent's "Permanent_Hostility" = FALSE;
	AIRootAgent's "End_Coord" = $LocationOf ( thisagent );

  	thisagent's "type" = "Dead";

	$Dump_Contained_Units (ThisAgent);
	//$release_occupants ( thisagent );

	$performaction ( thisagent, "Become_Rubble", thisagent );

	gold = $getplayerdata ( thisagent, "gold" );
	$adjustplayerdata ( thisagent, "gold", 0 - gold );
	$dropgoldeveryone ( thisagent, gold );

	$deleteagent ( thisagent );

	$Siege_Victory ();
end

///////////////////////////////////////////////////////////////////////////////
Function SiegeOutOfMoney ()
declare
	agent enemy_palace;

begin
	enemy_palace = $GetPlayerTwoPalace ();

	$setattribute ( enemy_palace, #ATTRIB_HP, -50 );
end

///////////////////////////////////////////////////////////////////////////////
Function Siege_victory ()
// This function ends the game.
declare
	agent palace, AIRootAgent;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $GetPlayerOnePalace ();

	// Clean up all the continuous support threads.
	$KillThread ( AIRootAgent's "VictoryCondition" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );
	$KillThread ( AIRootAgent's "SpecialSpawnScript" );
	$KillThread ( AIRootAgent's "SpecialSpawnScript2" );

	$End_Flag_Remover ();

	$DeclareVictory ( palace, AIRootAgent's "end_coord" );
end



////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////
// The Fortress of Ixmil Quest entry point
function FORTRESS_IXMIL ()
declare
	agent AIRootAgent;
	agent palace;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "Quest_Number" = #QNumber_Fortress_Ixmil;

	palace = $GetPlayerOnePalace ();

	$Setup_Quest_Music ( AiRootAgent );

	//Start playing music

	// what can't be used in this quest?

	// setup starting messages

	// setup special things
	AIRootAgent's "Quest_Flag_1" = TRUE; 	// Quest flag one tracks whether or not the Fortress
														// is phased in or out. FALSE means it is phased out.

	AIRootAgent's "Quest_Flag_2" = TRUE;	// These flags indicate that light and medium spawn waves
	AIRootAgent's "Quest_Flag_3" = TRUE;   // (respectively) have not gone off yet.

	AIRootAgent's "day_counter" = 0;
	AIRootAgent's "victory_score" = 4;

	// defeat_score is being used to track multiple-jump logic and moderate wave strengths
	// during and after such events.  It is pretty complex, so I'll outline it here.
	// - defeat_score is always modified in the Warp In/Out functions.
	// - If the Warp function enters with a 0 value, it will do a normal warp sequence and
	// spawn, OR randomly decide to kick off a multi-warp sequence by setting the value to a
	// positive number (representing the number of jumps).
	// - If the Warp function enters with a > 1 value, it will do a super short warp
	// with a reduced strength spawn. (actually, any non-zero value will cause the spawn system
	// to reduce its strength) and iterate downward one.
	// - If the Warp In function enters with a value of 1, it will do a fast warp and reduced spawn,
	// but will then warp out and stay warped out for an extended period.  The value is set to -1.
	// - If the Warp In function enters with a value of -1, it will do a normal warp, but will still
	// use the reduced spawn values.

	AIRootAgent's "defeat_score" = -1;


	$Set_Up_Fortress ();
	$Fortress_Ixmil_Warp_Engine ();

	// start all scripts that need to be run
	// AIRootAgent's "VictoryCondition" = $Fortress_Ixmil_Victory;
	// $NewThread ( AIRootAgent's "VictoryCondition", #VictoryCondition_callback_frequency );

	AIRootAgent's "VictoryCondition2" = $day_counter;
	$NewThread ( AIRootAgent's "VictoryCondition2", 60000 );

	AIRootAgent's "SpecialSpawnScript" = $Fortress_Ixmil_Warp_Engine;
	$NewThread ( AIRootAgent's "SpecialSpawnScript", 240000 );

	// AIRootAgent's "SpecialSpawnScript2" = $Enemy_Actions;
	// $NewThread ( AIRootAgent's "SpecialSpawnScript2", ( 90000 ));

end

///////////////////////////////////////////////////////////////////////////////
function Set_Up_Fortress ()
// Does the GPL setup necessary for the Fortress and subsidiary systems.
declare
	list markers, lairs;
	agent palace, fortress, marker;

begin
	$Debugout ( 911, "Setting up Fortress." );

	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap, #InsideOtherUnits );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	// Find and list the sign to be used as the fortress marker.
	$listobjects ( palace, "color", -1, markers, #NoHiddenMap );

	$Debugout ( 911, "Fortress marker: ", markers );

	markers = $listtitles ( markers, "obelisk" );
	marker = $listmember ( markers, 1 );
	$post_message ( marker, #Sign_Fortress_Ixmil_Marker );

	// Set up a unique title for the fortress' marker
	marker's "title" = "Fortress_Marker";

	// Set the fortress' basic repair rate.
	$setattribute ( fortress, #ATTRIB_HealingRateModifier, 4 );
	fortress's "IGDeathScript" = $Fortress_Death;

end

///////////////////////////////////////////////////////////////////////////////
function Fortress_Active ( agent thisagent )
// This is the spire activescript.  It handles the attack spell targetting.
declare
	list	enemies;

Begin
	if ( thisagent's "enemytype" != "nothing" )
		begin
			Enemies = $list_enemies_seen ( thisagent, $getattribute ( ThisAgent, #ATTRIB_SightRange ));
			If ( $ListSize ( Enemies ) > 0 )
				ThisAgent's "ActiveScript" = $Ixmil_Attack;
		end
end

///////////////////////////////////////////////////////////////////////////////
function Fortress_Ixmil_Warp_Engine ()
// This function causes the Fortress of Ixmil to warp in or out respectively, depending on its
// current status.  It will then call other event or spawn routines as appropriate.

declare
	agent AIRootAgent, palace, fortress, marker;
	list lairs, markers;
	coordinate coord;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap, #InsideOtherUnits );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	if ( $IsDead ( fortress ) == TRUE )
		return;

	if ( AIRootAgent's "Quest_Flag_1" == FALSE )
		begin
			// Check to see if fortress should start a multi-jump sequence.
			if ( AIRootAgent's "defeat_score" == 0 )
				if ( $RandomNumber ( 4 ) < 1 )
					AIRootAgent's "defeat_score" = 3;

			// Find a location and warp the fortress onto the map.
			AIRootAgent's "Quest_Flag_1" = TRUE;
			coord = $RandomCoord ( palace, 1000, 4500 );
			$Unhide ( fortress, coord );

			$createeffector ( fortress, "Ixmil_Teleport_In_Effector", 7250 );
			$FadeIn ( fortress, 700 );
			$adjustattribute ( fortress, #ATTRIB_HealingRateModifier, 3 );

			// Spawn all the fortress critters.
			$Fortress_Ixmil_Spawn ();

			// Don't spawn a grove during a multi-jump sequence.
			if ( AIRootAgent's "defeat_score" < 1 )
				$Spawn_Fortress_Grove ();

			// Activate the main gun.
			$NewThread ( fortress's "ActiveScript", 500, fortress );

			// Reveal the fortress to the player.
			$RevealArea ( palace, coord, 300 );
			$MiniMapAnimation ( fortress, "Event_beacon" );

			$debugout ( 911, "Fortress Warping In. Sequence Value = ", AIRootAgent's "defeat_score" );

			if ( AIRootAgent's "defeat_score" == -1 )
				AIRootAgent's "defeat_score" = 0;

			// This handles the multi-jump countdown.
			if ( AIRootAgent's "defeat_score" > 0 )
				begin
					if ( AIRootAgent's "defeat_score" == 1 )
						AIRootAgent's "defeat_score" = -1; // Negative one forces the fortress to 'rest' for a while and
					else                                  // avoids double jeapordy with the jump sequence.
						AIRootAgent's "defeat_score" -= 1;

					$NewThread ( AIRootAgent's "SpecialSpawnScript", ( 10000 ));
				end
			else
				$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $RandomNumber ( 90000 ) + 90000 ));
		end
	else
		begin
			// Turn off the main gun while hidden.
			$KillThread ( fortress's "ActiveScript" );
			$createeffector ( fortress, "Ixmil_Teleport_Out_Effector", 7250 );
			$FadeOut ( fortress, 700 );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Warp_Out ( agent fortress )
declare
	agent AIRootAgent, palace, marker;
	list markers;
	integer hits, max_hits, diff;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $GetPlayerOnePalace ();

	// Find the marker.
	$listobjects ( palace, "color", -1, markers, #NoHiddenMap );
	markers = $listtitles ( markers, "Fortress_Marker" );
	marker = $ListMember ( markers, 1 );

	if ( $isdead( fortress ))
		return;

	// Warp the fortress into the marker, bump up its repair rate.
	$hide ( fortress, marker, #TeleportInsideDestination );
	$Wither_Fortress_Grove ();
	AIRootAgent's "Quest_Flag_1" = FALSE;
	$adjustattribute ( fortress, #ATTRIB_HealingRateModifier, -3 );

	// Fortress heals half its damage instantly if it is significantly damaged.
	max_hits = $getattribute ( fortress, #ATTRIB_MaxHP );
	hits = $getattribute ( fortress, #ATTRIB_HP );
	diff = max_hits - hits;
	if ( diff > 90 )
		begin
			hits = hits + ( diff / 2 );
			$setattribute ( fortress, #ATTRIB_HP, hits);
		end

	// Set the victory score to act as the delay counter for the fortresses next appearance.
	AIRootAgent's "Victory_Score" = AIRootAgent's "day_counter";

	// Determine how long it will be till the fortresses next appearance.
	// Check for various multi-jump behaviors.
	$debugout ( 911, "Fortress Warping Out. Sequence Value = ", AIRootAgent's "defeat_score" );

	if ( AIRootAgent's "defeat_score" > 0 )
		$NewThread ( AIRootAgent's "SpecialSpawnScript", ( 6000 ));
	else
		begin
			if ( AIRootAgent's "defeat_score" == 0 )
				$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $RandomNumber ( 90000 ) + 120000 ));
			else if ( AIRootAgent's "defeat_score" == -1 )
				begin
					$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $RandomNumber ( 90000 ) + 210000 ));
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Day_Counter ()
// This function simply keeps track of the elapsed number of days during a quest.
// The number is stored on the rootagent.
declare
	agent AIRootAgent;
begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	AIRootAgent's "day_counter" += 1;
end

///////////////////////////////////////////////////////////////////////////////
function Fortress_Ixmil_Spawn ()
// This function spawns the main attack wave each time the fortress appears on the map.
declare
	integer random, base_value, day_modifier, delay_modifier;
	agent AIRootAgent;

begin

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	day_modifier = AIRootAgent's "day_counter";
	delay_modifier = day_modifier - AIRootAgent's "victory_score";

	// The random effect that determines the type of spawn generated is modestly increased
	// by the total number of days elapsed, while the number of days since the fortress
	// last appeared has a more drastic effect on the spawn.  Thus, if the fortress is
	// gone for a long period of time, the next spawn is likely to be more dangerous.

	random = ( $RandomNumber ( 30 ) + ( day_modifier * 1 ) + ( delay_modifier * 2 ));

	$debugout ( 911, "Day modifier = +", ( day_modifier * 1 ), " Delay modifier = +", ( delay_modifier * 2 ));
	$Debugout ( 911, "Spawn level Random = ", random );

	// Tone down wave type if fortress is multi-jumping.
	if ( AIRootAgent's "defeat_score" != 0 )
		random *= 0.7;

	// Randomly determines the wave type based on the modified random roll. Note that the light and
	// medium waves are GUARANTEED to run the first time the roll indicates that wave type or higher.
	if ( random < 31 || AIRootAgent's "Quest_Flag_2" )
		begin
			$Fortress_Ixmil_Spawn_Light ();
			AIRootAgent's "Quest_Flag_2" = FALSE;
		end
	else if ( random < 60 || AIRootAgent's "Quest_Flag_3" )
		begin
			$Fortress_Ixmil_Spawn_Moderate ();
			AIRootAgent's "Quest_Flag_3" = FALSE;
		end
	else
		begin
			$Fortress_Ixmil_Spawn_Heavy ();
		end
end

///////////////////////////////////////////////////////////////////////////////
Function Fortress_Ixmil_Spawn_Light ()
declare
	agent fortress, palace, AIRootAgent, monster;
	integer random, day_modifier, delay_modifier, spawns, spawn_number;
	float spawnpower;
	list lairs;

begin
  	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	day_modifier = AIRootAgent's "day_counter";  // How many days have passed total.
	delay_modifier = day_modifier - AIRootAgent's "victory_score";  // How many days have passed since last appearance.

 	// Determine the random number of spawns that will occur.  Modify lightly for days elapsed,
	// and modify heavily for the delay since the fortress's last appearance.

	SpawnPower = $RandomNumber ( 100 );
	SpawnPower = SpawnPower + ( 20 + ( day_modifier * 2 ) + ( delay_modifier * 8 ));
	SpawnPower = SpawnPower / 100.0;

	// Tone down wave type if fortress is multi-jumping.
	if ( AIRootAgent's "defeat_score" != 0 )
		SpawnPower *= 0.7;

	if ( SpawnPower > 2 )
		SpawnPower = 2;

	$Debugout ( 911, "Spawnpower = ", spawnpower );

	// Determine which spawnwave will occur.
	random = ( $RandomNumber ( 100 ) + 1 );

	if ( random < 50 )
		begin
			spawns = 12.0 * SpawnPower;  // Determines how MANY spawns will occur.
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					random = ( $RandomNumber ( 100 ) + 1 ); // Determine which creature is spawned.
					if ( random < 60 )
						$SpawnUnit ( fortress, "Zombie", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else if ( random < 92 )
						$SpawnUnit ( fortress, "Skeleton", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else
						$SpawnUnit ( fortress, "Vampire", fortress, #monster_player );

					spawn_number += 1;
				end
		end
	else
	  	begin
			spawns = 9.0 * SpawnPower;
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					random = ( $RandomNumber ( 100 ) + 1 );
					if ( random < 40 )
						$SpawnUnit ( fortress, "Ratman", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else if ( random < 65 )
						$SpawnUnit ( fortress, "RatmanShaman", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else if ( random < 90 )
						$SpawnUnit ( fortress, "RatmanChampion", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else
						$SpawnUnit ( fortress, "RatmanCatapult", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));

					spawn_number += 1;
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
Function Fortress_Ixmil_Spawn_Moderate ()
declare
	agent fortress, palace, AIRootAgent;
	integer random, day_modifier, delay_modifier, spawns, spawn_number;
	float spawnpower;
	list lairs;

begin
  	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	day_modifier = AIRootAgent's "day_counter";
	delay_modifier = day_modifier - AIRootAgent's "victory_score";


 	// Determine the random number of spawns that will occur.  Modify for days elapsed,
	// and modify for the delay since the fortresses last appearance.

	SpawnPower = $RandomNumber ( 100 );
	SpawnPower = SpawnPower + ( 20 + ( day_modifier * 2 ) + ( delay_modifier * 10 ));
	SpawnPower = SpawnPower / 100.0;

	// Tone down wave type if fortress is multi-jumping.
	if ( AIRootAgent's "defeat_score" != 0 )
		SpawnPower *= 0.7;

	if ( SpawnPower > 2 )
		SpawnPower = 2;

	$Debugout ( 911, "Spawnpower = ", spawnpower );

	// Determine which spawnwave will occur.
	random = ( $RandomNumber ( 100 ) + 1 );

	if ( random < 50 )
		begin
			spawns = 16.0 * SpawnPower;
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					random = ( $RandomNumber ( 100 ) + 1 );
					if ( random < 50 )
						$SpawnUnit ( fortress, "ShadowBeast", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_bomber ));
					else
						$SpawnUnit ( fortress, "Rust_Spitter", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));

					spawn_number += 1;
				end
		end
	else
	  	begin
			spawns = 9.0 * SpawnPower;
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					$SpawnUnit ( fortress, "Minotaur", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_bomber ));

					spawn_number += 1;
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Fortress_Ixmil_Spawn_Heavy ()
declare
	agent fortress, palace, AIRootAgent;
	integer random, day_modifier, delay_modifier, spawns, spawn_number;
	float spawnpower;
	list lairs;

begin
  	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	day_modifier = AIRootAgent's "day_counter";
	delay_modifier = day_modifier - AIRootAgent's "victory_score";


	// Determine the random number of spawns that will occur.  Modify for days elapsed,
	// and modify for the delay since the fortresses last appearance.

	SpawnPower = $RandomNumber ( 100 );
	SpawnPower = SpawnPower + ( 20 + ( day_modifier * 2 ) + ( delay_modifier * 10 ));
	SpawnPower = SpawnPower / 100.0;

	// Tone down wave type if fortress is multi-jumping.
	if ( AIRootAgent's "defeat_score" != 0 )
		SpawnPower *= 0.7;


	if ( SpawnPower > 2 )
		SpawnPower = 2;

	$Debugout ( 911, "Spawnpower = ", spawnpower );

	// Determine which spawnwave will occur.
	random = ( $RandomNumber ( 100 ) + 1 );

	if ( random < 50 )
		begin
			spawns = 6.0 * SpawnPower;
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					random = ( $RandomNumber ( 100 ) + 1 );
					if ( random < 50 )
		  				$SpawnUnit ( fortress, "Rock_Golem", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else
						$SpawnUnit ( fortress, "Evil_Oculus", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));

					spawn_number += 1;
				end
		end
	else
	  	begin
			spawns = 6.0 * SpawnPower;
			$Debugout ( 911, "Spawns = ", spawns );

			while ( spawn_number < spawns ) do
				begin
					random = ( $RandomNumber ( 100 ) + 1 );
					if ( random < 50 )
						$SpawnUnit ( fortress, "GreaterGorgon", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));
					else
						$SpawnUnit ( fortress, "Dragon", fortress, #monster_player, $concatenate ( #ATTRIB_Artifice, #force_raider ));

					spawn_number += 1;
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Spawn_Fortress_Grove ()
// This function spawns a cluster of daemonwoods and strangleweeds to act as an initial
// defensive perimiter around the fortress each time it warps in.
declare
	integer count, random;
	list grovelist, lairs;
	agent fortress, palace, AIRootAgent;

begin
  	palace = $GetPlayerOnePalace ();
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap, #InsideOtherUnits );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	count = 0;
	While ( count < 8 ) do
		begin
			count += 1;
			random = ( $RandomNumber ( 100 ) + 1 );
			if ( random < 75 )
				grovelist << $SpawnUnit ( Fortress, "Strangleweed", $RandomCoord ( fortress, 200, 350 ), "clear" );
			else
				grovelist << $SpawnUnit ( Fortress, "Daemonwood", $RandomCoord ( fortress, 200, 350 ), "clear" );
		end
	fortress's "grovelist" = grovelist;
end

///////////////////////////////////////////////////////////////////////////////
function Wither_Fortress_Grove ()
// This function finds and cleans up the defensive flora positioned around the fortress.
// This is normally called when the fortress warps out.
declare
	agent fortress, palace, shrubbery;
	list grovelist, lairs;

begin
  	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap, #InsideOtherUnits );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	grovelist = fortress's "grovelist";

	foreach shrubbery in grovelist do
		begin
			if ( $IsValidGamePiece ( shrubbery ))
				begin
					$createeffector ( shrubbery, "shrubbery_effector", 1000 );
					$FadeOut ( shrubbery, 100 );
				end
		end
	$ClearList ( fortress's "grovelist" );
end

///////////////////////////////////////////////////////////////////////////////
function Fortress_Death ( agent thisagent )
// runs the usual death routines, as well as kicking off the quest victory calls.
declare
	agent palace, fortress, AIRootAgent;
	list lairs;
begin

	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
  	palace = $GetPlayerOnePalace ();
	$ListObjects ( palace, "lair", -1, lairs, #NoHiddenMap, #InsideOtherUnits );
	lairs = $ListTitles ( lairs, "FortressOfIxmil" );
	fortress = $ListMember ( lairs, 1 );

	AIRootAgent's "end_coord" = $LocationOf ( fortress );

	// $messageflag ( fortress, #Message_Fortress_Ixmil_Destroyed );
	$PlaySound ( Palace, "Victory_Theme", "Begin" );
	$KillThread ( AIRootAgent's "SpecialSpawnScript" );
	$KillThread ( AIRootAgent's "VictoryCondition2" );

	$dropgoldinradius ( thisagent, $getattribute ( thisagent, #ATTRIB_gold ));
	$chance_drop_equip ( thisagent );
	$Drop_QItems ( ThisAgent );
	$building_death ( thisagent );

	$DeclareVictory ( palace, AIRootAgent's "end_coord" );
end

///////////////////////////////////////////////////////////////////////////////
function Shrubbery_Death ( agent thisagent )
// When the fortress cleans away its defensive flora, it disappears instantly, it doesn't
// die normally.  This script handles the actual unit removal.
// NOTE: there's probably some extraneous code in this, but I didn't want to screw with it
// too much for fear of awakening old 'death' bugs.
declare

begin
	$stopmoving ( thisagent );
	thisagent's "type" = "Dead";

	// NLS BUGFIX2
	// need to do this to fix freeze spell gravestone bug
	$ResumeThread ( thisagent's "Activescript" );

   thisagent's "type" = "Waiting_to_die";
	$killthread ( thisagent's "activescript" );
	$deletegamepiece ( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
Function Fortress_Ixmil_Events ()

declare

begin
end

///////////////////////////////////////////////////////////////////////////////
Function Ixmil_Scan ( agent ThisAgent )
Declare
	list	Enemies;

Begin
	if ( thisagent's "enemytype" != "nothing" )
		begin
			Enemies = $list_enemies_seen ( thisagent, $getattribute ( ThisAgent, #ATTRIB_SightRange ));
			If ( $ListSize ( Enemies ) > 0 )
				ThisAgent's "ActiveScript" = $Ixmil_Attack;
		end
End

///////////////////////////////////////////////////////////////////////////////
Function Ixmil_Attack ( agent ThisAgent )
Declare
	list	Enemies;

Begin
	enemies = $list_enemies_seen ( thisagent, $getattribute ( ThisAgent, #ATTRIB_SightRange ));
	If ( $ListSize ( Enemies ) > 0 )
		begin
			ThisAgent's "Target" = $ListMember ( Enemies, 1 );

			$CreateEffector ( Thisagent, "Ixmil_Attack_Effector", 0 );
			$PerformAction ( ThisAgent, ThisAgent's "Attack_Action", THisAgent's "Target" );
		end
	Else
		ThisAgent's "ActiveScript" = $Ixmil_Scan;
End



// Spires of Death Quest entry point
function SPIRES_DEATH ()

declare
	agent AIRootAgent;
	agent palace;

begin
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );

	AIRootAgent's "Quest_Number" = #QNumber_Spires_Death;

	palace = $GetPlayerOnePalace ();

	//Start playing music
	$Setup_Quest_Music ( AiRootAgent );

	// what can't be used in this quest?

	// setup starting messages

	// setup special things

	// This handles the basic spawn cycle for the spires. Normally all spires
	// spawn simultaniously.
	AIRootAgent's "SpecialSpawnScript" = $Force_Spire_Spawns;
	$NewThread ( AIRootAgent's "SpecialSpawnScript", ( $randomnumber ( 60000 ) + 100000 ));

	// This causes a spire to regenerate every 4-6 minutes if any have been destroyed.
	AIRootAgent's "SpecialSpawnScript2" = $Check_Spire_Regeneration;
	$NewThread ( AIRootAgent's "SpecialSpawnScript2", ( $randomnumber ( 120000 ) + 240000 ));

end


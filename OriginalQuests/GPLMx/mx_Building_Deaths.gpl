///////////////////////////////////////////////////////////////////////////////
function dropgoldeveryone(agent thisagent, integer amount)

// This is for when a palace dies, it gives out all the treasury gold to nearby
// heroes and monsters

declare
	list guysnearby,newguys, monstersnearby;
	agent guy;
	integer num_guys,goldper;

begin
	$ListObjects(thisagent,"hero",#gold_drop_radius * 2, guysnearby, #CheckSubtypes, "Hero" );

//	foreach guy in guysnearby do
//		begin
//			//if (($getsubtype(guy) != "henchman"))
//			  //	if ($GetSubtype (Guy) != "Controlled")
//			If (Guy's "Subtype" == "Hero")
//				begin
//					newguys << guy;
//				end
//		end

//	guysnearby = newguys;

	$listobjects(thisagent,"monster",#gold_drop_radius * 2,monstersnearby);

	guysnearby = $addlists(guysnearby,monstersnearby);

	num_guys = $listsize(guysnearby);

	if (num_guys > 0)
		begin
			goldper = (amount / num_guys);
			foreach guy in guysnearby do
				$give_gold(guy,goldper);
		end

end


///////////////////////////////////////////////////////////////////////////////
function gnome_camp_destroyed(agent thisagent)

declare
	agent palace;
	list	hovels;

begin
	palace = $gettruepalace(thisagent);

	If ($NotValid (Palace) == False)
		begin

			$ListObjects (ThisAgent, "Building", -1, Hovels, #CheckTitles, "Gnome_Hovel", #MyPlayer);

			//If this is the last Hovel, then kill the Hovel spawn script, and don't spawn another one.
			If ($ListSize (Hovels) == 0)
				begin
					If ($IsRunning (Palace's "Gnome_Camp_Spawner"))
						begin

							$KillThread (Palace's "Gnome_Camp_Spawner");

						end
				end

			//Otherwise, see if we want to run it again.
			Else
				begin
					If ($isrunning(palace's "gnome_camp_spawner") == FALSE)
						$runthread(palace's "gnome_camp_spawner",#gnome_camp_delay,palace);

				end
		end


	$guild_destroyed_2 ( thisagent );
end


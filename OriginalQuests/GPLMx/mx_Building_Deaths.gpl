function hideout_death(agent thisagent)

declare
	agent hero;
	list heroes;

begin

	$dropgoldinradius(thisagent,$getattribute(thisagent,#ATTRIB_gold));

	$chance_drop_equip(thisagent);

	$Drop_QItems (ThisAgent);

	$building_death( thisagent );
end

///////////////////////////////////////////////////////////////////////////////
// Death script for the Witch_King_Tower
function witch_king_tower_death(agent thisagent)

declare
	coordinate coord;

begin
	// spawn 5 spiders in far corner from the tower
	coord = $farthestmapcorner(thisagent);

	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,300));
	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,350));
	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,300));
	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,300));
	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,300));
	$spawnunit(thisagent,"Giant_spider",$randomcoord(coord,300));

	$lair_death(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function chance_drop_equip(agent thisagent)

declare
	agent hero;
	list heroes;

begin

	// check for special weapons and armor to be dropped
	$ListObjects(thisagent,"hero",#GOLD_drop_radius, heroes );

	foreach hero in heroes do
		begin
			// Make sure this is a real Hero
			If (Hero's "SubType" == "Hero")
			 	begin
					$chance_weapon(thisagent,hero);
					$chance_armor(thisagent,hero);
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function chance_weapon(agent thisagent,agent hero)

declare
	integer bonus_limit,struct_bonus,magic_bonus;
	boolean goody_flag;

begin
	//$Debugout( 911, "chance_weapon: " );
	//$Debugout( 911, "building : ", thisagent );
	//$Debugout( 911, "hero : ", hero, "weapon index : ", $getattribute(hero,#ATTRIB_weapontypeindex) );
	if ($getattribute(hero,#ATTRIB_weapontypeindex) > 0)
		begin
			// check to see if the hero gets a bonus weapon
			goody_flag = FALSE;
			//$Debugout( 911, "rolling for chance against difficulty : ", thisagent's "difficulty" );
			if ($randomnumber(100) < #lair_weapon_chance * thisagent's "difficulty")
				begin
//								if ($randomnumber(100) > 3 * thisagent's "difficulty")
						begin
							// they found a normal 'bonus' weapon
							bonus_limit = (thisagent's "difficulty" / 3) + 2;
							struct_bonus = $randomnumber(bonus_limit);
							magic_bonus = $randomnumber(bonus_limit);
							//$Debugout( 911, "with bonus limit of ", bonus_limit, ", rolled struct_bonus: ", struct_bonus, " magic_bonus:", magic_bonus );
							//$Debugout( 911, "current weapon struct_bonus: ", $getattribute(hero,#ATTRIB_weapon_struct_bonus), " magic_bonus:", $getattribute(hero,#ATTRIB_Weapon_magic_bonus) );
							if (struct_bonus + magic_bonus > $getattribute(hero,#ATTRIB_weapon_struct_bonus) + $getattribute(hero,#ATTRIB_Weapon_magic_bonus))
								goody_flag = TRUE;
						end
//								else
//									begin
							// they found a special weapon
//									end
					if (goody_flag)
						begin
							//$Debugout( 911, "updating weapon" );
							$setattribute(hero,#ATTRIB_weapon_struct_bonus,struct_bonus);
							$setattribute(hero,#ATTRIB_weapon_magic_bonus,magic_bonus);
//							$performaction(hero,"got_weapon",hero);
							$createeffector(hero,"got_weapon",0);
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function chance_armor(agent thisagent, agent hero)

declare
	integer bonus_limit,struct_bonus,magic_bonus;
	boolean goody_flag;

begin
	if ($getattribute(hero,#ATTRIB_armortypeindex) > 0)
		begin
			// check for bonus armor
			goody_flag = FALSE;
			if ($randomnumber(100) < #Lair_armor_chance * thisagent's "difficulty")
				begin
//								if ($randomnumber(100) > 3 * thisagent's "difficulty")
						begin
							// they found a normal 'bonus' armor
							bonus_limit = (thisagent's "difficulty" / 3) + 2;
							struct_bonus = $randomnumber(bonus_limit);
							magic_bonus = $randomnumber(bonus_limit);
							if (struct_bonus + magic_bonus > $getattribute(hero,#ATTRIB_armor_struct_bonus) + $getattribute(hero,#ATTRIB_armor_magic_bonus))
								goody_flag = TRUE;
						end
//								else
//									begin
							// they found special armor
//									end
					if (goody_flag)
						begin
							$setattribute(hero,#ATTRIB_armor_struct_bonus,struct_bonus);
							$setattribute(hero,#ATTRIB_armor_magic_bonus,magic_bonus);
							//$performaction(hero,"got_armor",hero);
							$createeffector(hero,"got_armor",0);
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function building_death(agent thisagent)

declare

begin
  	thisagent's "type" = "Dead";

	$release_occupants(thisagent);

	//Make sure the building is taken off of the palace's construction lists
	$Clean_Palace_Construction_Lists (ThisAgent);

	$performaction( thisagent,"Become_Rubble",thisagent );

	$deleteagent(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function statue_death(agent thisagent)

declare
	list guys;
	agent guy;

begin
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);

	foreach guy in guys do
		if (guy's "subtype" == "hero")
			begin
				guy's "loyalty" -= #statue_loyalty_boost;

				if (guy's "loyalty" < 0)
					guy's "loyalty" = 0;
			end

	$building_death(thisagent);
end


////////////////////////////////////////////////////////////////////////////////
function RandomAttribute(boolean passed) is string

declare
	integer rand;
	string r_attribute;
	
begin
	if (passed == TRUE)
		return;
		
	rand = ($RandomNumber(6) + 1);
	
	if (rand == 1)
		r_attribute = "Strength_Base";
	else if (rand == 2)
		r_attribute = "Intelligence_Base";
	else if (rand == 3)
		r_attribute = "Artifice_Base";
	else if (rand == 4)
		r_attribute = "Vitality_Base";
	else if (rand == 5)
		r_attribute = "Willpower_Base";
	else if (rand == 6)
		r_attribute = "Wisdom_Base";
		
	return r_attribute;
end

////////////////////////////////////////////////////////////////////////////////
function StartingWisdom(agent thisagent) is integer

declare
	string unit_name;
	integer adjust, random_n, negative, amount;
begin
	unit_name = thisagent's "title";
	amount = 0;
	adjust = 0;
	random_n = $randomnumber(3);
	negative = $randomnumber(2) + 1;
	
	if (random_n > 0)
		begin
			if (negative == 1)
				adjust += random_n;
			else
				adjust -= random_n;
		end
		
	amount += adjust;
	
	if (unit_name == "warrior")
		begin
			amount += 5;
		end
		
	else if (unit_name == "ranger")
		begin
			amount += 14;
		end
		
	else if (unit_name == "rogue")
		begin
			amount += 2;
		end
		
	else if (unit_name == "wizard")
		begin
			amount += 15;
		end
		
	else if (unit_name == "paladin")
		begin
			amount += 16;
		end
		
	else if (unit_name == "warrior_of_discord")
		begin
			amount += 1;
		end
		
	else if (unit_name == "adept")
		begin
			amount += 14;
		end
		
	else if (unit_name == "barbarian")
		begin
			amount += 3;
		end
		
	else if (unit_name == "cultist")
		begin
			amount += 6;
		end
		
	else if (unit_name == "healer")
		begin
			amount += 17;
		end
		
	else if (unit_name == "monk")
		begin
			amount += 21;
		end
		
	else if (unit_name == "priestess")
		begin
			amount += 9;
		end
		
	else if (unit_name == "solarus")
		begin
			amount += 7;
		end
		
	else if (unit_name == "dwarf")
		begin
			amount += 8;
		end
		
	else if (unit_name == "elf")
		begin
			amount += 4;
		end
		
	else if (unit_name == "gnome")
		begin
			amount += 2;
		end
		
	return amount;
end


function UpdateVitality(agent thisagent)
declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_Vitality, "Vitality");
	$UpdateHealthRegeneration(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
//The Max XP before a hero reaches their next level.
function UpdateHealthRegeneration(agent thisagent)
declare
begin
	$EnsureStatAttr(thisagent, "HealthRegeneration", #Health_Regeneration_Base + (thisagent's "Vitality_Base" * #Health_Regeneration_Vit));
	thisagent's "HealthRegeneration_Base" = #Health_Regeneration_Base + (thisagent's "Vitality_Total" * #Health_Regeneration_Vit);
	$UpdateCustomAttribute(thisagent, "HealthRegeneration");
end


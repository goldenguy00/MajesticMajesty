function LevelTenHero(agent thisagent)

declare
	agent palace;
begin
	if (thisagent's "title" == "warrior")
		begin
			palace = $GetPalace(thisagent);
			if ($IsRunning (palace's "Guard_Spawn_Function") == False)
				begin
					$RunThread (palace's "Guard_Spawn_Function", 1000, palace);
				end
		end
	
end


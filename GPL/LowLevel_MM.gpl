function AddHealthPoints( Agent ThisAgent, integer HealthPoint_Amount )

Declare

Begin
	//$adjustattribute(thisagent, #ATTRIB_ResearchWizardMeteorStorm, HealthPoint_Amount);
	thisagent's "CurrentHealthPoints_Base" += HealthPoint_Amount;
	//current_healthpoints = $getattribute(thisagent, #ATTRIB_ResearchWizardMeteorStorm);
	while (thisagent's "CurrentHealthPoints_Base" >= #Health_point_limit) do
		begin
			$Heal(thisagent, thisagent, 1);
			//$adjustattribute(thisagent, #ATTRIB_ResearchWizardMeteorStorm, -#Health_point_limit);
			thisagent's "CurrentHealthPoints_Base" -= #Health_point_limit;
		end
End

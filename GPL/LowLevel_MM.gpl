// a perpetual callback system for health regeneration for valid heroes.
function Health_Regeneration( agent thisagent )
declare
	integer stat_vit, healthregen_amount, embers_increase;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "HealthRegeneration");
			return;
		end
		
	//stat_vit = $getattribute(thisagent, #ATTRIB_Vitality);
	//healthregen_amount = (#Health_Regeneration_Base);
	
	stat_vit = thisagent's "Vitality_Total";
	
	//if (stat_vit > 0)
	//	healthregen_amount += (stat_vit * #Health_Regeneration_Vit);
	
	//if ($HasAttribute("Embers_HealthRegeneration", thisagent) == True)
	//	begin
	//		embers_increase = thisagent's "Embers_HealthRegeneration";
	//		healthregen_amount += (embers_increase * 50);
	//	end
		
	$UpdateHealthRegeneration(thisagent);
	
	//if (thisagent's "HealthRegeneration_Increase" > 0)
	//	healthregen_amount += (thisagent's "HealthRegeneration_Increase" * 50);
	
	//if (thisagent's "HealthRegeneration_Percent" > 0)
	//	healthregen_amount = $IncreaseByPercent(healthregen_amount, thisagent's "HealthRegeneration_Percent", False);
	
	healthregen_amount = thisagent's "HealthRegeneration_Total";
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddHealthPoints(thisagent, healthregen_amount);
		end
end


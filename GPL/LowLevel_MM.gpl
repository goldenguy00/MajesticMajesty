////////////////////////////////////////////////////////////////////////////////
function AddInsightPoints(agent thisagent, integer points)

declare
	integer total_points, attribute_points, picked_attribute;
	
begin
	$adjustattribute(thisagent, #ATTRIB_ResearchWizardFireBlast, points);
	total_points = $getAttribute(thisagent, #ATTRIB_ResearchWizardFireBlast);
	while (total_points >= #insight_point_limit) do
		begin
			attribute_points ++;
			$adjustattribute(thisagent, #ATTRIB_ResearchWizardFireBlast, -#insight_point_limit);
			total_points -= #insight_point_limit;
		end
		
	While (attribute_points > 0) do
		begin
			if ((attribute_points % 2) == 1)
				begin
					picked_attribute = $PreferredAttributeExtra(thisagent, FALSE);
					$adjustattribute(thisagent,picked_attribute,1);
					if (picked_attribute == #ATTRIB_Artifice)
						begin
							$ArtificeIncrease(thisagent);
						end
				end
			else
				begin
					picked_attribute = $PreferredAttributeExtra(thisagent, TRUE);
					$adjustattribute(thisagent,picked_attribute,1);
					if (picked_attribute == #ATTRIB_Artifice)
						begin
							$ArtificeIncrease(thisagent);
						end
				end
				
			attribute_points --;
		end
end


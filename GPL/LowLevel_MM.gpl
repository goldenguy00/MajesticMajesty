////////////////////////////////////////////////////////////////////////////////
function AddInsightPoints(agent thisagent, integer insight_points)

declare
	integer attribute_points;
	string picked_attribute;
	
begin
	if ($AddAttribute(thisagent, "InsightPoints", "integer") == false)
		insight_points += thisagent's "InsightPoints";

	while (insight_points >= #insight_point_limit) do
		begin
			attribute_points ++;
			insight_points -= #insight_point_limit;
		end

	thisagent's "InsightPoints" = insight_points;

	While (attribute_points > 0) do
		begin
			picked_attribute = $PreferredAttribute(thisagent, (attribute_points % 2) == 0);
			$AdjustBaseStat(thisagent, picked_attribute, 1);
			attribute_points--;
		end

end

/////////////////////////////////////////////////////////////////////////////////////////////////
function PercentOf( integer amount, integer percent, boolean high ) is integer
// Should have made this ages ago


declare
	integer new_amount;
	
begin
	if (high != TRUE)
		begin
			new_amount = ((amount * percent) / 100);
			return new_amount;
		end
	else
		begin
			new_amount = ((amount / 100) * percent);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IncreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high != TRUE)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function DecreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high != TRUE)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function MinMax(integer minimum, integer maximum) is integer

declare
	integer return_int;

begin
	//Makes it so the integer will be anywhere from minimum to maximum
	
	if (maximum > minimum)
		return_int = $randomnumber(maximum - minimum) + minimum;

	if (return_int < minimum)
		 return_int = minimum;
	else if (return_int > maximum)
		return_int = maximum;
		 
	return return_int;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function HasProperty(agent thisagent, string property) is boolean
//Check if a unit has this in their "Properties" List
declare
	
begin
	if ($stringinlist(property, thisagent's "Properties"))
		return True;
		
	return False;
		
end
////////////////////////////////////////////////////////////////////////////////
function MoveWaypoint(agent thisagent, list destinations)
//Setup move to with waypoints for coordinates

declare
	coordinate l_dest;

begin
	foreach l_dest in destinations do
		$move(thisagent, l_dest, "Add_Waypoint");
end

////////////////////////////////////////////////////////////////////////////////
function Hero_Build_Condition(agent thisagent) is boolean
//A condition solely for the $Hero_Build action in Help Build task package.

declare
	boolean flag;
	agent palace, target;

begin
	if ($notvalid(thisagent))
		return true;
		 
	palace = $gettruepalace(thisagent);
	if ($HasAttribute("TaskPackageTargetCurrent", thisagent))
		target = thisagent's "TaskPackageTargetCurrent";
	if ($isdead(target))
		return True;
	else if ($offrepair(target))
		return True;
	else if ($getattribute(target,#ATTRIB_HP) == $getattribute(target,#ATTRIB_MAXHP))
		return True;
	else if	($isdead(palace))
		return True;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function make_attack_assassination( agent thisagent, agent target)
//For Rogue Assassination, deal 5x damage in one strike if the blow lands.
declare
	integer hitresult,exp_given;

begin
	// these two checks are here due to the time delay between the action initiation
	// and the action conclusion;
	if ($notvalid(target))
		return;


	if ($notvalid_attacker(thisagent))
		return;


	$react(thisagent,target);


	hitresult = $hit(thisagent,target);

	// expereience checking

	exp_given = $exp_value(thisagent,target);


	if (hitresult == 1) // hit!
		begin
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
		end
		
	$attack_end(thisagent,exp_given);

end

///////////////////////////////////////////////////////////////////////////////
// This function is used to determine is the intent of the agent is a resting state
Function IsResting (agent ThisAgent) is boolean
Declare
	boolean return_boolean;
	string current_intent;
	
Begin
	return_boolean = False;
	
	if ($HasAttribute("Running_Intent",thisagent) != True)
		return return_boolean;
	
	current_intent = thisagent's "Running_Intent";
	
	if ((current_intent == "IDTXT_INTENT_RECUPERATINGGAZEBO") || (current_intent == "IDTXT_INTENT_RECUPERATINGHOME") ||
		(current_intent == "IDTXT_INTENT_RECUPERATINGINN") || (current_intent == "IDTXT_INTENT_RESTINGGAZEBO") ||
		(current_intent == "IDTXT_INTENT_RESTINGHOME") || (current_intent == "IDTXT_INTENT_RESTINGINN"))
		return_boolean = True;
	
	return return_boolean;
End

///////////////////////////////////////////////////////////////////////////////
function hero_damage(agent thisagent) is integer

declare
	integer value;

begin
	value = $hero_weapon_value(thisagent);
	value += ($getattribute(thisagent,#ATTRIB_Strength) / #strength_div);
	if (value < 1)
		value = 1;
	return value;
end

///////////////////////////////////////////////////////////////////////////////
// ThisAgent is only passed so that GetPalace works
Function Vaporize_Gold (agent ThisAgent, integer Gold)
Declare
	agent	Palace,spawn_target;
	list buildings;
	integer i, troll_count;

Begin
	Palace = $GetPalace (ThisAgent);

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	Palace's "Vaporized_Gold" += Gold;

	Palace's "troll_gold" += gold;

	if (Palace's "troll_gold" > #troll_gold_limit)
		begin
			Palace's "troll_gold" -= #troll_gold_limit;
			
			$adjustattribute(palace,#ATTRIB_HtoH, 1);
			troll_count = $getattribute(palace, #ATTRIB_HtoH);
			
			// spawn a troll from a random complete building
			$listobjects(palace,"building",-1,buildings,#MyPlayer);
			buildings = $listcompleted(buildings);

			buildings << palace;

			i = $listsize(buildings);
			
			spawn_target = $listmember(buildings,$randomnumber(i) + 1);

			if (troll_count < #Spirit_Troll_limit)
				begin
					$spawnUnit(spawn_target,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay));
				end
			else
				begin
					$adjustattribute(palace, #ATTRIB_HtoH, - #Spirit_Troll_limit);
					$spawnUnit(spawn_target,"Spirit_Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay));
				end
		end
End

///////////////////////////////////COMBINED REGEN SYSTEM/////////////////////////////////////////////////////////
//Regeneration Increase for both health and mana values are 0.25 per point since it is multiplied by 50 in this section. For an increase of 1 Regeneration per second requires 4 points.
function Regeneration_System( agent thisagent )
declare
	integer healthregen_amount, manaregen_amount;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "RegenerationSystem");
			return;
		end
	
	if ($Isdead(thisagent))
		begin
			return;
		end
		
	if ($HasAttribute("Embers_ManaRegeneration", thisagent))
		begin
			$Embers_Passive(thisagent);
		end
		
	$UpdateManaRegeneration(thisagent);
	$UpdateHealthRegeneration(thisagent);
	
	healthregen_amount = $GetBaseStatTotal(thisagent, "HealthRegeneration");
	manaregen_amount = $GetBaseStatTotal(thisagent, "ManaRegeneration");
	
	if ($IsResting(thisagent)) // Will have to eventually roll these results into the prototype system instead of having a boolean check here all the time.
		begin
			manaregen_amount += (manaregen_amount / 4);
			manaregen_amount += 250;
		end
		
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddManaPoints(thisagent, manaregen_amount);
			$AddHealthPoints(thisagent, healthregen_amount);
		end
end
////////////////////////////////////////////////////////////////////////////////////////////
//Test for embers in its own thread
function Embers_System( agent thisagent ) //Only here separately because the regeneration system thread was weighed down by the addition of this.
declare
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "EmbersSystem");
			return;
		end

	$Embers_Passive(thisagent);
		
end

///////////////////////////////////////////////////////////////////////////////////////////////////////
// a perpetual callback system for mana regeneration for valid heroes.
//Regeneration Increase for both health and mana values are 0.25 per point since it is multiplied by 50 in this section. For an increase of 1 Regeneration per second requires 4 points.
function Mana_Regeneration( agent thisagent )
declare
	integer stat_int, manaregen_amount, max_mana, embers_increase;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "ManaRegeneration");
			return;
		end
		
	stat_int = $GetAttribute(thisagent, #ATTRIB_Intelligence);
	max_mana = thisagent's "MaxMana_Total";
	
	if ($HasAttribute("Embers_ManaRegeneration", thisagent))
		begin
			$Embers_Passive(thisagent);
		end
	$UpdateManaRegeneration(thisagent);

	manaregen_amount = thisagent's "ManaRegeneration_Total";
	
	if ($IsResting(thisagent) != False) // Will have to eventually roll these results into the prototype system instead of having a boolean check here all the time.
		begin
			manaregen_amount += (manaregen_amount / 4);
			manaregen_amount += 250;
		end
		
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddManaPoints(thisagent, manaregen_amount);
		end
end

///////////////////////////////////////////////////////////////////////////////////////////////////////
function AddManaPoints( Agent ThisAgent, integer ManaPoint_Amount )

Declare

Begin
	thisagent's "ManaRegenPoints" += ManaPoint_Amount;
	while (thisagent's "ManaRegenPoints" >= #Mana_point_limit) do
		begin
			$RestoreMana(thisagent, thisagent, 1);
			thisagent's "ManaRegenPoints" -= #Mana_point_limit;
		end
End
///////////////////////////////////////////////////////////////////////////////////////////////////////
function RestoreMana( Agent ThisAgent, Agent Target, integer Mana_Amount )

Declare
	integer	Max_Mana;

Begin
	if ($isdead(target))
		return;

	//This is the maximum amount of mana restored that a target can endure before they are over their maximum
	Max_Mana = (thisagent's "MaxMana_Total" - thisagent's "CurrentMana");

	If (Mana_Amount > Max_Mana)
		Mana_Amount = Max_Mana;

	thisagent's "CurrentMana" += Mana_Amount;
End

///////////////////////////////////////////////////////////////////////////////////////////////////////
function SpendMana( Agent Thisagent, integer Mana_Amount )

Declare

Begin
	if ($isdead(thisagent))
		return;

	thisagent's "CurrentMana" += Mana_Amount;
End

///////////////////////////////////////////////////////////////////////////////
function haslowMP(agent thisagent) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana";
	maxMP = thisagent's "MaxMana_Total";
	
	if (maxMP == 0)
		maxMP = 1;
	
 	if (((MP * 100) / maxMP) <= 25) return TRUE;
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function hasMPPercent(agent thisagent, integer whatpercent) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana";
	maxMP = thisagent's "MaxMana_Total";

	if (maxMP == 0)
		maxMP = 1;
	
 	if (((MP * 100) / maxMP) >= whatpercent) return TRUE;
	else
		return FALSE;
end
///////////////////////////////////////////////////////////////////////////////
function hasMPFlat(agent thisagent, integer whatamount) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana";

 	if (MP >= whatamount) return TRUE;
	else
		return FALSE;
end

///////////////////////////////////HP REGEN SYSTEM//////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////////////////////////////
// a perpetual callback system for health regeneration for valid heroes.
function Health_Regeneration( agent thisagent )
declare
	integer stat_vit, healthregen_amount, embers_increase;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "HealthRegeneration");
			return;
		end

	stat_vit = thisagent's "Vitality_Total";
		
	$UpdateHealthRegeneration(thisagent);

	healthregen_amount = thisagent's "HealthRegeneration_Total";
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddHealthPoints(thisagent, healthregen_amount);
		end
end

///////////////////////////////////////////////////////////////////////////////////////////////////////
function AddHealthPoints( Agent ThisAgent, integer HealthPoint_Amount ) 
declare
Begin
	thisagent's "HealthRegenPoints" += HealthPoint_Amount;
	while (thisagent's "HealthRegenPoints" >= #Health_point_limit) do
		begin
			$Heal(thisagent, thisagent, 1);
			thisagent's "HealthRegenPoints" -= #Health_point_limit;
		end
End

//////////////////////////////////////////////////////////////////////////////
function Display_Total_Attack_Damage(agent thisagent)

declare
	integer total_min, total_max, total_average;

begin
	total_min += thisagent's "Fire_Attack_Damage_Min" + thisagent's "Cold_Attack_Damage_Min" + thisagent's "Electric_Attack_Damage_Min"
	 + thisagent's "Poison_Attack_Damage_Min" + thisagent's "Arcane_Attack_Damage_Min" + thisagent's "Force_Attack_Damage_Min"
	  + thisagent's "Divine_Attack_Damage_Min" + thisagent's "Necrotic_Attack_Damage_Min" + thisagent's "Chaotic_Attack_Damage_Min"
	   + thisagent's "Slashing_Attack_Damage_Min" + thisagent's "Crushing_Attack_Damage_Min" + thisagent's "Piercing_Attack_Damage_Min";

	total_max += thisagent's "Fire_Attack_Damage_Max" + thisagent's "Cold_Attack_Damage_Max" + thisagent's "Electric_Attack_Damage_Max"
	 + thisagent's "Poison_Attack_Damage_Max" + thisagent's "Arcane_Attack_Damage_Max" + thisagent's "Force_Attack_Damage_Max"
	  + thisagent's "Divine_Attack_Damage_Max" + thisagent's "Necrotic_Attack_Damage_Max" + thisagent's "Chaotic_Attack_Damage_Max"
	   + thisagent's "Slashing_Attack_Damage_Max" + thisagent's "Crushing_Attack_Damage_Max" + thisagent's "Piercing_Attack_Damage_Max";

	total_average = ((total_min + total_max) / 2);
	total_average -= $GetAttribute(thisagent, #ATTRIB_Weapon_Struct_Bonus);
	$SetAttribute(thisagent, #ATTRIB_weapon_basic_damage, total_average);
end

function HasCooldown(agent thisagent, string cooldown_name) is boolean
declare
begin
	if ($HasAttribute(cooldown_name, thisagent))
		return $IsRunning (thisAgent's cooldown_name);
	return false;
end
	
//Spell Cooldowns not in prototype
////////////////////////////////////////////////////////////////////////////////
function StartingSpellCooldowns(agent thisagent)
//This is used for adding cooldowns for the allowed spels heroes start with.
//Spells they gain through means OTHER than leveling will be added in the function where they gain the spell.

declare
	string unit_name;
begin
	unit_name = thisagent's "title";
	
	if (unit_name == "wizard")
		begin
			$AddAttribute(thisagent, "wizard_energyblast_cooldown", "function", $Cooldown_End);
			//$AddAttribute(thisagent, "wizard_firebolt_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "wizard_fireshield_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "wizard_fireblast_cooldown", "function", $Cooldown_End);
			//$AddAttribute(thisagent, "wizard_fireball_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "wizard_resistmagic_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "wizard_transmute_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "wizard_meteorstorm_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "solarus")
		begin
			$AddAttribute(thisagent, "solarus_sunscorch_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "priestess")
		begin
			$AddAttribute(thisagent, "priestess_drainlife_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "priestess_animateskeleton_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "priestess_wither_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "priestess_controlundead_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "paladin")
		begin
			$AddAttribute(thisagent, "paladin_shieldoflight_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "monk")
		begin
			$AddAttribute(thisagent, "monk_handsofsteel_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "monk_stoneskin_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "monk_ironwill_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "healer")
		begin
			$AddAttribute(thisagent, "healer_healerheal_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "healer_meditation_cooldown", "function", $Cooldown_End);
		end
	else if (unit_name == "cultist")
		begin
			$AddAttribute(thisagent, "cultist_camouflage_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "cultist_charmmonster_cooldown", "function", $Cooldown_End);
			$AddAttribute(thisagent, "cultist_changeshape_cooldown", "function", $Cooldown_End);
		end
		
end


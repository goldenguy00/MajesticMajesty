function CustomAdjustAttributeInteger(agent thisagent, string Attribute, integer amount)

declare

begin
	if ($HasAttribute(Attribute, thisagent)!=True)
		$AddAttribute(thisagent, Attribute, "integer", amount);
	else
		thisagent's Attribute += amount;
end
//////////////////////////////////////////////////////////////////////////////
function CustomSetAttributeInteger(agent thisagent, string Attribute, integer amount)

declare

begin
	if ($HasAttribute(Attribute, thisagent)!=True)
		$AddAttribute(thisagent, Attribute, "integer", amount);
	else
		thisagent's Attribute = amount;
end
	

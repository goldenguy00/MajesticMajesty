function UpdateMaxHP(agent thisagent)
declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_MaxHP, "MaxHP");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateWillpower(agent thisagent)
declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_Willpower, "Willpower");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateWisdom(agent thisagent)
declare
	integer default;
begin
	if ($HasAttribute("Wisdom_Base", thisagent) == false)
		default = $StartingWisdom(thisagent);
	$EnsureStatAttr(thisagent, "Wisdom", default);
	$UpdateCustomAttribute(thisagent, "Wisdom");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateIntelligence(agent thisagent)
declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_Intelligence, "Intelligence");
	$UpdateManaRegeneration(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
//The Max XP before a hero reaches their next level.
function UpdateManaRegeneration(agent thisagent)
declare
	integer default;
begin
	$EnsureStatAttr(thisagent, "ManaRegeneration", #Mana_Regeneration_Base + (thisagent's "Intelligence_Base" * #Mana_Regeneration_Int));
	thisagent's "ManaRegeneration_Base" = #Mana_Regeneration_Base + (thisagent's "Intelligence_Total" * #Mana_Regeneration_Int);
	$UpdateCustomAttribute(thisagent, "ManaRegeneration");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateMaxMana(agent thisagent)
declare
begin
	$EnsureStatAttr(thisagent, "MaxMana", #Base_Mana + (thisagent's "Intelligence_Base" * #Mana_Amount_Int));
	thisagent's "MaxMana_Base" = #Base_Mana + (thisagent's "Intelligence_Total" * #Mana_Amount_Int);
	$UpdateCustomAttribute(thisagent, "MaxMana");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateCurrentMana(agent thisagent)
declare
	integer base_currentmana;
begin
	$AddAttribute(thisagent, "CurrentMana_Base", "integer", $GetAttribute(thisagent, #ATTRIB_NumHealingPotions));
	base_currentmana = thisagent's "CurrentMana_Base";
	$setattribute(thisagent, #ATTRIB_NumHealingPotions, base_currentmana);
end

////////////////////////////////////////////////////////////////////////////////
function UpdateAttribute(agent thisagent, integer attrib_int, string attrib)
declare
begin
	$EnsureStatAttr(thisagent, attrib, $GetAttribute(thisagent, attrib_int));
	$setattribute(thisagent, attrib_int, $UpdateCustomAttribute(thisagent, attrib));
end

////////////////////////////////////////////////////////////////////////////////
function UpdateCustomAttribute(agent thisagent, string attrib) is integer
declare
	integer base_attrib, attrib_adjust, total_attrib;
	string total, base, flat, percent;

begin
	base = attrib + "_Base";
	flat = attrib + "_Flat_Modifier";
	percent = attrib + "_Percent_Modifier";
	total = attrib + "_Total";
	
	base_attrib = thisagent's base;
	attrib_adjust = $PercentOf(base_attrib, thisagent's percent, (base_attrib >= 1000));
	total_attrib = base_attrib + thisagent's flat + attrib_adjust;
	thisagent's total = total_attrib;
	return total_attrib;
end

////////////////////////////////////////////////////////////////////////////////
function UpdatePhysicalArmor(agent thisagent)

declare
	integer base_armor, flat_armor, percent_armor, armor_adjust, total_armor;
	boolean high_value;

begin
	total_armor = $UpdateCustomAttribute(thisagent, "Armor_Physical", 10);
	total_armor += thisagent's "Armor_Physical_BodyArmor" + thisagent's "Armor_Physical_Helm" + thisagent's "Armor_Physical_Gloves"
				 + thisagent's "Armor_Physical_Boots" + thisagent's "Armor_Physical_Belt" + thisagent's "Armor_Physical_Shield";
	thisagent's "Armor_Physical_Total" = total_armor;
end

////////////////////////////////////////////////////////////////////////////////
function GenerateHeroAttributes(agent thisagent)
//Cleaned out now that new attribute system is in place
//This isn't being used yet, but will be.

declare

begin
	//$NewThread(ThisAgent's "ManaRegeneration", 200, ThisAgent ); // Might be able to roll the regenerations into just one function
	//$NewThread(ThisAgent's "HealthRegeneration", 200, ThisAgent );
	$NewThread(ThisAgent's "RegenerationSystem", 300, ThisAgent ); //Doubled the cycle time, halved the threshold for regen
	$RestoreMana(thisagent, thisagent, thisagent's "MaxMana_Total");
	thisagent's "Primary_Orientation" = $HeroSkillOrientationPrimary(thisagent);
	thisagent's "Secondary_Orientation" = $HeroSkillOrientationSecondary(thisagent);
	$HeroPreferredSkills(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
function SetNegativeResistance(agent thisagent)

declare

begin
	if (thisagent's "Fire_Resistance_Percent_Neg" == True)
		thisagent's "Fire_Resistance_Percent" *= -1;

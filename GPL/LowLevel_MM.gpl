/////////////////////////////////////////////////////////////////////////////////////////////////
function PercentOf( integer amount, integer percent, boolean high ) is integer
// Should have made this ages ago


declare
	integer new_amount;
	
begin
	if (high != TRUE)
		begin
			new_amount = ((amount * percent) / 100);
			return new_amount;
		end
	else
		begin
			new_amount = ((amount / 100) * percent);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IncreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high != TRUE)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function DecreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high != TRUE)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	return new_amount;
end

function MinMaxAttackType(agent attacker, string type) is integer

declare

begin
	return $MinMax(attacker's (type+"_Attack_Damage_Min") + attacker's (type+"_Attack_Damage_Min_Modifier"), 
					attacker's (type+"_Attack_Damage_Max") + attacker's (type+"_Attack_Damage_Max_Modifier"));
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function MinMax(integer minimum, integer maximum) is integer

declare
	integer return_int;

begin
	return_int = 0;
	
	//Makes it so the integer will be anywhere from minimum to maximum
	
	if (maximum > minimum)
		return_int = $randomnumber(maximum - minimum) + minimum;

	if (return_int < minimum)
		 return_int = minimum;
		 
	return return_int;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function HasProperty(agent thisagent, string property) is boolean
//Check if a unit has this in their "Properties" List
declare
	
begin
	if ($stringinlist(property, thisagent's "Properties"))
		return True;
		
	return False;
		
end
////////////////////////////////////////////////////////////////////////////////
function MoveWaypoint(agent thisagent, list destinations)
//Setup move to with waypoints for coordinates

declare
	coordinate l_dest;

begin
	foreach l_dest in destinations do
		$move(thisagent, l_dest, "Add_Waypoint");
end

////////////////////////////////////////////////////////////////////////////////
function Hero_Build_Condition(agent thisagent) is boolean
//A condition solely for the $Hero_Build action in Help Build task package.

declare
	boolean flag;
	agent palace, target;

begin
	if ($notvalid(thisagent))
		return true;
		 
	palace = $gettruepalace(thisagent);
	if ($HasAttribute("TaskPackageTargetCurrent", thisagent))
		target = thisagent's "TaskPackageTargetCurrent";
	if ($isdead(target))
		return True;
	else if ($offrepair(target))
		return True;
	else if ($getattribute(target,#ATTRIB_HP) == $getattribute(target,#ATTRIB_MAXHP))
		return True;
	else if	($isdead(palace))
		return True;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function make_attack_assassination( agent thisagent, agent target)
//For Rogue Assassination, deal 5x damage in one strike if the blow lands.
declare
	integer hitresult,exp_given;

begin
	// these two checks are here due to the time delay between the action initiation
	// and the action conclusion;
	if ($notvalid(target))
		return;


	if ($notvalid_attacker(thisagent))
		return;


	$react(thisagent,target);


	hitresult = $hit(thisagent,target);

	// expereience checking

	exp_given = $exp_value(thisagent,target);


	if (hitresult == 1) // hit!
		begin
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
			$damage(thisagent,target);
		end
		
	$attack_end_level(thisagent,exp_given, $XPLevel_Value_Base(target));

end

///////////////////////////////////////////////////////////////////////////////
// This function is used to determine is the intent of the agent is a resting state
Function IsResting (agent ThisAgent) is boolean
Declare
	boolean return_boolean;
	string current_intent;
	
Begin
	return_boolean = False;
	
	if ($HasAttribute("Running_Intent",thisagent) != True)
		return return_boolean;
	
	current_intent = thisagent's "Running_Intent";
	
	if ((current_intent == "IDTXT_INTENT_RECUPERATINGGAZEBO") || (current_intent == "IDTXT_INTENT_RECUPERATINGHOME") ||
		(current_intent == "IDTXT_INTENT_RECUPERATINGINN") || (current_intent == "IDTXT_INTENT_RESTINGGAZEBO") ||
		(current_intent == "IDTXT_INTENT_RESTINGHOME") || (current_intent == "IDTXT_INTENT_RESTINGINN"))
		return_boolean = True;
	
	return return_boolean;
End

///////////////////////////////////////////////////////////////////////////////
function hero_damage(agent thisagent) is integer

declare
	integer value;

begin
	value = $hero_weapon_value(thisagent);
	value += ($getattribute(thisagent,#ATTRIB_Strength) / #strength_div);
	if (value < 1)
		value = 1;
	return value;
end

///////////////////////////////////////////////////////////////////////////////
// ThisAgent is only passed so that GetPalace works
Function Vaporize_Gold (agent ThisAgent, integer Gold)
Declare
	agent	Palace,spawn_target;
	list buildings;
	integer i, troll_count;

Begin
	Palace = $GetPalace (ThisAgent);

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	if ($isvalidgamepiece(palace) == FALSE)
		return;

	Palace's "Vaporized_Gold" += Gold;

	Palace's "troll_gold" += gold;

	if (Palace's "troll_gold" > #troll_gold_limit)
		begin
			Palace's "troll_gold" -= #troll_gold_limit;
			
			$adjustattribute(palace,#ATTRIB_HtoH, 1);
			troll_count = $getattribute(palace, #ATTRIB_HtoH);
			
			// spawn a troll from a random complete building
			$listobjects(palace,"building",-1,buildings,#MyPlayer);
			buildings = $listcompleted(buildings);

			buildings << palace;

			i = $listsize(buildings);
			
			spawn_target = $listmember(buildings,$randomnumber(i) + 1);

			if (troll_count < #Spirit_Troll_limit)
				begin
					$spawnUnit(spawn_target,"Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay));
				end
			else
				begin
					$adjustattribute(palace, #ATTRIB_HtoH, - #Spirit_Troll_limit);
					$spawnUnit(spawn_target,"Spirit_Troll",#Monster_Player,$concatenate(#ATTRIB_artifice,#force_overlay));
				end
		end
End

///////////////////////////////////COMBINED REGEN SYSTEM/////////////////////////////////////////////////////////
//Regeneration Increase for both health and mana values are 0.25 per point since it is multiplied by 50 in this section. For an increase of 1 Regeneration per second requires 4 points.
function Regeneration_System( agent thisagent )
declare
	integer healthregen_amount, manaregen_amount;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "RegenerationSystem");
			return;
		end
	
	if ($Isdead(thisagent))
		begin
			return;
		end
		
	if ($HasAttribute("Embers_ManaRegeneration", thisagent))
		begin
			$Embers_Passive(thisagent);
		end
		
	$UpdateManaRegeneration(thisagent);
	$UpdateHealthRegeneration(thisagent);
	
	healthregen_amount = thisagent's "HealthRegeneration_Total";
	manaregen_amount = thisagent's "ManaRegeneration_Total";
	
	if ($IsResting(thisagent)) // Will have to eventually roll these results into the prototype system instead of having a boolean check here all the time.
		begin
			manaregen_amount += (manaregen_amount / 4);
			manaregen_amount += 250;
		end
		
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddManaPoints(thisagent, manaregen_amount);
			$AddHealthPoints(thisagent, healthregen_amount);
		end
end
////////////////////////////////////////////////////////////////////////////////////////////
//Test for embers in its own thread
function Embers_System( agent thisagent ) //Only here separately because the regeneration system thread was weighed down by the addition of this.
declare
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "EmbersSystem");
			return;
		end

	$Embers_Passive(thisagent);
		
end

///////////////////////////////////////////////////////////////////////////////////////////////////////
// a perpetual callback system for mana regeneration for valid heroes.
//Regeneration Increase for both health and mana values are 0.25 per point since it is multiplied by 50 in this section. For an increase of 1 Regeneration per second requires 4 points.
function Mana_Regeneration( agent thisagent )
declare
	integer stat_int, manaregen_amount, max_mana, embers_increase;
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "ManaRegeneration");
			return;
		end
		
	//stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	//max_mana = (#Base_Mana + thisagent's "MaxMana_Bonus" + (stat_int * #Mana_Amount_Int));
	
	stat_int = thisagent's "Intelligence_Total";
	max_mana = thisagent's "MaxMana_Total";
	
	if ($HasAttribute("Embers_ManaRegeneration", thisagent))
		begin
			$Embers_Passive(thisagent);
			//embers_increase = thisagent's "Embers_ManaRegeneration";
			//manaregen_amount += (embers_increase * 50);
		end
	$UpdateManaRegeneration(thisagent);
	//if (stat_int > 0)
	//	manaregen_amount += (stat_int * #Mana_Regeneration_Int);
		
	//if (thisagent's "ManaRegeneration_Increase" > 0)
	//	manaregen_amount += (thisagent's "ManaRegeneration_Increase" * 50);
	
	
	//if (thisagent's "ManaRegeneration_Percent" > 0)
	//	manaregen_amount = $IncreaseByPercent(manaregen_amount, thisagent's "ManaRegeneration_Percent", False);
	
	manaregen_amount = thisagent's "ManaRegeneration_Total";
	
	if ($IsResting(thisagent) != False) // Will have to eventually roll these results into the prototype system instead of having a boolean check here all the time.
		begin
			manaregen_amount += (manaregen_amount / 4);
			manaregen_amount += 250;
		end
		
	
	if ($isdead(thisagent) != TRUE)
		begin
			$AddManaPoints(thisagent, manaregen_amount);
	//		$SetAttribute(thisagent, #ATTRIB_ResearchEnergyBlast, max_mana);
		end
end

///////////////////////////////////////////////////////////////////////////////////////////////////////
function AddManaPoints( Agent ThisAgent, integer ManaPoint_Amount )

Declare

Begin
	//$adjustattribute(thisagent, #ATTRIB_ResearchHealingPotions, ManaPoint_Amount);
	thisagent's "CurrentManaPoints_Base" += ManaPoint_Amount;
	//current_manapoints = $getattribute(thisagent, #ATTRIB_ResearchHealingPotions);
	while (thisagent's "CurrentManaPoints_Base" >= #Mana_point_limit) do
		begin
			$RestoreMana(thisagent, thisagent, 1);
			//$adjustattribute(thisagent, #ATTRIB_ResearchHealingPotions, -#Mana_point_limit);
			thisagent's "CurrentManaPoints_Base" -= #Mana_point_limit;
		end
End
///////////////////////////////////////////////////////////////////////////////////////////////////////
function RestoreMana( Agent ThisAgent, Agent Target, integer Mana_Amount )

Declare
	integer	Max_Mana;

Begin
	if ($isdead(target))
		return;

	//This is the maximum amount of mana restored that a target can endure before they are over their maximum
	//Max_Mana = ($getattribute( Target,#ATTRIB_ResearchEnergyBlast )) - ($getattribute( Target,#ATTRIB_NumHealingPotions ));
	Max_Mana = (thisagent's "MaxMana_Total" - thisagent's "CurrentMana_Base");

	If (Mana_Amount > Max_Mana)
		Mana_Amount = Max_Mana;

	thisagent's "CurrentMana_Base" += Mana_Amount;
	$UpdateCurrentMana(thisagent);
	//$adjustattribute( Target, #ATTRIB_NumHealingPotions, Mana_Amount );
End

///////////////////////////////////////////////////////////////////////////////////////////////////////
function SpendMana( Agent Thisagent, integer Mana_Amount )

Declare

Begin
	if ($isdead(thisagent))
		return;

	thisagent's "CurrentMana_Base" += Mana_Amount;
	$UpdateCurrentMana(thisagent);
End

///////////////////////////////////////////////////////////////////////////////
function haslowMP(agent thisagent) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana_Base";
	maxMP = thisagent's "MaxMana_Total";
	
	if (maxMP == 0)
		maxMP = 1;
	
 	if (((MP * 100) / maxMP) <= 25) return TRUE;
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function hasMPPercent(agent thisagent, integer whatpercent) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana_Base";
	maxMP = thisagent's "MaxMana_Total";

	if (maxMP == 0)
		maxMP = 1;
	
 	if (((MP * 100) / maxMP) >= whatpercent) return TRUE;
	else
		return FALSE;
end
///////////////////////////////////////////////////////////////////////////////
function hasMPFlat(agent thisagent, integer whatamount) is boolean

declare
	integer MP,maxMP;

begin
	MP = thisagent's "CurrentMana_Base";

 	if (MP >= whatamount) return TRUE;
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
// Return the Palace ThisAgent belongs to, this can return an Outpost if
// an Outpost is ThisAgent's "Parent"
function GetPalace (Agent ThisAgent) is agent
Declare
	list	Palaces;
	agent	Closest_Palace;
	agent Parent;

Begin

	 Parent = $Parent (ThisAgent);

	If ($IsDead (Parent) == False)
		begin
			If (Parent's "SubType" == "Outpost")
				return Parent;
		end

	$ListObjects (ThisAgent, "Building", -1, Palaces, #CheckTitles, "Palace", #MyPlayer, #NoHiddenMap);

	If (ThisAgent's "Title" == "Palace")
		Palaces << ThisAgent;

	If ($ListSize (Palaces) > 0)
		return $ListMember (Palaces, 1);

	return $NullAgent ();
End

///////////////////////////////////////////////////////////////////////////////
// Returns the Palace of the player ThisAgent belongs to, even if ThisAgent
// is owned by an Outpost of the player.
Function GetTruePalace (agent ThisAgent) is agent
Declare
	list	Palaces;
	agent Palace;

Begin

	$ListObjects (ThisAgent, "Building", -1, Palaces, #CheckTitles, "Palace", #MyPlayer, #NoHiddenMap);

	If (ThisAgent's "Title" == "Palace")
		Palaces << ThisAgent;

	If ($ListSize (Palaces) > 0)
		return $ListMember (Palaces, 1);

	return $NullAgent ();
End

///////////////////////////////////////////////////////////////////////////////
// Checks to see is marketplace is dead or closed
function MarketInvalid ( agent thisagent ) is boolean
declare
begin
	if ($isdead(thisagent) == TRUE)
		return TRUE;

	if (thisagent's "Title" == "Closed")
		return TRUE;

	return FALSE;
end
///////////////////////////////////////////////////////////////////////////////
function listtitlesinRadiusAdvanced(agent thisagent,string type, string title, integer dist, integer modifier) is list

declare
	list new_list;
	list final_list;
	agent diddly;

begin
	$ListObjects(thisagent,type,dist,new_list, modifier );

	foreach diddly in new_list do
		begin
			if (diddly's "title" == title)
				begin
					final_list << diddly;
				end
		end
	return final_list;
end

///////////////////////////////////////////////////////////////////////////////
function give_gold(agent thisagent, integer amount)

declare

begin
	// play overlay over thisagent
	if (amount > 0)
		if ($HasAttribute("Has_Bank_Account", thisagent) != True)
			begin
				$createeffector(thisagent,"got_gold",0, Amount);
				$adjustattribute(thisagent,#ATTRIB_gold,amount);
				$debugout(thisagent's "title","got",amount,"gold.");
			end
		else if ($HasAttribute("Has_Bank_Account", thisagent) != False)
			if (thisagent's "Has_Bank_Account" != True)
				begin
					$createeffector(thisagent,"got_gold",0, Amount);
					$adjustattribute(thisagent,#ATTRIB_gold,amount);
					$debugout(thisagent's "title","got",amount,"gold.");
				end
			else if (thisagent's "Has_Bank_Account" != False)
				begin
					$createeffector(thisagent,"got_gold",0, Amount);
					$adjustattribute(thisagent,#ATTRIB_StoredGold,amount);
					$debugout(thisagent's "title","got",amount,"gold.");
					thisagent's "Bank_Account_Gold" = $GetAttribute(thisagent, #ATTRIB_StoredGold);
				end
end
///////////////////////////////////////////////////////////////////////////////
function RandomNumberNonZero(integer rand) is integer

declare
	integer return_int;

begin
	return_int = ($RandomNumber(rand) + 1);
	return return_int;
end
///////////////////////////////////////////////////////////////////////////////
// Returns the absolute value of an integer passed to it.
function AbsoluteValue ( integer number ) is integer
declare
begin
	if ( number < 0 )
		number = ( number * ( - 1 ));

	return number;
end

//////////////////////////////////////////////////////////////////////////////
function Display_Total_Attack_Damage(agent thisagent)

declare
	integer total_min, total_max, total_average;

begin
	total_min += thisagent's "Fire_Attack_Damage_Min" + thisagent's "Cold_Attack_Damage_Min" + thisagent's "Electric_Attack_Damage_Min" + thisagent's "Poison_Attack_Damage_Min" + thisagent's "Arcane_Attack_Damage_Min" + thisagent's "Force_Attack_Damage_Min" + thisagent's "Divine_Attack_Damage_Min" + thisagent's "Necrotic_Attack_Damage_Min" + thisagent's "Chaotic_Attack_Damage_Min" + thisagent's "Slashing_Attack_Damage_Min" + thisagent's "Crushing_Attack_Damage_Min" + thisagent's "Piercing_Attack_Damage_Min";
	total_min += thisagent's "Fire_Attack_Damage_Min_Modifier" + thisagent's "Cold_Attack_Damage_Min_Modifier" + thisagent's "Electric_Attack_Damage_Min_Modifier" + thisagent's "Poison_Attack_Damage_Min_Modifier" + thisagent's "Arcane_Attack_Damage_Min_Modifier" + thisagent's "Force_Attack_Damage_Min_Modifier" + thisagent's "Divine_Attack_Damage_Min_Modifier" + thisagent's "Necrotic_Attack_Damage_Min_Modifier" + thisagent's "Chaotic_Attack_Damage_Min_Modifier" + thisagent's "Slashing_Attack_Damage_Min_Modifier" + thisagent's "Crushing_Attack_Damage_Min_Modifier" + thisagent's "Piercing_Attack_Damage_Min_Modifier";
	
	total_max += thisagent's "Fire_Attack_Damage_Max" + thisagent's "Cold_Attack_Damage_Max" + thisagent's "Electric_Attack_Damage_Max" + thisagent's "Poison_Attack_Damage_Max" + thisagent's "Arcane_Attack_Damage_Max" + thisagent's "Force_Attack_Damage_Max" + thisagent's "Divine_Attack_Damage_Max" + thisagent's "Necrotic_Attack_Damage_Max" + thisagent's "Chaotic_Attack_Damage_Max" + thisagent's "Slashing_Attack_Damage_Max" + thisagent's "Crushing_Attack_Damage_Max" + thisagent's "Piercing_Attack_Damage_Max";
	total_max += thisagent's "Fire_Attack_Damage_Max_Modifier" + thisagent's "Cold_Attack_Damage_Max_Modifier" + thisagent's "Electric_Attack_Damage_Max_Modifier" + thisagent's "Poison_Attack_Damage_Max_Modifier" + thisagent's "Arcane_Attack_Damage_Max_Modifier" + thisagent's "Force_Attack_Damage_Max_Modifier" + thisagent's "Divine_Attack_Damage_Max_Modifier" + thisagent's "Necrotic_Attack_Damage_Max_Modifier" + thisagent's "Chaotic_Attack_Damage_Max_Modifier" + thisagent's "Slashing_Attack_Damage_Max_Modifier" + thisagent's "Crushing_Attack_Damage_Max_Modifier" + thisagent's "Piercing_Attack_Damage_Max_Modifier";
	
	total_average = ((total_min + total_max) / 2);
	total_average -= $GetAttribute(thisagent, #ATTRIB_Weapon_Struct_Bonus);
	$SetAttribute(thisagent, #ATTRIB_weapon_basic_damage, total_average);
end
//////////////////////////////////////////////////////////////////////////////
function Display_Total_Armor(agent thisagent)

declare
	integer total;

begin
	total += thisagent's "Armor_Physical_Total";
	total -= $GetAttribute(thisagent, #ATTRIB_Armor_Struct_Bonus);
	$SetAttribute(thisagent, #ATTRIB_armor_basic_damage, total);
end

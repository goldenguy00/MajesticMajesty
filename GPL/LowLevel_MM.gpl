///////////////////////////////////////////////////////////////////////////////
function compile_enemies_buildings(agent thisagent, integer range) is list
//Use this for the caster of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#NotMyPlayer);
	$ListObjects(thisagent,"lair",range,t4,#NotMyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#NotMyTeam);
	$ListObjects(thisagent,"building",range,t3,#NotMyTeam);
	t5 = $addlists(targets,t2,t3,t4);
	return t5;
end
///////////////////////////////////////////////////////////////////////////////
function compiletarget_enemies(agent thisagent, integer range) is list
//Use this for the target of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#MyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#MyPlayer);
	t5 = $addlists(targets,t2);
	return t5;
end
///////////////////////////////////////////////////////////////////////////////
function compiletarget_enemies_buildings(agent thisagent, integer range) is list
//Use this for the target of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#MyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#MyPlayer);
	$ListObjects(thisagent,"building",range,t3,#MyPlayer);
	$ListObjects(thisagent,"lair",range,t4,#MyPlayer);
	t5 = $addlists(targets,t2,t3,t4);
	return t5;
end

///////////////////////////////////////////////////////////////////////////////
function list_all_enemy_heroes(agent palace) is list

declare
	list guys,l2,l3;
	agent thing;

begin
	$listobjects(palace,"hero",-1,guys,#NotMyPlayer,#NoHiddenMap);
	$listobjects(palace,"invisible",-1,l2,#NotMyPlayer,#NoHiddenMap);
	$listobjects(palace,"camouflaged",-1,l3,#NotMyPlayer,#NoHiddenMap);

	l2 = $addlists(l2,l3);
	foreach thing in l2 do
		if (thing's "subtype" == "hero")
			guys << thing;

	return guys;
end

////////////////////////////////////////////////////////////////////////////////
function LevelTenHero(agent thisagent)

declare
	agent palace;
begin
	if (thisagent's "title" == "warrior")
		begin
			palace = $GetPalace(thisagent);
			if ($IsRunning (palace's "Guard_Spawn_Function") == False)
				begin
					$RunThread (palace's "Guard_Spawn_Function", 1000, palace);
				end
		end
	
end

////////////////////////////////////////////////////////////////////////////////
function AddAllAttributes(agent thisagent) is integer

declare
	integer stat_art, stat_int, stat_str, stat_vit, stat_will, stat_wis, stat_total;
	
begin
	if ($isvalidgamepiece(thisagent) != TRUE)
		return;
	stat_total = 0;
	stat_art = thisagent's "Artifice_Base";
	stat_total += stat_art;
	stat_int = thisagent's "Intelligence_Base";
	stat_total += stat_int;
	stat_str = thisagent's "Strength_Base";
	stat_total += stat_str;
	stat_vit = thisagent's "Vitality_Base";
	stat_total += stat_vit;
	stat_will = thisagent's "Willpower_Base";
	stat_total += stat_will;
	stat_wis = thisagent's "Wisdom_Base";
	stat_total += stat_wis;
		
	return stat_total;
end

////////////////////////////////////////////////////////////////////////////////
function PreferredAttribute(agent thisagent) is string

declare
	boolean passed;
	string unit_name, pref_attribute;
	integer chance, total_attributes;
	integer stat_art, stat_int, stat_str, stat_vit, stat_will, stat_wis;
	integer chance_total, seq_task;
	
begin
	chance_total = $RandomNumberNonZero(thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance" + thisagent's "UpStrengthChance" + thisagent's "UpVitalityChance" + thisagent's "UpWillpowerChance" + thisagent's "UpWisdomChance");
	unit_name = thisagent's "title";
	passed = TRUE;
	chance = 100;
	stat_art = thisagent's "Artifice_Base";
	stat_int = thisagent's "Intelligence_Base";
	stat_str = thisagent's "Strength_Base";
	stat_vit = thisagent's "Vitality_Base";
	stat_will = thisagent's "Willpower_Base";
	stat_wis = thisagent's "Wisdom_Base";
	total_attributes = $AddAllAttributes(thisagent);
	pref_attribute = thisagent's "PrimaryStat_Base";
	
	if (thisagent's "UpArtificeChance" <= chance_total)
		pref_attribute = "Artifice_Base";
	else if ((thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance")  <= chance_total)
		pref_attribute = "Intelligence_Base";
	else if ((thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance" + thisagent's "UpStrengthChance")  <= chance_total)
		pref_attribute = "Strength_Base";
	else if ((thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance" + thisagent's "UpStrengthChance" + thisagent's "UpVitalityChance")  <= chance_total)
		pref_attribute = "Vitality_Base";
	else if ((thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance" + thisagent's "UpStrengthChance" + thisagent's "UpVitalityChance" + thisagent's "UpWillpowerChance")  <= chance_total)
		pref_attribute = "Willpower_Base";
	else if ((thisagent's "UpArtificeChance" + thisagent's "UpIntelligenceChance" + thisagent's "UpStrengthChance" + thisagent's "UpVitalityChance" + thisagent's "UpWillpowerChance" + thisagent's "UpWisdomChance")  <= chance_total)
		pref_attribute = "Wisdom_Base";
	
	if (unit_name == "warrior")
		begin
			if ($RandomNumber(stat_str) + 80 < $RandomNumber(total_attributes))
				pref_attribute = "Strength_Base";
			else if ($RandomNumber(stat_vit) + 70 < $RandomNumber(total_attributes))
				pref_attribute = "Vitality_Base";
			else if ($RandomNumber(stat_will) + 60 < $RandomNumber(total_attributes))
				pref_attribute = "Willpower_Base";
			else if ($RandomNumber(stat_int) + 50 < $RandomNumber(total_attributes))
				pref_attribute = "Intelligence_Base";
			else if ($RandomNumber(stat_art) + 40 < $RandomNumber(total_attributes))
				pref_attribute = "Artifice_Base";
			else if ($RandomNumber(stat_wis) + 30 < $RandomNumber(total_attributes))
				pref_attribute = "Wisdom_Base";
			else
				passed = FALSE;
		end
		
	else if (unit_name == "ranger")
		begin
			if ($RandomNumber(stat_will) + 80 < $RandomNumber(total_attributes))

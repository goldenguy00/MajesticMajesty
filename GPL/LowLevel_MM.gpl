///////////////////////////////////////////////////////////////////////////////
// The necessary function for if heroes have not loaded in their hero attributes for leveling up
Function Level_Up_Required_Attributes(agent thisagent)
declare
begin
	$EnsureAllAttr(thisagent);

	$UpdateArtifice(thisagent);
	$UpdateStrength(thisagent);
	$UpdateVitality(thisagent);
	$UpdateIntelligence(thisagent);
	$UpdateWillpower(thisagent);
	$UpdateWisdom(thisagent);

	$UpdateMaxXP(thisagent);
	$UpdateMaxHP(thisagent);
	$UpdateMaxMana(thisagent);
end

function EnsureAllAttr(agent thisagent)
declare
begin

	if ($HasAttribute("Has_Level_Up_Attributes", thisagent) == True)
		begin
			$AddAttribute(thisagent, "Has_Level_up_attributes", "boolean", true);

			$AddAttribute(thisagent, "InsightPoints", "integer");
			$AddAttribute(thisagent, "self_estimation", "integer");
			$AddAttribute(thisagent, "percentageHPretreat", "integer");
			$AddAttribute(thisagent, "loyalty", "integer");

			$AddAttribute(thisagent, "PrimaryStat", "integer", #ATTRIB_Vitality);
			$AddAttribute(thisagent, "PrimaryStat_Base", "string", "Vitality_Base");

			$AddAttribute(thisagent, "UpArtificeChance", "integer", 10);
			$AddAttribute(thisagent, "UpIntelligenceChance", "integer", 10);
			$AddAttribute(thisagent, "UpStrengthChance", "integer", 10);
			$AddAttribute(thisagent, "UpVitalityChance", "integer", 10);
			$AddAttribute(thisagent, "UpWillpowerChance", "integer", 10);
			$AddAttribute(thisagent, "UpWisdomChance", "integer", 10);

			$AddAttribute(thisagent, "Experience_Value_Base", "integer", 100);
		end
end

function EnsureStatAttr(agent thisagent, string stat, integer default)
declare
begin
	$AddAttribute(thisagent, stat+"_Base", "integer", default);
	$AddAttribute(thisagent, stat+"_Flat_Modifier", "integer");
	$AddAttribute(thisagent, stat+"_Percent_Modifier", "integer");
	$AddAttribute(thisagent, stat+"_Total", "integer");
end
///////////////////////////////////////////////////////////////////////////////
// this function is called by the in-game code when a vehicle is generated
Function Generate_Character_Attributes(agent thisagent)

declare
	integer var_range,i,var_amount,adjustment,mult;
	list var_names,buildings,sublist1;
	integer thisvar;
	agent RootAgent;

begin
	// fairground, library, Fervus, and Krolm affect attributes of all heros
	// Fervus gives rogues artifice...

	// do the basic randomness per var
	var_names << #ATTRIB_strength;
	var_names << #ATTRIB_vitality;
	var_names << #ATTRIB_Artifice;
	var_names << #ATTRIB_intelligence;
	var_names << #ATTRIB_willpower;
	
	thisagent's "MaxLevelXP_Base" = ($getattribute(thisagent,#ATTRIB_LevelXP) * 10);

	i = 0;

	while (i < 4) do
		begin
			thisvar = $listmember(var_names,1);
			var_names -= thisvar;

			var_range = $randomnumber(5) - 2;

			var_amount = $getattribute(thisagent,thisvar);
			var_amount += var_range;
			if (var_amount < 1) var_amount = 1;

			$setattribute(thisagent,thisvar,var_amount);
			i++;
		end
		
	$Level_Up_Required_Attributes(thisagent);	
		
	// check for special conditions in the kingdom
	$ListObjects(thisagent,"building",-1,buildings,#MyPlayer);

	// library +1 intelligence per 1,2,4,8... libraries
	sublist1 = $removetitles(buildings,"library");

	adjustment = 0; mult = 1; i = 1;

	while ($listsize(sublist1) > 0) do
		begin
			if (i / mult > 0)
				begin
					adjustment += (i / mult);
					mult *= 2;
				end
			i++;
			$removelistmember(sublist1,1);
		end

	$adjustattribute(thisagent,#ATTRIB_intelligence,adjustment);
	thisagent's "Intelligence_Base" = $getAttribute(thisagent, #ATTRIB_intelligence);

	// fairground +1 stregnth
	sublist1 = $removetitles(buildings,"fairgrounds");

	if ($listsize(sublist1) > 0)
		$adjustattribute(thisagent,#ATTRIB_strength,1);

	thisagent's "Strength_Base" = $getAttribute(thisagent, #ATTRIB_strength);
	
	// fervus rogues +3 artifice, everyone +1 luck

	// Krolm +.1 self_estimation, -5 HPretreat per temple
	sublist1 = $removetitles(buildings,"Temple_krolm");

	adjustment = $listsize(sublist1);

	thisagent's "self_estimation" += (adjustment / 10);
	adjustment *= 5;
	adjustment = thisagent's "percentageHPretreat" - adjustment;
	if (adjustment < 5) adjustment = 5;
	thisagent's "percentageHPretreat" = adjustment;

	// gnomes +1 luck

	// statues +5 loyalty each
	sublist1 = $removetitles(buildings,"statue");

	adjustment = $listsize(sublist1) *	#statue_loyalty_boost;
	thisagent's "loyalty" += adjustment;

	sublist1 = $removetitles(buildings,"royal_gardens");
	adjustment = $listsize(sublist1) *	#gardens_loyalty_boost;

	thisagent's "loyalty" += adjustment;

	//Quest-specific ActiveScript overrides to make units dumber. See Wizard's Curse
	RootAgent = $RetrieveAgent ("GPLAiRoot");

	If (RootAgent's "Quest_Number" == #QNumber_Wizards_Curse)
		begin
			If ($GetUnitPlayerNumber (ThisAgent) == #Player_1)
				begin

					//This is run after a heroes be dumb script runs
					ThisAgent's "QuestScript" = ThisAgent's "StartingScript";

					//Init scripts to be_dumb. it will call their decision trees via QuestScript
					ThisAgent's "StartingScript" = $Be_Dumb;


					//Make the hero stupid, with the worst intel being 1
					If ($GetAttribute (ThisAgent, #ATTRIB_Intelligence) <= #WCurse_Dumb_Penalty)
						$SetAttribute (ThisAgent, #ATTRIB_Intelligence, 1);

					Else
						$AdjustAttribute (ThisAgent, #ATTRIB_Intelligence, -(#WCurse_Dumb_Penalty));

				end
		end
end

////////////////////////////////////////////////////////////////////////////////
function AdjustAttributeBase(agent thisagent, integer gameAttrib, string attribute, integer amount)

declare

begin
	if (gameAttrib != 0)
		begin
			$adjustattribute(thisagent, gameAttrib, amount);
			thisagent's attribute += amount;
		end
	else
		thisagent's attribute += amount;
end
////////////////////////////////////////////////////////////////////////////////
function UpdatePrimaryStat(agent thisagent)

declare

begin
	if (thisagent's "PrimaryStat_Base" == "Artifice_Base")
		$UpdateArtifice(thisagent);
	else if (thisagent's "PrimaryStat_Base" == "Intelligence_Base")
		$UpdateIntelligence(thisagent);
	else if (thisagent's "PrimaryStat_Base" == "Strength_Base")
		$UpdateStrength(thisagent);
	else if (thisagent's "PrimaryStat_Base" == "Vitality_Base")
		$UpdateVitality(thisagent);
	else if (thisagent's "PrimaryStat_Base" == "Willpower_Base")
		$UpdateWillpower(thisagent);
	else if (thisagent's "PrimaryStat_Base" == "Wisdom_Base")
		$UpdateWisdom(thisagent);
end

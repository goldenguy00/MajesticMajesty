function BuffDebuffList(agent thisagent)
//Adds these attributes whenever searching for a valid target.

declare

begin
	//GENERIC
	$AddAttribute(thisagent, "Generic_RegenerateBuff_End", "function", $Generic_RegenerateBuff_End);

///////////////////////////////////////////////////////////////////////////////
function Henchman_haslowHP(agent thisagent) is boolean

declare
	integer HP,maxHP;

begin
	HP = $getattribute(thisagent,#ATTRIB_HP);
	maxHP = $getattribute(thisagent,#ATTRIB_MAXHP);

 	if (((HP * 100) / maxHP) <= 50) return TRUE;
	else
		return FALSE;
end


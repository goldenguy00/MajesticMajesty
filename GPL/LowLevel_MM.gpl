///////////////////////////////////////////////////////////////////////////////
function Henchman_haslowHP(agent thisagent) is boolean

declare
	integer HP,maxHP;

begin
	HP = $getattribute(thisagent,#ATTRIB_HP);
	maxHP = $getattribute(thisagent,#ATTRIB_MAXHP);

 	if (((HP * 100) / maxHP) <= 50) return TRUE;
	else
		return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function StringInList(string thisstring,list thislist) is Boolean

declare
	string any_string;
	boolean is_it_here;

begin
	is_it_here = FALSE;

	foreach any_string in thislist do
		if (any_string == thisstring) is_it_here = TRUE;

	return is_it_here;

end

///////////////////////////////////////////////////////////////////////////////
function IntegerInList(integer thisinteger,list thislist) is Boolean

declare
	integer any_integer;
	boolean is_it_here;

begin
	is_it_here = FALSE;

	foreach any_integer in thislist do
		if (any_integer == thisinteger) is_it_here = TRUE;

	return is_it_here;

end

///////////////////////////////////////////////////////////////////////////////
function compile_enemies_buildings(agent thisagent, integer range) is list
//Use this for the caster of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#NotMyPlayer);
	$ListObjects(thisagent,"lair",range,t4,#NotMyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#NotMyTeam);
	$ListObjects(thisagent,"building",range,t3,#NotMyTeam);
	t5 = $addlists(targets,t2,t3,t4);
	return t5;
end
///////////////////////////////////////////////////////////////////////////////
function compiletarget_enemies(agent thisagent, integer range) is list
//Use this for the target of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#MyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#MyPlayer);
	t5 = $addlists(targets,t2);
	return t5;
end
///////////////////////////////////////////////////////////////////////////////
function compiletarget_enemies_buildings(agent thisagent, integer range) is list
//Use this for the target of an area of effect spell
declare
	list targets,t2,t3,t4,t5;

begin
	$ListObjects(thisagent,"monster",range,targets,#MyPlayer);
	$ListObjects(thisagent,"hero",range,t2,#MyPlayer);
	$ListObjects(thisagent,"building",range,t3,#MyPlayer);
	$ListObjects(thisagent,"lair",range,t4,#MyPlayer);
	t5 = $addlists(targets,t2,t3,t4);
	return t5;
end

///////////////////////////////////////////////////////////////////////////////
function list_all_enemy_heroes(agent palace) is list

declare
	list guys,l2,l3;
	agent thing;

begin
	$listobjects(palace,"hero",-1,guys,#NotMyPlayer,#NoHiddenMap);
	$listobjects(palace,"invisible",-1,l2,#NotMyPlayer,#NoHiddenMap);
	$listobjects(palace,"camouflaged",-1,l3,#NotMyPlayer,#NoHiddenMap);

	l2 = $addlists(l2,l3);
	foreach thing in l2 do
		if (thing's "subtype" == "hero")
			guys << thing;

	return guys;
end

////////////////////////////////////////////////////////////////////////////////
function LevelTenHero(agent thisagent)

declare
	agent palace;
begin
	if (thisagent's "title" == "warrior")
		begin
			palace = $GetPalace(thisagent);
			if ($IsRunning (palace's "Guard_Spawn_Function") == False)
				begin
					$RunThread (palace's "Guard_Spawn_Function", 1000, palace);
				end
		end
	
end

function GetStatOrder(string unit_name) is list
declare
	list stat_list;
begin
	if (unit_name == "warrior")
		begin
			stat_list << "Strength";
			stat_list << "Vitality";
			stat_list << "Willpower";
			stat_list << "Intelligence";
			stat_list << "Artifice";
			stat_list << "Wisdom";
		end
		
	else if (unit_name == "ranger")
		begin
			stat_list << "Willpower";
			stat_list << "Artifice";
			stat_list << "Intelligence";
			stat_list << "Strength";
			stat_list << "Wisdom";
			stat_list << "Vitality";
		end
		
	else if (unit_name == "rogue")
		begin
			stat_list << "Artifice";
			stat_list << "Intelligence";
			stat_list << "Vitality";
			stat_list << "Strength";
			stat_list << "Willpower";
			stat_list << "Wisdom";
		end
		
	else if (unit_name == "wizard")
		begin
			stat_list << "Intelligence";
			stat_list << "Willpower";
			stat_list << "Wisdom";
			stat_list << "Artifice";
			stat_list << "Vitality";
			stat_list << "Strength";
		end
		
	else if (unit_name == "paladin")
		begin
			stat_list << "Willpower";
			stat_list << "Strength";
			stat_list << "Vitality";
			stat_list << "Wisdom";
			stat_list << "Intelligence";
			stat_list <<  "Artifice";
		end
		
	else if (unit_name == "warrior_of_discord")
		begin

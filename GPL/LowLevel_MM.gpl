function UpdateArtifice(agent thisagent)
declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_Artifice, "Artifice");
end

////////////////////////////////////////////////////////////////////////////
function UpdateStrength(agent thisagent)

declare
begin
	$UpdateAttribute(thisagent, #ATTRIB_Strength, "Strength");
end


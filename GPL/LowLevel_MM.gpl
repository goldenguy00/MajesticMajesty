////////////////////////////////////////////////////////////////////////////////
function PreferredAttributeExtra(agent thisagent, boolean primary_allowed) is string

declare
	boolean passed;
	string unit_name, pref_attribute;
	integer chance, total_attributes;
	integer stat_art, stat_int, stat_str, stat_vit, stat_will, stat_wis;
	
begin
	unit_name = thisagent's "title";
	passed = TRUE;
	chance = 100;
	pref_attribute = thisagent's "PrimaryStat_Base";
	stat_art = thisagent's "Artifice_Base";
	stat_int = thisagent's "Intelligence_Base";
	stat_str = thisagent's "Strength_Base";
	stat_vit = thisagent's "Vitality_Base";
	stat_will = thisagent's "Willpower_Base";
	stat_wis = thisagent's "Wisdom_Base";
	total_attributes = $AddAllAttributes(thisagent);
	
	if (unit_name == "warrior")
		begin
			if ($RandomNumber(stat_str) + 80 < $RandomNumber(total_attributes) && (primary_allowed != FALSE))
				pref_attribute = "Strength_Base";
			else if ($RandomNumber(stat_vit) + 70 < $RandomNumber(total_attributes))
				pref_attribute = "Vitality_Base";
			else if ($RandomNumber(stat_will) + 60 < $RandomNumber(total_attributes))
				pref_attribute = "Willpower_Base";
			else if ($RandomNumber(stat_int) + 50 < $RandomNumber(total_attributes))
				pref_attribute = "Intelligence_Base";
			else if ($RandomNumber(stat_art) + 40 < $RandomNumber(total_attributes))
				pref_attribute = "Artifice_Base";
			else if ($RandomNumber(stat_wis) + 30 < $RandomNumber(total_attributes))
				pref_attribute = "Wisdom_Base";
			else
				passed = FALSE;
		end
		
	else if (unit_name == "ranger")
		begin
			if ($RandomNumber(stat_will) + 80 < $RandomNumber(total_attributes))
				pref_attribute = "Willpower_Base";

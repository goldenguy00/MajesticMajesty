	//HEALER
	$AddAttribute(thisagent, "Healer_MeditationBuff_End", "function", $Healer_MeditationBuff_End);
	
	//MONK
	$AddAttribute(thisagent, "Monk_HandsOfSteelBuff_End", "function", $Monk_HandsOfSteelBuff_End);
	$AddAttribute(thisagent, "Monk_StoneSkinBuff_End", "function", $Monk_StoneSkinBuff_End);
	$AddAttribute(thisagent, "Monk_IronWillBuff_End", "function", $Monk_IronWillBuff_End);
	
	//PALADIN
	$AddAttribute(thisagent, "Paladin_ShieldOfLightBuff_End", "function", $Paladin_ShieldOfLightBuff_End);
	

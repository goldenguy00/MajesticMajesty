	$AddAttribute(thisagent, "Wizard_ResistMagicBuff_End", "function", $Wizard_ResistMagicBuff_End);
			
end
///////////////////////////////////////////////////////////////////////////////
// this function is called by the in-game code when a vehicle is generated
Function Generate_Character_Attributes(agent thisagent)

declare
	integer var_range,i,var_amount,adjustment,mult;
	list var_names,buildings,sublist1;
	string thisvar;
	agent RootAgent;

begin
	$InitBaseStats(thisagent);

	// fairground, library, Fervus, and Krolm affect attributes of all heros
	// Fervus gives rogues artifice...

	// do the basic randomness per var
	var_names << "strength";
	var_names << "vitality";
	var_names << "Artifice";
	var_names << "intelligence";
	var_names << "willpower";
	
	i = 0;

	while (i < 4) do
		begin
			thisvar = $listmember(var_names,1);
			var_names -= thisvar;

			var_range = $randomnumber(5) - 2;

			var_amount = $GetBaseStat(thisagent,thisvar);
			var_amount += var_range;
			if (var_amount < 1) var_amount = 1;

			$AdjustBaseStat(thisagent,thisvar,var_amount);
			i++;
		end
	
	// check for special conditions in the kingdom
	$ListObjects(thisagent,"building",-1,buildings,#MyPlayer);

	// library +1 intelligence per 1,2,4,8... libraries
	sublist1 = $removetitles(buildings,"library");

	adjustment = 0; mult = 1; i = 1;

	while ($listsize(sublist1) > 0) do
		begin
			if (i / mult > 0)
				begin
					adjustment += (i / mult);
					mult *= 2;
				end
			i++;
			$removelistmember(sublist1,1);
		end

	$AdjustBaseStat(thisagent, "Intelligence", adjustment);

	// fairground +1 stregnth
	sublist1 = $removetitles(buildings,"fairgrounds");

	if ($listsize(sublist1) > 0)
		$AdjustBaseStat(thisagent,"strength", 1);
	
	// fervus rogues +3 artifice, everyone +1 luck

	// Krolm +.1 self_estimation, -5 HPretreat per temple
	sublist1 = $removetitles(buildings,"Temple_krolm");

	adjustment = $listsize(sublist1);

	thisagent's "self_estimation" += (adjustment / 10);
	adjustment *= 5;
	adjustment = thisagent's "percentageHPretreat" - adjustment;
	if (adjustment < 5) adjustment = 5;
	thisagent's "percentageHPretreat" = adjustment;

	// gnomes +1 luck

	// statues +5 loyalty each
	sublist1 = $removetitles(buildings,"statue");

	adjustment = $listsize(sublist1) *	#statue_loyalty_boost;
	thisagent's "loyalty" += adjustment;

	sublist1 = $removetitles(buildings,"royal_gardens");
	adjustment = $listsize(sublist1) *	#gardens_loyalty_boost;

	thisagent's "loyalty" += adjustment;

	//Quest-specific ActiveScript overrides to make units dumber. See Wizard's Curse
	RootAgent = $RetrieveAgent ("GPLAiRoot");

	If (RootAgent's "Quest_Number" == #QNumber_Wizards_Curse)
		begin
			If ($GetUnitPlayerNumber (ThisAgent) == #Player_1)
				begin

					//This is run after a heroes be dumb script runs
					ThisAgent's "QuestScript" = ThisAgent's "StartingScript";

					//Init scripts to be_dumb. it will call their decision trees via QuestScript
					ThisAgent's "StartingScript" = $Be_Dumb;


					//Make the hero stupid, with the worst intel being 1
					If ($GetAttribute (ThisAgent, #ATTRIB_Intelligence) <= #WCurse_Dumb_Penalty)
						$SetBaseStat (ThisAgent, "Intelligence", 1);

					Else
						$AdjustBaseStat (ThisAgent, "Intelligence", -(#WCurse_Dumb_Penalty));

				end
		end

	$RecalculateStats(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
// The necessary function for if heroes have not loaded in their hero attributes for leveling up
Function RecalculateStats(agent thisagent)
declare
begin
	$UpdateArtifice(thisagent);
	$UpdateStrength(thisagent);
	$UpdateVitality(thisagent);
	$UpdateIntelligence(thisagent);
	$UpdateWillpower(thisagent);
	$UpdateWisdom(thisagent);

	$UpdateMaxHP(thisagent);
	$UpdateMaxMana(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
function InitBaseStats(agent thisagent)
declare
begin
	// just check if something only created here exists. not foolproof but the attribute bloat needs to stop.
	if ($HasAttribute("Presige", thisagent) == false)
		begin
			$InitBaseStat(thisagent, "Artifice", $GetAttribute(thisagent, #ATTRIB_Artifice));
			$InitBaseStat(thisagent, "Strength", $GetAttribute(thisagent, #ATTRIB_Strength));
			$InitBaseStat(thisagent, "Vitality", $GetAttribute(thisagent, #ATTRIB_Vitality));
			$InitBaseStat(thisagent, "Intelligence", $GetAttribute(thisagent, #ATTRIB_Intelligence));
			$InitBaseStat(thisagent, "Willpower", $GetAttribute(thisagent, #ATTRIB_Willpower));
			$InitBaseStat(thisagent, "Wisdom", $StartingWisdom(thisagent));

			$InitBaseStat(thisagent, "Armor_Magical", $GetAttribute(thisagent, #ATTRIB_MagicResistance));
			if ($HasAttribute("Armor_Physical_Base", thisagent) == false)
				$InitBaseStat(thisagent, "Armor_Physical", $GetAttribute(thisagent, #ATTRIB_armor_basic_damage));
			$AddAttribute(thisagent, "Armor_Physical_Flat_Modifier", "integer");

			$InitBaseStat(thisagent, "MaxHP", $GetAttribute(thisagent, #ATTRIB_MaxHP));
			$InitBaseStat(thisagent, "MaxMana", #Base_Mana + ($GetBaseStat(thisagent, "Intelligence") * #Mana_Amount_Int));
			$AddAttribute(thisagent, "CurrentMana", "integer", $GetBaseStatTotal(thisagent, "MaxMana"));
			$InitBaseStat(thisagent, "ManaRegeneration", #Mana_Regeneration_Base + ($GetBaseStat(thisagent, "Intelligence") * #Mana_Regeneration_Int));
			$InitBaseStat(thisagent, "HealthRegeneration", #Health_Regeneration_Base + ($GetBaseStat(thisagent, "Vitality") * #Health_Regeneration_Vit));
			
			$AddAttribute(thisagent, "PrimaryStat", "integer", #ATTRIB_Vitality);
			$AddAttribute(thisagent, "PrimaryStat_Name", "string", "Vitality");
			$AddAttribute(thisagent, "loyalty", "integer", 50);
			$AddAttribute(thisagent, "Prestige", "integer", $StartingPrestige(thisagent));
			$AddAttribute(thisagent, "InsightPoints", "integer");
			$SetNegativeResistance(thisagent);
			$RecalculateStats(thisagent);
		end
end

////////////////////////////////////////////////////////////////////////////////
function InitBaseStat(agent thisagent, string stat, integer default)
declare
begin
	if ($AddAttribute(thisagent, stat+"_Base", "integer", default) == false)
		thisagent's (stat+"_Base") = default;
	
	if ($AddAttribute(thisagent, stat+"_Total", "integer", default) == false)
		thisagent's (stat+"_Total") = default;
end

////////////////////////////////////////////////////////////////////////////////
function GetBaseStat(agent thisagent, string stat) is integer
declare
begin
	return thisagent's (stat+"_Base");
end

////////////////////////////////////////////////////////////////////////////////
function GetBaseStatTotal(agent thisagent, string stat) is integer
declare
begin
	return thisagent's (stat+"_Total");
end

////////////////////////////////////////////////////////////////////////////////
function AdjustBaseStat(agent thisagent, string stat_name, integer delta)
declare
	function update_func;
begin
	thisagent's (stat_name+"_Base") += delta;

	update_func = $LookupFunction("Update"+stat_name);
	if ($ValidFunction(update_func))
		update_func(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
function SetBaseStat(agent thisagent, string stat_name, integer delta)
declare
	function update_func;
begin
	thisagent's (stat_name+"_Base") = delta;

	update_func = $LookupFunction("Update"+stat_name);
	if ($ValidFunction(update_func))
		update_func(thisagent);
end

////////////////////////////////////////////////////////////////////////////////
function GetAttributeSafe(agent thisagent, string attr) is integer
declare
begin
	if ($HasAttribute(attr, thisagent) == false) return 0;
	return thisagent's attr;
end

////////////////////////////////////////////////////////////////////////////////
function AdjustAttributeSafe(agent thisagent, string attr, integer delta)
declare
begin
	if (delta == 0) return;
	if ($AddAttribute(thisagent, attr, "integer", delta) == false)
		thisagent's attr += delta;
end

////////////////////////////////////////////////////////////////////////////////
function SetAttributeSafe(agent thisagent, string attr, integer value)
declare
begin
	if ($AddAttribute(thisagent, attr, "integer", value) == false)
		thisagent's attr = value;
end

////////////////////////////////////////////////////////////////////////////////
function UpdateArtifice(agent thisagent)
declare
	integer delta;
begin
	delta = $RecalculateAttributeTotal(thisagent, #ATTRIB_Artifice, "Artifice");
	if (delta != 0)
		begin
			delta *= -1;
			$adjustattribute(thisagent,#ATTRIB_MovementRateModifier, delta * #artifice_movespeed );
			$adjustattribute(thisagent,#ATTRIB_ActionRateModifier, delta * #artifice_attackspeed );
		end
end

////////////////////////////////////////////////////////////////////////////
function UpdateStrength(agent thisagent)
declare
begin
	$RecalculateAttributeTotal(thisagent, #ATTRIB_Strength, "Strength");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateVitality(agent thisagent)
declare
	integer delta;
begin
	delta = $RecalculateAttributeTotal(thisagent, #ATTRIB_Vitality, "Vitality");
	$AdjustBaseStat(thisagent, "Armor_Physical", (delta / 10));
	$SetBaseStat(thisagent, "HealthRegeneration", #Health_Regeneration_Base + ($GetBaseStat(thisagent, "Vitality") * #Health_Regeneration_Vit));
end

////////////////////////////////////////////////////////////////////////////////
function UpdateHealthRegeneration(agent thisagent)
declare
begin
	$RecalculateStatTotal(thisagent, "HealthRegeneration");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateWillpower(agent thisagent)
declare
begin
	$RecalculateAttributeTotal(thisagent, #ATTRIB_Willpower, "Willpower");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateWisdom(agent thisagent)
declare
begin
	$RecalculateStatTotal(thisagent, "Wisdom");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateIntelligence(agent thisagent)
declare
	integer delta;
begin
	delta = $RecalculateAttributeTotal(thisagent, #ATTRIB_Intelligence, "Intelligence");
	$AdjustBaseStat(thisagent, "Armor_Magical", (delta / 10));
	$SetBaseStat(thisagent, "MaxMana", #Base_Mana + ($GetBaseStat(thisagent, "Intelligence") * #Mana_Amount_Int));
	$SetBaseStat(thisagent, "ManaRegeneration", #Mana_Regeneration_Base + ($GetBaseStat(thisagent, "Intelligence") * #Mana_Regeneration_Int));
end

////////////////////////////////////////////////////////////////////////////////
function UpdateManaRegeneration(agent thisagent)
declare
begin
	$RecalculateStatTotal(thisagent, "ManaRegeneration");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateMaxMana(agent thisagent)
declare
begin
	$RecalculateStatTotal(thisagent, "MaxMana");
	if (thisagent's "CurrentMana" > $GetBaseStatTotal(thisagent, "MaxMana"))
		thisagent's "CurrentMana" = $GetBaseStatTotal(thisagent, "MaxMana");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateMaxHP(agent thisagent)
declare
	integer delta;
begin
	delta = $RecalculateAttributeTotal(thisagent, #ATTRIB_MaxHP, "MaxHP");
	if (delta > 0)
		$AdjustAttribute(thisagent, #ATTRIB_HP, delta);
end

////////////////////////////////////////////////////////////////////////////////
function UpdateArmor_Physical(agent thisagent)
declare
begin
	if ($HasAttribute("Armor_Physical_BodyArmor", thisagent))
		thisagent's "Armor_Physical_Flat_Modifier" = thisagent's "Armor_Physical_BodyArmor" + thisagent's "Armor_Physical_Helm" + thisagent's "Armor_Physical_Gloves"
				 									+ thisagent's "Armor_Physical_Boots" + thisagent's "Armor_Physical_Belt" + thisagent's "Armor_Physical_Shield";
	$RecalculateAttributeTotal(thisagent, #ATTRIB_armor_basic_damage, "Armor_Physical");
end

////////////////////////////////////////////////////////////////////////////////
function UpdateArmor_Magical(agent thisagent)
declare
begin
	$RecalculateAttributeTotal(thisagent, #ATTRIB_MagicResistance, "Armor_Magical");
end

////////////////////////////////////////////////////////////////////////////////
function RecalculateAttributeTotal(agent thisagent, integer attrib_int, string attrib) is integer
declare
	integer delta;
begin
	delta = $RecalculateStatTotal(thisagent, attrib);
	if (delta != 0)
		$AdjustAttribute(thisagent, attrib_int, delta);
	//thisagent's (attrib+"_Total") = $GetAttribute(thisagent, attrib_int);
	return delta;
end

////////////////////////////////////////////////////////////////////////////////
function RecalculateStatTotal(agent thisagent, string attrib) is integer
declare
	integer prev_total, base, flat, percent;

begin
	base = $GetBaseStat(thisagent, attrib);
	flat = $GetAttributeSafe(thisagent, attrib+"_Flat_Modifier");
	percent = $GetAttributeSafe(thisagent, attrib+"_Percent_Modifier");

	if (percent != 0) 
		percent = $PercentOf(base, percent, (base >= 1000));

	prev_total = $GetBaseStatTotal(thisagent, attrib);
	thisagent's (attrib+"_Total") = base + flat + percent;

	return $GetBaseStatTotal(thisagent, attrib) - prev_total;
end

////////////////////////////////////////////////////////////////////////////////
function GenerateHeroAttributes(agent thisagent)
declare
begin
	if ($HasAttribute("RegenerationSystem", thisagent))
		return;

	$AddAttribute(thisagent, "ManaRegenPoints", "integer");
	$AddAttribute(thisagent, "HealthRegenPoints", "integer");
	$AddAttribute(thisagent, "RegenerationSystem", "function", $Regeneration_System);
	$NewThread(ThisAgent's "RegenerationSystem", 300, ThisAgent ); //Doubled the cycle time, halved the threshold for regen
	$RestoreMana(thisagent, thisagent, thisagent's "MaxMana_Total");

	if (thisagent's "title" == "wizard")
		$AddFireTree(thisagent);			//Need to rewrite the entire spell system first.

	$AddAttribute(thisagent, "Primary_Orientation", "string");
	thisagent's "Primary_Orientation" = $HeroSkillOrientationPrimary(thisagent);
	$AddAttribute(thisagent, "Secondary_Orientation", "string");
	thisagent's "Secondary_Orientation" = $HeroSkillOrientationSecondary(thisagent);
	$HeroPreferredSkills(thisagent);
	
	$StartingSpellCooldowns(thisagent);
	
	if ($HasAttribute("Uses_Equipment", thisagent))
		if (thisagent's "Uses_Equipment"== True)
			$HeroStartingEquipment(thisagent); // Take care of this part now that new prototype is used
	
end

////////////////////////////////////////////////////////////////////////////////
function SetNegativeResistance(agent thisagent)

declare

begin
	// not our prototype
	if ($HasAttribute("Fire_Resistance_Percent_Neg", thisagent) == false)
		return;

	if (thisagent's "Fire_Resistance_Percent_Neg" == True)
		thisagent's "Fire_Resistance_Percent" *= -1;
	if (thisagent's "Cold_Resistance_Percent_Neg" == True)
		thisagent's "Cold_Resistance_Percent" *= -1;
	if (thisagent's "Electric_Resistance_Percent_Neg" == True)
		thisagent's "Electric_Resistance_Percent" *= -1;
	if (thisagent's "Poison_Resistance_Percent_Neg" == True)
		thisagent's "Poison_Resistance_Percent" *= -1;
	if (thisagent's "Arcane_Resistance_Percent_Neg" == True)
		thisagent's "Arcane_Resistance_Percent" *= -1;
	if (thisagent's "Force_Resistance_Percent_Neg" == True)
		thisagent's "Force_Resistance_Percent" *= -1;
	if (thisagent's "Divine_Resistance_Percent_Neg" == True)
		thisagent's "Divine_Resistance_Percent" *= -1;
	if (thisagent's "Necrotic_Resistance_Percent_Neg" == True)
		thisagent's "Necrotic_Resistance_Percent" *= -1;
	if (thisagent's "Chaotic_Resistance_Percent_Neg" == True)
		thisagent's "Chaotic_Resistance_Percent" *= -1;
	if (thisagent's "Crushing_Resistance_Percent_Neg" == True)
		thisagent's "Crushing_Resistance_Percent" *= -1;
	if (thisagent's "Slashing_Resistance_Percent_Neg" == True)
		thisagent's "Slashing_Resistance_Percent" *= -1;
	if (thisagent's "Piercing_Resistance_Percent_Neg" == True)
		thisagent's "Piercing_Resistance_Percent" *= -1;
		
	if (thisagent's "Fire_Resistance_Flat_Neg" == True)
		thisagent's "Fire_Resistance_Flat" *= -1;
	if (thisagent's "Cold_Resistance_Flat_Neg" == True)
		thisagent's "Cold_Resistance_Flat" *= -1;
	if (thisagent's "Electric_Resistance_Flat_Neg" == True)
		thisagent's "Electric_Resistance_Flat" *= -1;
	if (thisagent's "Poison_Resistance_Flat_Neg" == True)
		thisagent's "Poison_Resistance_Flat" *= -1;
	if (thisagent's "Arcane_Resistance_Flat_Neg" == True)
		thisagent's "Arcane_Resistance_Flat" *= -1;
	if (thisagent's "Force_Resistance_Flat_Neg" == True)
		thisagent's "Force_Resistance_Flat" *= -1;
	if (thisagent's "Divine_Resistance_Flat_Neg" == True)
		thisagent's "Divine_Resistance_Flat" *= -1;
	if (thisagent's "Necrotic_Resistance_Flat_Neg" == True)
		thisagent's "Necrotic_Resistance_Flat" *= -1;
	if (thisagent's "Chaotic_Resistance_Flat_Neg" == True)
		thisagent's "Chaotic_Resistance_Flat" *= -1;
	if (thisagent's "Crushing_Resistance_Flat_Neg" == True)
		thisagent's "Crushing_Resistance_Flat" *= -1;
	if (thisagent's "Slashing_Resistance_Flat_Neg" == True)
		thisagent's "Slashing_Resistance_Flat" *= -1;
	if (thisagent's "Piercing_Resistance_Flat_Neg" == True)
		thisagent's "Piercing_Resistance_Flat" *= -1;

end


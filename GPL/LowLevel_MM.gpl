///////////////////////////////////////////////////////////////////////////////
function getintentext(agent thisagent) is string

declare

begin
	if ($HasAttribute("intentext", thisagent) == false)
		return "";
	return thisagent's "intentext";

end

// https://stackoverflow.com/questions/31241304/how-can-i-check-that-a-bit-is-set-without-bitwise-operation
// floor(value/mask) mod 2 = 1
function HasFlag(integer value, integer mask) is integer
declare
	integer result;
begin
	result = value / mask;
	result = result % 2;
	return result == 1; 
end
	
///////////////////////////////////////////////////////////////////////////////
function AddHelpSign(agent thisagent, string sign, coordinate sign_loc)

declare
	agent new_sign, palace;

begin
	palace = $gettruepalace(thisagent);
	if ($IsValidGamePiece(palace) == True)
		begin
			if ($HasAttribute("Toggle_Signs", palace) == False)
				begin
					$AddAttribute(palace, "Toggle_Signs", "boolean", True);  //Not In Prototype
					new_sign = $SpawnUnit(palace, "Help_Sign_Toggle_Off");
					$AddAttribute(new_sign, "IGdeathscript", "function", $HelpDeath);  //Not In Prototype
					$AddAttribute(new_sign, "HelpSignAutoRemoval", "function", $HelpSignAutoRemoval);  //Not In Prototype
					$NewThread(new_sign's "HelpSignAutoRemoval", 1500, new_sign, palace );
					$AddAttribute(new_sign, "SignParent", "list");  //Not In Prototype
					new_sign's "SignParent" << palace;
				end
			else if (palace's "Toggle_Signs" == False)
				return;
		end
		
	if ($HasAttribute("Help_Signs", thisagent) == True)
		begin
			new_sign = $SpawnUnit(thisagent, sign, sign_loc);
			thisagent's "Help_Signs" << new_sign;
			$AddAttribute(new_sign, "SignParent", "list");  //Not In Prototype
			new_sign's "SignParent" << thisagent;
			$AddAttribute(new_sign, "HelpSignAutoRemoval", "function", $HelpSignAutoRemoval);  //Not In Prototype
			$NewThread(new_sign's "HelpSignAutoRemoval", 1500, new_sign, thisagent );
			$AddAttribute(new_sign, "IGdeathscript", "function", $building_death);  //Not In Prototype
		end
	else
		begin
			$AddAttribute(ThisAgent, "Help_Signs", "list");  //Not In Prototype
			new_sign = $SpawnUnit(thisagent, sign, sign_loc);
			thisagent's "Help_Signs" << new_sign;
			$AddAttribute(new_sign, "SignParent", "list");  //Not In Prototype
			new_sign's "SignParent" << thisagent;
			$AddAttribute(new_sign, "HelpSignAutoRemoval", "function", $HelpSignAutoRemoval);  //Not In Prototype
			$NewThread(new_sign's "HelpSignAutoRemoval", 1500, new_sign, thisagent );
			$AddAttribute(new_sign, "IGdeathscript", "function", $building_death);  //Not In Prototype
		end
end


///////////////////////////////////////////////////////////////////////////////
function RemoveHelpSigns(agent thisagent)

declare
	agent sign;

begin
	if ($HasAttribute("Help_Signs", thisagent) == True)
		if ($ListSize(thisagent's "Help_Signs") > 0)
			foreach sign in thisagent's "Help_Signs" do
				if ($IsValidGamePiece(sign) == True)
					begin
						sign's "type" = "Dead";
						$performaction( sign,"Become_Rubble",sign );
						$deleteagent(sign);
					end
end

///////////////////////////////////////////////////////////////////////////////
function HelpDeath(agent thisagent)

declare
	agent parent, new_sign;
	string name;

begin
	if ($IsValidGamePiece(thisagent) == True)
		begin
			thisagent's "type" = "Dead";
			name = thisagent's "title";
			
			if ($IsValidGamePiece($ListMember(thisagent's "SignParent", 1)) == True)
				parent = $ListMember(thisagent's "SignParent", 1);
			else if ($IsValidGamePiece($GetPalace(thisagent)) == True)
				parent = $GetPalace(thisagent);
			else
				begin
					$deleteagent(thisagent);
					return;
				end
				
			if (name == "Help_Sign_Toggle_On")
				begin
					$AddAttribute(parent, "Toggle_Signs", "boolean");  //Not In Prototype
					parent's "Toggle_Signs" = True;
					new_sign = $SpawnUnit(parent, "Help_Sign_Toggle_Off");
					$AddAttribute(new_sign, "IGdeathscript", "function", $HelpDeath);  //Not In Prototype
					$AddAttribute(new_sign, "HelpSignAutoRemoval", "function", $HelpSignAutoRemoval);  //Not In Prototype
					$NewThread(new_sign's "HelpSignAutoRemoval", 1500, new_sign, parent );
					$AddAttribute(new_sign, "SignParent", "list");  //Not In Prototype
					new_sign's "SignParent" << parent;
				end
			else if (name == "Help_Sign_Toggle_Off")
				begin
					$AddAttribute(parent, "Toggle_Signs", "boolean");  //Not In Prototype
					parent's "Toggle_Signs" = False;
					new_sign = $SpawnUnit(parent, "Help_Sign_Toggle_On");
					$AddAttribute(new_sign, "IGdeathscript", "function", $HelpDeath);  //Not In Prototype
					$AddAttribute(new_sign, "HelpSignAutoRemoval", "function", $HelpSignAutoRemoval);  //Not In Prototype
					$NewThread(new_sign's "HelpSignAutoRemoval", 1500, new_sign, parent );
					$AddAttribute(new_sign, "SignParent", "list");  //Not In Prototype
					new_sign's "SignParent" << parent;
				end
			
			
			$performaction( thisagent,"Become_Rubble",thisagent );
			$deleteagent(thisagent);
		end
end

///////////////////////////////////////////////////////////////////////////////
function ExceedMapBounds(coordinate c) is boolean

declare
	integer x1, y1, x2, y2;
	coordinate board_size;

begin
	board_size = $getboardextents();
	
	x1 = $GetX(c);
	y1 = $GetY(c);
	
	x2 = $GetX(board_size);
	y2 = $GetY(board_size);
	
	if ((x1 > x2) || (y1 > y2))
		return TRUE;
	
	return FALSE;
end

///////////////////////////////////////////////////////////////////////////////
function UnitPointWithOffset(agent thisagent, integer dx, integer dy) is coordinate

declare
	integer x1, y1, x2, y2;
	coordinate thisagent_loc, return_loc;

begin
	thisagent_loc = $LocationOf(thisagent);
	x1 = $GetX(thisagent_loc);
	y1 = $GetY(thisagent_loc);
	
	x2 = x1 + dx;
	y2 = y1 + dy;
	return_loc = $MakeCoord(x2, y2);
	
	return return_loc;
end

///////////////////////////////////////////////////////////////////////////////
function LocationPointWithOffset(coordinate this_loc, integer dx, integer dy) is coordinate

declare
	integer x1, y1, x2, y2;
	coordinate return_loc;

begin
	x1 = $GetX(this_loc);
	y1 = $GetY(this_loc);
	
	x2 = x1 + dx;
	y2 = y1 + dy;
	return_loc = $MakeCoord(x2, y2);
	
	return return_loc;
end

///////////////////////////////////////////////////////////////////////////////
function LocationPointWithOffsetRandom(coordinate this_loc, integer dx, integer dy) is coordinate
//This is for locations to return with an offset ranging from 0 to dx/dy and having the possibility of being negative or positive
declare
	integer x1, y1, x2, y2;
	coordinate return_loc;

begin
	x1 = $GetX(this_loc);
	y1 = $GetY(this_loc);
	
	if ($RandomNumberNonZero(2) == 1)
		x2 = x1 + $RandomNumberNonZero(dx);
	else
		x2 = x1 - $RandomNumberNonZero(dx);
		
	if ($RandomNumberNonZero(2) == 1)
		y2 = y1 + $RandomNumberNonZero(dy);
	else
		y2 = y1 - $RandomNumberNonZero(dy);
	
	return_loc = $MakeCoord(x2, y2);
	
	return return_loc;
end

///////////////////////////////////////////////////////////////////////////////
function LocationPointWithOffsetSimpleRandom(coordinate this_loc, integer offset) is coordinate
//This is for locations to return with an offset ranging from 0 to offset and having the possibility of being negative or positive
declare
	integer x1, y1, x2, y2;
	coordinate return_loc;

begin
	x1 = $GetX(this_loc);
	y1 = $GetY(this_loc);
	
	if ($RandomNumberNonZero(2) == 1)
		x2 = x1 + $RandomNumberNonZero(offset);
	else
		x2 = x1 - $RandomNumberNonZero(offset);
		
	if ($RandomNumberNonZero(2) == 1)
		y2 = y1 + $RandomNumberNonZero(offset);
	else
		y2 = y1 - $RandomNumberNonZero(offset);
	
	return_loc = $MakeCoord(x2, y2);
	
	return return_loc;
end

///////////////////////////////////////////////////////////////////////////////
//Returns an offset coordinate in the direction of xy2 from xy1
function PointPolarOffset(coordinate xy1, coordinate xy2, integer offset) is coordinate

declare
	integer x1, y1, x2, y2, dx, dy, ddx, ddy, dddx, dddy, rx, ry, total_ddxy, distance;
	coordinate return_xy;

begin
	x1 = $GetX(xy1);
	y1 = $GetY(xy1);
	x2 = $GetX(xy2);
	y2 = $GetY(xy2);
	distance = $DistanceBetweenCoords(xy1, xy2);
	
	dx = (x2 - x1);
	dy = (y2 - y1);
	
	if (dx < 0)
		ddx = (dx * -1);
	else
		ddx = dx;
					
	if (dy < 0)
		ddy = (dy * -1);
	else
		ddy = dy;
					
	total_ddxy = ddx + ddy;
	
	if (total_ddxy == 0)
		return xy1;
		
	dddx = (dx * offset) / total_ddxy;
	dddy = (dy * offset) / total_ddxy;
	
	rx = x1 + dddx;
	ry = y1 + dddy;
	
	return_xy = $MakeCoord(rx, ry);
	
	return return_xy;
end


//////////////////////////////////////////////////////////////////////////////
function i2s(integer int) is string
declare
	string return_s;
	integer mod_int, control_int;

begin
	control_int = int;
	mod_int = int;
	return_s = "";
	
	if (int < 10)
		return $i2s_sub(int);
		
	if (int > 1000000)
		begin
			return "Value too high";
		end
	
	if (int > 100000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/100000);
			while (int > 100000) do
				int -= 100000;
			return_s += $i2s_sub(int/10000);
		end
	else if (int == 10000)
		return_s += "1";
	
	if (int > 10000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/10000);
			while (int > 10000) do
				int -= 10000;
			return_s += $i2s_sub(int/1000);
		end
	else if (int == 10000)
		return_s += "1";
	
	if (int > 1000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/1000);
			while (int > 1000) do
				int -= 1000;
			return_s += $i2s_sub(int/100);
		end
	else if (int == 1000)
		return_s += "1";
	
	if (int > 100)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/100);
			while (int > 100) do
				int -= 100;
			return_s += $i2s_sub(int/10);
		end
	else if (int == 100)
		return_s += "1";
	
	if (int > 10)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/10);
			while (int > 10) do
				int -= 10;
			return_s += $i2s_sub(int);
		end
	else if (int == 10)
		return_s += "10";
	
	return return_s;
end
///////////////////////////////////////////////////////////////////////////////
function stringinlist(string thistitle,list thislist) is boolean
//Find out if a list has the supplied string. This is only for lists containing strings.
declare
	string joe_smith;
	boolean is_it_here;

begin
	is_it_here = FALSE;

	foreach joe_smith in thislist do
		if (joe_smith == thistitle) 
			is_it_here = TRUE;

	return is_it_here;

end

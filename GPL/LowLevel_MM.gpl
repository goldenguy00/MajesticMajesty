////////////////////////////////////////////////////////////////////////////////
function AddInsightPoints(agent thisagent, integer insight_points)

declare
	integer attribute_points;
	string picked_attribute;
	
begin
	if ($AddAttribute(thisagent, "InsightPoints", "integer") == false)
		insight_points += thisagent's "InsightPoints";

	while (insight_points >= #insight_point_limit) do
		begin
			attribute_points ++;
			insight_points -= #insight_point_limit;
		end

	thisagent's "InsightPoints" = insight_points;

	While (attribute_points > 0) do
		begin
			picked_attribute = $PreferredAttribute(thisagent, (attribute_points % 2) == 0);
			$AdjustBaseStat(thisagent, picked_attribute, 1);
			attribute_points--;
		end

end

/////////////////////////////////////////////////////////////////////////////////////////////////
function PercentOf( integer amount, integer percent, boolean high ) is integer
// Should have made this ages ago


declare
	integer new_amount;
	
begin
	if (high == false)
		begin
			new_amount = ((amount * percent) / 100);
			return new_amount;
		end
	else
		begin
			new_amount = ((amount / 100) * percent);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IncreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high == false)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount + amount_diff);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function DecreaseByPercent( integer amount, integer percent, boolean high) is integer
// Should have made this ages ago

declare
	integer amount_diff, new_amount;
	
begin
	if (high == false)
		begin
			amount_diff = ((amount * percent) / 100);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	else
		begin
			amount_diff = ((amount / 100) * percent);
			new_amount = (amount - amount_diff);
			return new_amount;
		end
	return new_amount;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function MinMax(integer min, integer max) is integer

declare
	integer return_int;

begin
	if (min == max)
		return max;

	// will be anywhere from minimum to maximum
	// regardless of param order
	if (max < min)
		begin
			return_int = max;
			max = min;
			min = return_int;
		end

	return_int = $randomnumber(max - min) + min;

	return return_int;
end


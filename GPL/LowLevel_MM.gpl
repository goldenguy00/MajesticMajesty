end

////////////////////////////////////////////////////////////////////////////////
function PreferredAttribute(agent thisagent, boolean allow_primary) is string

declare
	list stat_list;
	string pref_attribute, stat;
	integer chance, max_roll, roll;
	
begin
	stat_list = $GetStatOrder(thisagent's "title");
	if ($ListSize(stat_list) == 0)
		return $RandomAttribute();

	pref_attribute = thisagent's "PrimaryStat_Name";
	if (allow_primary == false)
		stat_list -= pref_attribute;

	foreach stat in stat_list do
		begin
			chance = $GetBaseStat(thisagent,stat) + $GetAttributeSafe(thisagent, ("Up"+stat+"Chance"));
			max_roll += chance;
		end

	roll = $RandomNumber(max_roll);

	foreach stat in stat_list do
		begin
			chance = $GetBaseStat(thisagent,stat) + $GetAttributeSafe(thisagent, ("Up"+stat+"Chance"));
			if (chance <= roll)
				begin
					pref_attribute = stat;
					break;
				end
		end
		
	return pref_attribute;
end

////////////////////////////////////////////////////////////////////////////////
function RandomAttribute() is string

declare
	integer rand;
	
begin
	rand = $RandomNumber(5);
	
	if (rand == 0)
		return "Intelligence";
	else if (rand == 1)
		return "Artifice";
	else if (rand == 2)
		return "Vitality";
	else if (rand == 3)
		return "Willpower";
	else if (rand == 4)
		return "Wisdom";
		
	return "Strength";
end

////////////////////////////////////////////////////////////////////////////////
function StartingWisdom(agent thisagent) is integer

declare
	string unit_name;
	integer random_n, amount;
begin
	unit_name = thisagent's "title";

	random_n = $randomnumber(3);
	if (random_n > 0)
		if (($randomnumber(2) + 1) == 1)
			amount += random_n;
		else
			amount -= random_n;

	if (unit_name == "warrior")
		amount += 5;
	else if (unit_name == "ranger")
		amount += 14;
	else if (unit_name == "rogue")
		amount += 2;
	else if (unit_name == "wizard")
		amount += 15;
	else if (unit_name == "paladin")
		amount += 16;
	else if (unit_name == "warrior_of_discord")
		amount += 1;
	else if (unit_name == "adept")
		amount += 14;
	else if (unit_name == "barbarian")
		amount += 6;
	else if (unit_name == "cultist")
		amount += 6;
	else if (unit_name == "healer")
		amount += 17;
	else if (unit_name == "monk")
		amount += 21;
	else if (unit_name == "priestess")
		amount += 9;
	else if (unit_name == "solarus")
		amount += 7;
	else if (unit_name == "dwarf")
		amount += 8;
	else if (unit_name == "elf")
		amount += 4;
	else if (unit_name == "gnome")
		amount += 2;
	return amount;
end


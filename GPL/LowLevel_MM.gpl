///////////////////////////////////////////////////////////////////////////////
// Return the Palace ThisAgent belongs to, this can return an Outpost if
// an Outpost is ThisAgent's "Parent"
function GetPalace (Agent ThisAgent) is agent
Declare
	list	Palaces;
	agent Parent;

Begin
	Parent = $Parent (ThisAgent);

	If ($IsDead (Parent) == False)
		begin
			If (Parent's "SubType" == "Outpost")
				return Parent;
		end
		
	return $GetTruePalace(thisagent);
End

///////////////////////////////////////////////////////////////////////////////
// Returns the Palace of the player ThisAgent belongs to, even if ThisAgent
// is owned by an Outpost of the player.
Function GetTruePalace (agent ThisAgent) is agent
Declare
	list	Palaces;
	agent Palace;

Begin
	if ($HasAttribute("Palace", thisagent))
		begin
			Palace = thisagent's "Palace";
			if ($IsDead(Palace) == false)
				if ($GetUnitPlayerNumber(thisagent) == $GetUnitPlayerNumber(Palace))
					return Palace;
		end

	$ListObjects (ThisAgent, "Building", -1, Palaces, #CheckTitles, "Palace", #MyPlayer, #NoHiddenMap);

	If (ThisAgent's "Title" == "Palace")
		Palaces << ThisAgent;

	If ($ListSize (Palaces) > 0)
		Palace = $ListMember (Palaces, 1);
	else
		Palace = $NullAgent();

	if ($AddAttribute(thisagent, "Palace", "agent", Palace) == false)
		thisagent's "Palace" = Palace;

	return Palace;
End

function Palace_Central_Lists(agent thisagent)
declare
	list monsters, enemies, allies, buildings, attractions, fairgrounds, peasants;
begin
	$ListObjects(thisagent,"monster",-1, monsters,#NotMyTeam);
	if ($AddAttribute(thisagent, "Enemy_Monster_List", "list", monsters) == false)
		thisagent's "Enemy_Monster_List" = monsters;

	$ListObjects(thisagent,"hero",-1, enemies,#NotMyTeam);
	if ($AddAttribute(thisagent, "Enemy_Hero_List", "list", enemies) == false)
		thisagent's "Enemy_Hero_List" = enemies;

	$ListObjects(thisagent,"hero",-1, allies,#myplayer);
	if ($AddAttribute(thisagent, "Ally_Hero_List", "list", allies) == false)
		thisagent's "Ally_Hero_List" = allies;

	$ListObjects(thisagent,"building",-1, buildings,#myplayer);
	if ($agentinlist(thisagent,buildings) == FALSE)
		buildings << thisagent;
	if ($AddAttribute(thisagent, "Ally_Building_List", "list", buildings) == false)
		thisagent's "Ally_Building_List" = buildings;

		//fuckin pursue entertainment
		
	$listobjects(thisagent,"building",-1,attractions, #CheckSubTypes, "Entertainment", #ATTRIB_FirstStageBuilt, 1);
	if ($AddAttribute(thisagent, "Entertainment_List", "list", attractions) == false)
		thisagent's "Entertainment_List" = attractions;

	//$listobjects(thisagent,"building",-1,fairgrounds, #CheckTitles, "Fairgrounds", #ATTRIB_FirstStageBuilt, 1);
	fairgrounds = $ListCompletedTitlesJ(buildings, "Fairgrounds");
	if ($AddAttribute(thisagent, "Fairgrounds_List", "list", fairgrounds) == false)
		thisagent's "Fairgrounds_List" = fairgrounds;

	peasants = $ListTitles (allies, "Peasant");
	if ($AddAttribute(thisagent, "Peasant_List", "list", peasants) == false)
		thisagent's "Peasant_List" = peasants;

// so that peasants dont lag the fuck outta the game doing this reconstructing
// they will be slightly less responsive, but thats honestly a good thing. their reaction times were too good.	
	$reconstruct_lists_opt(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function reconstruct_lists(agent palace)

declare
	agent bldg;
	list buildings,newlist;

begin
	// check lists for buildings who shouldn't be on them
	buildings = palace's "buildings_under_construction";

	foreach bldg in buildings do
		begin
			If ($IsDead (Bldg) == False)
				begin
					if ($building_level_complete(bldg))
						if (($getattribute(bldg,#ATTRIB_isrepaired) == 0) && ($getattribute(bldg,#ATTRIB_QuickRepair) == 0))
							palace's "buildings_under_construction" -= bldg;
				end
			else
				palace's "buildings_under_construction" -= bldg;
		end
end
///////////////////////////////////////////////////////////////////////////////
function reconstruct_lists_opt(agent palace)

declare
	agent bldg;
	list buildings,newlist;

begin
	// check lists for buildings who shouldn't be on them
	buildings = palace's "buildings_under_construction";

	foreach bldg in buildings do
		begin
			If ($IsDead (Bldg) == False)
				begin
					if ($building_level_complete(bldg))
						if (($getattribute(bldg,#ATTRIB_isrepaired) == 0) && ($getattribute(bldg,#ATTRIB_QuickRepair) == 0))
							palace's "buildings_under_construction" -= bldg;
				end
			else
				palace's "buildings_under_construction" -= bldg;
		end

	// check all existing buildings, to see if they are damaged and need to be added
	//$listobjects(palace,"building",-1,buildings,#MyPLayer, #ATTRIB_FirstStageBuilt, 1);
	//buildings = $listcompleted(buildings);
	//buildings << palace; // the palace wasn't getting checked before!!!

	foreach bldg in palace's "Ally_Building_List" do
		begin
			If ($IsDead (Bldg) == False)
				if ($building_level_complete(bldg))
					if ($getattribute(bldg,#ATTRIB_HP) < $getattribute(bldg,#ATTRIB_MAXHP))
						if ($agentinlist(bldg,palace's "buildings_under_construction") == FALSE)
							if (($getattribute(bldg,#ATTRIB_isrepaired) == 1) || ($getattribute(bldg,#ATTRIB_QuickRepair) == 1))
								palace's "buildings_under_construction" << bldg;
		end
end

///////////////////////////////////////////////////////////////////////////////
// This checks to see if ThisAgent is the closest Peasant with the intention of building their target
Function Closest_Peasant_Building (agent ThisAgent) is boolean
Declare
	list		Peasants;
	agent		Peasant, Target, palace;
	integer	My_Dist, Their_Dist;
	boolean closest_flag;

Begin
	closest_flag = true;

	Target = ThisAgent's "Target";
	My_Dist = $DistanceBetweenAgents (ThisAgent, Target);
	
	Palace = $GetTruePalace (ThisAgent);
	if ($isdead(palace))
		begin
			$ListObjects (ThisAgent, "hero", -1, Peasants, #CheckTitles, "Peasant", #myplayer);
		end
	else if ($HasAttribute("Peasant_List", palace) == false)
		begin
			$ListObjects (ThisAgent, "hero", -1, Peasants, #CheckTitles, "Peasant", #myplayer);
		end
	else
		begin
			peasants = palace's "Peasant_List";
		end

	//Peasants = $ListTitles (Peasants, "Peasant");

	//$DebugOut (911, "Listsize of Peasants:", $ListSize (Peasants));

//	If ($ListSize (Peasants) > 0)
//		begin
	Foreach Peasant in Peasants do
		begin
			if (closest_flag)
				if ($IsValidGamePiece(peasant))
					If (Peasant's "Target" == Target && peasant != thisagent)
						begin
							Their_Dist = $DistanceBetweenAgents (Peasant, Target);
							If (Their_Dist <= My_Dist)
								begin
									//$DebugOut (911, "Their dist is less than or equal to my dist.");
									//return False;
									closest_flag = FALSE;
								end
						end
		end
//		end

	//$DebugOut (911, "I am the closest Peasant with the intention of building this building.");
	//return True;
	return closest_flag;

End

///////////////////////////////////////////////////////////////////////////////
// Checks to see is marketplace is dead or closed
function MarketInvalid ( agent thisagent ) is boolean
declare
begin
	if ($isdead(thisagent) == TRUE)
		return TRUE;

	if (thisagent's "Title" == "Closed")
		return TRUE;

	return FALSE;
end
///////////////////////////////////////////////////////////////////////////////
function listtitlesinRadiusAdvanced(agent thisagent,string type, string title, integer dist, integer modifier) is list

declare
	list new_list;
	list final_list;
	agent diddly;

begin
	$ListObjects(thisagent,type,dist,new_list, modifier );

	foreach diddly in new_list do
		begin
			if (diddly's "title" == title)
				begin
					final_list << diddly;
				end
		end
	return final_list;
end

///////////////////////////////////////////////////////////////////////////////
function give_gold(agent thisagent, integer amount)

declare
	boolean has_bank;

begin
	if (amount < 1)
		return;
	
	$createeffector(thisagent,"got_gold",0, Amount);

	has_bank = $GetBooleanSafe(thisagent, "has_bank_account");

	if (has_bank)
		begin
			$adjustattribute(thisagent,#ATTRIB_StoredGold,amount);
			thisagent's "Bank_Account_Gold" = $GetAttribute(thisagent, #ATTRIB_StoredGold);
		end
	else
		begin
			$adjustattribute(thisagent,#ATTRIB_gold,amount);
		end
end
///////////////////////////////////////////////////////////////////////////////
function RandomNumberNonZero(integer rand) is integer

declare
	integer return_int;

begin
	if (rand  <= 1)
		return rand;
	
	return_int = $RandomNumber(rand-1) + 1;
	return return_int;
end
///////////////////////////////////////////////////////////////////////////////
// Returns the absolute value of an integer passed to it.
function AbsoluteValue ( integer number ) is integer
declare
begin
	if ( number < 0 )
		number = ( number * ( - 1 ));

	return number;
end
	
//////////////////////////////////////////////////////////////////////////////
function i2s(integer int) is string
declare
	string return_s;
	integer mod_int, control_int;

begin
	control_int = int;
	mod_int = int;
	return_s = "";
	
	if (int < 10)
		return $i2s_sub(int);
		
	if (int > 1000000)
		begin
			return "Value too high";
		end
	
	if (int > 100000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/100000);
			while (int > 100000) do
				int -= 100000;
			return_s += $i2s_sub(int/10000);
		end
	else if (int == 10000)
		return_s += "1";
	
	if (int > 10000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/10000);
			while (int > 10000) do
				int -= 10000;
			return_s += $i2s_sub(int/1000);
		end
	else if (int == 10000)
		return_s += "1";
	
	if (int > 1000)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/1000);
			while (int > 1000) do
				int -= 1000;
			return_s += $i2s_sub(int/100);
		end
	else if (int == 1000)
		return_s += "1";
	
	if (int > 100)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/100);
			while (int > 100) do
				int -= 100;
			return_s += $i2s_sub(int/10);
		end
	else if (int == 100)
		return_s += "1";
	
	if (int > 10)
		begin
			if (int == control_int)
				return_s += $i2s_sub(int/10);
			while (int > 10) do
				int -= 10;
			return_s += $i2s_sub(int);
		end
	else if (int == 10)
		return_s += "10";
	
	return return_s;
end
//////////////////////////////////////////////////////////////////////////////
function i2s_sub(integer int) is string
declare
	string return_s;

begin
	return_s = "";
	if (int == 0)
		return_s = "0";
	else if (int == 1)
		return_s = "1";
	else if (int == 2)
		return_s = "2";
	else if (int == 3)
		return_s = "3";
	else if (int == 4)
		return_s = "4";
	else if (int == 5)
		return_s = "5";
	else if (int == 6)
		return_s = "6";
	else if (int == 7)
		return_s = "7";
	else if (int == 8)
		return_s = "8";
	else if (int == 9)
		return_s = "9";
	return return_s;
end
///////////////////////////////////////////////////////////////////////////////
function stringinlist(string thistitle,list thislist) is boolean
//Find out if a list has the supplied string. This is only for lists containing strings.
declare
	string joe_smith;
	boolean result;

begin
	result = false;
	foreach joe_smith in thislist do
		if (joe_smith == thistitle) 
			begin
				result = true;
			end

	return result;

end
///////////////////////////////////////////////////////////////////////////////
function addstringtolist(string thistitle,list thislist)
//Find out if a list has the supplied string. This is only for lists containing strings.
declare
begin
	if ($StringInList(thistitle, thislist) == false)
		thislist << thistitle;
end

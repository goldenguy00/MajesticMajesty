		return_string = "Cinders";
	else if (spell_name == "Cinders_11")
		return_string = "Cinders";
	else if (spell_name == "Cinders_12")
		return_string = "Cinders";
	else if (spell_name == "Cinders_13")
		return_string = "Cinders";
	else if (spell_name == "Cinders_14")
		return_string = "Cinders";
	else if (spell_name == "Cinders_15")
		return_string = "Cinders";
	else if (spell_name == "Cinders_16")
		return_string = "Cinders";

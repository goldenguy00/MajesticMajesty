	if ((target's "type" != "Building") && (target's "type" != "lair"))
	  	begin

			if (thisagent != target)
				begin
					if ($agentinlist(thisagent,target's "Hostiles") == FALSE)
						if ($GetAttribute( thisagent, #ATTRIB_HasEffectInvisibility) != 1)
							target's "Hostiles" << thisagent;
				end
			else
				begin

					//This is here because if the unit just attacked themselves, then they
					//should flee if they are a magic-based class
					If (ThisAgent's "Title" == "Wizard" || ThisAgent's "Title" == "Priestess")
 						$Flee_Absolute ( ThisAgent, "IDTXT_INTENT_FLEEING" );

				end
		end

	else
		if (target's "type" == "Building")
			begin
				type = target's "subtype";
				if ((type == "guild") || (type == "Palace") || (type == "outpost"))
					target's "In_danger" = TRUE;

				$release_occupants(target);

					begin
						palace = $gettruepalace(target);
						if ($isvalidgamepiece(palace))
							begin
								If ($AgentInList (Target, Palace's "Buildings_Under_Construction") == False)
									palace's "buildings_under_construction" << target;
							end
					end

				If (Target's "Title" == "Palace")
					begin

						$PlaySound (Target, "Advisor_Palace_Beseiged", "VFX_ADVISOR");

					end

			end

end

/////////////////////////////////////////////////////////////////////////////////////////////////
function exp_value(agent thisagent,agent target) is integer

declare
	integer exp_given, exp_mult;

begin
	if (target's "type" == "monster")
		begin
			exp_given = $getattribute(target,#ATTRIB_LevelXP);
			$debugout(exp_given);
		end
	else
		if (target's "type" == "lair")
			exp_given = target's "difficulty" * #lair_exp;
		else
			if (target's "subtype" == "hero")// && ($getsubtype(target) != "Henchman" && $GetSubtype(target) != "Controlled"))
				exp_given = $getattribute(target,#ATTRIB_experienceLevel) * #attack_hero_exp;
			else
				if ((target's "type" == "building") || (target's "subtype" == "henchman"))
					begin
						if ($getunitplayernumber(thisagent) == $getunitplayernumber(target))
							exp_given = 0;
						else
							exp_given = #attack_other_exp;
					end
				else
					exp_given = #attack_other_exp;

	if ($HasAttribute("XPMultiplier", target))
		begin
			exp_given *= target's "XPMultiplier";
		end
	return exp_given;
end

///////////////////////////////////////////////////////////////////////////////
function damage(agent attacker, agent defender)

declare

	integer dmg,dmg_stopped,t,t2,dmg_exp;
	boolean magic_effect;
	boolean do_poison,critical_effect;

begin
	//This is a hack so that the Towers can attack
	magic_effect = FALSE;
	
	//Check for Damage Shield. If it exists, then the attacker takes some damage via an effector that
	//calls back. Note that we are now assuming that the attacker is not a building or lair
	if ($IsExpansion(attacker)!= False)
		If ($GetAttribute (Defender, #ATTRIB_HasEffectDamageShield) != 0)
			begin

				//Only do damage shield damage if Attacker is a HtoH attacker
				//We are assuming that the Attacker didn't cast a spell to arrive here, otherwise
				//we would be in $Spell_Damage
				If (Attacker's "AttackType" != 2)
					begin
						$CreateEffector (Attacker, "Damage_Shield_Reflect_Effector", 0);
					end
			end


	if ((( defender's "type" != "building" ) && ( defender's "type" != "lair" )) && ( $randomnumber ( 100 ) < attacker's "critical_chance" ))
		begin
			dmg = $getattribute ( defender, #ATTRIB_MAXHP );
			critical_effect = TRUE;
			if ( $hasattribute ( "resist_critical", defender ))
				if ( defender's "resist_critical" == TRUE )
					dmg = dmg / 6;
		end
	else
		begin	
			dmg = $AttackDamageType_Calculations(defender, attacker);
		end

	dmg_stopped = $GetAttribute ( defender, #ATTRIB_armor_basic_damage );

	if ( defender's "subtype" == "hero" )
		begin
			dmg_stopped += $GetAttribute ( defender, #ATTRIB_armor_struct_bonus );
			dmg_stopped += $GetAttribute ( defender, #ATTRIB_armor_magic_bonus );
		end

	//t = dmg_stopped / 4;

	t2 = $randomnumber ( dmg_stopped - t );

//				$debugout(911,"lowdamage",t,"variabledamage",t2,defender's "type");
				dmg_stopped = t + t2;

				dmg -= dmg_stopped;
	
	if ($IsExpansion(attacker) == True)
		if ( defender's "title" == "GoblinFortress" )
			$GoblinFortHitSpawn ( defender );

	if ( dmg < 0 ) dmg = 0;

	if ( dmg > 0 )
		begin
			if ( defender's "type" != "building" && defender's "type" != "lair" )
				begin
					if ( magic_effect )
						$createeffector ( defender, "wound_special", 0 );
					else
						if ( critical_effect )
							begin
								if ($IsExpansion(attacker)!=False)
									begin
										//Have the Attacker say their critical hit voice line!
										$Say (Attacker, "VFX_Special2");


										//$createeffector ( defender, "wound_critical",0 );
										$CreateSpellUnit (Attacker, "Critical_hit", Defender);
									end
								else
									$createeffector(defender,"wound_critical",0);

							end
						else
							$createeffector ( defender, "wounded_large", 0 );

					$playsound ( defender, "gethit" );

					if ( $getattribute ( attacker, #ATTRIB_weaponpoisoned ) == 1 )
						begin
							do_poison = TRUE;
							if ( $hasattribute ( "Immune_to_poison", defender ))
								if ( defender's "immune_to_poison" == TRUE )
									do_poison = FALSE;

							if ( do_poison )
								$poison_begin ( attacker, defender );
						end
				end
			else
				$playsound ( defender, "gethit" );

			// does the creature have a special splat?
			if ( $hasattribute ( "special_splat", attacker ))
				if ( attacker's "special_splat" != "" )
					begin
						$createeffector ( defender, attacker's "special_splat", 0 );
					end

			if (($GetAttribute(defender, #ATTRIB_HP) < dmg) && ($IsValidGamePiece(attacker) == True))
				begin
					if ($addattribute(defender, "Killing_unit", "agent", attacker) == False)
						defender's "Killing_Unit" = attacker;
					if ($HasAttribute("Cinders_Learned", attacker) == True)
						$Cinders_Passive(attacker);
					if ($Checkeffector(defender, "Pyrelight_icon") == True)
						$PyrelightDebuff_Death(defender);
				end
			
			dmg_exp = $exp_value(attacker, defender);
			if (attacker's "subtype" == "hero")
				begin
					$give_exp(attacker, dmg_exp);
				end
				
			if ($hasattribute("familiar",attacker))
				if (attacker's "familiar" == TRUE)
					begin
						if ($isdead(attacker's "leader") == FALSE)
							$give_exp(attacker's "leader", dmg_exp);
					end
					
			$adjustattribute ( defender, #ATTRIB_HP, -dmg );
		end

	// check for defender recoil

end

///////////////////////////////////////////////////////////////////////////////
function AttackDamageType_Calculations(agent defender, agent attacker ) is integer

declare
	string damage_type;
	integer dmg, dmg_total;

begin
	dmg_total = 0;
	
	if (attacker == $nullagent() || $IsValidGamePiece(attacker) == False)
		return dmg_total;

	if (attacker's "attacktype" == 1)
		dmg_total = $getattribute(attacker, #ATTRIB_Strength) / #strength_div;

	dmg_total += $TryAttackWithType(attacker, defender, "Crushing");
	dmg_total += $TryAttackWithType(attacker, defender, "Slashing");
	dmg_total += $TryAttackWithType(attacker, defender, "Piercing");

	dmg_total += $TryAttackWithType(attacker, defender, "Fire");
	dmg_total += $TryAttackWithType(attacker, defender, "Cold");
	dmg_total += $TryAttackWithType(attacker, defender, "Electric");
	dmg_total += $TryAttackWithType(attacker, defender, "Poison");
	dmg_total += $TryAttackWithType(attacker, defender, "Arcane");
	dmg_total += $TryAttackWithType(attacker, defender, "Force");
	dmg_total += $TryAttackWithType(attacker, defender, "Divine");
	dmg_total += $TryAttackWithType(attacker, defender, "Necrotic");
	dmg_total += $TryAttackWithType(attacker, defender, "Chaotic");

	return dmg_total;
end

function CanAttackWithType(agent attacker, string type) is boolean
declare
begin

	if ($HasAttribute((type+"_Attack_Damage_Min"), attacker) == false)
		return false;
	return attacker's (type + "_Attack_Damage_Min") > 0 || attacker's (type + "_Attack_Damage_Max") > 0 ||
			attacker's (type + "_Attack_Damage_Min_Modifier") != 0 || attacker's (type + "_Attack_Damage_Max_Modifier") != 0;
end

function TryAttackWithType(agent attacker, agent defender, string type) is integer
declare
begin
	if ($CanAttackWithType(attacker, type))
		return $GetDamage(attacker, defender, type);
	return 0;
end

function GetDamage(agent attacker, agent defender, string damage_type) is integer

declare
	integer dmg;

begin
		dmg = $MinMaxAttackType(attacker, damage_type);
		dmg = $DamageTypeIncrease(defender, attacker, damage_type, dmg);
		dmg = $DamageTypeResistance(defender, attacker, damage_type, dmg);
		return dmg;
end

///////////////////////////////////////////////////////////////////////////////
function DamageTypeIncrease(agent defender, agent attacker, string s_type, integer damage ) is integer

declare
	string damage_type_percent, damage_type_flat;
	integer damage_amount_percent, damage_amount_flat, return_damage, damage_mod_percent, damage_mod_flat;

begin
	return_damage = damage;
	
	if ((attacker == $nullagent()) || ($IsValidGamePiece(attacker) == False))
		return return_damage;

	damage_amount_flat = 0;
	Damage_type_flat = s_type+"_Damage_Flat";
	if ($HasAttribute(damage_type_flat, attacker))
	begin
		damage_amount_flat = attacker's damage_type_flat;
		damage_amount_flat = $DamageModifiersFlat(defender, attacker, s_type, damage_amount_flat);
	end
	
	return_damage += damage_amount_flat;
	
	if (return_damage < 1)
		begin
			return_damage = 0;
			return return_damage;
		end
	
	damage_amount_percent = 0;
	Damage_type_percent = s_type+"_Damage_Percent";
	if ($HasAttribute(damage_type_percent, attacker))
	begin
		damage_amount_percent = attacker's damage_type_percent;
		damage_amount_percent = $DamageModifiersPercent(defender, attacker, s_type, damage_amount_percent);
	end

	if (damage_amount_percent == 0)
		return return_damage;
		
	return_damage += ((return_damage * damage_amount_percent) / 100);
	
	if (return_damage < 0)
		return_damage = 0;
	
	return return_damage;
	
end

///////////////////////////////////////////////////////////////////////////////
function DamageTypeResistance(agent defender, agent attacker, string s_type, integer damage ) is integer

declare
	string resistance_type_percent, resistance_type_flat;
	integer resist_amount_percent, resist_amount_flat, return_damage, damage_mod_percent, damage_mod_flat;

begin
	return_damage = damage;
	
	if ((defender == $nullagent()) || ($IsValidGamePiece(defender) == False))
		return return_damage;
		
	resist_amount_flat = 0;
	resistance_type_flat = s_type+"_Resistance_Flat";
	if ($HasAttribute(resistance_type_flat, defender))
		begin
			resist_amount_flat = defender's resistance_type_flat;
			resist_amount_flat = $ResistanceModifiersFlat(defender, attacker, s_type, resist_amount_flat);
			return_damage -= resist_amount_flat;
		end
		
	if (return_damage < 1)
		begin
			return_damage = 0;
			return return_damage;
		end
	
	resist_amount_percent = 0;
	resistance_type_percent = s_type+"_Resistance_Percent";
	if ($HasAttribute(resistance_type_percent, defender))
		begin
			resist_amount_percent = defender's resistance_type_percent;
			resist_amount_percent = $ResistanceModifiersPercent(defender, attacker, s_type, resist_amount_percent);
			return_damage -= ((return_damage * resist_amount_percent) / 100);
		end
		
	if (return_damage < 0)
		begin
			return_damage = 0;
			return return_damage;
		end
	
	if ((s_type == "Crushing") || (s_type == "Slashing") || (s_type == "Piercing"))
		return_damage = $PhysicalArmor_Calculations(defender, return_damage);
	else
		return_damage = $MagicalArmor_Calculations(defender, return_damage);
		
		
	if (return_damage < 0)
		return_damage = 0;
	
	return return_damage;
	
end

///////////////////////////////////////////////////////////////////////////////
function PhysicalArmor_Calculations(agent defender, integer damage ) is integer

declare
	integer dmg, dmg_total, armor, reduction;

begin
	dmg = damage;
	
	dmg_total = damage;
	
	armor = $GetTotalArmorType(defender, "Armor_Physical");
	if (armor > 0)
		reduction = (((6 * armor) * dmg) / (100 + 6 * armor));
	else
		reduction = (((9 * armor) * dmg) / (100 + 9 * armor)) * -1;
		
	
	dmg_total -= reduction;
	 
	return dmg_total;
	
end

///////////////////////////////////////////////////////////////////////////////
function MagicalArmor_Calculations(agent defender, integer damage ) is integer

declare
	integer dmg, dmg_total, armor, reduction;

begin
	dmg = damage;
	
	dmg_total = damage;
	
	armor = $GetTotalArmorType(defender, "Armor_Magical");
	
	if (armor > 0)
		reduction = (((6 * armor) * dmg) / (100 + 6 * armor));
	else
		reduction = (((9 * armor) * dmg) / (100 + 9 * armor)) * -1;
	
	dmg_total -= reduction;
	 
	return dmg_total;
	
end

///////////////////////////////////////////////////////////////////////////////
function DamageModifiersPercent(agent defender, agent attacker, string s_type, integer damage ) is integer

declare
	integer return_damage;

begin
	return_damage = damage;
	if (s_type == "fire")
		begin
			if ($HasAttribute("Cinders_Damage_Percent", attacker) == True)
				begin
					return_damage += attacker's "Cinders_Damage_Percent";
				end
		end
	return return_damage;
end
///////////////////////////////////////////////////////////////////////////////
function DamageModifiersFlat(agent defender, agent attacker, string s_type, integer damage ) is integer

declare
	integer return_damage;

begin
	return_damage = damage;
	if (s_type == "fire")
		begin
			if ($HasAttribute("Cinders_Damage_Flat", attacker) == True)
				begin
					return_damage += attacker's "Cinders_Damage_Flat";
				end
		end
	return return_damage;
end
///////////////////////////////////////////////////////////////////////////////
function ResistanceModifiersPercent(agent defender, agent attacker, string s_type, integer resistance ) is integer

declare
	integer return_resistance;

begin
	return_resistance = resistance;
	if (s_type == "fire")
		begin
			//SearingMantle_Fire_Resistance is a positive value. This is resistance increase.
			if ($HasAttribute("SearingMantle_Fire_Resistance", defender) == True)
				begin
					return_resistance += defender's "SearingMantle_Fire_Resistance";
				end
			//Pyrelight_Fire_Resistance_Reduction is a negative value. This is resistance reduction.
			else if ($HasAttribute("Pyrelight_Fire_Resistance_Reduction", defender) == True)
				begin
					return_resistance += defender's "Pyrelight_Fire_Resistance_Reduction";
				end
		end
	return return_resistance;
end
///////////////////////////////////////////////////////////////////////////////
function ResistanceModifiersFlat(agent defender, agent attacker, string s_type, integer resistance ) is integer

declare
	integer return_resistance;

begin
	return_resistance = resistance;
	//if (s_type == "fire")
	//	begin
	//		if ($HasAttribute("SearingMantle_Fire_Resistance", defender) == True)
	//			begin
	//				return_resistance += defender's "SearingMantle_Fire_Resistance";
	//			end
	//	end
	return return_resistance;
end

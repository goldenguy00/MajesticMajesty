function PyrelightCondition( agent thisagent, string spell_name) is agent
declare
	//string icon, manapercent;
	
begin
	//icon = spell_name + "_Icon";
	return $AdvancedCastCombatDebuffEnemy_hero(thisagent, thisagent's "Target", "Pyrelight_icon", spell_name, 30);
end

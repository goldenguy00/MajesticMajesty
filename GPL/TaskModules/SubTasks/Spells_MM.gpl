function cm_Acid_Fog_Hit( agent thisagent, agent target )
// court mage spell - Three Spires
// - this spell doesn't need this many functions, reduce size from 4 to 2.
declare
	agent fog;
	integer stat, cooldown, duration, periodic;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	periodic = (2000 - (stat * 20));
	cooldown = (35000 - (stat * 250));
	duration = (14000 + (stat * 250));
	
	// have to create a new unit and set the variable for it, adjust it's intelligence to match the caster's
	$createeffector( thisagent, "cm_acid_fog_icon", cooldown );
	
	$SpellTimeoutEffectAdvanced( thisagent, "cm_acid_fog", target, $cm_Acid_Fog_Active, $spelldummydeath, "cm_acid_fog_effector", periodic, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Acid_Fog_Active(agent thisagent)
// court mage spell - Three Spires
// - activescript for cm_acid_fog unit
declare
	list targets;
	agent target, parent;
	integer stat, CurrentHP, CurrentMaxHP, HPDifference, minus_MaxHP, debuff_duration, max_damage, min_damage, duration;

begin
	stat = $GetAttribute(thisagent, #ATTRIB_Intelligence);
	minus_MaxHP = (stat / 12);
	min_damage = (stat / 15);
	max_damage = (stat / 10);
	debuff_duration = (7000 + (stat * 250));
	targets = $compile_enemies(thisagent,75 + stat);

	foreach target in targets do
		begin
			duration = debuff_duration;
			$player_spell_attack( target, max_damage, min_damage );
			$createeffector(target, "Rustspit_Splat", 0);
			CurrentHP = $getattribute(target,#ATTRIB_HP);
			CurrentMaxHP = $getattribute(target,#ATTRIB_MaxHP);
			HPDifference = (CurrentMaxHP - CurrentHP);
			if (CurrentHP > 0)
				begin
					if (HPDifference < minus_MaxHP)
						begin
							$setattribute(target, #ATTRIB_MaxHP, CurrentHP);
							duration = $WillpowerDurationDebuff(target, duration);
							$SpellTimeoutEffect( target, $cm_AcidFogDebuff_Death, duration, #ATTRIB_Intelligence, HPDifference, 0, 0,0,0,0  );
						end
					else
						begin
							$adjustattribute(target, #ATTRIB_MaxHP, - minus_MaxHP);
							duration = $WillpowerDurationDebuff(target, duration);
							$SpellTimeoutEffect( target, $cm_AcidFogDebuff_Death, duration, #ATTRIB_Intelligence, minus_MaxHP, 0, 0,0,0,0  );
						end
					end
		end
end

///////////////////////////////////MONSTER SPELLS////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////

function bm_Consume_Life_Hit( agent thisagent, agent target )
// Blood Mage spell - basic spell
// - callback from missile hit

declare
	agent mage_spawn;
	integer  targetHP, HP_threshold;
	string target_name, spawn_name;
	coordinate target_loc;

begin
	if ($isvalidgamepiece(target) == FALSE)
		return;

	targetHP = $getattribute(target, #ATTRIB_HP);
	target_name = target's "title";
	target_loc = $LocationOf(target);
	
	spawn_name = $bm_Consume_Life_Names(target_name);
	
	HP_threshold = ($getattribute( ThisAgent, #ATTRIB_intelligence ) / 6);
	
	If (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			//If I am hurt, then heal me
			If ($GetAttribute (ThisAgent, #ATTRIB_HP) < $GetAttribute (ThisAgent, #ATTRIB_MaxHP))
				begin
					$createeffector( ThisAgent, "life_drain_effector2", 0 );
					$heal(thisagent,thisagent,($getattribute( ThisAgent, #ATTRIB_intelligence ) / 4));
				end
		end

	if ($isdead(target) == false)
		begin
			if ((targetHP > HP_threshold) || (spawn_name == "None"))
				begin
					$createeffector( target, "life_drain_effector", 0);
					$spell_type_attack(thisagent, target, "Necrotic", 5, 7);
					//$spell_attack( thisagent, target, 6 );
				end
			else
				begin
					$DeleteGamePiece(target);
					mage_spawn = $spawnunit(thisagent, spawn_name, target_loc);
					$createeffector( mage_spawn, "life_drain_effector", 0);
				end
		end
	
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function bm_Consume_Life_Names( string unit_name ) is string
// Blood Mage list of names for new unit

declare
	string new_name;

begin
	new_name = "None";
	
	if (unit_name == "Peasant")
		new_name = "Sanguine_Peasant";
	else if (unit_name == "Royal_Archer")
		new_name = "Crimson_Archer";
	else if (unit_name == "Mercenary_Arbalest")
		new_name = "Maniacal_Arbalest";
	else if (unit_name == "Court_Mage")
		new_name = "Blood_Mage";
	else if (unit_name == "Squire")
		new_name = "Scarlet_Squire";
	else if ((unit_name == "Palace_Guard") || (unit_name == "City_Guard") || (unit_name == "Veteran_City_Guard"))
		new_name = "Gore_Guard";
	
	return new_name;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function minotaur_lord_multiple_enemy_attack(agent thisagent, agent target)
// Minotaur Lord basic attack
declare
	list targets;
	agent target1,target2,target3;

begin
	if ((target's "type" == "building") || (target's "type" == "lair"))
		$make_attack(thisagent,target);
		
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,30);


	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// attack the three nearest targets
	$make_attack(thisagent,target1);
	$make_attack(thisagent,target2);
	$make_attack(thisagent,target3);
	
		
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function NewSpellCheck_henchman( agent thisagent, agent target ) is string
// This function is for attack spells using the new Cooldown system as well.
// This will check all custom spells for this henchman and return the name of a valid spell.
declare
	agent newtarget;
	boolean next_spell;
	list spell_targets;
	string spell_name, unit_name;
	integer targetrange, attackrange;
begin
	unit_name = thisagent's "title";
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	spell_name = "nothing";
	newtarget = target;
	next_spell = FALSE;
	if (unit_name == "court_mage")
		begin
			if (($isspellAvailable(thisagent,"cm_enchant_wizard_tower") == TRUE) && ($Checkeffector(thisagent,"cm_enchant_wizard_tower_icon") == false))
				begin
					spell_targets = $listtitlesinRadiusAdvanced (ThisAgent, "Building", "wizards_tower", thisagent's "castingrange", #MyPlayer);
					if ($ListSize (spell_targets) > 0)
						begin
							newtarget = $ListMember(spell_targets,1);
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (($Checkeffector(newtarget,"cm_enchant_wizard_tower_end") == false) && (targetrange <= attackrange))
								begin
									spell_name = "cm_enchant_wizard_tower";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
			 if (($isspellAvailable(thisagent,"cm_etherealize") == TRUE) && ($Checkeffector(thisagent,"cm_etherealize_icon") == false) && (next_spell == TRUE))
				begin
					if ((newtarget's "type" != "building") && (newtarget's "type" != "lair"))
						begin
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (targetrange <= attackrange)
								begin
									spell_name = "cm_etherealize";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
			 if (($isspellAvailable(thisagent,"cm_acid_fog_spell") == TRUE) && ($Checkeffector(thisagent,"cm_acid_fog_icon") == false) && (next_spell == TRUE))
				begin
					if ((newtarget's "type" != "building") && (newtarget's "type" != "lair"))
						begin
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (targetrange <= attackrange)
								begin
									spell_name = "cm_acid_fog_spell";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
		end
		
	return spell_name;
end
/////////////////////////////////////////////////////////////////////////////////////////////////
function NewSpellTarget_henchman( agent thisagent, agent target, string spell_name ) is agent
// This will return a valid target for the spell listed for this agent.
declare
	agent newtarget;
	boolean is_learned, on_cooldown;
	list spell_targets;
	string unit_name;
	integer targetrange, attackrange;
	
begin
	unit_name = thisagent's "title";
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	newtarget = target;
	if (spell_name == "cm_Enchant_Wizard_Tower")
		begin
			spell_targets = $listtitlesinRadiusAdvanced (ThisAgent, "Building", "wizards_tower", thisagent's "castingrange", #MyPlayer );
			if ($ListSize (spell_targets) > 0)
				begin
					newtarget = $ListMember(spell_targets,1);
				end
		end
	else if (spell_name == "cm_Etherealize")
		begin
			newtarget = target;
		end
	else if (spell_name == "cm_acid_fog_spell")
		begin
			newtarget = target;
		end
		
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ProperUnitColor_HB( agent thisagent ) is string
// List of names for units to retrieve proper art for

declare
	string new_color, unit_name;

begin
	unit_name = thisagent's "title";
	new_color = "none";
	
	if (unit_name == "Sanguine_Peasant")
		new_color = "red";
	else if (unit_name == "Crimson_Archer")
		new_color = "red";
	else if (unit_name == "Maniacal_Arbalest")
		new_color = "red";
	else if (unit_name == "Blood_Mage")
		new_color = "red";
	else if (unit_name == "Scarlet_Squire")
		new_color = "red";
	else if (unit_name == "Gore_Guard")
		new_color = "red";
	else if (unit_name == "Spirit_Troll")
		new_color = "gray";
	else if (unit_name == "Minotaur_Lord")
		new_color = "gray";
	else if (unit_name == "Elder_Orbs")
		new_color = "gray";
	
	return new_color;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ProperUnitTransparency_HB( agent thisagent ) is integer
// List of names for units to retrieve proper art for

declare
	string unit_name;
	integer new_transparency;

begin
	unit_name = thisagent's "title";
	new_transparency = 0;
	
	if (unit_name == "Spirit_Troll")
		new_transparency = 3;
	
	return new_transparency;
end


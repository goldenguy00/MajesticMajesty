/////////////////////////////////////////////////////////////////////////////////////////////////
function Flame_Shield_Begin( agent thisagent, agent target )
// generic library hero spell - lvl 1 - uses Fire Shield art
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_armor, add_resistance, mana_cost;
	string buff_name;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	mana_cost =  $Spell_Mana_Cost(thisagent,"flame_shield");
	duration = 14000;
	cooldown = 12000;
	add_armor = (1 + (stat_int / 10));
	add_resistance = (8 + (stat_int / 6));
	buff_name = "Generic_FlameShieldBuff_End";
	
	duration = $DurationBuff(thisagent, target, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	add_armor = $EffectBuff(thisagent, target, add_armor);
	add_resistance = $EffectBuff(thisagent, target, add_resistance);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( target, "fire_shield_effector", 0 );
	
	$AddAttribute(ThisAgent, "generic_flameshield_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "generic_flameshield_cooldown", cooldown, thisAgent, "generic_flameshield_cooldown" );
	
	if ($HasAttribute(buff_name, target) != False)
		begin
			if ($IsRunning (target's buff_name) == TRUE)
				return;
		end
	else
		$AddAttribute(target, buff_name, "function", $Generic_FlameShieldBuff_End);
	
	$createeffector( target, "flame_shield_icon", duration );
	$NewThread(target's buff_name, duration, thisagent, stat_int, stat_willpower, stat_wisdom);

	$adjustattribute(target,#ATTRIB_Armor_Basic_Damage,add_armor);
	$MagicalAdjustAttribute(target,#ATTRIB_Magicresistance,add_resistance);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Generic_FlameShieldBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// generic library hero spell - lvl 1
// - callback from "flame_shield_icon" effector
declare
	integer add_resistance, add_armor;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	add_armor = (1 + (intelligence / 10));
	add_resistance = (8 + (intelligence / 6));
	
	add_resistance = $EffectBuff_Thread(willpower, wisdom, add_resistance);
	add_armor = $EffectBuff_Thread(willpower, wisdom, add_armor);
	
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage, - add_armor);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_magicresistance, - add_resistance);
	
	$KillThread(thisagent's "Generic_FlameShieldBuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
//CULTIST
/////////////////////////////////////////////////////////////////////////////////////////////////
function Camouflage_Begin( agent thisagent, agent target )
// cultist spell - lvl 4
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, mana_cost;
	string buff_name;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"camouflage");
	duration = 16000;
	cooldown = 8000;
	buff_name = "Cultist_CamouflageBuff_End";
	
	duration = $DurationBuff(thisagent, thisagent, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( thisagent, "camouflage_effector", 0 );
	$createeffector( thisagent, "camouflage_icon", duration );
	
	$AddAttribute(ThisAgent, "cultist_camouflage_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "cultist_camouflage_cooldown", cooldown, thisAgent, "cultist_camouflage_cooldown" );
	
	if ($HasAttribute(buff_name, thisagent) != False)
		begin
			if ($IsRunning(thisagent's buff_name) == TRUE)
				$KillThread(thisagent's buff_name);
		end
	else
		$AddAttribute(thisagent, buff_name, "function", $Cultist_CamouflageBuff_End);
		
	
	$NewThread(thisagent's buff_name, duration, thisagent, stat_int, stat_willpower, stat_wisdom);

	$SetAttribute( thisagent, #ATTRIB_HasEffectCamouflage, 1 );
	$GetProperUnitArt( thisagent );

	thisagent's "type" = "camouflaged";
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Cultist_CamouflageBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// cultist spell - lvl 4
// - callback from "camouflage_icon" effector
declare

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
	
	if (($GetAttribute(thisagent, #ATTRIB_HasEffectCamouflage) > 0) && (thisagent's "type" == "camouflaged"))
		begin
	
			$SetAttribute( thisagent, #ATTRIB_HasEffectCamouflage, 0 );

			thisagent's "type" = thisagent's "original_type";
	
		end
		
	$GetProperUnitArt( thisagent );
	
	$KillThread(thisagent's "Cultist_CamouflageBuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Charm_Monster_Begin( agent thisagent, agent target )
// cultist spell - lvl 1
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, cooldown, mana_cost;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"charm_monster");
	cooldown = 5000;
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( thisagent, "charm_monster_effector", 0 );
	
	if ($CheckEffector(target, "Charm_icon") == TRUE)
		return;
	
	$AddAttribute(ThisAgent, "cultist_charmmonster_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "cultist_charmmonster_cooldown", cooldown, thisAgent, "cultist_charmmonster_cooldown" );
	
	$control_monster(thisagent,target);
	
	$adjustattribute( target, #ATTRIB_MaxHP, ($getattribute(thisagent, #ATTRIB_ExperienceLevel) * 2));
	$adjustattribute( target, #ATTRIB_HP,  ($getattribute(thisagent, #ATTRIB_ExperienceLevel) * 2));
	$adjustattribute( target, #ATTRIB_Dodge, (stat_art / 2));
	$adjustattribute( target, #ATTRIB_HtoH, (stat_art / 3));
	$adjustattribute( target, #ATTRIB_Ranged, (stat_art / 3));
	$adjustattribute( target, #ATTRIB_Parry, (stat_art / 4));
	$adjustattribute( target, #ATTRIB_MagicResistance, (stat_int / 6));
	$adjustattribute( target, #ATTRIB_Strength,($getattribute(thisagent, #ATTRIB_Strength) / 10));
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Change_Shape_Begin( agent thisagent, agent target )
// cultist spell - lvl 7
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_strength, add_vitality, add_MaxHP, add_armor, mana_cost;
	string buff_name;
	
begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"change_shape");
	duration = 20000;
	cooldown = 34000;
	add_armor = (3 + (stat_int / 8));
	add_strength = (6 + (stat_int / 7));
	add_vitality = (9 + (stat_int / 6));
	add_MaxHP = (24 + (stat_int / 5));
	buff_name = "Cultist_ChangeShapeBuff_End";
	
	duration = $DurationBuff(thisagent, thisagent, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	add_armor = $EffectBuff(thisagent, thisagent, add_armor);
	add_strength = $EffectBuff(thisagent, thisagent, add_strength);
	add_vitality = $EffectBuff(thisagent, thisagent, add_vitality);
	add_MaxHP = $EffectBuff(thisagent, thisagent, add_MaxHP);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( thisagent, "change_shape_effector", 0 );
	$createeffector( thisagent, "change_shape_icon", duration );
	
	$AddAttribute(ThisAgent, "cultist_changeshape_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "cultist_changeshape_cooldown", cooldown, thisAgent, "cultist_changeshape_cooldown" );
	
	if ($HasAttribute(buff_name, thisagent) == False)
		$AddAttribute(thisagent, buff_name, "function", $Cultist_ChangeShapeBuff_End);
		
		
	$NewThread(thisagent's buff_name, duration, thisagent, stat_int, stat_willpower, stat_wisdom);

	$ChangeUnitType( thisagent, "Red_Bear" );

	// increase various attributes
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage,add_armor);

	$MagicalAdjustAttribute(thisagent,#ATTRIB_Strength,add_strength);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Vitality,add_vitality);

	$AdjustAttributeSafe(thisagent, "Strength_Flat_Modifier", add_strength);
	$AdjustAttributeSafe(thisagent, "Vitality_Flat_Modifier", add_vitality);
	$AdjustAttributeSafe(thisagent, "MaxHP_Flat_Modifier", add_vitality);

	$adjustattribute(thisagent,#ATTRIB_MaxHP,add_MaxHP);
	$adjustattribute(thisagent,#ATTRIB_HP,add_MaxHP);

	$RecalculateStats(thisagent);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Cultist_ChangeShapeBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// cultist spell - lvl 7
// - callback from "change_shape_icon" effector
declare

	integer maxHP, add_strength, add_vitality, add_MaxHP, add_armor;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	add_armor = (3 + (intelligence / 8));
	add_strength = (6 + (intelligence / 7));
	add_vitality = (9 + (intelligence / 6));
	add_MaxHP = (24 + (intelligence / 5));
	
	add_armor = $EffectBuff_Thread(willpower, wisdom, add_armor);
	add_strength = $EffectBuff_Thread(willpower, wisdom, add_strength);
	add_vitality = $EffectBuff_Thread(willpower, wisdom, add_vitality);
	add_MaxHP = $EffectBuff_Thread(willpower, wisdom, add_MaxHP);
	
	$RevertUnitType( thisagent );

	// revert the attributes
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage, -add_armor);
	
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Strength, -add_strength);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Vitality, -add_vitality);

	$AdjustAttributeSafe(thisagent, "Strength_Flat_Modifier", -add_strength);
	$AdjustAttributeSafe(thisagent, "Vitality_Flat_Modifier", -add_vitality);
	$AdjustAttributeSafe(thisagent, "MaxHP_Flat_Modifier", -add_vitality);

	$adjustattribute(thisagent,#ATTRIB_MaxHP, -add_MaxHP);
	$adjustattribute(thisagent,#ATTRIB_HP, -add_MaxHP);


	// revert HP to full, if are above max
	maxHP = $getattribute(thisagent,#ATTRIB_MaxHP);
	if ($getattribute(thisagent,#ATTRIB_HP) > maxHP)
		$SetAttribute( thisagent, #ATTRIB_HP, maxHP );
	
	$RecalculateStats(thisagent);
	$KillThread(thisagent's "Cultist_ChangeShapeBuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
//HEALER
function Healer_Heal_Effect( agent thisagent, agent target )
// healer spell - lvl 1
// - callback from cast action
declare
	agent AIRootAgent;
	integer Healing;
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_strength, add_htoh, mana_cost;
begin
	if ( $isdead ( target ))
		return;

	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_wisdom = thisagent's "Wisdom_Total";
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	cooldown = 2000;
	mana_cost =  $Spell_Mana_Cost(thisagent,"healer_heal");
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$AddAttribute(ThisAgent, "healer_healerheal_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "healer_healerheal_cooldown", cooldown, thisAgent, "healer_healerheal_cooldown" );
	
	if ( $isdead ( thisagent ) == FALSE )
		begin
			$createeffector( target, "healer_healing_effector", 0 );

			AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
  			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				begin
					if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
						begin
							healing = ( #Deathmatch_Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
							if ( healing > #Deathmatch_Agrella_Healing_Cap )
								healing = #Deathmatch_Agrella_Healing_Cap;
						end
					else
						begin
							healing = ( #Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
						end
				end
			else
				begin
					healing = ( #Agrella_Healing_Multiplier * $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel ));
				end

			$Heal ( ThisAgent, Target, healing );
			if ( target's "backscript" == $use_building_safe )
				begin
					if ( $haslowHP ( target ) == False )
						$reset_tasks ( target );
				end
		end
end


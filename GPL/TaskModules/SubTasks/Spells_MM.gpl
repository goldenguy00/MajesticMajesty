		return $PercentOf(cast_range, 67, False);
	if (spell_name == "animate_skeleton")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "control_undead")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "priestess_wither")
		return $PercentOf(cast_range, 70, False);
		
	////SOLARUS
	if (spell_name == "sun_scorch")
		return $PercentOf(cast_range, 25, False);
		
	////WIZARD
	if (spell_name == "energy_blast")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_shield")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_blast")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_ball")
		return $PercentOf(cast_range, 75, False);
	if (spell_name == "resist_magic")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "wizard_Transmute")
		return $PercentOf(cast_range, 67, False);
		
	////GENERIC
	if (spell_name == "generic_regenerate")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "flame_shield")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "power_shock")
		return $PercentOf(cast_range, 60, False);
		
	////GADGETS
	if (spell_name == "deploy_dart_sentry")
		return $PercentOf(cast_range, 60, False);
		
	////FIRE SKILL TREE
	if (spell_name == "Fire_Bolt")
		return $PercentOf(cast_range, 70, False);
	if (spell_name == "fireball")
		return $PercentOf(cast_range, 80, False);
	if (spell_name == "Perdition_Barrage")
		return $PercentOf(cast_range, 90, False);
	if (spell_name == "Incandescent_Ray")
		return $PercentOf(cast_range, 70, False);
	if (spell_name == "searing_mantle")
		return $PercentOf(cast_range, 60, False);
	if (spell_name == "Pyrelight")
		return $PercentOf(cast_range, 85, False);
	if (spell_name == "ignite")
		return $PercentOf(cast_range, 75, False);
		
	return cast_range;
end


function Drain_Life_Cast(agent thisagent, agent target)
// wizard spell - lvl 1
// - callback from cast action
declare
	integer stat_int, stat_art, cooldown, mana_cost;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"drain_life");
	cooldown = 2000;
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$AddAttribute(ThisAgent, "drain_life_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "drain_life_cooldown", cooldown, thisAgent, "drain_life_cooldown" );
	
	$createmissile("life_drain_missile",thisagent,target);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Drain_Life_Hit( agent thisagent, agent target )
// priestess spell - lvl 1
// - callback from missile hit
declare
	list		My_Skeletons;
	agent		Skeleton, Best_Skeleton;
	integer  Healing_Needed, Temp_Healing_Needed, HP, MaxHP;

begin
	if ($isvalidgamepiece(target) == FALSE)
		return;

	If (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			//If I am hurt, then heal me
			If ($GetAttribute (ThisAgent, #ATTRIB_HP) < $GetAttribute (ThisAgent, #ATTRIB_MaxHP))
				begin
					$createeffector( ThisAgent, "life_drain_effector2", 0 );
					$heal(thisagent,thisagent,($getattribute( ThisAgent, #ATTRIB_intelligence ) / 4));
	   		end

			Else
				//Heal a controlled skeleton nearby
				begin
					//init Healing_Needed and Temp_Healing_Needed to 0, in order to eval for SKele needing it the most
					Temp_Healing_Needed = 0;
		   		Healing_Needed = 0;

					My_Skeletons = $ListSubtypesInRadius (ThisAgent, "hero", "controlled", $GetAttribute (ThisAgent, #ATTRIB_SightRange));
					My_Skeletons = $ListTitles (My_Skeletons, "Skeleton");
		   		Foreach Skeleton in My_Skeletons do
						begin
							HP = $GetAttribute (Skeleton, #ATTRIB_HP);
							MaxHP = $GetAttribute (Skeleton, #ATTRIB_MaxHP);

							//pick the Skele that needs it the most
							If (HP < MaxHP)
								begin
									Temp_Healing_Needed = MaxHP - HP;
									If (Temp_Healing_Needed > Healing_Needed)
										begin
											Healing_Needed = Temp_Healing_Needed;
											Best_Skeleton = Skeleton;
										end
								end
						end
					If ($IsValidGamePiece (Best_Skeleton))
						begin
							$createeffector( Best_Skeleton, "life_drain_effector2", 0 );
							$Heal (ThisAgent, Best_Skeleton, ($getattribute( ThisAgent, #ATTRIB_intelligence ) / 4));
						end
				end
		end

	$createeffector( target, "life_drain_effector", 0);
	$spell_type_attack(thisagent, target, "Necrotic", 13, 16);
	//$spell_attack( thisagent, target, 15 );
end



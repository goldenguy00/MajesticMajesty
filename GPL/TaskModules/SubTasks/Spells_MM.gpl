function ra_split_shot_cast(agent thisagent, agent target)
// Royal Archer - 3 Spires
// - callback from cast action
declare
	list targets;
	agent target1,target2;
	integer attackrange;

begin
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,attackrange);

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	// fire 3 projectiles at the closest ones
	$createmissile("Green_Ranger_Arrow", thisagent,target1);
	$createmissile("Green_Ranger_Arrow", thisagent,target2);
end


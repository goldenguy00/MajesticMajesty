function Meditation_Begin( agent thisagent, agent target )
// healer spell - lvl 4
// - callback from cast action
// Heal rate commented out until the Health Regeneration system is properly implemented
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_dodge, add_parry, add_sight, add_healrate, mana_cost;
	string buff_name, spell_cast;
	
begin
	spell_cast = "meditation";
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	duration = 33000;
	cooldown = 22000;
	add_dodge = (15 + (stat_int / 5));
	add_parry = (15 + (stat_int / 5));
	add_sight = (30 + (stat_int / 4));
	buff_name = "Healer_MeditationBuff_End";
	//add_healrate = (1 + (stat_int / 12));
	
	duration = $DurationBuff(thisagent, target, duration);
	
	add_dodge = $EffectBuff(thisagent, target, add_dodge);
	add_parry = $EffectBuff(thisagent, target, add_parry);
	add_sight = $EffectBuff(thisagent, target, add_sight);
	//add_healrate = $EffectBuff(thisagent, target, add_healrate);
	
	mana_cost =  $SpellManaCost(thisagent, spell_cast);
	$SpendMana(thisagent, mana_cost);

	cooldown = $GetSpellCooldown(thisagent, cooldown);
	$StartCooldown(thisagent, spell_cast, cooldown);

	$createeffector(target,"Meditation_effector",0);
	
	if ($AddAttribute(target, buff_name, "function", $Healer_MeditationBuff_end) == false)
		if ($IsRunning (target's buff_name) == TRUE)
			return;		
		
	$createeffector(target,"Meditation_icon",duration);
	$NewThread(target's buff_name, duration, target, stat_int, stat_willpower, stat_wisdom);
	
	$MagicalAdjustAttribute(target,#ATTRIB_dodge,add_dodge);
	$MagicalAdjustAttribute(target,#ATTRIB_parry,add_parry);
	$adjustattribute(target,#ATTRIB_sightrange,add_sight);
	//$adjustattribute(target,#ATTRIB_HealingRateModifier,add_healrate);

end


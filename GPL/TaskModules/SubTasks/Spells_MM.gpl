function Power_Shock_Cast(agent thisagent, agent target)
// Generic Spell
// - callback from cast action
declare
	integer cooldown, mana_cost;
	string spell_cast;

begin
	spell_cast = "power_shock";
	cooldown = 6000;
	
	mana_cost =  $SpellManaCost(thisagent, spell_cast);
	$SpendMana(thisagent, mana_cost);

	cooldown = $GetSpellCooldown(thisagent, cooldown);
	$StartCooldown(thisagent, spell_cast, cooldown);

	$createmissile("power_shock_missile",thisagent,target);
end

function Power_Shock_Check(agent thisagent) is integer
declare
begin
	return $GenericSpellCheck(thisagent, "power_shock");
end


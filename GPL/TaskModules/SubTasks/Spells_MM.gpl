function HandleSearingMantle(agent thisagent, agent target)
declare
begin
		if ($IsDead(target) == True)
			return;
			
		if ($HasAttribute("SearingMantleBuff_End", target) == True)
		if ($IsRunning(Target's "SearingMantleBuff_End") == True)
			begin
				if ($GetAttribute(thisagent, #ATTRIB_MaxAttackRange) < 50)
					begin
						$createeffector( thisagent, "SearingMantleDamage_Effector", 0 );
						$spelltypedamage(target, thisagent, "fire", target's "SearingMantle_Damage_Min",  target's "SearingMantle_Damage_Max");
					end
			end
end
// --- Howl of Discord Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Howl_of_Discord_Begin ( agent thisagent, agent target )
declare
	list heroes, monsters, all_targets;
	agent hero, victim;
	integer level, fear_mod, min_damage, max_damage;

begin
	$CreateEffector ( thisagent, "Howl_of_Discord_Effector", 0 );

	All_Targets = $compile_enemies (ThisAgent, #Howl_of_Discord_Radius);

	level = $GetAttribute ( ThisAgent, #ATTRIB_ExperienceLevel );
	fear_mod = ( level * 5 );
	min_damage = ( #Howl_of_Discord_Damage + level );
	max_damage = ( min_damage * 1.5 );

	foreach victim in all_targets do
		begin
			if ( $isdead ( victim ) == FALSE )
				begin
					// All valid targets get the effector.
					$CreateEffector ( victim, "Howl_of_Discord_Hit", 0 );
					//$Spell_Attack ( thisagent, victim, max_damage );
					$spell_type_attack(thisagent, target, "Chaos", min_damage, max_damage);

					// Only actual heroes can be affected by the fear.
					if ( victim's "subtype" == "hero" )
						begin
							if (( $randomnumber ( 100 ) + fear_mod ) > ( #Howl_of_Discord_Resist * victim's "self_estimation" ))
								begin
									// Must check the if the unit is dead here, as it may have been killed
									// by the howl damage called earlier
									if ( $isdead ( victim ) == FALSE )
										$Flee_Absolute_packet ( victim, "IDTXT_INTENT_FLEEING" );
								end
						end
				end
		end
end


///////////////////////////////////////////////////////////////////////////////
//Returns 1 if there are valid enemies nearby
function howl_check ( agent thisagent ) is integer

declare
	list targets;

begin
	targets = $compile_enemies ( thisagent, #Howl_of_Discord_Radius );

	//Only cast if there is more than one enemy nearby
	if ( $listsize ( targets ) > 1 )
		return 1;
	else
		return 0;
end

///////////////////////////////////////////////////////////////////////////////
function Terrify_effect(agent thisagent,agent target)

// make nearby heroes run!
declare
	list guys;
	agent guy;

begin
	if ($isdead(thisagent))
		return;

	guys = $list_enemies_seen(thisagent,$getattribute(thisagent,#ATTRIB_sightrange));
	foreach guy in guys do
		begin
			if (guy's "subtype" == "hero")
				if ($randomnumber(100) < 75)
					begin
						// play effector
//						If ( $InsideBuilding ( guy ))
//							$Exit_Building ( ThisAgent, ThisAgent's "Target" );

						$Flee_packet( guy, "IDTXT_INTENT_FLEEING");
						$createeffector(guy,"Terrify_effector",0);

					end
		end
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function get_healer_begin(agent thisagent, agent target)

declare
	list heroes;

begin
	// first look for healers
	$listobjects(thisagent,"hero",thisagent's "castingRange" * 2,heroes,#NotMyTeam);
	heroes = $listtitles(heroes,"healer");

	if ($listsize(heroes) > 0)
		begin
			if ($randomnumber(100) < 35)
				begin
					// then see if you cast a missle at the nearest one
					$createmissile("energy_blast_missile",thisagent,$listmember(heroes,1));
				end
		end
end

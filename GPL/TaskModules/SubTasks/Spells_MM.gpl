/////////////////////////////////////////////////////////////////////////////////////////////////
function Priestess_AnimateSkeleton_Summon( agent thisagent )
// priestess spell - lvl 4
// - callback from animate_skeleton_effector effector
declare
	agent s_Minion;
	integer p_Level;
begin
	p_Level = $getattribute(thisagent, #ATTRIB_ExperienceLevel);
	s_Minion = $SpawnUnit ( thisagent, "Skeleton" );
	$adjustattribute( s_Minion, #ATTRIB_MaxHP, ($getattribute(thisagent, #ATTRIB_ExperienceLevel)));
	$adjustattribute( s_Minion, #ATTRIB_HP, ($getattribute(thisagent, #ATTRIB_ExperienceLevel)));
	$adjustattribute( s_Minion, #ATTRIB_Dodge, ($getattribute(thisagent, #ATTRIB_Intelligence) / 20));
	$adjustattribute( s_Minion, #ATTRIB_Strength, ($getattribute(thisagent, #ATTRIB_Intelligence) / 14));
	$adjustattribute( s_Minion, #ATTRIB_SightRange, ($getattribute(s_Minion, #ATTRIB_SightRange) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 8)));
	$adjustattribute( s_Minion, #ATTRIB_MagicResistance, ($getattribute(thisagent, #ATTRIB_Intelligence) / 8));
	$adjustattribute( s_Minion, #ATTRIB_Parry, ($getattribute(thisagent, #ATTRIB_Intelligence) / 7));
	$adjustattribute( s_Minion, #ATTRIB_HtoH, ($getattribute(thisagent, #ATTRIB_Intelligence) / 6));
	$adjustattribute( s_Minion, #ATTRIB_Ranged, ($getattribute(thisagent, #ATTRIB_Intelligence) / 6));
	(ThisAgent's "Num_Followers") ++;
	
	$KillThread(thisagent's "Priestess_AnimateSkeleton_Summon");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Control_Undead_Begin( agent thisagent, agent target )
// priestess spell - lvl 7
// - callback from cast action
declare

	integer stat_int, stat_willpower, stat_wisdom, stat_art, cooldown, mana_cost;
	string spell_cast;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	spell_cast = "control_undead";
	cooldown = 4000;
	
	mana_cost =  $SpellManaCost(thisagent, spell_cast);
	$SpendMana(thisagent, mana_cost);

	cooldown = $GetSpellCooldown(thisagent, cooldown);
	$StartCooldown(thisagent, spell_cast, cooldown);

	$createeffector( thisagent, "control_undead_effector", 0 );
	
	if ($CheckEffector(target, "Charm_icon") == TRUE)
		return;
	
	$control_monster(thisagent,target);
	
	$setattribute( target, #ATTRIB_MaxHP, ($getattribute(target, #ATTRIB_MaxHP) + ($getattribute(thisagent, #ATTRIB_ExperienceLevel) / 2)));
	$setattribute( target, #ATTRIB_HP, ($getattribute(target, #ATTRIB_HP) + ($getattribute(thisagent, #ATTRIB_ExperienceLevel) / 2)));
	$setattribute( target, #ATTRIB_Dodge, ($getattribute(target, #ATTRIB_Dodge) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 40)));
	$setattribute( target, #ATTRIB_Strength, ($getattribute(target, #ATTRIB_Strength) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 28)));
	$setattribute( target, #ATTRIB_SightRange, ($getattribute(target, #ATTRIB_SightRange) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 16)));
	$setattribute( target, #ATTRIB_MagicResistance, ($getattribute(target, #ATTRIB_MagicResistance) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 16)));
	$setattribute( target, #ATTRIB_Parry, ($getattribute(target, #ATTRIB_Parry) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 14)));
	$setattribute( target, #ATTRIB_HtoH, ($getattribute(target, #ATTRIB_HtoH) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 12)));
	$setattribute( target, #ATTRIB_Ranged, ($getattribute(target, #ATTRIB_Ranged) + ($getattribute(thisagent, #ATTRIB_Intelligence) / 12)));
end


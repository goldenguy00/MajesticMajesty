	$player_spell_type_attack( target, "cold", 12, 5 );
end


///////////////////////////////////////////////////////////////////////////////
Function ChainLightning_MissileHit ( agent victim )
//
Declare
	integer 	max_damage, min_damage, int_pulse;
	float 	pulse;
	agent 	target;
	list 		targets, Monsters, Heroes;
	boolean  fired;

Begin
	// First check to see if the target has a mirror up, if so, just jump
	// out of the effect.
	if ( $GetAttribute ( victim, #ATTRIB_HasEffectMagicMirror ) == 1 )
		return;
	if ( $IsDead ( victim ))
		return;
		
	$createeffector ( victim, "Chainlightning_effector", 0 );

	// Set the damage based on the pulse strength of the chain attribute.
	Pulse = $GetAttribute ( victim, #ATTRIB_StruckByChainLightning );
	int_pulse = pulse; // Setattribute later in function needs an integer attribute.

	Max_Damage = ( pulse * #Chainlightning_DamageMultiplier );
	Min_Damage = ( Max_Damage / 1.5 );

	// If there's more than one pulse strength left, move into the propogation sequence.
	if (( Pulse ) > 1 )
		begin
			$ListObjects ( victim, "Hero", #ChainLightning_Radius, Heroes, #MyTeam, #NoHiddenMap );
			$ListObjects ( victim, "Monster", #ChainLightning_Radius, Monsters, #MyTeam, #NoHiddenMap );

			Targets = $AddLists (Heroes, Monsters);

			if ( $ListSize ( targets ) > 0 )
				begin
					Foreach target in Targets do
						begin
							if ( fired == false )
								begin
									if ( $IsDead ( target ) == FALSE )
										begin
											// Dont target anyone who's been hit by the chain already.
											if ( $GetAttribute ( target, #ATTRIB_StruckByChainLightning ) < 1 )
												begin
													// Setting the chain attrib on the target both allows the missile
													// to affect its target without a callback from the attacker,
													// and lets us properly decrement the effect as it propogates.
													$SetAttribute ( target, #ATTRIB_StruckByChainLightning, ( int_pulse - 1 ));
													$createeffector ( target, "Chainlightning_Icon", 3000 );
													$CreateMissile ( "chain_lightning_missile", victim, target );
													fired = TRUE;
												end
										end
								end
						end
				end
		end
	// Do your damage at the end of the entire sequence.
	$Player_Spell_type_Attack ( victim, "electric", Max_Damage, Min_Damage );
end

///////////////////////////////////////////////////////////////////////////////
// Damage all undead in thisagent's "sightrange"
function turn_undead_hit (agent ThisAgent)
Declare
	list	Targets;
	agent	Dude;

Begin
	If ($IsDead (thisAgent) == False)
		begin

			targets = $compile_enemies(thisagent, 200);
			targets = $ListSubtypes (targets, "undead");

			foreach dude in targets do
				begin
					$createeffector( dude, "turn_undead_hit", 0 );

					//Use player spell attacks as this won't instantiate ThisAgent on the target's
					//hostiles list - which makes the spell not strategic for the Healers
					$player_spell_type_attack( dude, "divine", 10 + $getattribute( thisagent,#ATTRIB_experienceLevel ) / 2, 8 );
				end

		end
End


/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastHealAlly_hero( agent thisagent, agent target, string spell_name ) is agent
// Return a viable allied target for support spell.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count, CurrentHP, MaxHP;
	
begin
	unit_name = thisagent's "title";
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	CurrentHP = $getattribute(target, #ATTRIB_HP);
	MaxHP = $getattribute(target, #ATTRIB_MaxHP);
	castrange = $SpellRangeList(castrange, spell_name);
	
	if (CurrentHP < MaxHP)
		newtarget = thisagent;
	else
		begin
			$ListObjects(thisagent, "hero", castrange, potential_targets, #MyPlayer);
			count = $listsize(potential_targets);
			if (count > 0)
				begin
					foreach picked in potential_targets do
						begin
							CurrentHP = $getattribute(picked, #ATTRIB_HP);
							MaxHP = $getattribute(picked, #ATTRIB_MaxHP);
							if ((CurrentHP < MaxHP) && ($IsDead(picked) != TRUE))
								begin
									if (picked != thisagent)
										spell_targets << picked;
								end
						end
					if ($listsize(spell_targets) > 0)
						begin
							newtarget = $listmember(spell_targets, 1);
						end
				end
		end
	return newtarget;
end


///////////////////////////////////////////////////////////////////////////////
function Infectious_Cloud_Hit ( agent thisagent, agent target )
// monster spell
// - callback from missile hit
declare

begin
	$createeffector ( target, "Infectious_Cloud_Effector", 0 );
	//$spell_attack ( thisagent, target, 10 );
	$spell_type_attack(thisagent, target, "Poison", 9, 10);

	if ( $isdead ( target ) == FALSE )
		if ( $GetAttribute ( target, #ATTRIB_HasEffectRatmanPlague ) < 1 )
			if (( $RandomNumber ( 100 ) + 1 ) < #Plague_Chance )

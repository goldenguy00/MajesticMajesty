////////////////////////////////////////EXPANSION SPELLS///////////////////////////////////////////////

// --- Solarii Supernova Functions begin here --- //

///////////////////////////////////////////////////////////////////////////////
function Supernova_Blast ( agent thisagent, agent target )
// This spell is called directly when high level Solarii die. The standard 'target'
// that the blast is centered on is themselves.

declare
	list targets;
	agent unit;

begin
	$createeffector ( target, "Supernova_Blast_Effector", 0 );

	targets = $compile_enemies ( target, #Supernova_Radius );

	foreach unit in targets do
		begin
				If ($Does_Resist_Fire (Unit) == False)
					begin

						$createeffector ( unit, "Supernova_Hit_Effector", 0 );
						$spell_type_attack(thisagent, target, "Fire", (#Supernova_Damage - 5) + ( $getattribute ( thisagent, #ATTRIB_experienceLevel ) * 2 ), (#Supernova_Damage + 3) + ( $getattribute ( thisagent, #ATTRIB_experienceLevel ) * 2 ));
						//$spell_attack ( thisagent, unit, #Supernova_Damage + ( $getattribute ( thisagent, #ATTRIB_experienceLevel ) * 2 ));

					end
		end
end

///////////////////////////////////////////////////////////////////////////////
// Returns TRUE if ThisAgent's resist fire is TRUE, AND they make a random roll
Function Does_Resist_Fire (agent ThisAgent) is boolean
Declare

Begin
	If ($HasAttribute ("Resists_Fire", ThisAgent) )
		begin

			If (ThisAgent's "Resists_Fire")

				If ( ( ( $GetAttribute (ThisAgent, #ATTRIB_ExperienceLevel) * 5) + 30) > $RandomNumber (100) + 1)
					return True;

		end

	return False;

End

///////////////////////////////////////////////////////////////////////////////
function Champions_Vigor_Begin ( agent thisagent )
// GPL cast spell - from hall of champions
declare
begin
	if ( $IsDead ( ThisAgent ) )
		return;

	$createeffector( thisagent, "Champions_Vigor_effector", 0 );
	$createeffector( thisagent, "Champions_Vigor_icon", 90000 );

	$AdjustAttribute ( thisagent, #ATTRIB_MaxHP, 15 );
	$AdjustAttribute ( thisagent, #ATTRIB_HealingRateModifier, -3 );

	$setattribute ( thisagent, #ATTRIB_HP, $getattribute ( thisagent, #ATTRIB_MaxHP ));
end

///////////////////////////////////////////////////////////////////////////////
function ChangeOfHeart_Begin ( agent thisagent )
//This makes fleeing heroes go berserk, otherwise it makes them flee.
declare
	string Intent;
	integer intent_int;

begin
	If ( ThisAgent's "Subtype" == "Hero" )
		begin
			If ( $IsDead ( ThisAgent ))
				return;


			$createeffector( thisagent, "ChangeHeart", 0 );

			Intent = $GetStringSafe(thisagent's "Running_Intent");
			Intent_int = $GetAttribute ( ThisAgent, #ATTRIB_AIIntentionString );

			//If the unit is currently leaving Ardania, then don't do anything
			//Also, if the unit is currently frozen don't do anthing
			If ( Intent == "IDTXT_INTENT_FLEEINGMAP" || Intent_int == #intent_flee_Map || $IsFrozen ( ThisAgent ))
				return;


			//ThisAgent should go berserk if they are currently fleeing
			If ( Intent == "IDTXT_INTENT_FLEEING" || Intent == "IDTXT_INTENT_FLEEINGINJURED" ||
				Intent_int == #intent_flee_Scared || Intent_int == #intent_flee_lowHP )
				begin

					$Go_Berserk ( ThisAgent );

				end

			//Otherwise, if they aren't inside a building, they should flee
			Else
				begin
					If ( $InsideBuilding ( ThisAgent ) == False )
						begin

							$Flee_Absolute_packet ( ThisAgent, "IDTXT_INTENT_FLEEING" );

						end

					//Potentially kick unit out of the building if they are in it...
					Else
						begin

							$Exit_Building ( ThisAgent, ThisAgent's "Target" );

							$Go_Berserk ( ThisAgent );

						end

				end

		end
end

///////////////////////////////////////////////////////////////////////////////
function Pestilence_begin(agent thisagent, agent target)
// RHoden spell
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3,target4;

begin
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,thisagent's "castingrange");

//	$ListObjects(thisagent,"monster",thisagent's "castingrange",targets,#NotMyPlayer);

	$createeffector( thisagent, "ratman_pest_eff", $GetSpellAttribute( "Pestilence", "effector_duration" ) );

	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target4 = $listmember(targets,1);

	// fire 4 projectiles at the closest ones
	$createmissile("ratman_pest_proj",thisagent,target1);
	$createmissile("ratman_pest_proj",thisagent,target2);
	$createmissile("ratman_pest_proj",thisagent,target3);
	$createmissile("ratman_pest_proj",thisagent,target4);
end

///////////////////////////////////////////////////////////////////////////////
function Pestilence_missile_Hit( agent thisagent, agent target )
// - callback from pestilence missile hit
declare

begin
	if ($isdead(target))
		return;

	// CBT note: as of Majesty Alpha the effector duration below is 0

	$createeffector( target, "ratman_pest_hit", $GetSpellAttribute( "Pestilence", "effector_duration" ) );
	//$spell_attack( thisagent, target, 15 );
	$spell_type_attack(thisagent, target, "Poison", 13, 17);

	if ( $hasattribute ( "Immune_to_poison", target ))
		if ( target's "immune_to_poison" == FALSE )
			$poison_begin ( thisagent, target );

end


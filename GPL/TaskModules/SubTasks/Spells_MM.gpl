/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastTarget_hero( agent thisagent, agent target, string spell_name ) is agent
// Return a viable target for support spell.
declare
	agent newtarget;
	list spell_targets;
	integer targetrange, castrange;
	
begin
	newtarget = $NullAgent();
	castrange = (thisagent's "castingrange");
	targetrange = $distanceBetweenAgents(thisagent,target);
	
	castrange = $SpellRangeList(castrange, spell_name);
	
	if (targetrange <= castrange)
		begin
			newtarget = target;
			if (target's "Type" == "Building" || target's "Type" == "Lair")
				begin
					spell_targets = $compile_enemies(thisagent,castrange);
					if ($listsize(spell_targets) > 0)
						newtarget = $listmember(spell_targets, 1);
				end
		end
	else
		begin
			spell_targets = $compile_enemies(thisagent,castrange);
			if ($listsize(spell_targets) > 0)
				newtarget = $listmember(spell_targets, 1);
		end
	
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastControlEnemy_hero( agent thisagent, agent target, string buff_name, string spell_name ) is agent
// Return a viable allied target for support spell while following and supporting another hero.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count;
	
begin
	unit_name = thisagent's "title";
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	targetrange = $distanceBetweenAgents(thisagent,target);
	
	castrange = $SpellRangeList(castrange, spell_name);
	
	if ($Checkeffector(target,buff_name) != TRUE)
		newtarget = target;
		
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpecialCastEnemyUnit_Transmute( agent thisagent, agent target, string spell_name ) is agent
// Return a viable allied target for support spell.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count, TargetHP, TargetMaxHP, Transmute_HP, stat_int;
	
begin
	unit_name = thisagent's "title";
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	targetrange = $distanceBetweenAgents(thisagent,target);
	TargetHP = $getattribute(target, #ATTRIB_HP);
	TargetMaxHP = $getattribute(target, #ATTRIB_MaxHP);
	Transmute_HP = $PercentOf(TargetMaxHP, (10 + (stat_int / 6)), FALSE);
	
	castrange = $SpellRangeList(castrange, spell_name);
	
	if ((TargetHP <= Transmute_HP) && (target's "Type" != "Building") && (target's "Type" != "Lair"))
		newtarget = target;
	else
		potential_targets = $compile_enemies(thisagent,castrange);

	if ($listsize(potential_targets) > 0)
		count = $listsize(potential_targets);
		if (count > 0)
			begin
				foreach picked in potential_targets do
					begin
						TargetHP = $getattribute(picked, #ATTRIB_HP);
						TargetMaxHP = $getattribute(picked, #ATTRIB_MaxHP);
						Transmute_HP = $PercentOf(TargetMaxHP, (10 + (stat_int / 6)), FALSE);
						if ((TargetHP <= Transmute_HP) && ($IsDead(picked) != TRUE))
							begin
								if (picked != thisagent)
									spell_targets << picked;
							end
					end
				if ($listsize(spell_targets) > 0)
					begin
						newtarget = $listmember(spell_targets, 1);
					end
			end
		
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function AdvancedCastCombatSupportAlly_hero( agent thisagent, agent target, string buff_name, string spell_name, integer required_mana ) is agent
// Return a viable allied target for support spell. This version prioritizes the caster's Mana in concern towards casting support spells on allies.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count;
	
begin
	unit_name = thisagent's "title";
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	
	castrange = $SpellRangeList(castrange, spell_name);
	
	if ($Checkeffector(thisagent,buff_name) != TRUE)
		newtarget = thisagent;
	else if ($HasMPPercent(thisagent, required_mana) == True)
		begin
			$ListObjects(thisagent, "hero", castrange, potential_targets, #MyPlayer);
			count = $listsize(potential_targets);
			if (count > 0)
				begin
					foreach picked in potential_targets do
						begin
							if (($Checkeffector(picked,buff_name) != TRUE) && ($IsDead(picked) != TRUE))
								begin
									if (picked != thisagent)
										spell_targets << picked;
								end
						end
					if ($listsize(spell_targets) > 0)
						begin
							newtarget = $listmember(spell_targets, 1);
						end
				end
		end
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function AdvancedCastCombatDebuffEnemy_hero( agent thisagent, agent target, string debuff_name, string spell_name, integer required_mana ) is agent
// Return a viable allied target for support spell.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count;
	
begin
	unit_name = thisagent's "title";
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	
	if ($HasMPPercent(thisagent, required_mana) == True)
		return newtarget;
	
	castrange = $SpellRangeList(castrange, spell_name);
	
	if ((target's "Type" == "Building") || (target's "Type" == "Lair"))
		potential_targets = $compile_enemies(thisagent,castrange);
	else if ($Checkeffector(target,debuff_name) != TRUE)
		newtarget = target;
	else
		potential_targets = $compile_enemies(thisagent,castrange);
	
	count = $listsize(potential_targets);
	if (count > 0)
		begin
			foreach picked in potential_targets do
				begin
					if (($Checkeffector(picked,debuff_name) != TRUE) && ($IsDead(picked) != TRUE))
						begin
							if (picked != thisagent)
								spell_targets << picked;
						end
				end
			if ($listsize(spell_targets) > 0)
				begin
					newtarget = $listmember(spell_targets, 1);
				end
		end
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Heal( agent thisagent, agent target ) is string
// List of Healing spells to retrieve for a hero.
// Currently ignoring mana cost.

declare
	string new_spell, unit_name;
	integer targetrange, attackrange, castrange, count;

begin
	unit_name = thisagent's "title";
	new_spell = "nothing";
	
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	targetrange = $distanceBetweenAgents(thisagent,target);
	
	if (unit_name == "Healer")
		begin
			if ($CastableSpell_Heal(thisagent, target, "healer_heal") == TRUE)
				begin
					if ($HasCooldown(thisagent, "healer_healerheal_cooldown") != TRUE)
						begin
							new_spell = "healer_heal";
							return new_spell;
						end
				end
		end
	
	if ($CastableSpell_Heal(thisagent, target, "generic_regenerate") == TRUE)
		begin
			if ($HasCooldown(thisagent, "generic_regenerate_cooldown") != TRUE)
				return  "generic_regenerate";
		end
	
	return new_spell;
end


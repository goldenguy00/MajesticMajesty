/////////////////////////////////////////////////////////////////////////////////////////////////
function Fire_Ball_Hit( agent thisagent, agent target )
// wizard spell - lvl 5
// - callback from missile hit
declare
	integer stat_int, radius, add_damage, max_damage, min_damage;
	list targets;
	agent guy;
	coordinate target_loc;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	radius = 70 + (stat_int / 5);

	target_loc = $locationof(target);
	
	// have to create a new unit
	$CreateSpellUnit( thisagent, "fire_ball", target );

	// attack the original target
	$createeffector( target, "fireball_effector2", 500 );
	$spell_type_attack(thisagent, target, "Fire", 10, 15);
	
	$RevealArea(thisagent, target_loc, radius );
	
	targets = $compile_enemies_buildings(target,radius);
	foreach guy in targets do
		begin
			$createeffector( guy, "fireball_effector2", 500 );
			$spell_type_attack(thisagent, guy, "Fire", 10, 15);
		end
		
end


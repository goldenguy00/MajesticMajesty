function Meteor_Storm_Hit( agent thisagent, agent target )
// wizard spell - lvl 7
// - callback from cast
declare
	integer stat_int, stat_wisdom, stat_art, duration, periodic, cooldown, mana_cost, radius;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_wisdom = thisagent's "Wisdom_Total";
	mana_cost =  $Spell_Mana_Cost(thisagent,"meteor_storm");
	periodic = 1600;
	cooldown = 31000;
	duration = 16000;
	radius = (160 + (stat_int / 2));
	
	//Wisdom will buff this one's duration using the same duration buff as the effective power
	duration = $WisdomBuffEffect(thisagent, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$AddAttribute(ThisAgent, "meteor_storm_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "meteor_storm_cooldown", cooldown, thisAgent, "meteor_storm_cooldown" );
	
	$SpellTimeoutEffectAdvanced( thisagent, "meteor_storm", thisagent, $Meteor_Storm_Active, $spelldummydeath, "wizard_meteor_storm_effector", periodic, duration, #ATTRIB_Intelligence, stat_int, 0, #ATTRIB_SightRange, radius, #ATTRIB_maxattackrange, radius  );
end


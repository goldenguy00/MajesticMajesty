function Inferno_Hit( agent thisagent, agent target )
declare
	list Targets, t1, t2;
	agent dude;

begin
	$ListObjects(thisagent,"building",ThisAgent's "CastingRange",t1,#NotMyPlayer);
	$ListObjects(thisagent,"hero",ThisAgent's "CastingRange",t2,#NotMyPlayer);
	targets = $addlists(t1,t2);

	foreach dude in targets do
		begin
			$createeffector( dude, "inferno_effector2", 0 );
			$spell_type_attack(thisagent, dude, "Fire", 38, 42);
			//$spell_attack( thisagent, dude, 40 );
		end
end


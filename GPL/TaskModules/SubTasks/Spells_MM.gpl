function Iron_Will_Begin( agent thisagent, agent target )
// monk spell - lvl 7
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_resistance, add_crit, mana_cost;
	string buff_name, spell_cast;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	spell_cast = "iron_will";
	duration = 32000;
	cooldown = 20000;
	add_resistance = (35 + (stat_int / 2));
	add_crit = (1 + (stat_int / 7));
	buff_name = "Monk_IronWillBuff_End"; 

	duration = $DurationBuff(thisagent, target, duration);
	
	add_resistance = $EffectBuff(thisagent, target, add_resistance);
	add_crit = $EffectBuff(thisagent, target, add_crit);
	
	mana_cost =  $SpellManaCost(thisagent, spell_cast);
	$SpendMana(thisagent, mana_cost);

	cooldown = $GetSpellCooldown(thisagent, cooldown);
	$StartCooldown(thisagent, spell_cast, cooldown);

	$createeffector( target, "iron_will_effector", 0 );

	if ($AddAttribute(target, buff_name, "function", $Monk_IronWillBuff_End) == false)
		if ($IsRunning (target's buff_name) == TRUE)
			return;
	
	$createeffector( target, "iron_will_icon", duration );
	$NewThread(target's buff_name, duration, target, stat_int, stat_willpower, stat_wisdom);
	
	$MagicalAdjustAttribute(target, #ATTRIB_magicresistance,add_resistance);
	$adjustattribute(target, #ATTRIB_Healingratemodifier,-1);
		
	target's "critical_chance" += add_crit;
	
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Monk_IronWillBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// What happens when the buff ends.

declare
	integer add_resistance, add_crit;

begin
	if ($IsValidGamePiece(thisagent) == false)
		return;
		
	add_resistance = (35 + (intelligence / 2));
	add_crit = (1 + (intelligence / 7));
	
	add_resistance = $EffectBuff_Thread(willpower, wisdom, add_resistance);
	add_crit = $EffectBuff_Thread(willpower, wisdom, add_crit);
	
	$MagicalAdjustAttribute(thisagent,#ATTRIB_magicresistance, - add_resistance);
	$adjustattribute(thisagent,#ATTRIB_Healingratemodifier, 1);
	
	thisagent's "critical_chance" -= add_crit;
	
	$KillThread(thisagent's "Monk_IronWillBuff_End");
end


	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	duration = (1500 + (stat * 100));
	attackspeed =  2000;
	$createeffector( thisagent, "ma_volley_effector", duration );
	$adjustattribute(thisagent, #ATTRIB_ActionRateModifier, - attackspeed);
	$createmissile("ma_volley_missile", thisagent, target);
	$SpellTimeoutEffect( thisagent, $ma_VolleyBuff_Death, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_corrosion_ball_Hit( agent thisagent, agent target )
// court mage spell - Starting Spell
// - callback from missile hit
// Crashes when used on a building and the building dies.
declare
	integer stat, duration, minusarmor, current_armor;
begin
	if ($isvalidgamepiece(target) == FALSE)
		return;
		
		
	$createeffector(target, "Rustspit_Splat", 0);
	$spell_type_attack( thisagent, target, "poison", 6, 8 );
	
	if ($isvalidgamepiece(target) == FALSE)
		return;
		
	if (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			stat = $getattribute(thisagent, #ATTRIB_Intelligence);
			duration = (stat * 250);
			minusarmor = (stat / 20);
			current_armor = $getattribute(target, #ATTRIB_Armor_Basic_Damage);
	
			duration = $WillpowerDurationDebuff(target, duration);
	
			if (current_armor < minusarmor)
				minusarmor = current_armor;
		
			$createeffector( target, "cm_corrosionball_Splat", duration );
			$adjustattribute(target, #ATTRIB_Armor_Basic_Damage, - minusarmor);
			$SpellTimeoutEffect( thisagent, $cm_CorrosionBallDebuff_Death, duration, #ATTRIB_Armor_Basic_Damage, minusarmor, 0, 0,0,0,0  );
		end
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function CanCast(agent thisagent, string spell_name) is boolean
declare
begin
	if ($isspellAvailable(thisagent, spell_name))
		if ($HasCooldown(thisagent, spell_name))
			if ($Spell_Mana_Available(thisagent, spell_name))
				return true;
	return false;
end
/////////////////////////////////////////////////////////////////////////////////////////////////
function CastableSpell( agent thisagent, agent target, string spell_name ) is boolean
// Returns a valid spell to cast ONLY for Spell_List_Support

declare
begin
	if ($CanCast(thisagent, spell_name))
		return $ValidSpellTarget_hero(thisagent, target, spell_name) != $NullAgent();
	return false;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function generic_Regenerate_cast ( agent thisagent, agent target )
//
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, regen_amount, heal_amount, mana_cost;
	string buff_name;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	duration = 8000;
	cooldown = 14000;
	mana_cost =  $Spell_Mana_Cost(thisagent,"generic_regenerate");
	heal_amount = (1 + (stat_int / 6));
	regen_amount = (2 + ((stat_int) / 2));
	buff_name = "Generic_RegenerateBuff_End";
	
	duration = $DurationBuff(thisagent, target, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	regen_amount = $EffectBuff(thisagent, target, regen_amount);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector ( target, "generic_Regenerate_effector", 0 );
	
	$AddAttribute(ThisAgent, "generic_regenerate_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "generic_regenerate_cooldown", cooldown, thisAgent, "generic_regenerate_cooldown" );
	
	$Heal ( thisagent, target, heal_amount );
	
	if ($HasAttribute(buff_name, target) != False)
		begin
			if ($IsRunning (target's buff_name) == TRUE)
				return;
		end
	else
		$AddAttribute(target, buff_name, "function", $Generic_RegenerateBuff_End);
	
	$NewThread(target's buff_name, duration, target, stat_int, stat_willpower, stat_wisdom);
	
	$createeffector ( target, "generic_Regenerate_icon", duration );
	$AdjustAttributeSafe(target, "HealthRegeneration_Flat_Modifier", regen_amount);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Generic_RegenerateBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// What happens when the buff ends.

declare
	integer regen_amount;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	regen_amount = (4 + ((intelligence * 4) / 6));
	
	regen_amount = $EffectBuff_Thread(willpower, wisdom, regen_amount);
	
	$AdjustAttributeSafe(thisagent, "HealthRegeneration_Flat_Modifier", -regen_amount);

	$KillThread(thisagent's "Generic_RegenerateBuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Priestess_Wither_Cast( agent thisagent, agent target )
// priestess spell - Level 5, 1 Spire
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, attack_slow, move_slow, minus_strength, mana_cost;
	string buff_name;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	duration = 10000;
	cooldown = 12000;
	mana_cost =  $Spell_Mana_Cost(thisagent,"priestess_Wither");
	attack_slow = (150 + (stat_int * 2));
	minus_strength = (3 + (stat_int / 5));
	move_slow = (60 + (stat_int));
	buff_name = "Priestess_WitherDebuff_End";
	
	duration = $DurationDebuff(thisagent, target, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	attack_slow = $EffectDebuff(thisagent, target, attack_slow);
	minus_strength = $EffectDebuff(thisagent, target, minus_strength);
	move_slow = $EffectDebuff(thisagent, target, move_slow);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector(target,"priestess_wither_effector",0);
	
	$AddAttribute(ThisAgent, "priestess_wither_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "priestess_wither_cooldown", cooldown, thisAgent, "priestess_wither_cooldown" );
	
	if ($HasAttribute(buff_name, target) != False)
		begin
			if ($IsRunning (target's buff_name) == TRUE)
				return;
		end
	else
		$AddAttribute(target, buff_name, "function", $Priestess_WitherDebuff_End);
	
	$createeffector(target,"priestess_wither_icon",duration);
	$NewThread(target's buff_name, duration, target, stat_int, stat_willpower, stat_wisdom);

	$MagicalAdjustAttribute(target,#ATTRIB_Strength,- minus_strength);
	
	$AdjustAttributeSafe(target, "Strength_Flat_Modifier", - minus_strength);
	$UpdateStrength(target);
	$adjustattribute(target,#ATTRIB_ActionRateModifier, attack_slow);
	$adjustattribute(target,#ATTRIB_MovementRateModifier, move_slow );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Priestess_WitherDebuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// What happens when the buff ends.

declare
	integer attack_slow, move_slow, minus_strength;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	attack_slow = (150 + (intelligence * 2));
	minus_strength = (3 + (intelligence / 5));
	move_slow = (60 + (intelligence));
	
	attack_slow = $EffectDebuff_Thread(willpower, wisdom, attack_slow);
	minus_strength = $EffectDebuff_Thread(willpower, wisdom, minus_strength);
	move_slow = $EffectDebuff_Thread(willpower, wisdom, move_slow);
	
	$AdjustAttribute(thisagent,#ATTRIB_ActionRateModifier, - attack_slow);
	$AdjustAttribute(thisagent,#ATTRIB_MovementRateModifier, - move_slow);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_Strength, minus_strength);
	$AdjustAttributeSafe(thisagent, "Strength_Flat_Modifier", minus_strength);
	$UpdateStrength(thisagent);
	
	$KillThread(thisagent's "Priestess_WitherDebuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Wizard_Transmute_Cast( agent thisagent, agent target )
// Wizard spell - Level 4, 1 Spire
declare
	integer stat_int, stat_art, mana_cost, cooldown, CurrentHP, GoldAmount, ExpAmount;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	cooldown = 12500;
	mana_cost =  $Spell_Mana_Cost(thisagent,"wizard_transmute");
	CurrentHP = $GetAttribute(target, #ATTRIB_HP);
	GoldAmount = (stat_int * CurrentHP);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	GoldAmount = $WisdomBuffEffect(thisagent, GoldAmount);
	ExpAmount = ((GoldAmount * 2) / 3);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$createeffector(target,"wizard_transmute_effector",0);
	$AddAttribute(ThisAgent, "wizard_transmute_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "wizard_transmute_cooldown", cooldown, thisAgent, "wizard_transmute_cooldown" );

	$setattribute(target, #ATTRIB_HP, 0);
	$Give_gold(thisagent, GoldAmount);
	$Give_exp(thisagent, ExpAmount);
end


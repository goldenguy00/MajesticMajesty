/////////////////////////////////////////////////////////////////////////////////////////////////
function Fire_Shield_Begin( agent thisagent, agent target )
// wizard spell - lvl 2
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_armor, add_resistance, mana_cost;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	mana_cost =  $Spell_Mana_Cost(thisagent,"fire_shield");
	duration = 15000;
	cooldown = 7000;
	add_armor = (1 + (stat_int / 8));
	add_resistance = (10 + (stat_int / 5));
	
	duration = $DurationBuff(thisagent, target, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	add_armor = $EffectBuff(thisagent, target, add_armor);
	add_resistance = $EffectBuff(thisagent, target, add_resistance);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( target, "fire_shield_effector", 0 );
	
	$AddAttribute(ThisAgent, "fire_shield_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "fire_shield_cooldown", cooldown, thisAgent, "fire_shield_cooldown" );
	
	if ($IsRunning (target's "Wizard_FireShieldBuff_End") == TRUE)
		return;
	
	$createeffector( target, "fire_shield_icon", duration );
	$NewThread(target's "Wizard_FireShieldBuff_End", duration, target, stat_int, stat_willpower, stat_wisdom);

	$adjustattribute(target,#ATTRIB_Armor_Basic_Damage,add_armor);
	$MagicalAdjustAttribute(target,#ATTRIB_Magicresistance,add_resistance);
	
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Wizard_FireShieldBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// What happens when the buff ends.

declare
	integer add_resistance, add_armor;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	add_armor = (1 + (intelligence / 8));
	add_resistance = (10 + (intelligence / 5));
	
	add_resistance = $EffectBuff_Thread(willpower, wisdom, add_resistance);
	add_armor = $EffectBuff_Thread(willpower, wisdom, add_armor);
	
	$adjustattribute(thisagent,#ATTRIB_Armor_Basic_Damage, - add_armor);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_magicresistance, - add_resistance);
	
	$KillThread(thisagent's "Wizard_FireShieldBuff_End");
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Fire_Blast_Cast(agent thisagent, agent target)
// wizard spell - lvl 3
// - callback from cast action
declare
	list targets;
	agent target1,target2,target3;
	integer stat_int, cooldown, mana_cost, radius;

begin
	// list all enemies nearby -
	radius = $SpellRangeList(thisagent's "castingrange", "fire_blast");
	targets = $compile_enemies(thisagent,radius);

	if ($listsize(targets) == 0)
		return;

	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	mana_cost =  $Spell_Mana_Cost(thisagent,"fire_blast");
	cooldown = 2400;
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$AddAttribute(ThisAgent, "fire_blast_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "fire_blast_cooldown", cooldown, thisAgent, "fire_blast_cooldown" );
	
	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// fire 3 projectiles at the closest ones
	$createmissile("Fire_blast_missile",thisagent,target1);
	$createmissile("Fire_blast_missile",thisagent,target2);
	$createmissile("Fire_blast_missile",thisagent,target3);
end


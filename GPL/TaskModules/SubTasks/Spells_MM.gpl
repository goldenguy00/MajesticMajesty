////////////////////////////////////////NEW SPELLS///////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////

function deploy_dart_sentry_cast( agent thisagent, agent target )
// Basically done, just input the proper stats
declare
	integer stat_int, stat_wisdom, stat_art, cooldown, duration, periodic, add_strength, add_rangedattack, add_range, num_darts;
	agent sentry;
	integer x1, x2, y1, y2, dx, dy;
	coordinate target_loc, sentry_loc, thisagent_loc;

begin
	$ForgetSpell(thisagent, "deploy_dart_sentry");

	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	duration = 60000;
	periodic = 1500 - (10 * stat_art);
	num_darts = 10 + (stat_art / 5);
	add_strength = (stat_art / 10);
	add_range = stat_art;
	add_rangedattack = stat_art;
	
	thisagent_loc = $LocationOf(thisagent);
	x1 = $GetX(thisagent_loc);
	y1 = $GetY(thisagent_loc);
	
	target_loc = $LocationOf(target);
	x2 = $GetX(target_loc);
	y2 = $GetY(target_loc);
	
	dx = x1 + ((x2 - x1) / 2);
	dy = y1 + ((y2 - y1) / 2);
	sentry_loc = $MakeCoord(dx, dy);
	
	sentry = $spawnunit(thisagent, "dart_sentry_unit", sentry_loc);
	
	$SetDrawEffects( sentry, "none", 5 );
	$SetSpellUnitTimeout(sentry, duration);
	
	sentry's "type" = "Invisible";
	$SetAttribute( sentry, #ATTRIB_HasEffectInvisibility, 1 );
	
	$adjustattribute(sentry, #ATTRIB_Strength, add_strength);
	$adjustattribute(sentry, #ATTRIB_maxattackrange, add_range);
	$adjustattribute(sentry, #ATTRIB_SightRange, add_range);
	$adjustattribute(sentry, #ATTRIB_Ranged, add_rangedattack);
	
	$setattribute(sentry, #ATTRIB_Vitality, num_darts);
	
	if (periodic < 200)
		periodic = 200;
		
	$NewThread (sentry's "ActiveScript", periodic, sentry);
end

///////////////////////////////////////////////////////////////////////////////
function dart_sentry_scan(agent thisagent)

declare
	list		Enemies, crystal_list;
	integer distance;

begin
	Enemies = $list_enemies_seen(thisagent,$getattribute (ThisAgent, #ATTRIB_SightRange));
	If ($ListSize (Enemies) > 0)
		begin
			ThisAgent's "Target" = $ListMember (Enemies, 1);
			$PerformAction (ThisAgent, ThisAgent's "Attack_Action", ThisAgent's "Target");
			$adjustattribute(thisagent, #ATTRIB_Vitality, -1);
			if ($getattribute(thisagent, #ATTRIB_Vitality) < 1)
				begin
					$KillThread(thisagent's "ActiveScript");
					$performaction(thisagent,"henchman_death",thisagent);
				end
		end
end


/////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////NEW SPELL FUNCTIONS/////////////////////////////////////////////////
function SpellTimeoutEffectAdvanced( agent source, string unit_name, agent target, function AScript, function DScript, string attach_effect, integer period, integer timeout, integer attribute, integer amount, integer level, integer attribute_2, integer amount_2, integer attribute_3, integer amount_3 )
// This will be used to allow scaling duration spells with an area of effect
//
declare
	agent dummy;
	coordinate Target_Loc;

begin
	Target_Loc = $LocationOf(target);
	dummy = $spawnunit(source, unit_name, Target_Loc);
	dummy's "ActiveScript" = AScript;
	dummy's "DeathScript" = DScript;
	$setparent(dummy, target);
	$SetDrawEffects( dummy, "none", 9 );
	
	$createeffector( dummy, attach_effect, timeout );
	$SetSpellUnitTimeout( dummy, timeout );
	
	$NewThread( dummy's "activeScript", period, dummy );
	
	if (attribute != 0)
		begin
			$setattribute(dummy, attribute, amount);
		end
	if (level != 0)
		begin
			$setattribute(dummy, #ATTRIB_Experience, level);
		end
	if (attribute_2 != 0)
		begin
			$setattribute(dummy, attribute_2, amount_2);
		end
	if (attribute_3 != 0)
		begin
			$setattribute(dummy, attribute_3, amount_3);
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellTimeoutEffect( agent target, function Script, integer timeout, integer attribute, integer amount, integer level, integer attribute_2, integer amount_2, integer attribute_3, integer amount_3 )
// This will be used to allow scaling duration spells
//
declare
	agent dummy;

begin
	dummy = $spawnunit(target, "spell_dummy_unit");
	dummy's "DeathScript" = Script;
	$setparent(dummy, target);
	$SetDrawEffects( dummy, "none", 9 );
	$SetSpellUnitTimeout( dummy, timeout );
	if (attribute != 0)
		begin
			$setattribute(dummy, attribute, amount);
		end
	if (level != 0)
		begin
			$setattribute(dummy, #ATTRIB_Experience, level);
		end
	if (attribute_2 != 0)
		begin
			$setattribute(dummy, attribute_2, amount_2);
		end
	if (attribute_3 != 0)
		begin
			$setattribute(dummy, attribute_3, amount_3);
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ArtificeCooldownReduction_Magic( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of magic spells/abilities
//
declare
	integer stat_artifice, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_artifice = $getattribute(thisagent, #ATTRIB_Artifice);
	
	if (stat_artifice < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 133) * stat_artifice);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ArtificeCooldownReduction_NonMagic( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of non-magic spells/abilities
//
declare
	integer stat_artifice, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_artifice = $getattribute(thisagent, #ATTRIB_Artifice);
	
	if (stat_artifice < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 100) * stat_artifice);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceCooldownReduction( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of magic spells/abilities
//
declare
	integer stat_intelligence, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 200) * stat_intelligence);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceDurationBuff( agent thisagent, integer duration ) is integer
// The amount that Intelligence affects the duration of buffs on the target
//
declare
	integer stat_intelligence, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return duration;
	
	duration_diff = ((duration / 125) * stat_intelligence);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceDurationDebuff( agent thisagent, integer duration ) is integer
// The amount that Intelligence affects the duration of buffs on the target
//
declare
	integer stat_intelligence, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return duration;
	
	duration_diff = ((duration / 125) * stat_intelligence);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomBuffEffect( agent thisagent, integer power ) is integer
// The amount that Wisdom affects the power of buffs
//
declare
	integer stat_wisdom, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_wisdom = thisagent's "Wisdom_Total";
	
	if (stat_wisdom < 1)
		return power;
	
	power_diff = ((power / 133) * stat_wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomDebuffEffect( agent thisagent, integer power ) is integer
// The amount that Wisdom affects the power of debuffs
// Right now its the same as WisdomBuffEffect
declare
	integer stat_wisdom, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_wisdom = thisagent's "Wisdom_Total";
	
	if (stat_wisdom < 1)
		return power;
		
	power_diff = ((power / 133) * stat_wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomManaReduction( agent thisagent, integer mana ) is integer
// The amount that Wisdom reduces the mana spent on spells
//
declare
	integer stat_wisdom, mana_diff, new_mana;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_wisdom = thisagent's "Wisdom_Total";
	
	if (stat_wisdom < 1)
		return mana;
		
	mana_diff = ((mana * stat_wisdom) / 250);
	new_mana = (mana - mana_diff);
	
	if (new_mana < 0)
		new_mana = 0;
		
	return new_mana;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerBuffEffect( agent thisagent, integer power ) is integer
// The amount that Willpower affects the power of buffs on this hero
//
declare
	integer stat_willpower, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return power;
	
	power_diff = ((power * stat_willpower) / 100);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDebuffEffect( agent thisagent, integer power ) is integer
// The amount that Willpower affects the power of debuffs on this hero
//
declare
	integer stat_willpower, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return power;
		
	power_diff = ((power * stat_willpower) / 200);
	new_power = (power - power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerBuffEffect_Thread( integer willpower, integer power ) is integer
// The amount that Willpower affects the power of buffs on this hero
//
declare
	integer power_diff, new_power;

begin
	if (willpower < 1)
		return power;
	
	power_diff = ((power * willpower) / 100);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDebuffEffect_Thread( integer willpower, integer power ) is integer
// The amount that Willpower affects the power of debuffs on this hero
//
declare
	integer power_diff, new_power;

begin
	if (willpower < 1)
		return power;
		
	power_diff = ((power * willpower) / 200);
	new_power = (power - power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomBuffEffect_Thread( integer wisdom, integer power ) is integer
// The amount that Wisdom affects the power of buffs
//
declare
	integer power_diff, new_power;

begin
	if (wisdom < 1)
		return power;
	
	power_diff = ((power / 133) * wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomDebuffEffect_Thread( integer wisdom, integer power ) is integer
// The amount that Wisdom affects the power of debuffs
// Right now its the same as WisdomBuffEffect
declare
	integer power_diff, new_power;

begin
	if (wisdom < 1)
		return power;
		
	power_diff = ((power / 133) * wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDurationBuff( agent thisagent, integer duration ) is integer
// The amount that Willpower affects the duration of buffs
//
declare
	integer stat_willpower, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return duration;
	
	duration_diff = ((duration / 100) * stat_willpower);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDurationDebuff( agent thisagent, integer duration ) is integer
// The amount that Willpower affects the duration of debuffs
//
declare
	integer stat_willpower, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return duration;
		
	duration_diff = ((duration / 200) * stat_willpower);
	new_duration = (duration - duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end


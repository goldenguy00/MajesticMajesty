/////////////////////////////////////////////////////////////////////////////////////////////////
function ValidSpellTarget_hero( agent thisagent, agent target, string spell_name ) is agent
// This will return a valid target for the spell listed for this agent.
declare
	agent newtarget, picked;
	boolean is_learned, on_cooldown;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count;
	
begin
	unit_name = thisagent's "title";
	newtarget = target;
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	if (spell_name == "energy_blast")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "fire_shield")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "fire_shield_icon", spell_name);
		end
	else if (spell_name == "fire_blast")
		begin
			newtarget = $BasicCastEnemyUnit_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "fire_ball")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "resist_magic")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "resist_magic_icon", spell_name);
		end
	else if (spell_name == "wizard_Transmute")
		begin
			newtarget = $SpecialCastEnemyUnit_Transmute(thisagent, target, spell_name);
		end
	else if (spell_name == "meteor_storm")
		begin
			newtarget = $BasicCastEnemyUnit_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "hands_of_steel")
		begin
			if ($Checkeffector(thisagent, "hands_of_steel_icon") != TRUE)
				begin
					newtarget = thisagent;
				end
		end
	else if (spell_name == "monk_stone_skin")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "monk_stone_skin_icon", spell_name);
		end
	else if (spell_name == "iron_will")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "iron_will_icon", spell_name);
		end
	else if (spell_name == "healer_heal")
		begin
			newtarget = $BasicCastHealAlly_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "meditation")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "meditation_icon", spell_name);
		end
	else if (spell_name == "change_shape")
		begin
			if ($Checkeffector(thisagent, "change_shape_icon") != TRUE)
				begin
					newtarget = thisagent;
				end
		end
	else if (spell_name == "shield_of_light")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "shield_of_light_icon", spell_name);
		end
	else if (spell_name == "sun_scorch")
		begin
			newtarget = $BasicCastEnemyUnitAlt_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "drain_life")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "priestess_Wither")
		begin
			newtarget = $BasicCastDebuffEnemy_hero(thisagent, target, "priestess_wither_icon", spell_name);
		end
	else if (spell_name == "healer_heal")
		begin
			newtarget = $BasicCastHealSupport_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "generic_regenerate")
		begin
			newtarget = $BasicCastHealSupport_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "flame_shield")
		begin
			newtarget = $BasicCastSupportAlly_hero(thisagent, target, "flame_shield_icon", spell_name);
		end
	else if (spell_name == "power_shock")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "deploy_dart_sentry")
		begin
			newtarget = $BasicCastEnemyUnit_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "Fire_Bolt")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "Fireball")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "Perdition_Barrage")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "Incandescent_Ray")
		begin
			newtarget = $BasicCastTarget_hero(thisagent, target, spell_name);
		end
	else if (spell_name == "Searing_Mantle")
		begin
			newtarget = $AdvancedCastCombatSupportAlly_hero(thisagent, target, "searing_mantle_icon", spell_name, 40);
		end
	else if (spell_name == "Pyrelight")
		begin
			newtarget = $AdvancedCastCombatDebuffEnemy_hero(thisagent, target, "Pyrelight_icon", spell_name, 30);
		end
	else if (spell_name == "Ignite")
		begin
			newtarget = $BasicCastDebuffEnemy_hero(thisagent, target, "ignite_icon", spell_name);
		end
		
	return newtarget;
end


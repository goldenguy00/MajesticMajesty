	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	move_slow = ((stat * 3) / 2);
	attack_slow = (stat * 3);
	minus_res = (20 + (stat / 5));
	cooldown = (20000 - (stat * 250));

/////////////////////////////////////////////////////////////////////////////////////////////////
function IsSpellCaster( agent thisagent ) is boolean
// Is the hero a spellcaster?

declare
	string unit_name, original_name;
	boolean caster;
	
begin
	caster = FALSE;
	unit_name = thisagent's "title";
	
	if ($HasAttribute("Original_Title", thisagent) == True)
		original_name = thisagent's "Original_Title";
	else
		$AddAttribute(thisagent, "Original_Title", "string", unit_name);
		
	if (unit_name == "wizard")
		begin
			caster = TRUE;
		end
	
	else if ((unit_name == "priestess") || (original_name == "priestess"))
		begin
			caster = TRUE;
		end
	
	return caster;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellCastRange( agent thisagent ) is integer
// The range at which a spellcaster will start casting spells.

declare
	integer cast_range, new_range, final_range, count, size;
	string spell_name, range;
	list spells;
	
begin
	cast_range = thisagent's "castingRange";
	final_range = $PercentOf(cast_range, 67, False);			//67% is the normal spell cast range
//	count = 0;
//	spells = thisagent's "SpellsAttack";
//	size = $ListSize(spells);
	
//	if (size > 0)
//		begin
//			while (count < size) do
//				begin
//					count ++;
//					spell_name = "Nothing";
//					if (spell_name != "Nothing")
//						if ($SpellCastFirstPass(thisagent, spell_name))
//							begin
//								range = spell_name + "_Range";
//								new_range = $PercentOf(cast_range, thisagent's range, False);	//Set the new range
//								if (new_range > final_range)										//check if the new range is greater than the final one
//									final_range = new_range;
//							end
//						
//				end
//		end		
				
	if ($ListSize(thisagent's "SpellsAttack") > 0) 
		foreach spell_name in thisagent's "SpellsAttack" do
			if (spell_name != "Nothing")
				if ($SpellCastFirstPass(thisagent, spell_name))
					begin
						range = spell_name + "_Range";
						new_range = $PercentOf(cast_range, thisagent's range, False);	//Set the new range
						if (new_range > final_range)										//check if the new range is greater than the final one
							final_range = new_range;
					end
			
	return final_range;
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellCastDistance( agent thisagent ) is integer
// The distance at which a spellcaster will start casting spells.

declare
	integer cast_range;
	string unit_name, spell_name, original_name;
	
begin
	unit_name = thisagent's "title";
	cast_range = thisagent's "castingRange";
	
	if ($HasAttribute("Original_Title", thisagent) == True)
		original_name = thisagent's "Original_Title";
	else
		$AddAttribute(thisagent, "Original_Title", "string", unit_name);
		
	if (unit_name == "paladin")
		return $PercentOf(cast_range, 50, False);
	else if (unit_name == "healer")
		return $PercentOf(cast_range, 50, False);
	else if (unit_name == "rogue")
		return $PercentOf(cast_range, 50, False);
	else if (unit_name == "monk")
		return $PercentOf(cast_range, 50, False);
	else if ((unit_name == "cultist") || (original_name == "cultist"))
		return $PercentOf(cast_range, 50, False);
	else if (unit_name == "solarus")
		return $PercentOf(cast_range, 25, False);
	else if ((unit_name == "priestess") || (original_name == "priestess"))
		begin
			cast_range = $PercentOf(cast_range, 67, False);
			cast_range = $GreatestCastRange(thisagent, "drain_life", cast_range);
			return cast_range;
		end
	else if (unit_name == "wizard")
		begin
			cast_range = $PercentOf(cast_range, 67, False);
			cast_range = $GreatestCastRange(thisagent, "energy_blast", cast_range);
			cast_range = $GreatestCastRange(thisagent, "fire_ball", cast_range);
			cast_range = $GreatestCastRange(thisagent, "fire_bolt", cast_range);
			cast_range = $GreatestCastRange(thisagent, "fireball", cast_range);
			cast_range = $GreatestCastRange(thisagent, "incandescent_ray", cast_range);
			return cast_range;
		end
	
	// not casting
	return $getattribute(thisagent,#ATTRIB_maxattackrange);
end

function GreatestCastRange(agent thisagent, string spell_name, integer range) is integer

declare
	integer new_range;

begin
	if ((spell_name != "nothing") && ($isspellAvailable(thisagent,spell_name) == TRUE) && ($Spell_Mana_Available(thisagent, spell_name) == TRUE))
		begin
			new_range = $SpellRangeList(thisagent's "castingRange", spell_name);
			if (new_range > range)
				range = new_range;
		end
	return range;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Cooldown_End( agent thisagent, string cooldown_name )
// A simple cooldown function for various threads that require a simple timer.

declare

begin
	$KillThread(thisagent's cooldown_name);
	
end

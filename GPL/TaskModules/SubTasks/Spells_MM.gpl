//SOLARUS
function solarus_sun_scorch_check(agent thisagent) is integer

declare
	list targets;

begin
	if ($GenericSpellCheck(thisagent, "sun_scorch") == 0)
		return 0;
		
	targets = $compile_enemies(thisagent,65);
	if ($listsize(targets) > 0)
		return 1;
	else
		return 0;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Solarus_Sun_Scorch_Hit( agent thisagent, agent target )
//
declare
	list targets;
	agent dude;
	integer stat_int, cooldown, mana_cost, radius;
	string spell_cast;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	radius = 50 + (stat_int / 2);
	spell_cast = "sun_scorch";
	cooldown = 8000;
	
	radius = $EffectBuff(thisagent, target, radius);
	
	$createeffector( thisagent, "sun_scorch_effector1", 0 );

	mana_cost =  $SpellManaCost(thisagent, spell_cast);
	$SpendMana(thisagent, mana_cost);

	cooldown = $GetSpellCooldown(thisagent, cooldown);
	$StartCooldown(thisagent, spell_cast, cooldown);

	targets = $compile_enemies(thisagent,radius);
	if ($listsize(targets) > 0)
		foreach dude in targets do
			begin
				$createeffector( dude, "sun_scorch_effector2", 0 );
				$spell_type_attack(thisagent, dude, "Fire", 14 + $getattribute(thisagent,#ATTRIB_experienceLevel), 16 + $getattribute(thisagent,#ATTRIB_experienceLevel));
				//$spell_attack( thisagent, dude, 15 + $getattribute(thisagent,#ATTRIB_experienceLevel));
			end
end


function Hands_of_Steel_Begin( agent thisagent, agent target )
// monk spell - lvl 1
// - callback from cast action
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_strength, add_htoh, mana_cost;
	string buff_name;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"hands_of_steel");
	duration = 20000;
	cooldown = 10000;
	add_strength = (8 + (stat_int / 5));
	add_htoh = (12 + (stat_int / 4));
	buff_name = "Monk_HandsOfSteelBuff_End";
	
	duration = $DurationBuff(thisagent, thisagent, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	add_strength = $EffectBuff(thisagent, thisagent, add_strength);
	add_htoh = $EffectBuff(thisagent, thisagent, add_htoh);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector( thisagent, "hands_of_steel_effector", 0 );
	$createeffector( thisagent, "hands_of_steel_icon", duration );
	
	$AddAttribute(ThisAgent, "hands_of_steel_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "hands_of_steel_cooldown", cooldown, thisAgent, "hands_of_steel_cooldown" );
	
	if ($HasAttribute(buff_name, thisagent) != False)
		begin
			if ($IsRunning (thisagent's buff_name) == TRUE)
				$KillThread(thisagent's buff_name);
		end
	else
		$AddAttribute(thisagent, buff_name, "function", $Monk_HandsOfSteelBuff_End);
		
	$NewThread(thisagent's buff_name, duration, thisagent, stat_int, stat_willpower, stat_wisdom);


	$MagicalAdjustAttribute(thisagent,#ATTRIB_strength, add_strength);
	$AdjustAttributeSafe(thisagent, "Strength_Flat_Modifier", add_strength);
	$UpdateStrength(thisagent);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_HtoH, add_htoh);
	
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Monk_HandsOfSteelBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// What happens when the buff ends.

declare
	integer add_strength, add_htoh;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	add_strength = (8 + (intelligence / 5));
	add_htoh = (12 + (intelligence / 4));
	
	add_strength = $EffectBuff_Thread(willpower, wisdom, add_strength);
	add_htoh = $EffectBuff_Thread(willpower, wisdom, add_htoh);
	
	$MagicalAdjustAttribute(thisagent,#ATTRIB_strength, - add_strength);
	$AdjustAttributeSafe(thisagent, "Strength_Flat_Modifier", -add_strength);
	$UpdateStrength(thisagent);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_HtoH, - add_htoh);
	
	$KillThread(thisagent's "Monk_HandsOfSteelBuff_End");
end


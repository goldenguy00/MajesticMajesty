/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Support( agent thisagent) is string
// List of spells to retrieve for a hero
// Finally arranges on its own based on distance. Only concern would be whether the hero prioritizes other variables in spellcasting.

declare
	string new_spell, unit_name, original_name;
	integer attackrange, count;
	agent target;

begin
	unit_name = thisagent's "title";
	target = thisagent's "Target";
	new_spell = "nothing";
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	$AddAttribute(thisagent, "castingrange", "integer");
	$BuffDebuffList(thisagent);
	
	if ($HasAttribute("Original_Title", thisagent) == True)
		original_name = thisagent's "Original_Title";
	else
		$AddAttribute(thisagent, "Original_Title", "string", unit_name);
		
	if ((unit_name == "cultist") || (original_name == "cultist"))
		begin
			if ($CastableSpell(thisagent, target, "change_shape") == TRUE)
				return "change_shape";
		end
		
	else if (unit_name == "Healer")
		begin
			if ($CastableSpell(thisagent, target, "meditation") == TRUE)
				return "meditation";
		end
		
	else if (unit_name == "Monk")
		begin
			if ($CastableSpell(thisagent, target, "hands_of_steel") == TRUE)
				return "hands_of_steel";
			if ($CastableSpell(thisagent, target, "monk_stone_skin") == TRUE)
				return "monk_stone_skin";
			if ($CastableSpell(thisagent, target, "iron_will") == TRUE)
				return "iron_will";
		end
	
	else if (unit_name == "Paladin")
		begin
			if ($CastableSpell(thisagent, target, "shield_of_light") == TRUE)
				return "shield_of_light";
		end
		
	else if ((unit_name == "priestess") || (original_name == "priestess"))
		begin
			if ($CastableSpell(thisagent, target, "priestess_wither") == TRUE)
				return "priestess_wither";
		end
		
	else if (unit_name == "Solarus")
		begin
		end
		
	else if (unit_name == "Wizard")
		begin
			if ($CastableSpell(thisagent, target, "fire_shield") == TRUE)
				return "fire_shield";
			if ($CastableSpell(thisagent, target, "resist_magic") == TRUE)
				return "resist_magic";
			if ($CastableSpell(thisagent, target, "wizard_transmute") == TRUE)
				return "wizard_Transmute";
				
			
			if ($CastableSpell(thisagent, target, "Searing_Mantle") == TRUE)
				return "Searing_Mantle";
			if ($CastableSpell(thisagent, target, "Pyrelight") == TRUE)
				return "Pyrelight";
			if ($CastableSpell(thisagent, target, "Ignite") == TRUE)
				return "Ignite";
		end
		
	//GENERIC SPELLS
	if ($CastableSpell(thisagent, target, "generic_regenerate") == TRUE)
		return "generic_regenerate";
		
	//GADGET SPELLS
	if ($CastableSpell(thisagent, target, "deploy_dart_sentry") == TRUE)
		return "deploy_dart_sentry";
	
	return "nothing";
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function AttackSpellList( agent thisagent ) is string
//Use while instead of foreach as foreach for now
//Do not use return inside of a foreach struct
declare
	agent spell_target, new_target;
	string new_spell, spell_name, cooldown, condition;
	integer size, count;

begin
	spell_name = "Nothing";
	new_spell = "Nothing";
	new_target = $nullagent();
	
	if ($HasAttribute("SpellsAttack", thisagent))
		if ($ListSize(thisagent's "SpellsAttack") > 0)
			foreach spell_name in thisagent's "SpellsAttack" do
				if (spell_name != "Nothing")
					begin
						condition = spell_name + "_Condition";
						if ($SpellCastFirstPass(thisagent, spell_name))
							begin
								spell_target = (thisagent's condition)(thisagent, spell_name);
								if (spell_target != $NullAgent())
									begin
										cooldown = spell_name + "_Cooldown";
										if ($HasCooldown(thisagent, cooldown) != TRUE)
											begin
												new_spell = spell_name;
												new_target = spell_target;			//Keep the new spell target consistent with the new spell, otherwise might get null agent targets with valid new spells
											end
									end
							end
					end
	if ($HasAttribute("Spell_Target", thisagent))
		thisagent's "Spell_Target" = new_target;
	return new_spell;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellCastFirstPass( agent thisagent, string spell_name) is boolean //Take the normal spell_name
// Check the mana and cooldown of the spell
//Normal spell_name is without the level qualifer: "Fire_Bolt"
declare

begin
	if (($isspellAvailable(thisagent, spell_name) == TRUE) && ($Spell_Resource_Available(thisagent, spell_name) == TRUE))
		return TRUE;
	return FALSE;
end
/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellDefaultAttackPass( agent thisagent, string spell_name) is agent //For this, return an agent as the pass condition for spells
//Basic fire tree attack spells currently all use this
declare

begin
	return $BasicCastTarget_hero(thisagent, thisagent's "Target", spell_name);
end

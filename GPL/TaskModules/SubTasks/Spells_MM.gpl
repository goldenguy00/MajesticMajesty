/////////////////////////////////////////////////////////////////////////////////////////////////
function ma_Volley_Cast(agent thisagent, agent target)
// Mercenary Arbalest Volley - 3 Spires
// - callback from cast action
declare
	integer stat, duration, attackspeed;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	duration = (1500 + (stat * 100));
	attackspeed =  2000;
	$createeffector( thisagent, "ma_volley_effector", duration );
	$adjustattribute(thisagent, #ATTRIB_ActionRateModifier, - attackspeed);
	$createmissile("ma_volley_missile", thisagent, target);
	$SpellTimeoutEffect( thisagent, $ma_VolleyBuff_Death, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_corrosion_ball_Hit( agent thisagent, agent target )
// court mage spell - Starting Spell
// - callback from missile hit
// Crashes when used on a building and the building dies.
declare
	integer stat, duration, minusarmor, current_armor;
begin
	if ($isvalidgamepiece(target) == FALSE)
		return;
		
		
	$createeffector(target, "Rustspit_Splat", 0);
	$spell_type_attack( thisagent, target, "poison", 6, 8 );
	
	if ($isvalidgamepiece(target) == FALSE)
		return;
		
	if (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			stat = $getattribute(thisagent, #ATTRIB_Intelligence);
			duration = (stat * 250);
			minusarmor = (stat / 20);
			current_armor = $getattribute(target, #ATTRIB_Armor_Basic_Damage);
	
			duration = $WillpowerDurationDebuff(target, duration);
	
			if (current_armor < minusarmor)
				minusarmor = current_armor;
		
			$createeffector( target, "cm_corrosionball_Splat", duration );
			$adjustattribute(target, #ATTRIB_Armor_Basic_Damage, - minusarmor);
			$SpellTimeoutEffect( thisagent, $cm_CorrosionBallDebuff_Death, duration, #ATTRIB_Armor_Basic_Damage, minusarmor, 0, 0,0,0,0  );
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Wizard_Tower_Enchant_Begin( agent thisagent, agent target )
// court mage spell - One Spire
declare
	integer stat, cooldown, duration;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	cooldown = (60000 - (stat * 250));
	duration = (45000 + (stat * 250));
	$createeffector( thisagent, "cm_enchant_wizard_tower_icon", cooldown );
	target's "ActiveScript" = $Wiz_Tower_Scan;
	$setattribute(target,#ATTRIB_Enchantmentlevel,1);
	$NewThread (target's "ActiveScript", #Normal_Cycle, target);
	$createeffector(target,"wiztower_enchantment", 1, "Infinite");
	$createeffector( target, "cm_enchant_wizard_tower_end", duration );
	//Need this now that the Tower uses buffs and debuffs. Tower Damage bonus is calculated in the Tower_HB.GPL.
	$adjustattribute(target,#ATTRIB_SightRange, stat );
	$adjustattribute(target,#ATTRIB_Intelligence, stat );
	$SpellTimeoutEffect( target, $cm_EnchantWizardTowerBuff_Death, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Wizard_Tower_Enchant_End( agent thisagent )
// callback for ending Wizard Tower Enchantment
declare

begin
	If ($IsValidGamePiece (ThisAgent))
		begin

			$KillThread (ThisAgent's "ActiveScript");

			$setattribute(thisagent,#ATTRIB_Enchantmentlevel,0);

			$deleteeffector(thisagent,"wiztower_enchantment");
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Etherealize_Begin( agent thisagent, agent target )
// court mage spell - Two Spires
declare
	integer stat, cooldown, duration, move_slow, attack_slow, minus_res;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	move_slow = ((stat * 3) / 2);
	attack_slow = (stat * 3);
	minus_res = (20 + (stat / 5));
	cooldown = (20000 - (stat * 250));
	duration = (10000 + (stat * 250));
	
	duration = $WillpowerDurationDebuff(target, duration);
	
	$createeffector( thisagent, "cm_etherealize_icon", cooldown );
	$createeffector(target,"cm_etherealize_effector", duration);
	//Need the SpellTimeoutEffect to hold the integers that track debuff numbers in case of stacking Etherealize spell.
	$adjustattribute(target,#ATTRIB_MovementRateModifier, move_slow );
	$adjustattribute(target,#ATTRIB_ActionRateModifier, attack_slow );
	$adjustattribute(target,#ATTRIB_MagicResistance, - minus_res );
	$GetProperUnitArt(target);
	$SpellTimeoutEffect( target, $cm_EtherealizeDebuff_Death, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_EtherealizeEffector_End( agent thisagent )
// Get this unit's proper art for when the effect ends. Not used anymore.
declare

begin
	$GetProperUnitArt(thisagent);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Acid_Fog_Hit( agent thisagent, agent target )
// court mage spell - Three Spires
// - this spell doesn't need this many functions, reduce size from 4 to 2.
declare
	agent fog;
	integer stat, cooldown, duration, periodic;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	periodic = (2000 - (stat * 20));
	cooldown = (35000 - (stat * 250));
	duration = (14000 + (stat * 250));
	
	// have to create a new unit and set the variable for it, adjust it's intelligence to match the caster's
	$createeffector( thisagent, "cm_acid_fog_icon", cooldown );
	
	$SpellTimeoutEffectAdvanced( thisagent, "cm_acid_fog", target, $cm_Acid_Fog_Active, $spelldummydeath, "cm_acid_fog_effector", periodic, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function cm_Acid_Fog_Active(agent thisagent)
// court mage spell - Three Spires
// - activescript for cm_acid_fog unit
declare
	list targets;
	agent target, parent;
	integer stat, CurrentHP, CurrentMaxHP, HPDifference, minus_MaxHP, debuff_duration, max_damage, min_damage, duration;

begin
	stat = $GetAttribute(thisagent, #ATTRIB_Intelligence);
	minus_MaxHP = (stat / 12);
	min_damage = (stat / 15);
	max_damage = (stat / 10);
	debuff_duration = (7000 + (stat * 250));
	targets = $compile_enemies(thisagent,75 + stat);

	foreach target in targets do
		begin
			duration = debuff_duration;
			$player_spell_attack( target, max_damage, min_damage );
			$createeffector(target, "Rustspit_Splat", 0);
			CurrentHP = $getattribute(target,#ATTRIB_HP);
			CurrentMaxHP = $getattribute(target,#ATTRIB_MaxHP);
			HPDifference = (CurrentMaxHP - CurrentHP);
			if (CurrentHP > 0)
				begin
					if (HPDifference < minus_MaxHP)
						begin
							$setattribute(target, #ATTRIB_MaxHP, CurrentHP);
							duration = $WillpowerDurationDebuff(target, duration);
							$SpellTimeoutEffect( target, $cm_AcidFogDebuff_Death, duration, #ATTRIB_Intelligence, HPDifference, 0, 0,0,0,0  );
						end
					else
						begin
							$adjustattribute(target, #ATTRIB_MaxHP, - minus_MaxHP);
							duration = $WillpowerDurationDebuff(target, duration);
							$SpellTimeoutEffect( target, $cm_AcidFogDebuff_Death, duration, #ATTRIB_Intelligence, minus_MaxHP, 0, 0,0,0,0  );
						end
					end
		end
end

///////////////////////////////////MONSTER SPELLS////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////

function bm_Consume_Life_Hit( agent thisagent, agent target )
// Blood Mage spell - basic spell
// - callback from missile hit

declare
	agent mage_spawn;
	integer  targetHP, HP_threshold;
	string target_name, spawn_name;
	coordinate target_loc;

begin
	if ($isvalidgamepiece(target) == FALSE)
		return;

	targetHP = $getattribute(target, #ATTRIB_HP);
	target_name = target's "title";
	target_loc = $LocationOf(target);
	
	spawn_name = $bm_Consume_Life_Names(target_name);
	
	HP_threshold = ($getattribute( ThisAgent, #ATTRIB_intelligence ) / 6);
	
	If (Target's "Type" != "Building" && Target's "Type" != "Lair")
		begin
			//If I am hurt, then heal me
			If ($GetAttribute (ThisAgent, #ATTRIB_HP) < $GetAttribute (ThisAgent, #ATTRIB_MaxHP))
				begin
					$createeffector( ThisAgent, "life_drain_effector2", 0 );
					$heal(thisagent,thisagent,($getattribute( ThisAgent, #ATTRIB_intelligence ) / 4));
				end
		end

	if ($isdead(target) != TRUE)
		begin
			if ((targetHP > HP_threshold) || (spawn_name == "None"))
				begin
					$createeffector( target, "life_drain_effector", 0);
					$spell_type_attack(thisagent, target, "Necrotic", 5, 7);
					//$spell_attack( thisagent, target, 6 );
				end
			else
				begin
					$DeleteGamePiece(target);
					mage_spawn = $spawnunit(thisagent, spawn_name, target_loc);
					$createeffector( mage_spawn, "life_drain_effector", 0);
				end
		end
	
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function bm_Consume_Life_Names( string unit_name ) is string
// Blood Mage list of names for new unit

declare
	string new_name;

begin
	new_name = "None";
	
	if (unit_name == "Peasant")
		new_name = "Sanguine_Peasant";
	else if (unit_name == "Royal_Archer")
		new_name = "Crimson_Archer";
	else if (unit_name == "Mercenary_Arbalest")
		new_name = "Maniacal_Arbalest";
	else if (unit_name == "Court_Mage")
		new_name = "Blood_Mage";
	else if (unit_name == "Squire")
		new_name = "Scarlet_Squire";
	else if ((unit_name == "Palace_Guard") || (unit_name == "City_Guard") || (unit_name == "Veteran_City_Guard"))
		new_name = "Gore_Guard";
	
	return new_name;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function minotaur_lord_multiple_enemy_attack(agent thisagent, agent target)
// Minotaur Lord basic attack
declare
	list targets;
	agent target1,target2,target3;

begin
	if ((target's "type" == "building") || (target's "type" == "lair"))
		$make_attack(thisagent,target);
		
	// list all enemies nearby -
	targets = $compile_enemies(thisagent,30);


	if ($listsize(targets) == 0)
		return;

	target1 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target2 = $listmember(targets,1);

	if ($listsize(targets) > 1)
		$removelistmember(targets,1);

	target3 = $listmember(targets,1);

	// attack the three nearest targets
	$make_attack(thisagent,target1);
	$make_attack(thisagent,target2);
	$make_attack(thisagent,target3);
	
		
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function NewSpellCheck_henchman( agent thisagent, agent target ) is string
// This function is for attack spells using the new Cooldown system as well.
// This will check all custom spells for this henchman and return the name of a valid spell.
declare
	agent newtarget;
	boolean next_spell;
	list spell_targets;
	string spell_name, unit_name;
	integer targetrange, attackrange;
begin
	unit_name = thisagent's "title";
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	spell_name = "nothing";
	newtarget = target;
	next_spell = FALSE;
	if (unit_name == "court_mage")
		begin
			if (($isspellAvailable(thisagent,"cm_enchant_wizard_tower") == TRUE) && ($Checkeffector(thisagent,"cm_enchant_wizard_tower_icon") != TRUE))
				begin
					spell_targets = $listtitlesinRadiusAdvanced (ThisAgent, "Building", "wizards_tower", thisagent's "castingrange", #MyPlayer);
					if ($ListSize (spell_targets) > 0)
						begin
							newtarget = $ListMember(spell_targets,1);
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (($Checkeffector(newtarget,"cm_enchant_wizard_tower_end") != TRUE) && (targetrange <= attackrange))
								begin
									spell_name = "cm_enchant_wizard_tower";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
			 if (($isspellAvailable(thisagent,"cm_etherealize") == TRUE) && ($Checkeffector(thisagent,"cm_etherealize_icon") != TRUE) && (next_spell == TRUE))
				begin
					if ((newtarget's "type" != "building") && (newtarget's "type" != "lair"))
						begin
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (targetrange <= attackrange)
								begin
									spell_name = "cm_etherealize";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
			 if (($isspellAvailable(thisagent,"cm_acid_fog_spell") == TRUE) && ($Checkeffector(thisagent,"cm_acid_fog_icon") != TRUE) && (next_spell == TRUE))
				begin
					if ((newtarget's "type" != "building") && (newtarget's "type" != "lair"))
						begin
							targetrange = $distanceBetweenAgents(thisagent,newtarget);
							if (targetrange <= attackrange)
								begin
									spell_name = "cm_acid_fog_spell";
									next_spell = FALSE;
								end
							else
								begin
									next_spell = TRUE;
								end
						end
					else
						begin
							next_spell = TRUE;
						end
				end
			else
				begin
					next_spell = TRUE;
				end
				
		end
		
	return spell_name;
end
/////////////////////////////////////////////////////////////////////////////////////////////////
function NewSpellTarget_henchman( agent thisagent, agent target, string spell_name ) is agent
// This will return a valid target for the spell listed for this agent.
declare
	agent newtarget;
	boolean is_learned, on_cooldown;
	list spell_targets;
	string unit_name;
	integer targetrange, attackrange;
	
begin
	unit_name = thisagent's "title";
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	newtarget = target;
	if (spell_name == "cm_Enchant_Wizard_Tower")
		begin
			spell_targets = $listtitlesinRadiusAdvanced (ThisAgent, "Building", "wizards_tower", thisagent's "castingrange", #MyPlayer );
			if ($ListSize (spell_targets) > 0)
				begin
					newtarget = $ListMember(spell_targets,1);
				end
		end
	else if (spell_name == "cm_Etherealize")
		begin
			newtarget = target;
		end
	else if (spell_name == "cm_acid_fog_spell")
		begin
			newtarget = target;
		end
		
	return newtarget;
end


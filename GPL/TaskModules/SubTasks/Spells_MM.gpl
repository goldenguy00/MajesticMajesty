	add_dodge = (6 + (intelligence / 4));
	add_parry = (6 + (intelligence / 4));
	add_resistance = (9 + (intelligence / 3));
	
	add_armor = $EffectBuff_Thread(willpower, wisdom, add_armor);
	add_dodge = $EffectBuff_Thread(willpower, wisdom, add_dodge);
	add_parry = $EffectBuff_Thread(willpower, wisdom, add_parry);
	add_resistance = $EffectBuff_Thread(willpower, wisdom, add_resistance);
	
	$adjustattribute(thisagent,#ATTRIB_armor_basic_damage, - add_armor);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_dodge, - add_dodge);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_parry, - add_parry);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_magicresistance, - add_resistance);
	
	$KillThread(thisagent's "Paladin_ShieldOfLightBuff_End");
end


function DurationBuff( agent thisagent, agent target, integer duration ) is integer
// Batch code for buff duration modifiers
//
declare
	integer new_duration;
begin
	new_duration = $IntelligenceDurationBuff(thisagent, duration);
	new_duration = $WillpowerDurationBuff(target, new_duration);
	return new_duration;
end


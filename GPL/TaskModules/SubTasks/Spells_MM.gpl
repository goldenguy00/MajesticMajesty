

// player spells

///////////////////////////////////////////////////////////////////////////////
function Earthquake_Active ( agent thisagent )
////////////////////////////////////////////////////////////////////
// player cast spell - from Sorcerer's Abode
// - activescript for Eartquake unit
////////////////////////////////////////////////////////////////////
// This function strikes all non-aligned buildings and lairs within
// its radius.  The damage drops off as the distance from the target
// center increases.
////////////////////////////////////////////////////////////////////
declare
	list targets;
	agent target;
	integer epicenter_distance, max_damage, min_damage;
	float damage_multiplyer, range_band;

begin
	//$DebugOut (911, "IN EARTHQUAKE ACTIVE");

	targets = $earthquake_targets ( thisagent, #Earthquake_Radius );
	range_band = ( #Earthquake_Radius / 8 );
	// The damage is reduced over 8 concentric range bands within the radius.

	foreach target in targets do
		begin
			if ( $IsDead ( Target ) == FALSE )
				begin
					//$DebugOut (911, "IN EARTHQUAKE ASSIGN DAMAGE CODE!");

					Epicenter_distance = $DistanceBetweenAgents ( ThisAgent, target );
					if ( epicenter_distance < range_band )
						damage_multiplyer = .75;
					else
						damage_multiplyer = ( range_band / epicenter_distance );

					max_damage = ( damage_multiplyer * #Earthquake_Damage );
					min_damage = ( damage_multiplyer * ( #Earthquake_Damage / 2 ));

					$createeffector ( target, "Earthquake_p", 0 );
					$player_spell_type_attack ( target, "force", max_damage, min_damage );
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function earthquake_targets ( agent thisagent, integer range ) is list

////////////////////////////////////////////////////////////////
// returns a list of all unfriendly buildings & lairs in radius.
////////////////////////////////////////////////////////////////

declare
	list targets, t2, t3;

begin
	$ListObjects ( thisagent, "building", range, targets, #NoHiddenMap );
	$ListObjects ( thisagent, "lair", range, t2, #NoHiddenMap );
	t3 = $addlists ( targets, t2 );
	return t3;
end


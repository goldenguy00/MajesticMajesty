function Meditation_Begin( agent thisagent, agent target )
// healer spell - lvl 4
// - callback from cast action
// Heal rate commented out until the Health Regeneration system is properly implemented
declare
	integer stat_int, stat_willpower, stat_wisdom, stat_art, duration, cooldown, add_dodge, add_parry, add_sight, add_healrate, mana_cost;
	string buff_name;
	
begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	stat_willpower = $getattribute(target, #ATTRIB_Willpower);
	stat_wisdom = thisagent's "Wisdom_Total";
	mana_cost =  $Spell_Mana_Cost(thisagent,"meditation");
	duration = 33000;
	cooldown = 22000;
	add_dodge = (15 + (stat_int / 5));
	add_parry = (15 + (stat_int / 5));
	add_sight = (30 + (stat_int / 4));
	buff_name = "Healer_MeditationBuff_End";
	//add_healrate = (1 + (stat_int / 12));
	
	duration = $DurationBuff(thisagent, target, duration);
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	add_dodge = $EffectBuff(thisagent, target, add_dodge);
	add_parry = $EffectBuff(thisagent, target, add_parry);
	add_sight = $EffectBuff(thisagent, target, add_sight);
	//add_healrate = $EffectBuff(thisagent, target, add_healrate);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", - mana_cost);
	
	$createeffector(target,"Meditation_effector",0);
		
	$AddAttribute(ThisAgent, "healer_meditation_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "healer_meditation_cooldown", cooldown, thisAgent, "healer_meditation_cooldown" );
	
	if ($HasAttribute(buff_name, target) != False)
		begin
			if ($IsRunning (target's buff_name) == TRUE)
				return;
		end
	else
		$AddAttribute(target, buff_name, "function", $Healer_MeditationBuff_End);
		
		
		
	$createeffector(target,"Meditation_icon",duration);
	$NewThread(target's buff_name, duration, target, stat_int, stat_willpower, stat_wisdom);
	
	$MagicalAdjustAttribute(target,#ATTRIB_dodge,add_dodge);
	$MagicalAdjustAttribute(target,#ATTRIB_parry,add_parry);
	$adjustattribute(target,#ATTRIB_sightrange,add_sight);
	//$adjustattribute(target,#ATTRIB_HealingRateModifier,add_healrate);

end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Healer_MeditationBuff_End( agent thisagent, integer intelligence, integer willpower, integer wisdom )
// healer spell - lvl 4
// - callback from "Meditation_icon" effector
declare
	integer add_dodge, add_parry, add_sight, add_healrate;

begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		return;
		
	add_dodge = (15 + (intelligence / 5));
	add_parry = (15 + (intelligence / 5));
	add_sight = (30 + (intelligence / 4));
	//add_healrate = (1 + (intelligence / 12));
	
	add_dodge = $EffectBuff_Thread(willpower, wisdom, add_dodge);
	add_parry = $EffectBuff_Thread(willpower, wisdom, add_parry);
	add_sight = $EffectBuff_Thread(willpower, wisdom, add_sight);
	//add_healrate = $EffectBuff_Thread(willpower, wisdom, add_healrate);
	
	$MagicalAdjustAttribute(thisagent,#ATTRIB_dodge,- add_dodge);
	$MagicalAdjustAttribute(thisagent,#ATTRIB_parry,- add_parry);
	$adjustattribute(thisagent,#ATTRIB_sightrange,- add_sight);
	//$adjustattribute(thisagent,#ATTRIB_HealingRateModifier,add_healrate);
	
	$KillThread(thisagent's "Healer_MeditationBuff_End");
	
end


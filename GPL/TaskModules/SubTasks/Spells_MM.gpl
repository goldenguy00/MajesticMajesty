	$adjustattribute(target,#ATTRIB_MagicResistance, - minus_res );
	$GetProperUnitArt(target);
	$SpellTimeoutEffect( target, $cm_EtherealizeDebuff_Death, duration, #ATTRIB_Intelligence, stat, 0, 0,0,0,0  );

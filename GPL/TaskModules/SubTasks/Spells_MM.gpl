//GENERIC
/////////////////////////////////////////////////////////////////////////////////////////////////
function Power_Shock_Cast(agent thisagent, agent target)
// Generic Spell
// - callback from cast action
declare
	integer stat_int, stat_art, cooldown, mana_cost;

begin
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	stat_art = $getattribute(thisagent, #ATTRIB_Artifice);
	mana_cost =  $Spell_Mana_Cost(thisagent,"power_shock");
	cooldown = 6000;
	
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	
	mana_cost = $WisdomManaReduction(thisagent, mana_cost);
	
	$adjustattributesafe(thisagent, "CurrentMana", 0 - mana_cost);
	
	$AddAttribute(ThisAgent, "generic_powershock_cooldown", "function", $Cooldown_End);
	$NewThread(thisAgent's "generic_powershock_cooldown", cooldown, thisAgent, "generic_powershock_cooldown" );
	
	$createmissile("power_shock_missile",thisagent,target);
end


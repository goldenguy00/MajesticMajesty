///////////////////////////////////////////////////////////////////////////////
function blacksmith_bonus_basic(agent thisagent)

declare
	agent building;
	list buildings, list1, blacksmiths_lvl2, blacksmiths_lvl3;
	integer num_blacksmith_lvl2, num_blacksmith_lvl3, FullHP;

begin
	$InitBaseStats(thisagent);
	$ListObjects(thisagent,"building",-1,buildings, #MyPlayer);
	list1 = $listtitles(buildings,"Blacksmith");
	
	foreach building in list1 do
		begin
			if (building's "Level" > 1)
				blacksmiths_lvl2 << building;
			if (building's "Level" > 2)
				blacksmiths_lvl3 << building;
		end
		
	blacksmiths_lvl2 = $listcompleted(blacksmiths_lvl2);
	num_blacksmith_lvl2 = $ListSize(blacksmiths_lvl2);
	
	blacksmiths_lvl3 = $listcompleted(blacksmiths_lvl3);
	num_blacksmith_lvl3 = $ListSize(blacksmiths_lvl3);
	
	FullHP = (($GetAttribute(thisagent, #ATTRIB_MaxHP) * num_blacksmith_lvl3) / 50);
	$AdjustAttribute(thisagent, #ATTRIB_MaxHP, FullHP);
	$AdjustBaseStat(thisagent, "Armor_Magical", 10 * num_blacksmith_lvl2);
	$AdjustBaseStat(thisagent, "Armor_Physical", num_blacksmith_lvl2);

end

///////////////////////////////////////////////////////////////////////////////
function blacksmith_bonus_upgrade(agent thisagent)

declare
	agent building;
	list buildings, list1, blacksmiths_lvl2, blacksmiths_lvl3;
	integer num_blacksmith_lvl2, num_blacksmith_lvl3, FullHP;

begin
	$InitBaseStats(thisagent);
	$ListObjects(thisagent,"building",-1,buildings, #MyPlayer);
	list1 = $listtitles(buildings,"Blacksmith");
	
	foreach building in list1 do
		begin
			if (building's "Level" > 1)
				blacksmiths_lvl2 << building;
			if (building's "Level" > 2)
				blacksmiths_lvl3 << building;
		end
		
	blacksmiths_lvl2 = $listcompleted(blacksmiths_lvl2);
	num_blacksmith_lvl2 = $ListSize(blacksmiths_lvl2);
	
	blacksmiths_lvl3 = $listcompleted(blacksmiths_lvl3);
	num_blacksmith_lvl3 = $ListSize(blacksmiths_lvl3);
	
	FullHP = (($GetAttribute(thisagent, #ATTRIB_MaxHP) * num_blacksmith_lvl3) / 50);
	$AdjustBaseStat(thisagent, "MaxHP", FullHP);
	$AdjustBaseStat(thisagent, "Armor_Magical", 10 * num_blacksmith_lvl2);
	$AdjustBaseStat(thisagent, "Armor_Physical", num_blacksmith_lvl2);
end
///////////////////////////////////////////////////////////////////////////////
// common code used by heroes,henchmen,and cheats for finishing up
// a building's upgrade or construction process
function BuildingReachedMaxHP(agent theBuilding)

declare
	agent AIRootAgent;
	integer member_limit;
	agent check;
	string name;

begin
	$InitBaseStats(theBuilding);
	AIRootAgent = $RetrieveAgent("GplAIRoot");
	member_limit = 4;

	////$DebugOut(911,"BuildingReachedMaxHP() for ",theBuilding);

	if($getattribute(theBuilding,#ATTRIB_FirstStageBuilt) != 1)
	begin
		if($hasattribute("birthscript2",theBuilding))
			begin
				//Have advisor say that a building has been upgraded
				$PlaySound(TheBuilding,"Advisor_Building_Complete","VFX_ADVISOR");
				$LocalChatMessage($GetUnitPlayerNumber(TheBuilding ),#chat_building_complete,TheBuilding);

				$runthread(theBuilding's "birthscript2",1,theBuilding);

				////$DebugOut(911," ran 'birthscript2'.");
			end
		//else
			////$DebugOut(911," COULDN'T run 'birthscript2'.");
	end
	else
		// is being repaired or upgraded?
		if($getattribute(theBuilding,#ATTRIB_currentstagebuilt) != 1)
			begin
				$UpgradeAgentAttributes(theBuilding);
				if ($listsize(theBuilding's "Checklist") > 0)
					foreach name in theBuilding's "Checklist" do
						begin
							check = $agenttitleinlist(name, $GetBuildingContents($agenttitleinlist("Research", theBuilding's "Attachments")));
							if ((check's "ResearchCheck")(theBuilding))
								$ResearchSet(check, "AVAILABLE");
						end
					
				if ($IsExpansion(theBuilding) != False)
					If (AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
						begin
							$SetAttribute(theBuilding,#ATTRIB_MaxGuildMembers,1);
							member_limit = 1;

							If(TheBuilding's "Subtype" == "Palace")
								If(TheBuilding's "Level" == 2)
									TheBuilding's "heroes_to_upgrade" = 4;

						end

				If(TheBuilding's "Title" == "Palace")
					begin

						//Play the special Palace voice line
						$PlaySound(TheBuilding,"Advisor_Palace_Upgrade","VFX_ADVISOR");

						// special case for palace
						$setattribute(TheBuilding,#ATTRIB_Upgrade_herosNeeded,TheBuilding's "heroes_to_upgrade");
					end

				Else
					begin
						//Have advisor say that a building has been upgraded
						$PlaySound(TheBuilding,"Advisor_Building_Upgraded","VFX_ADVISOR");
						$LocalChatMessage($GetUnitPlayerNumber(TheBuilding ),#chat_building_upgraded,TheBuilding);
						
//						If (($HasAttribute("max_members", TheBuilding) != False) || ($HasAttribute("member_title", TheBuilding) != False))
//							begin
//								If ($HasAttribute("Level", TheBuilding) != False)
//									begin
//										if (thebuilding's "level" > 0)
//											$setattribute(TheBuilding, #ATTRIB_MaxGuildMembers, (member_limit + (TheBuilding's "level" - 1)));
//									end
//							end
						
						If(TheBuilding's "Title" == "Guardhouse")
							begin
								// Max_Guards might have changed when the attributes were updated.
								$GuardhouseRestartGuardSpawnThread(TheBuilding,1,"City_Guard");
							end
					end
					
				////$DebugOut(911," ran $UpgradeAgentAttributes.");
			end
		else
			begin
				// done repairing
				if($getattribute(thebuilding,#ATTRIB_quickRepair) == 1)
					$setattribute(thebuilding,#ATTRIB_quickRepair,0);
			end

	$setattribute(theBuilding,#ATTRIB_HP,$getattribute(theBuilding,#ATTRIB_MaxHP));
	$setattribute(theBuilding,#ATTRIB_currentstagebuilt,1);
	$setattribute(theBuilding,#ATTRIB_FirstStageBuilt,1);
end

///////////////////////////////////////////////////////////////////////////////
function guild_birth ( agent thisagent )

declare
	agent	AIRootAgent;
	list 	strays,new_strays;
	agent stray;
	integer member_limit;

begin
	$InitBaseStats(thisagent);
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );
	member_limit = 4;

	if ($IsExpansion(thisagent) != False)
		If ( AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes )
			begin

				$SetAttribute ( ThisAgent, #ATTRIB_MaxGuildMembers, 1 );
				member_limit = 1;

			end

//	If ($HasAttribute("Level", thisagent) != False)
//		begin
//			if (thisagent's "level" > 0)
//				$setattribute(thisagent, #ATTRIB_MaxGuildMembers, (member_limit + (thisagent's "level" - 1)));
//		end
						
	thisagent's "in_danger" = FALSE;

	if ( $getunitplayernumber ( thisagent ) != #monster_player )
		begin
			$check_strays ( thisagent, thisagent's "member_title", #MyPlayer );
			$check_strays ( thisagent, thisagent's "member_title", #NotMyPlayer );
		end

	$setattribute ( thisagent, #ATTRIB_gold, 0 );

	If ( $HasAttribute ( "ActiveScript", ThisAgent ))
		$NewThread ( ThisAgent's "ActiveScript", #Normal_Cycle, ThisAgent );

	$Building_Birth ( ThisAgent );

end

///////////////////////////////////////////////////////////////////////////////
function magical_upgrade(agent thisagent)

declare
	agent palace, AIRootAgent;
	integer HP,Maxhp,build_rate;
	integer member_limit;

begin
	
	$InitBaseStats(thisagent);
	AIRootAgent = $RetrieveAgent("GPLAIRoot");
	member_limit = 4;
	if ($IsExpansion(thisagent) != False)
		If(AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
			begin
				$SetAttribute(ThisAgent, #ATTRIB_MaxGuildMembers, 1);
				member_limit = 1;
			end

//	If ($HasAttribute("Level", thisagent) != False)
//		begin
//			$setattribute(thisagent, #ATTRIB_MaxGuildMembers, (member_limit + (thisagent's "level" - 1)));
//		end
					
	HP = $getattribute(thisagent,#ATTRIB_HP);
	MaxHP = $getattribute(thisagent,#ATTRIB_MAXHP);
	
	if ($HasAttribute("magical_build_rate", thisagent) != False)
		build_rate = thisagent's "magical_build_rate";
	else
		build_rate = #magical_build_amount;

	if(HP != MAXHP)
		begin
  			if($HasAttribute("Deathmatch_Rules", AIRootAgent))
				begin
					if(AIRootAgent's "Deathmatch_Rules" == TRUE)
						HP += #Deathmatch_magical_build_amount;
					else
						HP += build_rate;
				end
			else
				HP += build_rate;

			if(HP > MAXHP)
				HP = MAXHP;

			$setattribute(thisagent,#ATTRIB_HP,HP);
			$runthread(thisagent's "upgradescript",#magical_build_delay,thisagent);
		end
	else
		begin
			$UpgradeAgentAttributes(thisagent);
			
			if ($IsExpansion(thisagent) != False)
				If(AIRootAgent's "Quest_Number" == #QNumber_Legendary_Heroes)
					begin
						$SetAttribute(ThisAgent, #ATTRIB_MaxGuildMembers, 1);
						member_limit = 1;
					end

//			If ($HasAttribute("Level", thisagent) != False)
//				begin
//					$setattribute(thisagent, #ATTRIB_MaxGuildMembers, (member_limit + (thisagent's "level" - 1)));
//				end
					
			$setattribute(thisagent,#ATTRIB_currentstageBuilt,1);
			//$setattribute(thisagent,#ATTRIB_firststageBuilt,1);
			$playsound(thisagent,"Advisor_Building_Upgraded","VFX_ADVISOR");

			//Chat to the message area
			if ($HasAttribute("Initial_Misc", thisagent))
				(thisagent's "Initial_Misc")(thisagent);

			if ($HasAttribute("Initial_Research", thisagent))
				(thisagent's "Initial_Research")(thisagent);

			$LocalChatMessage($GetUnitPlayerNumber(ThisAgent), #chat_building_upgraded, ThisAgent);
		end
end

///////////////////////////////////////////////////////////////////////////////
function building_upgraded(agent thisagent)
declare
begin
	$InitBaseStats(thisagent);

	$runthread(thisagent's "upgradescript",1,thisagent);
	$blacksmith_bonus_upgrade(thisagent);
	
	if ($HasAttribute("Initial_Misc", thisagent))
		(thisagent's "Initial_Misc")(thisagent);

	if ($HasAttribute("Initial_Research", thisagent))
		(thisagent's "Initial_Research")(thisagent);

	$count_building(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function GetSupportedHenchmen(agent thisagent, integer index) is integer

declare
	integer retval,num_fount,num_statue,num_garden;
	list fountains, statues, gardens;

begin
	retval = 0;

	if (index == 0)
		begin
			$listobjects(thisagent,"building",-1,statues,#Myplayer);
			statues = $listtitles(statues,"statue");
			num_statue = $listsize(statues);
			
			retval = thisagent's "max_peasants" + num_statue;
		end
	else if (index == 1)
		begin
			$listobjects(thisagent,"building",-1,fountains,#Myplayer);
			fountains = $listtitles(fountains,"fountain");
			num_fount = $listsize(fountains);

			retval = thisagent's "max_tax_collectors" + num_fount;
		end
	else if (index == 2)
		begin
			$listobjects(thisagent,"building",-1,gardens,#Myplayer);
			gardens = $listtitles(gardens,"royal_gardens");
			num_garden = $listsize(gardens);
			
			retval = thisagent's "Max_guards" + num_garden;
		end

	return retval;
end


///////////////////////////////////////////////////////////////////////////////
function arcane_spire_birth(agent thisagent)

declare
	list guys, towers, guilds;
	agent guy, palace;
	integer num_spire;

begin
	palace = $gettruepalace(thisagent);
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);
	$listobjects(thisagent,"building",-1,guilds,#MyPlayer);
	guilds = $listtitles(guilds,"wizards_guild");
	num_spire = $listsize(guilds);
	
	foreach guy in guys do
		if (guy's "subtype" == "hero")
			$adjustattribute(guy,#ATTRIB_Intelligence, 1 );
		else if (guy's "subtype" == "henchman")
			begin
				$adjustattribute(guy,#ATTRIB_Intelligence, 2 );
				$adjustattribute(guy,#ATTRIB_MagicResistance, 5);
				if ((guy's "title" == "Royal_Archer") && (num_spire == 1) && 
				($getattribute(guy, #ATTRIB_NumHealingPotions) == 0) && ($checkeffector(guy, "healing_salve_icon") == FALSE))
					$adjustattribute(guy,#ATTRIB_NumHealingPotions, 1 );
				else if ((guy's "title" == "Royal_Archer") && (num_spire == 3))
					$LearnSpell(guy, "ra_split_shot");
				else if ((guy's "title" == "Mercenary_Arbalest") && (num_spire == 1))
					guy's "critical_chance" = 15;
				else if ((guy's "title" == "Mercenary_Arbalest") && (num_spire == 3))
					$LearnSpell(guy, "ma_volley");
				else if ((guy's "title" == "Court_Mage") && (num_spire == 1))
					$LearnSpell(guy, "cm_enchant_wizard_tower");
				else if ((guy's "title" == "Court_Mage") && (num_spire == 2))
					$LearnSpell(guy, "cm_Etherealize");
				else if ((guy's "title" == "Court_Mage") && (num_spire == 3))
					$LearnSpell(guy, "cm_acid_fog_spell");
			end
	
	foreach guy in guilds do
		(guy's "Initial_Misc")(guy);
		
	
	if ($IsValidGamePiece(palace) == True)
		begin
			if ($isrunning(palace's "Guard_Spawn_Function") != TRUE)
				$runthread(palace's "Guard_Spawn_Function",#Guard_Spawn_Time,palace);
	end
		
		
	$count_building(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function shrine_birth(agent thisagent)

declare
	list guys, shrines;
	agent guy, palace;
	integer num_shrine;

begin
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);
	$listobjects(thisagent,"building",-1,shrines,#MyPlayer);
	shrines = $listtitles(shrines,"shrine");
	num_shrine = $listsize(shrines);
	
	$AddAttribute(ThisAgent, "Shrine_InsightGeneration", "function", $Shrine_InsightGeneration); //Not In Prototype
	$NewThread(ThisAgent's "Shrine_InsightGeneration", #Shrine_Insight_Interval, ThisAgent );
	
	foreach guy in guys do
		if (guy's "subtype" == "hero")
			$adjustattribute(guy,#ATTRIB_ResearchTrainIntelligence , 1 );
	
	$count_building(thisagent);
end


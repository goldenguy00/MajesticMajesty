/////////////////////////////////////////////////////////////////////////////
function manor_birth(agent thisagent)

declare
	list guys;
	agent guy;

begin
	$ListObjects ( thisagent, "hero", -1, guys, #MyPlayer, #insideOtherUnits );

	foreach guy in guys do
		if (guy's "subtype" == "henchman")
			$setattribute( guy, #ATTRIB_MaxHP, ($getattribute(guy, #ATTRIB_MaxHP) + #manor_HP_bonus));
			$setattribute( guy, #ATTRIB_HP, ($getattribute(guy, #ATTRIB_HP) + #manor_HP_bonus));
			
	$count_building(thisagent);
end
/////////////////////////////////////////////////////////////////////////////
function estate_birth(agent thisagent)

declare
	list guys;
	agent guy, palace;
	integer stat_adjust;

begin
	$AddAttribute(ThisAgent, "ReceivingVisitors", "boolean", true); //Not In Prototype
	$AddAttribute(ThisAgent, "EstateOpen", "function", $Estate_Open); //Not In Prototype
	
	palace = $gettruepalace(thisagent);
	$ListObjects ( thisagent, "hero", -1, guys, #MyPlayer, #insideOtherUnits );
	stat_adjust = #estate_primarystat_bonus;

	foreach guy in guys do
		if (guy's "subtype" == "hero")
			$adjustattribute(guy,guy's "PrimaryStat",stat_adjust);
	
	if ($IsValidGamePiece(palace) == True)
		begin
			if ($isrunning(palace's "Guard_Spawn_Function") != TRUE)
				$runthread(palace's "Guard_Spawn_Function",#Guard_Spawn_Time,palace);
		end
		
	$count_building(thisagent);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Estate_Open( agent thisagent )
// Function for when estate is receiving visitors again

declare

begin
	thisagent's "ReceivingVisitors" = true;
	
	$KillThread(thisagent's "EstateOpen");
	
end

///////////////////////////////////////////////////////////////////////////////
function statue_birth(agent thisagent)

declare
	list guys;
	agent guy, palace;
	integer bonusHP, firstHP;

begin
	palace = $gettruepalace(thisagent);
	$listobjects(thisagent,"hero",-1,guys,#MyPlayer,#insideOtherUnits);
	foreach guy in guys do
		if (guy's "subtype" == "hero")
			guy's "loyalty" += #statue_loyalty_boost;
		else if (guy's "subtype" == "henchman")
			begin
				firstHP = ($getattribute(guy, #ATTRIB_MaxHP) * 100);
				bonusHP = (firstHP / 2000);
					if (bonusHP < 1)
					begin
						bonusHP = 1;
					end
				$adjustattribute(guy,#ATTRIB_MovementRateModifier, -4 );
				$adjustattribute(guy,#ATTRIB_ActionRateModifier, -8);
				$adjustattribute(guy,#ATTRIB_SightRange, 5);
				$adjustattribute(guy,#ATTRIB_MaxHP, bonusHP);
				$adjustattribute(guy,#ATTRIB_HP, bonusHP);
				$adjustattribute(guy,#ATTRIB_HtoH, 1);
				$adjustattribute(guy,#ATTRIB_Ranged, 1);
				$adjustattribute(guy,#ATTRIB_Parry, 1);
				$adjustattribute(guy,#ATTRIB_Dodge, 1);
				$adjustattribute(guy,#ATTRIB_Strength, 1);
				$adjustattribute(guy,#ATTRIB_armor_basic_damage, 1);
				if ($getattribute(guy, #ATTRIB_maxattackrange) > 100)
					begin
						$adjustattribute(guy,#ATTRIB_maxattackrange, 5 );
						$adjustattribute(guy,#ATTRIB_Ranged, 1);
						guy's "castingrange" = $getattribute(guy, #ATTRIB_maxattackrange);
					end
			end

	if ($IsValidGamePiece(palace) == True)
		$runThread(palace's "peasant_spawn",#initial_peasant_delay, palace);
		
	$count_building(thisagent);
end


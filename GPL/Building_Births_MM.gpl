///////////////////////////////////////////////////////////////////////////////
function Shrine_InsightGeneration( agent thisagent )
declare
	
begin
	if ($IsValidGamePiece(thisagent) != TRUE)
		begin
			$KillThread(thisagent's "Shrine_InsightGeneration");
			return;
		end
		
	if ($getAttribute(thisagent, #ATTRIB_ResearchWizardFireBlast) < #Shrine_Insight_point_limit)
		$adjustattribute(thisagent, #ATTRIB_ResearchWizardFireBlast, 1);
	
end

///////////////////////////////////////////////////////////////////////////////
Function Palace_Birth (agent ThisAgent)
Declare
	coordinate sign_loc;

Begin
	$InitBaseStats(thisagent);
	sign_loc = $UnitPointWithOffset(thisagent, -150, 35);
	$AddHelpSign(thisagent, "Help_Sign_Attributes", sign_loc);
	
	sign_loc = $UnitPointWithOffset(thisagent, 160, 35);
	$AddHelpSign(thisagent, "Help_Sign_Spell_System", sign_loc);
	
	thisagent's "in_danger" = FALSE;
	$clearlist(thisagent's "tax_route");
	$clearlist(thisagent's "tax_targets");

	$NewThread( thisagent's "activeScript", #palace_revenue_cycle, thisagent );
	$NewThread( ThisAgent's "Guard_Function",#Normal_Cycle, ThisAgent);
	$RunThread (ThisAgent's "Guard_Spawn_Function", #initial_Palace_guard_delay, ThisAgent);
	$runThread( ThisAgent's "Tax_spawn",#initial_tax_collector_delay, thisagent);
	$runThread(thisagent's "peasant_spawn",#initial_peasant_delay, thisagent);
End

///////////////////////////////////////////////////////////////////////////////
function basic_birth(agent thisagent)

declare
	agent palace;
	integer HP,Maxhp;
	coordinate B_loc;

begin
	$InitBaseStats(thisagent);
	HP = $getattribute(thisagent,#ATTRIB_HP);
	MaxHP = $getattribute(thisagent,#ATTRIB_MAXHP);
	$AddAttribute(ThisAgent, "Help_Signs", "list"); //Not In Prototype
	thisagent's "in_danger" = FALSE;
				
	$blacksmith_bonus_basic(thisagent);
	
	$BasicHelpSignFilter(thisagent);
	
	if (HP != MAXHP)
	// if (thisagent is not completed)
		begin
		//put thisagent on the palace's list of buildings needing
			palace = $gettruepalace(thisagent);
			palace's "buildings_waiting" << thisagent;
		end
	else
		begin
			$runthread(thisagent's "birthscript2",1,thisagent);
		end
end

///////////////////////////////////////////////////////////////////////////////
function building_birth(agent thisagent)

declare

begin
	//	$NewThread( thisagent's "activeScript", #Normal_Cycle, thisagent );

	$InitBaseStats(thisagent);

	If ($HasAttribute ("RevenueScript", ThisAgent))
		If ($ValidFunction (ThisAgent's "RevenueScript"))
			$NewThread (ThisAgent's "RevenueScript", ThisAgent's "revenue_time", ThisAgent);

	$count_building(thisagent);

	if ($HasAttribute("Initial_Misc", thisagent))
		if ($ValidFunction(thisagent's "Initial_Misc"))
			(thisagent's "Initial_Misc")(thisagent);

	if ($HasAttribute("Initial_Research", thisagent))
		if ($ValidFunction(thisagent's "Initial_Research"))
			(thisagent's "Initial_Research")(thisagent);
	
	// to fix team changes and ranger guild moving
	$AddAttribute(thisagent, "SignParentChecker", "function", $SignParentChecker);
	$NewThread(thisagent's "SignParentChecker", 2000 + $RandomNumber(2000), thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function SignParentChecker(agent thisagent)
declare
	agent attach, widget;
	list attachments;
	integer myplayer, childplayer;
begin
	if ($HasAttribute("Attachments", thisagent) == false)
		return;

	attachments = thisagent's "Attachments";
	if ($ListSize(attachments) == 0)
		return;

	myplayer = $GetUnitPlayerNumber(thisagent);
	childplayer = $GetUnitPlayerNumber($ListMember(attachments, 1));
	if (childplayer == myplayer)
		return;
	
	foreach attach in attachments do
		begin
			$SetUnitPlayerNumber(attach, myplayer);
			foreach widget in $GetBuildingContents(attach) do
				if ($agentinagentlist(widget, attachments) == false)
					$SetUnitPlayerNumber(widget, myplayer);
		end
end

///////////////////////////////////////////////////////////////////////////////
function magical_birth ( agent thisagent )

declare
	agent palace, AIRootAgent;
	integer HP, Maxhp, build_rate;

begin
	$InitBaseStats(thisagent);
	AIRootAgent = $RetrieveAgent ("GPLAIRoot");

	HP = $getattribute ( thisagent, #ATTRIB_HP );
	MaxHP = $getattribute ( thisagent, #ATTRIB_MAXHP );
	$AddAttribute(ThisAgent, "Help_Signs", "list"); //Not In Prototype
	
	if ($HasAttribute("magical_build_rate", thisagent) != False)
		build_rate = thisagent's "magical_build_rate";
	else
		build_rate = #magical_build_amount;
	
	if ( HP != MAXHP )
		begin
  			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				begin
					if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
						HP += #Deathmatch_magical_build_amount;
					else
						HP += build_rate;
				end
			else
				HP += build_rate;

			if ( HP > MAXHP ) 
			begin
				HP = MAXHP;
			end
			
			$setattribute ( thisagent, #ATTRIB_HP, HP );

			if (HP > 0)
				$runthread ( thisagent's "birthscript", #magical_build_delay, thisagent );
		end
	else
		begin
			if ( $getattribute ( thisagent, #ATTRIB_firststageBuilt ) == 0 )
				begin
					$playsound ( thisagent, "Advisor_Building_Complete", "VFX_ADVISOR" );

					//Chat to the message area
					$LocalChatMessage ( $GetUnitPlayerNumber( ThisAgent ), #chat_building_complete, ThisAgent);
				end

			$BasicHelpSignFilter(thisagent);
			$setattribute ( thisagent, #ATTRIB_currentstageBuilt, 1 );
			$setattribute ( thisagent, #ATTRIB_firststageBuilt, 1 );
			$runthread ( thisagent's "birthscript2", 1, thisagent );
		end
end

///////////////////////////////////////////////////////////////////////////////
function BasicHelpSignFilter(agent thisagent)

declare
	string building_name;
	coordinate sign_loc;
	agent sign;

begin
	if ($HasAttribute("title", thisagent) != True)
		return;
		
	building_name = thisagent's "Title";
	
	if (building_name == "Library")
		begin
			sign_loc = $UnitPointWithOffset(thisagent, 5, 120);
			$AddHelpSign(thisagent, "Help_Sign_Library_Spells", sign_loc);
		end
  	else if (building_name == "Temple_Agrela")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, -15, 150);
  			$AddHelpSign(thisagent, "Help_Sign_Agrela_Spells", sign_loc);
  		end
  	else if (building_name == "Temple_Dauros")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, -100, 100);
  			$AddHelpSign(thisagent, "Help_Sign_Dauros_Spells", sign_loc);
  		end
  	else if (building_name == "Temple_Fervus")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, -25, 100);
  			$AddHelpSign(thisagent, "Help_Sign_Fervus_Spells", sign_loc);
  		end
  	else if (building_name == "Temple_Helia")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, -100, 40);
  			$AddHelpSign(thisagent, "Help_Sign_Helia_Spells", sign_loc);
  		end
  	else if (building_name == "Temple_Krypta")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, 50, 160);
  			$AddHelpSign(thisagent, "Help_Sign_Krypta_Spells", sign_loc);
  		end
  	else if (building_name == "Warriors_Guild")
  		begin
  			sign_loc = $UnitPointWithOffset(thisagent, 50, 160);
  			$AddHelpSign(thisagent, "Help_Sign_Paladin_Spells", sign_loc);
  		end
  	else if (building_name == "Wizards_Guild")
  		begin
  			  sign_loc = $UnitPointWithOffset(thisagent, 50, 160);
  			  $AddHelpSign(thisagent, "Help_Sign_Wizard_Fire_Skill_Tree", sign_loc);
  		end 
	
end

/////////////////////////////////////////////////////////////////////////////
// Add the building to the owner's Palace building count.
// This can cause other units to be auto-created, such as sewers.
function count_building(agent thisagent)

declare
	agent palace, bldg, AIRootAgent;
	list bldgs, sewers, pits, list1;
	integer i, num_sewer, num_pit, sanguine_pit_limit, dead_henchmen, temp_int, level;
	boolean flag;

begin
	$InitBaseStats(thisagent);
	
	AIRootAgent = $RetrieveAgent ( "GplAIRoot" );
	palace = $gettruepalace ( thisagent );
	flag = TRUE;
	
	$GeneralAttributes(thisagent);

	if ($isvalidgamepiece(palace))
		begin
				
			if (thisagent's "title" == "guardhouse")
				begin
					level = 1;
					if ($getattribute(thisagent,#ATTRIB_ResearchArrows) != 0)
						begin
							level = 2;
						end
				end
				
			if (level < 1)
				begin
					if ($HasAttribute("level", thisagent) != False)
						level = thisagent's "level";
					else
						level = 1;
				end
		
			if (palace != $NullAgent())
				if (level < 2)
					begin
						palace's "total_buildings" ++;
						palace's "buildings_lately" ++;
					end

			if ( $HasAttribute ( "Deathmatch_Rules", AIRootAgent ))
				if ( AIRootAgent's "Deathmatch_Rules" == TRUE )
					begin
						$listobjects ( palace, "AutoBuilding", -1, bldgs, #CheckTitles, "Sewers", #MyPlayer );
						if ( $ListSize ( bldgs ) >= #Deathmatch_Sewer_Limit )
							flag = FALSE;
					end
			if ($IsExpansion(thisagent) != False)
				if( AIRootAgent's "Quest_Number" == #QNumber_Vale_Serpents )
					begin

						Flag = False;

					end

			if ( Flag == TRUE )
				if (palace's "buildings_lately" >= #sewer_building_limit)
					begin
						palace's "buildings_lately" = 0;

						$listobjects(palace,"building",-1,bldgs,#MyPlayer, #ATTRIB_FirstStageBuilt, 1);

						bldgs << palace;

						i = $listsize(bldgs);

						bldg = $listmember(bldgs,$randomnumber(i) + 1);

						$listobjects ( palace, "Lair", -1, pits, #CheckTitles, "Sanguine_Pit", #MyPlayer );
						num_pit = $ListSize(pits);
						dead_henchmen = $getattribute(palace, #ATTRIB_ResearchArmorLevel_2);
						sanguine_pit_limit = (25 + (25 * num_pit));
						if (dead_henchmen < sanguine_pit_limit)
							$spawnunit(bldg,"sewers","maxhp");
						else
							begin
								//Make sure to adjust the attribute first before spawning the building! In MAJESTY Expansion, not doing this can cause infinite loop and crash.
								$adjustattribute(palace, #ATTRIB_ResearchArmorLevel_2, - sanguine_pit_limit);
								$spawnunit(bldg,"Sanguine_Pit","maxhp");
								//$spawnunit(bldg,"sewers","maxhp");
							end
						
						$ListObjects(thisagent,"building",-1,list1,#MyPlayer);
						list1 = $listtitles(list1,"gnome_hovel");
						if (palace != $NullAgent())
							begin
								$listobjects ( palace, "AutoBuilding", -1, sewers, #CheckTitles, "Sewers", #MyPlayer );
								num_sewer = $listsize(sewers);
								if (($listsize(list1) < #max_gnome_camps + num_sewer) && ($listsize(list1) > 0))
									$runthread(palace's "gnome_camp_spawner",#gnome_camp_delay,palace);
								end

					end

			if ((thisagent's "title" == "marketplace") || (thisagent's "title" == "trading_post") ||
				(thisagent's "title" == "inn"))
				begin
					palace's "fountain_buildings" ++;
					if (palace's "fountain_buildings" >= #fountain_building_limit)
						begin
							palace's "fountain_buildings" = 0;
							$spawnunit(palace,"fountain","maxhp");
						end
				end
				
			if ((thisagent's "title" == "blacksmith") || (thisagent's "title" == "palace") || 
				(thisagent's "title" == "warriors_guild") || (thisagent's "title" == "guardhouse"))
				begin
					$adjustattribute(palace,#ATTRIB_Strength, 1);
					if ($getattribute(palace,#ATTRIB_Strength) >= #statue_building_limit)
						begin
							$adjustattribute(palace,#ATTRIB_Strength, - #statue_building_limit );
							$spawnunit(palace,"statue","maxhp");
						end
				end
				
			if ((thisagent's "title" == "rangers_guild") || (thisagent's "title" == "fairgrounds") ||
				(thisagent's "title" == "temple_fervus") || (thisagent's "title" == "temple_agrela"))
				begin
					$adjustattribute(palace,#ATTRIB_Artifice, 1);
					if ($getattribute(palace,#ATTRIB_Artifice) >= #royalgardens_building_limit)
						begin
							$adjustattribute(palace,#ATTRIB_Artifice, - #royalgardens_building_limit );
							$spawnunit(palace,"royal_gardens","maxhp");
						end
				end
				
			if ((thisagent's "title" == "wizards_guild") || (thisagent's "title" == "temple_krypta") || (thisagent's "title" == "library"))
				begin
					$adjustattribute(palace,#ATTRIB_Intelligence, 1);
					if ($getattribute(palace,#ATTRIB_Intelligence) >= #arcanespire_building_limit)
						begin
							$adjustattribute(palace,#ATTRIB_Intelligence, - #arcanespire_building_limit );
							$spawnunit(palace,"arcane_spire","maxhp");
						end
				end
				//One or many of these temples are being bitches
			if ((thisagent's "title" == "temple_fervus") || (thisagent's "title" == "temple_krypta") ||
				(thisagent's "title" == "temple_dauros") || (thisagent's "title" == "temple_agrela") ||
				(thisagent's "title" == "temple_lunord") || (thisagent's "title" == "temple_helia") ||(thisagent's "title" == "temple_krolm"))
				begin
					$adjustattribute(palace,#ATTRIB_Willpower, 1);
					if ($getattribute(palace,#ATTRIB_Willpower) >= #shrine_building_limit)
						begin
							$adjustattribute(palace,#ATTRIB_Willpower, - #shrine_building_limit );
							$spawnunit(palace,"shrine","maxhp");
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function gnome_camp_birth(agent thisagent)

declare
	agent palace;
	list list1, sewers;
	integer num_sewer;

begin
	palace = $gettruepalace(thisagent);

	if ($IsValidGamePiece(palace) == True)
		begin
			$listobjects ( palace, "AutoBuilding", -1, sewers, #CheckTitles, "Sewers", #MyPlayer );
			$ListObjects(thisagent,"building",-1,list1,#MyPlayer);
			list1 = $listtitles(list1,"gnome_hovel");
	
			num_sewer = ($listsize(sewers) / 2);

			if ($isvalidgamepiece(palace))
				if ($listsize(list1) < #max_gnome_camps + num_sewer)
					if ($isrunning(palace's "gnome_camp_spawner") != TRUE)
						$runthread(palace's "gnome_camp_spawner",#gnome_camp_delay,palace);
		end
	$guild_birth(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function sanguine_pit_birth(agent thisagent)

declare
	integer time_to_spawn;

begin
	$auto_birth_red(thisagent);
	$lair_birth(thisagent);

	Time_To_Spawn = $GetAttribute (ThisAgent, #ATTRIB_Lair_BaseSpawnRate);
	time_to_spawn = $random_time(time_to_spawn);
	$SetThreadInterval (ThisAgent's "Spawn_Function", Time_To_Spawn);

	// set the built flag so that the sound isn't "under construction"
	$setattribute(thisagent,#ATTRIB_FirstStageBuilt,1);

end
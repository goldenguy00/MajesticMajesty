///////////////////////////////////////////////////////////////////////////////
function Library_Misc(agent thisagent)

declare
	agent misc, spawn;
	integer level, count;
	string book, mod_book;
	list spires, current_books;
	
begin
	if ($listsize(thisagent's "Potential_Misc") < 1)
		begin
			thisagent's "Potential_Misc" << "LostCults";
			thisagent's "Potential_Misc" << "MusingsOnTheAfterlife";
			thisagent's "Potential_Misc" << "LegendaryMonsters";
			thisagent's "Potential_Misc" << "GoblinTribesOfArdania";
			thisagent's "Potential_Misc" << "SanguineConclave";
			thisagent's "Potential_Misc" << "Futility";
			thisagent's "Potential_Misc" << "OneThousandSnowflakes";
			thisagent's "Potential_Misc" << "CommonBlood1";
			thisagent's "Potential_Misc" << "CommonBlood2";
			thisagent's "Potential_Misc" << "CommonBlood3";
			thisagent's "Potential_Misc" << "ShadowsOverArdania";
			thisagent's "Potential_Misc" << "Lunacy";
			thisagent's "Potential_Misc" << "ScionsOfChaos";
			thisagent's "Potential_Misc" << "AGnomesLife";
			thisagent's "Potential_Misc" << "TheVagrant";
			thisagent's "Potential_Misc" << "KROLM";
			thisagent's "Potential_Misc" << "VendralTheHarbinger";
			thisagent's "Potential_Misc" << "DaemonwoodForest";
			thisagent's "Potential_Misc" << "SecretsOfTheOculus";
			thisagent's "Potential_Misc" << "Lycanthropy";
			thisagent's "Potential_Misc" << "Unchained";
			thisagent's "Potential_Misc" << "DisappearanceOfTheDruids";
			thisagent's "Potential_Misc" << "DirgosFolly";
			thisagent's "Potential_Misc" << "SlumberingBeasts";
			thisagent's "Potential_Misc" << "IncompleteHistory";
		end
		
	if ($titleinagentlist("Available_Books", thisagent's "Attachments"))
		begin
			misc = $agenttitleinlist("Available_Books", thisagent's "Attachments");
			current_books = $GetBuildingContents(misc);
		end
	else
		begin
			misc = $SpawnUnit(thisagent, "Available_Books", $UnitPointWithOffset(thisagent, -75, 40));
			$setattribute(misc, #ATTRIB_FirstStageBuilt, 1);
			misc's "PrimaryStructure" = thisagent;
			thisagent's "Attachments" << misc;
		end
		
	//book = "MagicalTreatises";
	//mod_book = book;
	count = 0;
	
	
	level = 2 + (thisagent's "Level" * 3);
	
	if (level > 10)
		level = 10;
	
	if ($listsize(current_books) > 0)
		while (level > count) do
			begin
				count ++;
				mod_book = $ListMember(thisagent's "Potential_Misc", $RandomNumberNonZero($listsize(thisagent's "Potential_Misc")));
				thisagent's "Potential_Misc" -= mod_book;
				if ($titleinagentlist(mod_book, current_books) == FALSE)
					begin
						spawn = $spawnunit(misc, mod_book);
						spawn's "owned" = True;
						$Hide(spawn, misc, 1);
					end
			end
	else
		while (level > count) do
			begin
				count ++;
				mod_book = $ListMember(thisagent's "Potential_Misc", $RandomNumberNonZero($listsize(thisagent's "Potential_Misc")));
				thisagent's "Potential_Misc" -= mod_book;
				spawn = $spawnunit(misc, mod_book);
				spawn's "owned" = True;
				$Hide(spawn, misc, 1);
			end
end


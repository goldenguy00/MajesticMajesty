///////////////////////////////////////////////////////////////////////////////
function ResearchHealingPotions_Birth(agent thisagent)

declare

begin
	thisagent's "ResearchDisplayName" = "Research Healing Potions";		//Cannot be set in dat, so it must get its own function
	$ResearchSet(thisagent, "AVAILABLE");
	$Research_Birth(thisagent);					//Covers Gold and HP values for the research.
end

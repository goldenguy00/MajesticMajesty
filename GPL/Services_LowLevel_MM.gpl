///////////////////////////////////////////////////////////////////////////////
function ResearchRecruitAdditionalGuard_Check(agent thisbuilding) is boolean
declare
begin
	if (thisbuilding's "Num_Guards" < thisbuilding's "Max_Guards")
		return True;
	return False;
end	
///////////////////////////////////////////////////////////////////////////////
function ResearchRecruitAdditionalGuard_RepeatCheck(agent thisagent) is boolean
declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	if (p_structure's "Num_Guards" < p_structure's "Max_Guards")
		return True;
	return False;
end		
///////////////////////////////////////////////////////////////////////////////
function ResearchRecruitAdditionalGuard_Complete(agent thisagent)

declare
	agent p_structure;
	string max_guard;

begin
	p_structure = thisagent's "PrimaryStructure";
	max_guard = "Max_" + thisagent's "Service_Title";
	p_structure's max_guard ++;
	$GuardhouseRestartGuardSpawnThread(p_structure, 1, thisagent's "Service_Title"); //Recruit the new guard immediately, since the Research time is already a delay enough on it
	$Research_Complete(thisagent); 
end	
///////////////////////////////////////////////////////////////////////////////
function Wizard_Guild_Misc(agent thisagent)

declare
	agent misc, spawn;
	integer level, count;
	string book, mod_book;
	list spires, current_books;
	
begin
	if ($titleinagentlist("Available_Books", thisagent's "Attachments"))
		begin
			misc = $agenttitleinlist("Available_Books", thisagent's "Attachments");
			current_books = $GetBuildingContents(misc);
		end
	else
		begin
			misc = $SpawnUnit(thisagent, "Available_Books", $UnitPointWithOffset(thisagent, -100, 100));
			$setattribute(misc, #ATTRIB_FirstStageBuilt, 1);
			misc's "PrimaryStructure" = thisagent;
			thisagent's "Attachments" << misc;
		end
		
	book = "MagicalTreatises";
	mod_book = book;
	count = 0;
	
	$listobjects(thisagent,"building",-1,spires,#MyPlayer);
	spires = $listtitles(spires,"arcane_spire");
	
	level = thisagent's "Level";
	level += $listsize(spires);
	
	if (level > 5)
		level = 5;
	
	if ($listsize(current_books) > 0)
		while (level > count) do
			begin
				count ++;
				mod_book = book + $i2s(count);
				if ($titleinagentlist(mod_book, current_books) == FALSE)
					begin
						spawn = $spawnunit(misc, mod_book);
						spawn's "owned" = True;
						$Hide(spawn, misc, 1);
					end
			end
	else
		while (level > count) do
			begin
				count ++;
				mod_book = book + $i2s(count);
				spawn = $spawnunit(misc, mod_book);
				spawn's "owned" = True;
				$Hide(spawn, misc, 1);
			end
end


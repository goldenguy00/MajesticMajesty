///////////////////////////////////////////////////////////////////////////////
function ResearchSleepingQuarters_Complete(agent thisagent)

declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	p_structure's "Properties" << "Can_Rest_Here"; //Add the Can Rest Here string to the structure's Properties
	$Research_Complete(thisagent); 	
end
///////////////////////////////////////////////////////////////////////////////
function ResearchExpandedLivingQuarters_Birth(agent thisagent)

declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	thisagent's "ResearchDisplayName" = "Research Expanded Living Quarters";
	
	if ((thisagent's "ResearchCheck")(p_structure))
		$ResearchSet(thisagent, "AVAILABLE");
	else
		begin
			$ResearchSet(thisagent, "UNAVAILABLE");	
			p_structure's "Checklist" << "ResearchExpandedLivingQuarters";
		end
		
	$Research_Birth(thisagent);					
end
///////////////////////////////////////////////////////////////////////////////
function ResearchExpandedLivingQuarters_Check(agent thisBuilding) is boolean
declare

begin
	if (thisBuilding's "Level" == thisBuilding's "Max_Level")
		return True;
	return False;
end		
///////////////////////////////////////////////////////////////////////////////
function ResearchExpandedLivingQuarters_RepeatableCheck(agent thisagent) is boolean
declare

begin
	if (thisagent's "Level" < thisagent's "Max_Level")
		return True;
	return False;
end		
///////////////////////////////////////////////////////////////////////////////
function ResearchExpandedLivingQuarters_Complete(agent thisagent)

declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	$SetAttribute(p_structure,#ATTRIB_MaxGuildMembers,p_structure's "max_members");
	$Research_Complete(thisagent);
end	
///////////////////////////////////////////////////////////////////////////////
function ResearchRecruitmentQuarters_Birth(agent thisagent)

declare

begin	
	thisagent's "ResearchDisplayName" = "Research Recruitment Quarters";
	$ResearchSet(thisagent, "AVAILABLE");
	$Research_Birth(thisagent);					
end
///////////////////////////////////////////////////////////////////////////////
function ResearchRecruitmentQuarters_Complete(agent thisagent)

declare
	agent p_structure, guard;

begin
	p_structure = thisagent's "PrimaryStructure";
	p_structure's "Properties" << "Recruit_Here"; //Add the Can Rest Here string to the structure's Properties
	p_structure's "Upgrades" << $Guardhouse_RecruitTime_Upgade;
	
	foreach guard in p_structure's "Guards" do
		$Guardhouse_RecruitTime_Upgade(guard);
		
	$Research_Complete(thisagent); 	
end		
///////////////////////////////////////////////////////////////////////////////
function ResearchBarracks_Birth(agent thisagent)

declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	thisagent's "ResearchDisplayName" = "Research Barracks";
	
	thisagent's "Checklist" << "ResearchRecruitAdditionalGuard"; //Because this adds to the structure's max guard count, recruiting additional guards must be a checked by this.
	thisagent's "Checklist" << "ResearchRecruitAdditionalArcher";
	
	if ((thisagent's "ResearchCheck")(p_structure))
		$ResearchSet(thisagent, "AVAILABLE");
	else
		begin
			$ResearchSet(thisagent, "UNAVAILABLE");
			p_structure's "Checklist" << "ResearchBarracks";
		end
		
	$Research_Birth(thisagent);					
end
///////////////////////////////////////////////////////////////////////////////
function ResearchBarracks_Check(agent thisagent) is boolean
declare

begin
	if (thisagent's "Level" > 1)
		return True;
	return False;
end		
///////////////////////////////////////////////////////////////////////////////
function ResearchBarracks_Complete(agent thisagent)

declare
	agent p_structure;

begin
	p_structure = thisagent's "PrimaryStructure";
	p_structure's "Properties" << "Can_Rest_Here"; //Add the Can Rest Here string to the structure's Properties
	p_structure's "Max_Guards" += 4;
	$AdjustBaseStat(p_structure, "MaxHP", 150);
	$Research_Complete(thisagent); 	
end

///////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////
function Service_Birth(agent thisagent, string name)
//Research birth used by all researches
declare
	string fullname;
begin
	thisagent's "ServiceDisplayName" = name;
	$SpecifyIntent(thisagent, "IDTXT_RESEARCH_INSTOCK");
	fullname = "[color:999999]" + thisagent's "ServiceDisplayName";
	fullname += "[/color]";
	$SpecifyName(thisagent, fullname);
	
	$setattribute(thisagent, #ATTRIB_Gold, thisagent's "gold_value");
	$setattribute(thisagent, #ATTRIB_MaxHP, thisagent's "Service_Time");
	$setattribute(thisagent, #ATTRIB_HP, thisagent's "Service_Time_Increment");
end

///////////////////////////////////////////////////////////////////////////////
// This function looks at the passed list of structures and finds if they have the service listed
// Then it returns that list
Function List_Service (list ThisList, string Service) is list
Declare
	agent Entry;
	list 	NewList;
Begin
	Foreach Entry in ThisList do
		begin
			if ($titleinagentlist("Research", Entry's "Attachments"))
				begin
					if ($titleinagentlist(service, $GetBuildingContents($agenttitleinlist("Research", Entry's "Attachments"))))
						begin
							NewList << Entry;
						end
				end
		end

	return NewList;

End

///////////////////////////////////////////////////////////////////////////////
//For items, the hero just buys the item from the shop, it wouldn't really need any additional code since hero Task_Name should hold the item's title.
function ServiceHealingPotions_Birth(agent thisagent)
declare

begin
	$Service_Birth(thisagent, "Health Potions");					//Covers Gold and HP values for the service
end
///////////////////////////////////////////////////////////////////////////////
function ServiceManaPotions_Birth(agent thisagent)

declare

begin
	$Service_Birth(thisagent, "Mana Potions");
end

///////////////////////////////////////////////////////////////////////////////
function Guardhouse_Research(agent thisagent)

declare
	agent container;

begin
	thisagent's "Research_Loc" = $MakeCoord(30, 70);
	container = $GetResearchContainer(thisagent);
	$AddResearchItem(thisagent, "ResearchRecruitmentQuarters", container);
	$AddResearchItem(thisagent, "ResearchBarracks", container);
	$AddResearchItem(thisagent, "ResearchRecruitAdditionalGuard", container);
	$AddResearchItem(thisagent, "ResearchRecruitAdditionalArcher", container);
end

///////////////////////////////////////////////////////////////////////////////
function Marketplace_Research(agent thisagent)

declare
	agent container;

begin
	$setattribute(thisagent, #ATTRIB_ResearchHealingPotions, 1);
	thisagent's "Research_Loc" = $MakeCoord(35, 125);

	container = $GetResearchContainer(thisagent);
	$AddResearchItem(thisagent, "ResearchHealingPotions", container);
	$AddResearchItem(thisagent, "ResearchManaPotions", container);
end


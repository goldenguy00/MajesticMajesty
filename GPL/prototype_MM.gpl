	integer max_peasants;
	integer busy_peasants;
	list buildings_waiting;
	list buildings_under_construction;
	integer	Vaporized_Gold; 			// Gold that has been vapoized when heroes spend money, etc.
	integer  troll_gold; 				// Gold that is counting up to produce a troll somewhere in town
	agent Swarm_Target; 				//Holds the target that the Swarmers refer to/fill up when they want to combat wandering monsters
	function gnome_camp_spawner; 		// holds the function which spawns Gnome Camps
	Boolean Gambling_hall_building;
	boolean gazebo_building;
	integer Population_counter; 		// counts total # heroes recruited in town
	integer Waiting_population; 		// how much extras are waiting for housing
	integer num_deceased_heroes;
	integer total_buildings; 			// counts how many buildings have been built
	integer buildings_lately; 			// counts how many buildings have been built since the last sewer
	integer henchmen_dead_lately; 		// counts how many henchmen have died since last broken sewer main spawn
	integer fountain_buildings; 		// counts how many buildings towards a fountain have been buil
	integer blacksmith_trips; 			// how many visits to the blacksmith?
	integer heroes_to_upgrade; 		// how many heroes are needed to upgrade the palace
	integer	Armor;
	integer	Weapon;
	boolean gavereward;
	list heroes;
	integer charm_percentage;
	list TargetsHit; 					// Primarily used by Chain Lightning for cleanup purposes
	agent zoo_agent;


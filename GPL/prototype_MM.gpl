prototype unit ()
// Can't hold negative numbers
declare
//////////////////////////////////////////Artifact attributes///////////////
	string type;
	string subtype;
	string title;
	string Original_type;
	integer percentageHPretreat;
	float Enemy_estimation;
	float self_estimation;
	integer Greed;
	integer Loyalty;
	integer Luck;
	integer critical_chance; 		// how likely a character is to deliver a killing blow
	Boolean resist_critical; 		// does this guy resist critical hits? (reduce their damage)
	Boolean Immune_to_poison;
	Boolean rangeIncrease; 			// does this hero get a attackrange bonus per level up?
	boolean criticalIncrease; 		// does this hero get a point of critical attack per level?
	agent leader;  					// Chris hackarama so heros can be controlled monsters
	integer Counter; 				// Exactly what it says it is.
	coordinate destination;
	string special_splat; 			// does this creature need a special splat player
	agent target; 					// this holds the target for any particular task
	agent BackTarget; 				//this is for those special times when a Hero has to remember their target
	string taskname; 				// used to tell what the hero is up to
	list hostiles; 					// this is a list used by the unit to help determine
	string	Friend; 				//This holds subtype that this Hero is Friendly with
	integer num_followers; 			// used by Priestess, and probably Cultist in regards to controlled monsters
	integer max_followers;
	integer Reborn_Counter; 		//This holds how many free "go home and Ressurect"s the Healer has
	integer	Task_Number; 			//This typically holds Attrib references. For things like figuring out what a hero
	function StartingScript; 		//this holds the core start script that is inited with the agent. never change, because we rely
	function basicscript; 			// this holds the basic decision tree a hero
	function backscript;
	function activescript;			// this holds the current activity of the hero
	function evaluationScript; 		// holds the script which the hero uses to check nearby them fro danger
	function birthScript;  			// This script will be called once, when the unit is created;
	function IGdeathScript; 		// This script will be called once, when the unit is killed;
	function deathScript; 			// This script will be called once, when the unit is killed;
	agent home; 					// where the hero lives, set by the engine upon recruition
	agent palace; 					// the palace that this Hero is loyal to. set in the engine.
	boolean Raider_respond; 		// jim hackerama so heroes can become raider mosnters
	function teleportScript; 		// callback for the teleport spell
	function QuestScript; 			// This holds Quest-Specific logic
	integer castingrange;			// The distance a hero casts spells from
  	integer PrimaryStat;
	integer num_picked_goodies;		//These may be stored in the engine
	integer	Upgrade_Armor_Chance;	//The chance that a hero will decide to think about upgrading their armor
	integer	Upgrade_Weapon_Chance;	//The chance that a hero will decide to think about upgrading their weapon
	integer	Poison_Weapon_Chance;	//The chance that a hero will decide to think about poisoning their weapon
	boolean	Special_Boolean; 		//This is quest specific. For instance, in WCurse, it is TRUE if a Hooligan has been found.
	string Enemytype;				// What the agent attacks, can be "Hero", "Monster" or "Nothing"
	integer attacktype;				// The agent's attack type
	string attack_action;			// The name of the action to perform when attacking
	string special_attack_action;			// The name of the action to perform when attacking
	string cast_action;				// The name of the action to perform when casting a spell
	string Pickup_Action;			// The name of the action to perform when picking something up
	string Idle_Action;				// The name of the action to perform when going into idle
	function PlagueScript;
	function ShieldScript; 			//This is for the Frost Field spell
	boolean	Resists_Fire;
	integer	Target_Item; 			//This is for Item_Hunters (like the Black Phantoms in Magic Ring
	function SleeperScript; 		//This holds the script that calls the unit back to its lair after a duration.
	agent Sleeper_Home; 			//This is for Sleepers. It holds their agent home.
	integer	Guardian_Mod; 			//This is multiplied times a Guardian Monster's sightrange to find the area that
	boolean isLeader; 				// used by war_party logic
	coordinate	Coord_Home; 		//This holds the coord home for all monsters that use it (ie. Guardians and Offmap Sleepers)
	boolean Familiar; 				// if this is true, a monster is someone's 'familiar'
	boolean Relentless; 			// will the monster relentlessly pursue its target (ignore range cheking)
	string family; 					//This is used by buff-ing monsters, so they know which monster types to buff
	boolean in_danger; 					// has the building been hit lately
	integer Level; 						//This is what Level this building is
	integer Max_Level; 					//This is the max level the building can reach
	integer Sleep_For; 					//This holds how long a building holds Heroes for
	function visited_script; 			//holds the Building's visited function. Requested by Heroes.
	list Occupants;  					//List of all Occupants currently being held in this building
	function RevenueScript; 			//This holds the script that either Auto Adds or Subracts money from the player's gold
	integer	Revenue_Amount; 			//Either Pos or Neg, this is the amount of gold the Revenue Script adds or subtracts
	integer	Revenue_Time; 				//This is how frequently a building executes its RevenueScript
	integer Magical_Build_Rate; 		// Used to determine how fast magical buildings construct or upgrade.
	function spawn_1;  					// these are used if the building needs to spawn other buildings
	function spawn_2;  				// buildings and or units automatically when built. (Fervus uses this for spawning Monsters)
	function birthScript2;  			// This script will be called once, when the building is 'completed;
	function upgradescript;
	function upgradescript2;
	integer	History_Modifier; 		//A counter that is incremented depending on a monster's strength. Used to adjust spawn_rate.
	integer	Dispersion_Range;
	function Spawn_Function; 			// This Holds the agent's Spawning mechanism
	integer	Base_Spawn_Rate; 			// This is for lairs, it holds BaseLine interval between monster creations
	integer	difficulty; 				// this holds the relative difficulty of the lair for a character to undertake
	string Spawn_Type; 					// Holds the type of monster the lair spawns
	string Special_Spawn_Type; 			// Holds the "special" monster to spawn when the Lair is destroyed
	integer	Multi_Spawn_Num; 			// Number of spawns a lair will do when it dies if it uses Lair_Multispawn_Death
	integer  Stored_Spawns; 			// Number of spawns a lair has stored up to release when hit. Used only by Goblin fort.
	integer  Max_Simul_Spawns; 			// Currently Used by the Goblin Fortress. Max number of Gobs it spawns at a time.
	integer	Max_Stored_Spawns; 			// Currently used by the Goblin Fortress. Max number of spawns that the unit can store up
	boolean	Has_Special_Spawn; 			// This is set to TRUE if the lair wants to spawn its special spawn type instead of its
	boolean  Cleaning_Combatants ; 		// TRUE when the fair is not letting in new combatants because it is resetting
	list Combatants; 					//List of Heroes who are currently waiting for a Tourney, or on their way to the fair
	integer	Current_Contest; 			//This is the Fairgrounds current contest. It is directly informed by the ATTRIB 
	integer Current_XPLevel; 			//This is the Fairgrounds current max XP level. It is directly informed by the
	function ResetScript; 				// This function will callback and reset the fairgrounds to Fairgrounds_poll after a certain
	function Lived_In_Script; 		//Holds script that tells the character what to do here
	integer hero_lvl_upgrade; 			// minimum lvl any hero in this guild needs to be	
	list members; 						// all the current guild members
	string member_title;
	function member_basicscript;
	integer max_members;
	function SpecialScript; 		//This holds any quest-specific functionality for the guild. For instance, in
	list SpecialList; 			
	integer num_resources;
	integer	Strength;
	integer	HtoH;
	integer	Ranged;
	integer	SightRange;
	function Guard_Function;		//Guardhouse's version of an ActiveScript
	function Guard_Spawn_Function;
	list Waiting_Guards;				//This list holds Guards that have suspended their threads
	list Waiting_Guardhouses; 			//This is a list of Guardhouses that are waiting for Guards.
	list Guards;  						//List of this building's Guards
	list Under_Const_In_Sight; 			//This is the list of all Buildings Under construction within sight
	string current_gun; 				// Used for spires of death only.
	list grovelist; 					// used by the Fortress of Ixmil only.
	function spell_callback;			// special callback for spells (only used for supercharge for now)
	function tax_spawn;
	integer num_tax_collectors;
	integer max_tax_collectors;
	list tax_route;
	list tax_targets;
	list spawn_taxman_return_list; 		//These lists hold deadtax collectors tax attribs so
	list spawn_taxman_pickup_list; 		//that the next one gets spawned with the same Attribs
	integer tax_route_dead;
	function peasant_spawn;

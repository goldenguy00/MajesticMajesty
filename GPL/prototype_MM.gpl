	//Currently unknown what metric equipment uses to arrange itself, so leaving this alone for now
	
	list Equipment; //The list for the heroes equipped items.
	list Inventory; //The list for all other items.	(This list's items are not stacked in code because of Properties)
	
	list Equipment_Value;	//The list containing the Gold Value of items
	list Inventory_Value;
	
//	list Equipment_Properties;	//The list containing the functions of the item to be applied to the hero if equipped or removed if unequipped
//	list Inventory_Properties;	//Unnecessary until proper arrangement of inventory can be applied
	
//	list Equipment_CurrentLevel;	//The list containing the current level of items. Properties like enchantments affect current level.
//	list Inventory_CurrentLevel;	//Unnecessary until proper arrangement of inventory can be applied
	
//	list Equipment_PotentialLevel;	//The list containing the potential level of items.
//	list Inventory_PotentialLevel;	//Unnecessary until proper arrangement of inventory can be applied
	
	string Equipment_RightHand;		
	string Equipment_LeftHand;			//Just do a check to see is the Left Hand value is equal to the Right hand to see if Both hands are used on the same object.
	string Equipment_BodyArmor;
	
	string Equipment_RightHandType;		//Type of equipment (Sword/Axe/Bow)
	string Equipment_LeftHandType;
	string Equipment_BodyArmorType;		
	string Equipment_HeadType;			
	string Equipment_BeltType;			
	string Equipment_GlovesType;		
	string Equipment_BootsType;			
	
	string Starting_Equipment_1;
	string Starting_Equipment_2;
	string Starting_Equipment_3;		
	
	integer RightHandLevel;		//Used to be BS_WeaponLevel
	integer BodyArmorLevel;		//Used to be BS_BodyArmorLevel
	integer EN_WeaponLevel;
	integer EN_BodyArmorLevel;
	
	string ItemDrop1;
	string ItemDrop2;
	string ItemDrop3;
	string ItemDrop4;
	string ItemDrop5;
	string ItemDrop6;
	string ItemDrop7;
	string ItemDrop8;
	string ItemDrop9;
	string ItemDrop10;
	
	integer ItemDropChance1;
	integer ItemDropChance2;
	integer ItemDropChance3;
	integer ItemDropChance4;
	integer ItemDropChance5;
	integer ItemDropChance6;
	integer ItemDropChance7;
	integer ItemDropChance8;
	integer ItemDropChance9;
	integer ItemDropChance10;
	
	/////////////////////////////////////////Misc Attributes///////////////
	list Upgrades;					//A list holding functions for upgrades applied to this unit on birth
	
	integer num_guards; 			// Total number of guard slots used by this structure (not the current number of living guards, but the number of guard positions already assigned
	integer	Max_Guards; 				//Holds the Maximum number of Guards slots available at a guardhouse
	
	integer num_City_Guard;
	integer Max_City_Guard;
	integer num_Archer;
	integer Max_Archer;
	
	integer Recruit_Time; 		// Time to recruit this unit (hero or henchmen)
	
	boolean Uses_Equipment;
	boolean Attack_Damage_Based_On_Weapon;
	
	integer Unit_Magic_Find; //Can be used on structures as well for various purposes.
	integer Unit_Days_Active;
	integer Unit_Size_X;
	integer Unit_Size_Y;
	integer Unit_Size_Z;
	string Unit_Shape; //If structure, Spherical, Conical, Square. If unit, humanoid, insectoid, etc.
	integer Unit_Age;
	integer Unit_Mass;
	integer Unit_Inventory_Capacity;
	integer Unit_Inventory_CurrentWeight;
	integer Unit_Inventory_MaxWeight;
	string Unit_Race;
	string Unit_Gender;
	string Unit_Allegiance;
	string Unit_Composition1; // Things like what the unit is made of (Rock Golem made from Rock)
	string Unit_Composition2;
	string Unit_Composition3;
	string Unit_Composition4;
	string Unit_Composition5;
	string Unit_Percent_Composition1; // How much of the unit's overall mass is encompassed by this particular composition (Rock Golem is 99% Rock)
	string Unit_Percent_Composition2;
	string Unit_Percent_Composition3;
	string Unit_Percent_Composition4;
	string Unit_Percent_Composition5;
	integer Hunger;
	integer Thirst;
	integer Exhaustion;
	integer Fear;
	
	integer Units_Killed;
	integer Monsters_Killed;
	integer Heroes_Killed;
	integer Buildings_Razed;
	integer Lairs_Razed;
	integer Total_Kills;
	
	string IntentExt;
	string Unit_Type; // Building or Unit
	string Unit_Subtype; // Hero, Henchman, Monster, Peasant, Lair, Guild, Temple, Market, Etc.
	integer Unit_Type_Variance;
	function Unit_Type_Attributes; // To assign additional attributes to the unit
	
	function Unit_Type_Death; // Remove the unit from the game properly
	
	function Prepared_Task; //A task the structure prepared for the hero on their birth.
	
	function Initial_Misc; //Any objects that are added to the Available Misc List on the birth of the structure.
	function Initial_Research; //Upgrades that are added to the Available Upgrade List on the birth of the structure.
	
	list Attachments; //The list for structures that have attachments on them (Help Signs or Available Upgrades)
	list Available_Misc; //The list of miscellanious objects available at a structure to add to the list of their attachments.
	list Available_Research; //The list of upgrades available at a structure to add to the list of their attachments.
	
	list Potential_Misc; //The list of miscellanious objects that can potentially become available (Potential list of library books to choose from to create an available list)
						//Potential_Misc is a list of strings.
	list Books_Read; //The list of books that the agent has already read.
	
	list Properties;	//Miscellanious properties a unit can contain  (like Can_Rest_Here for structures) Properties listed must be strings
	
	list Checklist;			//The list for all Research titles in the structure that had this structure as a Requirement to now check for.
	
	boolean Is_Researching; //For whether or not a structure is doing Research
	agent research_text;	//The research text assosciated with the structure
	coordinate research_loc;	//The coordinate for the research text to display relative to the structure.
	
	begin
	end

///////////////////////////////////////////////////////////////////////////////
prototype Loot_Item()
Declare
	boolean owned;
	
	string type;
	string subtype;
	string title;
	string IntentExt;

	integer gold_value;

	function transferScript;  	// This script will be called when the item is transfered to its new owner.
	function birthScript;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;

begin
end

///////////////////////////////////////////////////////////////////////////////
//Convert books that are used for reading into Services, not items
prototype Book_Item()
Declare
	boolean owned;
	
	string type;
	string subtype;
	string title;
	string IntentExt;

	integer gold_value;
	integer XP_value; //Experience gained from reading this book
	integer XPMultiplier; //The Level of experience gained from the book being read.

	function transferScript;  	// This script will be called when the item is transfered to its new owner.
	function birthScript;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Research()
Declare
	string type;
	string subtype;
	string title;
	string IntentExt;

	string ResearchStatus;		//Is it Complete(Green), Available(Blue), Unavailable(Red), Researching(Yellow)
	string ResearchDisplayName;		//The string name for the Research when applying specify name changes to reflect status
									//The string name must be set in a function, not in .dat
	
	string ResearchVoice;		//The advisor voice to use for this research
	
	string Service_Title;		//If a service is assosciated with the research, then it's title is used to spawn the service at the corresponding attachment. If no service_title is listed, then use "None"
	string Service_Type;		//Item or Unit (If an item, it becomes a part of the Service menu, if a unit like a City Guard, it is used as the guard spawn type
	
	integer gold_value;			//The gold cost of the Research
	integer Research_Time;		//The time it takes for the research to complete
	integer Level;				//The Level of Research if it can have multiple levels (Blacksmith equipment upgrades for example)
	integer Max_Level;			//The max Level a research can reach
	
	list Checklist;			//The list for all Research titles in the same structure that had this research as a Requirement to now check for.

	function birthScript;  	// This script is a dummy call, since you don't necessarily want it triggered right when it spawns
	function birthScript2;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;
	function DismissScript; 	// Function to call when the research is attempted (The Dismiss Hero button in this case)
	function ResearchCompleteScript;	//The function to call when the research is complete
	function ResearchCheck;
	
	string Increment;			//The attribute this research increments on completion
	integer Increment_Amount;			//The amount to increase by
	
	boolean Repeatable;			//Is the research repeatable, still requires passing it's ResearchCheck
	function RepeatableCheck;		//Determine if the research should be labelled as Complete or Unavailable depending on this check.
	
	agent Container;			//The container object for this Research item
	agent PrimaryStructure;		//The structure that holds the container object. The Primary Building that the research is occurring at
	
	agent ResearchText;		//The floating text research assosciated with this agent

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Service() //For available service agents available at structures (Potions in Marketplace)
					//Can NOT double as items!!!
					//Sequence of events: Hero checks shop -> Looks at Services -> Active script set to use_building, Task_Name given by Service looked at (for this case, it's the service "Title"
					//Hero enters building -> Task_Name correlates to Service in list from which hero determines duration at structure, gold costs, and items gained.
Declare
	string type;
	string subtype;
	string title;
	string IntentExt;
	
	string service_title;			//If an item service, this corresponds to the item's title

	string ServiceDisplayName;		//The string name for the Service when applying specify name changes to reflect status
									//The string name must be set in a function, not in .dat
	
	integer gold_value;					//The gold cost of the Service for heroes
	integer Service_Time;				//The time it takes for the service to be handled for the hero
	integer Service_Time_Increment;		//The additional time if the service has been multi-purchased (buying multiple potions instead of one)
	integer Level;						//The Level of the service if applicable
	
	list Requirements;					//The requirements for the Service in order for a hero to use it.
	list Hero_Preference;				//The heroes that prefer this service.

	function birthScript;  				//This script will be called once, when the unit is created;
	function birthScript2;  	// This script will be called once, when the unit is created;
	function deathScript; 				//This script will be called once, when the unit is killed;
	function IGDeathScript;
	function DismissScript; 			//Respawns the service if it ends up being dismissed
	function ServiceCheckScript;		//The function to call when the service is being checked for by the hero (the Conditions for the service to be used)
	
	agent Container;					//The container object for this Service
	agent PrimaryStructure;				//The structure that holds the container object. The Primary Building that the service is occurring at

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype FloatingText()
Declare
	string type;
	string subtype;
	string title;

	string text;
	integer duration;			//The total amount of time needed to pass
	integer duration_current; 	//The amount of time currently passed
	integer update_counter;		//The counter for when to update the floating text display (should reset at 3, approximately 1500 miliseconds)
								//Update_Counter really only useful for Research % display
	list Research_Queue;			//The list for researches that are queued for this text
	
	integer gold_value;					//The gold cost for any research incurred for floating text
	
	function birthScript;  	// This script will be called once, when the unit is created
	function deathScript; 	// This script will be called once, when the unit is killed
	function textScript;  	// This script will periodically update the text for research
	function callbackScript; 	// This script will be called when the text duration ends
	
	agent research;			//The research that was dismissed to call the floating text if applicable
	
	agent target;			//The target agent for the floating text to use as a reference (The primary structure)
	coordinate loc;		//The location of the text if there is no target
	
	boolean target_linked;	//For whether the text relies on the target being valid in order to continue being run
	boolean target_locked;	//For whether the text updates and moves with the target while running

	boolean is_research;	//For whether the floating text is a Research text
begin
end


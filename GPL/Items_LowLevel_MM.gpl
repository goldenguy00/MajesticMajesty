///////////////////////////////////////////////////////////////////////////////
function HeroStartingEquipment(agent thisagent)

declare
	agent itemagent;
	string unit_name, starting_weapon, starting_armor, starting_item1;

begin
	unit_name = thisagent's "Title";
	
	if (thisagent's "Starting_Equipment_1" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_1");
	if (thisagent's "Starting_Equipment_2" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_2");
	if (thisagent's "Starting_Equipment_3" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_3");
end
///////////////////////////////////////////////////////////////////////////////
function Death_Item_Drops(agent thisagent)

declare
	string item, agentType;

begin
	$Death_Item_Drops_Process(thisagent, "ItemDrop1", "ItemDropChance1");
	$Death_Item_Drops_Process(thisagent, "ItemDrop2", "ItemDropChance2");
	$Death_Item_Drops_Process(thisagent, "ItemDrop3", "ItemDropChance3");
	$Death_Item_Drops_Process(thisagent, "ItemDrop4", "ItemDropChance4");
	$Death_Item_Drops_Process(thisagent, "ItemDrop5", "ItemDropChance5");
	$Death_Item_Drops_Process(thisagent, "ItemDrop6", "ItemDropChance6");
	$Death_Item_Drops_Process(thisagent, "ItemDrop7", "ItemDropChance7");
	$Death_Item_Drops_Process(thisagent, "ItemDrop8", "ItemDropChance8");
	$Death_Item_Drops_Process(thisagent, "ItemDrop9", "ItemDropChance9");
	$Death_Item_Drops_Process(thisagent, "ItemDrop10", "ItemDropChance10");
end

///////////////////////////////////////////////////////////////////////////////
function Death_Item_Drops_Process(agent thisagent, string itemdrop, string itemdropchance)

declare
	string agentType;

begin
	if ($HasAttribute(itemdrop, thisagent) == false)
		return;
	
	if ((thisagent's itemdropchance) >= $RandomNumberNonZero(#Item_Chance_Limit))
		begin
			agentType = $GetInventoryItemAgentType(thisagent's itemdrop);
			$SpawnUnit (thisAgent, agentType, "Override", $Concatenate($MakeInventoryAttribute(thisagent's itemdrop), 0) );
		end
end

///////////////////////////////////////////////////////////////////////////////
function Equipment_Item_Birth(agent thisagent)

declare
	string title;
	integer stack;

begin
	title = thisagent's "Title";
	$AddAttribute(thisAgent, title, "integer", 0);
	
	$SetDrawEffects( thisagent, "gray", 1 );
end

///////////////////////////////////////////////////////////////////////////////
function Stack_Item_Birth(agent thisagent)

declare
	integer despawn_time;
	string title;
	integer stack;

begin
	title = thisagent's "Title";
	if ($AddAttribute(thisAgent, title, "integer", 1) == false)
		begin
			stack = thisagent's title;
			if (stack < 1)
				thisagent's title = 1;		
		end

	$AddAttribute(thisAgent, "TransferScript", "function", $Basic_Stack_Transfer);
	$SetDrawEffects( thisagent, "gray", 1 );
	
	// prevent loot pile up
	if (thisagent's "Type" == "Loot" && $HasAttribute("gold_value", thisagent))
		begin
			despawn_time = (60 + thisagent's "gold_value") * 1000;
			$AddAttribute(thisagent, "DespawnTimer", "function", $DespawnTimer);
			$RunThread(thisagent's "DespawnTimer", despawn_time, thisagent);
		end
end

function DespawnTimer(agent thisagent)
declare
begin
	$DeleteGamePiece(thisagent);
end

////////////////////////////////////////////////////////////////////////////////////////////////////////
function Basic_Stack_Transfer(agent Item, agent Hero, integer attributeID)
// This will get called with someone has picked up the special item and put it in their inventory.
declare
	integer	stack;
	string  itemname;

begin
	if (Hero != $NullAgent ())
		begin
			itemname = Item's "Title";
			if ($HasAttribute(itemname, Item))
				begin
					stack = Item's itemname;
					
					if (stack == 0)
						stack = 1;
					$AdjustIntegerSafe(hero, itemname, stack);
				end
		end
	
end

///////////////////////////////////////////////////////////////////////////////
function CreateAndEquipItem(agent thisagent, string item)

declare
	agent itemagent;

begin
	if (item == "Nothing" || item == "")
		return;
	itemagent = $SpawnUnit (thisAgent, $GetInventoryItemAgentType(item), "Override", $Concatenate($MakeInventoryAttribute(item), 0) ); //Creates the item on the ground to apply its .dat attributes to the unit
	itemagent's "Owned" = True;
	(itemagent's "TransferScript")(itemagent, ThisAgent, -1);
	if ($IsValidGamePiece(itemagent))
		$DeleteGamePiece (itemagent);
end
///////////////////////////////////////////////////////////////////////////////
function UpgradeAndEquipItem(agent thisagent, string item, string equipment_slot, integer num_enchant, integer num_upgrade)

//item = Short Sword, num_upgrade = 1, equipment_slot = Equipment_RightHand
declare
	agent itemagent;
	
begin
	if (item == "Nothing" || item == "")
		return;
	itemagent = $SpawnUnit (thisAgent, $GetInventoryItemAgentType(item), "Override", $Concatenate($MakeInventoryAttribute(item), 0) );
	itemagent's "Owned" = True;
	itemagent's "num_enchant" = num_enchant;
	itemagent's "num_upgrade" = num_upgrade;
	(itemagent's "TransferScript")(itemagent, ThisAgent, -1);
	if ($IsValidGamePiece(itemagent))
		$DeleteGamePiece (itemagent);
end

////////////////////////////////////////////////////////////////////////////////////////////////////////
function Basic_Equipment_Transfer(agent Item, agent Hero, integer attributeID)
// This will get called with someone has picked up an equipment item and put it in their inventory.
declare
	string itemname, equip_name,  subclass, equip_slot, subtype, upgrade_increase;
	integer	upgrade_level, num_upgrade, num_enchant;

	string equip_slot_type;
	integer held_equip_level;

	string s_held_equip_level, s_held_equip_en_level, s_held_equip_slot, s_held_equip_type, held_equip;

	boolean should_equip;
	integer stack;
	
begin
	if (Hero == $NullAgent ())
		return;
	
	// item properties
	itemname = Item's "Title";						// WoodenStaff, Crossbow
	equip_name = itemname + "EQ";					// WoodenStaffEQ, CrossbowEQ
	subclass = Item's "Subclass";					// Sword, Bow, - Heavy, Light
	equip_slot = Item's "Equip_Slot";				// RightHand, BodyArmor
	subtype = Item's "Subtype"; 					// weapon, armor
	upgrade_increase = Item's "upgrade_increase";	// WitheredStaff, HeavyCrossbow, nothing
	upgrade_level = Item's "Upgrade_Level"; 		// 0-3 static item tier
	num_upgrade = Item's "num_upgrade";				// 0-3 target tier	
	num_enchant = Item's "num_enchant";				// 0-3 target tier
	stack = $GetIntegerSafe(item, itemname);

	// attribute strings
	s_held_equip_level = equip_slot+"Level";			// RightHandLevel
	s_held_equip_en_level = "EN_"+equip_slot+"Level";	// EN_RightHandLevel
	s_held_equip_slot = "Equipment_"+equip_slot;		// Equipment_RightHand
	s_held_equip_type = "Equipment_"+equip_slot+"Type";	// Equipment_RightHandType, Equipment_BodyArmorType

	// hero properties
	held_equip = $GetStringSafe(hero, s_held_equip_slot);
	held_equip_level = $GetIntegerSafe(hero, s_held_equip_level);
	equip_slot_type = $GetStringSafe(Hero, s_held_equip_type);
	
	if (num_upgrade > 0)
		begin
			num_upgrade -= 1;
			$DeleteGamePiece (Item);
			$UpgradeAndEquipItem(Hero, upgrade_increase, equip_slot, num_enchant, num_upgrade);
			return;
		end

	// can they weild this?
	should_equip = false;
	if (equip_slot_type == subclass)
		begin
			// has better item?
			if (held_equip == "Nothing")
				should_equip = true;
			else if (held_equip_level < upgrade_level)
				should_equip = true;
		end

	if (should_equip == false)
		begin
			if (stack < 1)
				stack = 1;

			$AdjustIntegerSafe(Hero, itemname, stack);

			$TransferInventoryItem (-1, item, hero);
			$DeleteGamePiece (Item);
			return;
		end
	
	// attempt to unequip current, move to inventory
	$UnequipItemSlot(Hero, s_held_equip_slot);

	// add new EQ version
	$CreateNewInventoryItem(equip_name, Hero, 1);
	$SetStringSafe(Hero, s_held_equip_slot, itemname);
	$SetIntegerSafe(Hero, s_held_equip_level, Upgrade_Level);
	$SetIntegerSafe(Hero, s_held_equip_en_level, num_enchant);
	
	// give new stats
	$EquipArmor(Hero, Item);

	// blacksmith bonuses
	if (equip_slot == "RightHand")
		begin
			$EquipWeapon(Hero, Item);

			$setattribute(Hero,#ATTRIB_weapon_struct_bonus,upgrade_level);
			$setattribute(Hero,#ATTRIB_weapon_magic_bonus,num_enchant);
		end
	else if (equip_slot == "BodyArmor")
		begin
			$setattribute(Hero,#ATTRIB_armor_struct_bonus,upgrade_level);
			$setattribute(Hero,#ATTRIB_armor_magic_bonus,num_enchant);
		end

	$DeleteGamePiece(item);
end


///////////////////////////////////////////////////////////////////////////////
function UnequipItemSlot(agent thisagent, string equip_slot)

declare
	string equipment_item, inventory_item;
	string held_equip_level, held_equip_en_level;
	integer armor, mr;

begin
	inventory_item = $GetStringSafe(thisagent, equip_slot);
	$SetStringSafe(thisagent, equip_slot, "Nothing");
	if (inventory_item == "Nothing")
		return;

	equipment_item = inventory_item + "EQ";
	if ($AgentHasInventoryItem(equipment_item, thisagent) == true)
		$DeleteInventoryItem(equipment_item, thisagent);

	if ($AgentHasInventoryItem(inventory_item, thisagent) == false)
		$CreateNewInventoryItem(inventory_item, thisagent, 1);
			
	$AdjustIntegerSafe(thisagent, inventory_item, 1);

	armor = $GetIntegerSafe(thisagent, "Armor_Physical_"+equip_slot);
	mr = $GetIntegerSafe(thisagent, "Armor_Magical_"+equip_slot);

	if (armor != 0)
		begin
			$AdjustIntegerSafe(thisagent, "Armor_Physical_Flat", (0 - armor));
			thisagent's ("Armor_Physical_"+equip_slot) = 0; 
			$UpdateArmor_Physical(thisagent);
		end

	if (mr != 0)
		begin
			$AdjustIntegerSafe(thisagent, "Armor_Magical_Flat", (0 - mr));
			thisagent's ("Armor_Magical_"+equip_slot) = 0;
			$UpdateArmor_Magical(thisagent);
		end
end

///////////////////////////////////////////////////////////////////////////////
function UpgradeEquipment(agent thisagent, string equip_slot, integer upgrade)

declare
	string inventory_item, held_equip_level, held_equip_en_level;
	integer held_upgrade, upgrade_adjust, held_enchant;

begin
	// blacksmith bonuses
	if (equip_slot == "RightHand")
		$setattribute(thisagent,#ATTRIB_weapon_magic_bonus,upgrade);
	else if (equip_slot == "BodyArmor")
		$setattribute(thisagent,#ATTRIB_armor_magic_bonus,upgrade);

	inventory_item = $GetStringSafe(thisagent, equip_slot);
	if (inventory_item == "Nothing")
		return;
	
	held_equip_level = equip_slot+"Level";	// RightHandLevel
	held_equip_en_level = "EN_"+equip_slot+"Level";	// EN_RightHandLevel
	held_upgrade = $GetIntegerSafe(thisagent, held_equip_level);
	held_enchant = $GetIntegerSafe(thisagent, held_equip_en_level);

	upgrade_adjust = upgrade - held_upgrade;
	$UpgradeAndEquipItem(thisagent, inventory_item, equip_slot, held_enchant, upgrade_adjust);
end

///////////////////////////////////////////////////////////////////////////////
function EnchantEquipment(agent hero, string equip_slot, integer num_enchant)

declare
	string held_equip_en_level;

begin
	// blacksmith bonuses
	if (equip_slot == "RightHand")
		$setattribute(Hero,#ATTRIB_weapon_magic_bonus,num_enchant);
	else if (equip_slot == "BodyArmor")
		$setattribute(Hero,#ATTRIB_armor_magic_bonus,num_enchant);
		
	held_equip_en_level = "EN_"+equip_slot+"Level";	// EN_RightHandLevel
	$SetIntegerSafe(hero, held_equip_en_level, num_enchant);
end

///////////////////////////////////////////////////////////////////////////////
function EquipWeapon(agent thisagent, agent item)

declare
	string physical_damage_type, magical_damage_type;
	integer physical_damage, magical_damage;

begin
	if ($GetBooleanSafe(thisagent, "Attack_Damage_Based_On_Weapon") == false)
		return;
	
	physical_damage = item's "Physical_Damage";
	physical_damage_type = $GetStringSafe(item, "Physical_Damage_Type");
	thisagent's "Physical_Attack" = physical_damage;
	thisagent's "Physical_Attack_Type" = physical_damage_type;

	magical_damage = item's "Magical_Damage";
	magical_damage_type = $GetStringSafe(item, "Magical_Damage_Type");
	thisagent's "Magical_Attack" = magical_damage;
	thisagent's "Magical_Attack_Type" = magical_damage_type;
	$SetAttribute(thisagent, #ATTRIB_Weapon_Basic_Damage, physical_damage + magical_damage);
end

///////////////////////////////////////////////////////////////////////////////
function EquipArmor(agent thisagent, agent item)
declare
	integer armor, mr;
	string equip_slot;
begin
	equip_slot = Item's "Equip_Slot";
	armor = $GetIntegerSafe(item, "Physical_Armor_Value");
	mr = $GetIntegerSafe(item, "Magical_Armor_Value");
	
	if (armor != 0)
		begin
			$AdjustIntegerSafe(thisagent, "Armor_Physical_Flat", armor);
			$SetIntegerSafe(thisagent, "Armor_Physical_"+equip_slot, armor);
			$UpdateArmor_Physical(thisagent);
		end

	if (mr != 0)
		begin
			$AdjustIntegerSafe(thisagent, "Armor_Magical_Flat", mr);
			$SetIntegerSafe(thisagent, "Armor_Magical_"+equip_slot, mr);
			$UpdateArmor_Magical(thisagent);
		end
end
///////////////////////////////////////////////////////////////////////////////
function Item_Stack(agent thisagent, agent target )

declare
	list items;
	string item, itemtype;

begin
	$Item_Stack_Process(thisagent, target, "ItemDrop1", "ItemDropChance1");
	$Item_Stack_Process(thisagent, target, "ItemDrop2", "ItemDropChance2");
	$Item_Stack_Process(thisagent, target, "ItemDrop3", "ItemDropChance3");
	$Item_Stack_Process(thisagent, target, "ItemDrop4", "ItemDropChance4");
	$Item_Stack_Process(thisagent, target, "ItemDrop5", "ItemDropChance5");
	$Item_Stack_Process(thisagent, target, "ItemDrop6", "ItemDropChance6");
	$Item_Stack_Process(thisagent, target, "ItemDrop7", "ItemDropChance7");
	$Item_Stack_Process(thisagent, target, "ItemDrop8", "ItemDropChance8");
	$Item_Stack_Process(thisagent, target, "ItemDrop9", "ItemDropChance9");
	$Item_Stack_Process(thisagent, target, "ItemDrop10", "ItemDropChance10");
end

///////////////////////////////////////////////////////////////////////////////
function Item_Stack_Process(agent thisagent, agent target, string itemdrop, string itemdropchance )

declare
	agent itemagent;

begin
	if ($HasAttribute(itemdrop, thisagent) != True || $HasAttribute("Total_Item_list", target) == false)
		return;
	else if ((thisagent's itemdropchance) >= $RandomNumberNonZero(#Item_Chance_Limit))
		begin
			$createeffector(target,"got_item",0);
			if ($AgentHasInventoryItem(thisagent's itemdrop, target) != True)
				begin
					$CreateNewInventoryItem(thisagent's itemdrop, target, 1);
					$AddAttribute(target, thisagent's itemdrop, "integer");
					itemagent = $SpawnUnit (thisAgent, $GetInventoryItemAgentType(thisagent's itemdrop), "Override", $Concatenate($MakeInventoryAttribute(thisagent's itemdrop), 0) );
					if (itemagent's "Type" == "Loot")
						begin
							if ($StringInList(thisagent's itemdrop, target's "Loot_Item_List") == False)
								begin
									target's "Loot_Item_List" << thisagent's itemdrop;
									target's "Loot_Item_Value_List" << itemagent's "Gold_Value";
								end
							if ($StringInList(thisagent's itemdrop, target's "Total_Item_List") == False)
								begin
									target's "Total_Item_List" << thisagent's itemdrop;
								end
						end
					else if (itemagent's "Type" == "Equipment")
						begin
							if ($StringInList(thisagent's itemdrop, target's "Loot_Item_List") == False)
								begin
									target's "Equipment_Item_List" << thisagent's itemdrop;
									target's "Equipment_Item_Value_List" << itemagent's "Gold_Value";
								end
							if ($StringInList(thisagent's itemdrop, target's "Total_Item_List") == False)
								begin
									target's "Total_Item_List" << thisagent's itemdrop;
								end
						end
					$DeleteGamePiece(itemagent);
					target's (thisagent's itemdrop) += 1;
				end
			else
				begin
					target's (thisagent's itemdrop) += 1;
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function Drop_All_Stack_Items(agent thisAgent)
declare
	integer	item, stack;
	string  agentType, itemname;
	list	items;
	agent dropped_item;
	list loot_on_ground;
	integer loot_dropped;
	
begin
	//$UnequipItemSlot(thisagent, "Equipment_RightHand");
	//$UnequipItemSlot(thisagent, "Equipment_BodyArmor");
	
	items = $GetInventoryItems(thisAgent);
	loot_dropped = $ListObjects(thisagent, "loot", 200, loot_on_ground);
	foreach item in items do
		begin
			if (loot_dropped < 5)
			if ($GetInventoryItemDropType(item) >= 3 && $RandomNumber(100) > 30)
				begin
					loot_dropped++;
					agentType = $GetInventoryItemAgentType(item);
					dropped_item = $SpawnUnit (thisAgent, agentType, "Override", $Concatenate($MakeInventoryAttribute(item), 0) );
					itemname = dropped_item's "Title";
					
					if ($HasAttribute(itemname, thisagent)!=False)
						begin
							stack = thisagent's itemname;
							$AddAttribute(dropped_item, itemname, "integer", stack);
						end
					$DeleteInventoryItem(item, thisAgent);
				end
		end
end
///////////////////////////////////////////////////////////////////////////////
function Drop_All_Stacks_Equipment_Process(agent thisAgent, string unequipname)

declare
	agent dropped_item;
	integer stack;
	string equipname, agentType, itemname;

begin
	if (unequipname != "Nothing")
		begin
			equipname = unequipname + "EQ";
			agentType = $GetInventoryItemAgentType(unequipname);
			dropped_item = $SpawnUnit (thisAgent, agentType, "Override", $Concatenate($MakeInventoryAttribute(unequipname), 0) );
			itemname = dropped_item's "Title";
			
			if ($HasAttribute(itemname, thisagent)!=False)
				begin
					stack = thisagent's itemname;
					$AddAttribute(dropped_item, itemname, "integer", stack);
				end
					
			$DeleteInventoryItem(equipname, thisAgent);
		end
end
///////////////////////////////////////////////////////////////////////////////
// A special function to drop only items that are marked as immediate drop.
function Drop_Immediate_Items(agent thisAgent)
declare
	integer	item;
	string  agentType;
	list	items;
begin
	
	items = $GetInventoryItems(thisAgent);

	foreach item in items do
		begin
			if ($GetInventoryItemDropType(item) == 2)
				begin
					// Get what type of agent the inventory item will be while it exists on the map
					agentType = $GetInventoryItemAgentType(item);
					// Create the item, adding a copy of its type to its attibute list for the inventory system to use.
					$SpawnUnit (thisAgent, agentType, "Override", $Concatenate($MakeInventoryAttribute(item), 0) );
					// Delete the item from their inventory
					$DeleteInventoryItem(item, thisAgent);
				end				
		end
end
///////////////////////////////////////////////////////////////////////////////
function Total_Loot_Value(agent thisagent) is integer

declare
	agent itemagent;
	list item_list, item_value_list;
	string item, thisstring;
	integer stack_multplier, item_value, loot_value, loot_size, i;

begin
	if ($HasAttribute("Loot_Item_list", thisagent) == false)
		return 0;

	item_list = thisagent's "Loot_Item_List";
	item_value_list = thisagent's "Loot_Item_Value_List";
	loot_size = $ListSize(item_list);
	while (loot_size > i) do
		begin
			i ++;
			thisstring = $listmember(item_list,i);
			item_value = $listmember(item_value_list,i);
			loot_value += (thisagent's thisstring * item_value);
		end
		
	return loot_value;
end


function Total_Equipment_Value_BlacksmithAdjust(agent thisagent, agent blacksmith) is integer

declare
	list item_list, item_value_list;
	string item, thisstring;
	integer stack_multplier, item_value, equipment_value, equipment_size, i;

begin
	equipment_value = 0;
	
	if ($HasAttribute("Equipment_Item_List", thisagent) == false)
		return 0;
		
	item_list = thisagent's "Equipment_Item_List";
	item_value_list = thisagent's "Equipment_Item_Value_List";
	equipment_size = $ListSize(item_list);
	while (equipment_size > i) do
		begin
			i ++;
			thisstring = $listmember(item_list,i);
			item_value = $listmember(item_value_list,i);
			//equipment_value += (thisagent's thisstring * item_value);
			if ($AgentHasInventoryItem(thisstring, thisagent) != False)
				equipment_value += $Item_Sell_Value_BlacksmithAdjust(thisagent, blacksmith, thisstring, item_value);
		end
		
	return equipment_value;

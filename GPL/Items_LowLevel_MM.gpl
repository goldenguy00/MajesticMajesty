///////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////

///////////////////////////////////////////////////////////////////////////////
function HeroStartingEquipment(agent thisagent)

declare
	agent itemagent;
	string unit_name, starting_weapon, starting_armor, starting_item1;

begin
	unit_name = thisagent's "Title";
	
	if (thisagent's "Starting_Equipment_1" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_1");
	if (thisagent's "Starting_Equipment_2" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_2");
	if (thisagent's "Starting_Equipment_3" != "Nothing")
		$CreateAndEquipItem(thisagent, thisagent's "Starting_Equipment_3");
end
///////////////////////////////////////////////////////////////////////////////
function Item_Equipped_Weapon_Damage(agent thisagent, agent item)

declare
	string min_d, max_d;

begin

	//if ($IsWeaponEquipped(thisagent) != True)
	if (thisagent's "Attack_Damage_Based_On_Weapon" != True)
		return;
		
	min_d = item's "damage_type_1" + "_Attack_Damage_Min";
	max_d = item's "damage_type_1" + "_Attack_Damage_Max";
	
	if (min_d == "_Attack_Damage_Min")
		return;

	thisagent's min_d = item's "damage_min_1";
	thisagent's max_d = item's "damage_max_1";
	
	min_d = item's "damage_type_2" + "_Attack_Damage_Min";
	max_d = item's "damage_type_2" + "_Attack_Damage_Max";
	
	if (min_d == "_Attack_Damage_Min")
		return;
		
	thisagent's min_d = item's "damage_min_2";
	thisagent's max_d = item's "damage_max_2";
	
	min_d = item's "damage_type_3" + "_Attack_Damage_Min";
	max_d = item's "damage_type_3" + "_Attack_Damage_Max";
	
	if (min_d == "_Attack_Damage_Min")
		return;
		
	thisagent's min_d = item's "damage_min_3";
	thisagent's max_d = item's "damage_max_3";
	
end

///////////////////////////////////////////////////////////////////////////////
function Item_Equipped_Armor_Amount(agent thisagent, agent item)

declare

begin
	if (item's "armor_type_1" == "Nothing")
		return;
	thisagent's (item's "armor_type_1") = item's "armor_1";
		
	if (item's "armor_type_2" == "Nothing")
		return;
	thisagent's (item's "armor_type_2") = item's "armor_2";
		
	if (item's "armor_type_3" == "Nothing")
		return;
	thisagent's (item's "armor_type_3") = item's "armor_3";
	
end

///////////////////////////////////////////////////////////////////////////////
function Item_Equipped_Attributes(agent thisagent, agent item)

declare
	string effect1, effect2, effect3;
		
begin
	if (item's "effect_type_1" != "Nothing")
		begin
			effect1 = item's "effect_type_1";
			thisagent's effect1 += item's "effect_1";
			(Item's "Update_1")(thisagent);	
		end
	else
		return;
	
	if (item's "effect_type_2" != "Nothing")
		begin
			effect2 = item's "effect_type_2";
			thisagent's effect2 += item's "effect_2";
			(Item's "Update_2")(thisagent);	
		end
	else
		return;
		
	if (item's "effect_type_3" != "Nothing")
		begin
			effect3 = item's "effect_type_3";
			thisagent's effect3 += item's "effect_3";
			(Item's "Update_3")(thisagent);	
		end
	else
		return;
end
///////////////////////////////////////////////////////////////////////////////
function Item_Unequipped_Attributes(agent thisagent, agent item)

declare
	string effect1, effect2, effect3;
		
begin
	if (item's "effect_type_1" != "Nothing")
		begin
			effect1 = item's "effect_type_1";
			thisagent's effect1 -= item's "effect_1";
			(Item's "Update_1")(thisagent);	
		end
	else
		return;
	
	if (item's "effect_type_2" != "Nothing")
		begin
			effect2 = item's "effect_type_2";
			thisagent's effect2 -= item's "effect_2";
			(Item's "Update_2")(thisagent);	
		end
	else
		return;
		
	if (item's "effect_type_3" != "Nothing")
		begin
			effect3 = item's "effect_type_3";
			thisagent's effect3 -= item's "effect_3";
			(Item's "Update_3")(thisagent);	
		end
end
///////////////////////////////////////////////////////////////////////////////

end

///////////////////////////////////////////////////////////////////////////////
function Item_Sell_Value_BlacksmithAdjust(agent thisagent, agent blacksmith, string item, integer itemcost) is integer

//expression #MP_ItemSellPrice_Max 150
//expression #MP_ItemSellPrice_Min 75
//expression #MP_ItemSellThreshold 100

declare
	integer return_int, adjust_cost, blacksmith_mod;

begin
	return_int = 0;
	
	if ($HasAttribute(item, blacksmith) != True)
		$AddAttribute(blacksmith, item, "integer");
	
	while (thisagent's item > 0) do
		begin
			if (blacksmith's item >= #MP_ItemSellThreshold)
				blacksmith_mod = (#MP_ItemSellPrice_Min);
			else
				blacksmith_mod = (#MP_ItemSellPrice_Max - blacksmith's item);
			
			if ((blacksmith_mod < #MP_ItemSellThreshold) && (blacksmith's item < 76))
				blacksmith_mod = 100;
				
			if (itemcost < 1000)	
				adjust_cost = ((itemcost * blacksmith_mod) / 100);
			else
				adjust_cost = ((itemcost / 100) * blacksmith_mod);
				
			return_int += adjust_cost;
			blacksmith's item += 1;
			thisagent's item -= 1;
			if (thisagent's item <= 0)
				$DeleteInventoryItem(item, thisAgent);
		end
		
	return return_int;
end

///////////////////////////////////////////////////////////////////////////////
function Total_Loot_Value_MarketplaceAdjust(agent thisagent, agent marketplace) is integer

declare
	list item_list, item_value_list;
	string item, thisstring;
	integer stack_multplier, item_value, loot_value, loot_size, i;

begin
	loot_value = 0;
	
	if ($HasAttribute("Loot_Item_List", thisagent) == false)
		return 0;
		
	item_list = thisagent's "Loot_Item_List";
	item_value_list = thisagent's "Loot_Item_Value_List";
	loot_size = $ListSize(item_list);
	while (loot_size > i) do
		begin
			i ++;
			thisstring = $listmember(item_list,i);
			item_value = $listmember(item_value_list,i);
			//loot_value += (thisagent's thisstring * item_value);
			if ($AgentHasInventoryItem(thisstring, thisagent) != False)
				loot_value += $Item_Sell_Value_MarketplaceAdjust(thisagent, marketplace, thisstring, item_value);
		end
		
	return loot_value;
end

///////////////////////////////////////////////////////////////////////////////
function Item_Sell_Value_MarketplaceAdjust(agent thisagent, agent marketplace, string item, integer itemcost) is integer

//expression #MP_ItemSellPrice_Max 150
//expression #MP_ItemSellPrice_Min 75
//expression #MP_ItemSellThreshold 100

declare
	integer return_int, adjust_cost, market_mod;

begin
	return_int = 0;
	
	if ($HasAttribute(item, marketplace) != True)
		$AddAttribute(marketplace, item, "integer");
	
	while (thisagent's item > 0) do
		begin
			if (marketplace's item >= #MP_ItemSellThreshold)
				market_mod = (#MP_ItemSellPrice_Min);
			else
				market_mod = (#MP_ItemSellPrice_Max - marketplace's item);
			
			if ((market_mod < #MP_ItemSellThreshold) && (marketplace's item < 76))
				market_mod = 100;
				
			if (itemcost < 1000)	
				adjust_cost = ((itemcost * market_mod) / 100);
			else
				adjust_cost = ((itemcost / 100) * market_mod);
				
			return_int += adjust_cost;
			marketplace's item += 1;
			thisagent's item -= 1;
			if (thisagent's item <= 0)
				$DeleteInventoryItem(item, thisAgent);
		end
		
	return return_int;
end

///////////////////////////////////////////////////////////////////////////////
function chance_weapon(agent thisagent,agent hero)

declare
	integer bonus_limit,struct_bonus,magic_bonus, enchant_level, upgrade_level, total_level;
	boolean goody_flag;

begin
	enchant_level = $GetIntegerSafe(hero, "EN_RightHandLevel");
	upgrade_level = $GetIntegerSafe(hero, "RightHandLevel");
	total_level = enchant_level + upgrade_level;
	if ($getattribute(hero,#ATTRIB_weapontypeindex) > 0)
		begin
			// check to see if the hero gets a bonus weapon
			goody_flag = FALSE;
			if ($randomnumber(100) < #lair_weapon_chance * thisagent's "difficulty")
				begin
						begin
							// they found a normal 'bonus' weapon
							bonus_limit = (thisagent's "difficulty" / 3) + 2;
							struct_bonus = $randomnumber(bonus_limit);
							if (struct_bonus > 3)
								struct_bonus = 3;
							magic_bonus = $randomnumber(bonus_limit);
							if (magic_bonus > 3)
								magic_bonus = 3;
							if (struct_bonus + magic_bonus > total_level)
								goody_flag = TRUE;
						end
					if (goody_flag)
						begin
							$setattribute(hero,#ATTRIB_weapon_struct_bonus,struct_bonus);
							$setattribute(hero,#ATTRIB_weapon_magic_bonus,magic_bonus);
							$UpgradeEquipment(hero, "RightHand", struct_bonus);
							$createeffector(hero,"got_weapon",0);
						end
				end
		end
end

///////////////////////////////////////////////////////////////////////////////
function chance_armor(agent thisagent, agent hero)

declare
	integer bonus_limit,struct_bonus,magic_bonus, enchant_level, upgrade_level, total_level;
	boolean goody_flag;

begin
	enchant_level = $GetIntegerSafe(hero, "EN_BodyArmorLevel");
	upgrade_level = $GetIntegerSafe(hero, "BodyArmorLevel");
	total_level = enchant_level + upgrade_level;
	if ($getattribute(hero,#ATTRIB_armortypeindex) > 0)
		begin
			// check to see if the hero gets a bonus armor
			goody_flag = FALSE;
			if ($randomnumber(100) < #lair_armor_chance * thisagent's "difficulty")
				begin
						begin
							// they found a normal 'bonus' weapon
							bonus_limit = (thisagent's "difficulty" / 3) + 2;
							struct_bonus = $randomnumber(bonus_limit);
							if (struct_bonus > 3)
								struct_bonus = 3;
							magic_bonus = $randomnumber(bonus_limit);
							if (magic_bonus > 3)
								magic_bonus = 3;
							if (struct_bonus + magic_bonus > total_level)
								goody_flag = TRUE;
						end
					if (goody_flag)
						begin
							$setattribute(hero,#ATTRIB_armor_struct_bonus,struct_bonus);
							$setattribute(hero,#ATTRIB_armor_magic_bonus,magic_bonus);
							$UpgradeEquipment(hero, "BodyArmor", struct_bonus);
							$createeffector(hero,"got_armor",0);
						end
				end
		end
end

function BuildTasks(agent thisagent)
declare
	integer count, size;
	string type;
	string _typeGuidList;

begin
	count = 0;
	size = $ListSize(thisagent's "TASK_globalTaskList"); // If an agent gets new tasks packets dynamically, the list part can be added in manually
	while (size > count) do
		begin
			count ++;
			type = $ListMember(thisagent's "TASK_globalTypeList", count);		// Prepare, Combat, Idle etc

			_typeGuidList = "TASK_typeGuidList" + type; 									// "TASK_typeGuidList{TYPE}"
			thisagent's _typeGuidList << count; 									// Add the global index as a guid into "TASK_typeGuidList{TYPE}";
		end
end

///////////////////////////////////////////////////////////////////////////////
function SetTaskParametersBasic (agent thisagent, string name, integer chance, string type)
//This function searches for new tasks for packets lacking one.
declare
begin
	// but why lol
	// global just means index with the task's guid ig, idk
	thisagent's "TASK_globalNameList" << name;
	thisagent's "TASK_globalChanceList" << chance;
	thisagent's "TASK_globalTypeList" << type;
//	thisagent's "TASK_globalTaskList" << func;
end

///////////////////////////////////////////////////////////////////////////////
function OverrideTaskSequence (agent thisagent, string thistask, string nexttask)

declare

begin
	$InvalidateTask(thisagent, thistask);

	if ($IsTaskValid(thisagent, nexttask) == true)
		begin
			thisagent's ("TASK_subIsValid" + thistask) = true;

			thisagent's ("TASK_subTaskName" + thistask) = thisagent's ("TASK_subTaskName" + nexttask);
			thisagent's ("TASK_subTarget" + thistask) = thisagent's ("TASK_subTarget" + nexttask);
			thisagent's ("TASK_subBackTarget" + thistask) = thisagent's ("TASK_subBackTarget" + nexttask);

			thisagent's ("TASK_subActiveScript" + thistask) = thisagent's ("TASK_subActiveScript" + nexttask);
			thisagent's ("TASK_subBackScript" + thistask) = thisagent's ("TASK_subBackScript" + nexttask);
			thisagent's ("TASK_subTravelScript" + thistask) = thisagent's ("TASK_subTravelScript" + nexttask);
			thisagent's ("TASK_subVisitingScript" + thistask) = thisagent's ("TASK_subVisitingScript" + nexttask);

			thisagent's ("TASK_subIntent" + thistask) = thisagent's ("TASK_subIntent" + nexttask);
			thisagent's ("TASK_subExitCondition" + thistask) = thisagent's ("TASK_subExitCondition" + nexttask);
			thisagent's ("TASK_subWaypoints" + thistask) = thisagent's ("TASK_subWaypoints" + nexttask);
		end
	
	$InvalidateTask(thisagent, nexttask);
end

///////////////////////////////////////////////////////////////////////////////
///////////CACHE INVALIDATION FUCK YEAAAAAAAAAAAAAAAAAHHHHHHHH/////////////////
///////////////////////////////////////////////////////////////////////////////
function InvalidateTask (agent thisagent, string thistask)

declare

begin
	thisagent's ("TASK_subIsValid" + thistask) = false;

	thisagent's ("TASK_subTarget" + thistask) = $nullagent();
	thisagent's ("TASK_subBackTarget" + thistask) = $nullagent();
	thisagent's ("TASK_subActiveScript" + thistask) = $NextTask;
	thisagent's ("TASK_subBackScript" + thistask) = $NextTask;
	thisagent's ("TASK_subTaskName" + thistask) = "";
	thisagent's ("TASK_subVisitingScript" + thistask) = $nullfunction;
	thisagent's ("TASK_subIntent" + thistask) = "";

	thisagent's ("TASK_subExitCondition" + thistask) = $nevervalid;
	thisagent's ("TASK_subTravelScript" + thistask) = $nullfunction;
	$clearlist(thisagent's ("TASK_subWaypoints" + thistask));
end
function InvalidateTasks(agent thisagent)
declare
begin
	$InvalidateTask(thisagent, "Current");
	$InvalidateTask(thisagent, "Next");
	$InvalidateTask(thisagent, "Reserve");
	$InvalidateTask(thisagent, "Backup");
end
function nevervalid(agent thisagent) is boolean
declare
begin
	return true;
end

function InitTaskAttributes(agent thisagent)
declare

begin
	$AddAttribute(thisagent, "Exhaustion", "integer");
	$AddAttribute(thisagent, "Fear", "integer");

	$inittasksub(thisagent, "Current");
	$inittasksub(thisagent, "Next");
	$inittasksub(thisagent, "Reserve");
	$inittasksub(thisagent, "Backup");
end

function InitTaskSub(agent thisagent, string thistask)
declare

begin
	$AddAttribute(thisagent, "TASK_subIsValid" + thistask, "boolean");

	$AddAttribute(thisagent, "TASK_subTarget" + thistask, "agentRef");
	$AddAttribute(thisagent, "TASK_subBackTarget" + thistask, "agentref");

	$AddAttribute(thisagent, "TASK_subActiveScript" + thistask, "function");
	$AddAttribute(thisagent, "TASK_subBackScript" + thistask, "function");
	$AddAttribute(thisagent, "TASK_subTravelScript" + thistask, "function");
	$AddAttribute(thisagent, "TASK_subVisitingScript" + thistask, "function");
	$AddAttribute(thisagent, "TASK_subExitCondition" + thistask, "function");
	
	$AddAttribute(thisagent, "TASK_subIntent" + thistask, "string");
	$AddAttribute(thisagent, "TASK_subTaskName" + thistask, "string");
	$AddAttribute(thisagent, "TASK_subWaypoints" + thistask, "list");
	
	$InvalidateTask(thisagent, thistask);
end

function UpdateTaskPackage(agent thisagent, function action, function condition, agent target, string intent)
declare
	string actionsub, conditionsub, targetsub, intentsub;
	string completeaction, completecondition, completetarget, completeintent;
	string taskindex;
begin
	//thisagent's "ActiveScript" = thisagent's "TASK_subActiveScriptCurrent";
	//thisagent's "Target" = thisagent's "TASK_subTargetCurrent";
	//$SpecifyIntentString (ThisAgent, thisagent's "TASK_subIntentCurrent");

	// could you make this any more fucking stupidly convoluted? like ohh my god im losing my mind here
	actionsub = "TASK_subActiveScript";
	conditionsub = "TASK_subExitCondition";
	targetsub = "TASK_subTarget";
	intentsub = "TASK_subIntent";

	taskindex = thisagent's "TASK_activeSubset";
	completeaction = actionsub + taskindex;
	completecondition = conditionsub + taskindex;
	completetarget = targetsub + taskindex;
	completeintent = intentsub + taskindex;
	
	thisagent's completeaction = action;
	thisagent's completecondition = condition;
	thisagent's completetarget = target;
	thisagent's completeintent = intent;
end

function UpdateVisitTaskPackage(agent thisagent, function action, function condition, agent target, string intent, string name, function visit)
declare
	string actionsub, conditionsub, targetsub, intentsub, namesub, visitsub;
	string completeaction, completecondition, completetarget, completeintent, completename, completevisit;
	string taskindex;
begin
	actionsub = "TASK_subActiveScript";
	conditionsub = "TASK_subExitCondition";
	targetsub = "TASK_subTarget";
	intentsub = "TASK_subIntent";
	namesub = "TASK_subTaskName";
	visitsub = "TASK_subVisitingScript";

	taskindex = thisagent's "TASK_activeSubset";
	completeaction = actionsub + taskindex;
	completecondition = conditionsub + taskindex;
	completetarget = targetsub + taskindex;
	completeintent = intentsub + taskindex;
	completename = namesub + taskindex;
	completevisit = visitsub + taskindex;
	
	thisagent's completeaction = action;
	thisagent's completecondition = condition;
	thisagent's completetarget = target;
	thisagent's completeintent = intent;
	thisagent's completename = name;
	thisagent's completevisit = visit;
end
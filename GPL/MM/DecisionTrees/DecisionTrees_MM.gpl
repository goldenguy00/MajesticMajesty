//the sets up the heroes initial task packets, it isn't the thread for calling new decisions, this is called once upon the hero's birth.
//Might be best to have multiple Prepares into a heroes package lists.
declare
	list flist;
begin
	flist << $Check_rewards_Packet;
	$SetTaskParametersBasic(thisagent, "None", 100, "General");
	
	flist << $Defend_home_Packet;				//Defend
	$SetTaskParametersBasic(thisagent, "None", 100, "General");

	flist << $Check_Wizards_Guild_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 85, "Prepare");
	
	flist << $Check_Library_Books_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 75, "Prepare");
	
	flist << $Open_Bank_Account_Packet;			//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Check_Marketplace_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Check_Blacksmith_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Purchase_bazaar_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 70, "Prepare");
	
	flist << $pursue_entertainment_Packet;		//Idle
	$SetTaskParametersBasic(thisagent, "None", 100, "Idle");
	
	flist << $Hall_Champs_Check_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 30, "Prepare");
	
	flist << $Raid_lair_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 45, "Combat");
	
	flist << $raid_enemy_building_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 30, "Combat");
	
	flist << $Combat_wandering_packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 65, "Combat");
	
	flist << $combat_wandering_heroes_packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 60, "Combat");
	
	flist << $Explore_Map_Packet;	//Explore
	$SetTaskParametersBasic(thisagent, "None", 50, "Explore");
	
	flist << $Go_Home_Packet;	//Idle
	$SetTaskParametersBasic(thisagent, "None", 85, "Idle");
	
	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Wizard_spell", 90, "Prepare");

	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Wizard_train_intel", 55, "Prepare");
	
	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Train_magic_resist", 15, "Prepare");
	
	flist << $defend_building_Packet;	//Defend
	$SetTaskParametersBasic(thisagent, "Library", 100, "General");
	
	flist << $defend_building_Packet;	//Defend
	$SetTaskParametersBasic(thisagent, "Marketplace", 100, "General");
	
	flist << $follow_support_check_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "barbarian", 30, "Combat");
	
	flist << $follow_support_check_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "monk", 20, "Combat");
	
	flist << $Visit_Building_Other_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "General_Housing_Lv3", 70, "Prepare");
	
	flist << $Visit_Building_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Royal_gardens", 5, "Prepare");
	
	flist << $Visit_Building_Other_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Shrine", 25, "Prepare");

	thisagent's "TASK_globalTaskList" = flist;
	$BuildTasks(thisagent);
end

///////////////////////////////////////////////////////////////////////////////
function Wizard_Initial_Task (agent thisagent)
declare
	
begin
	thisagent's "activescript" = $Wizard_Tree;

	if ($isvalidgamepiece(thisagent's "Home"))
		if ($GetTitle(thisagent's "Home") == "Wizards_Guild")
			begin
				thisagent's "activescript" = $NextTask;
				Thisagent's "TASK_subIsValidCurrent" = true;
				ThisAgent's "TASK_subTargetCurrent" = thisagent's "Home";
				ThisAgent's "TASK_subTaskNameCurrent" = "MAGICALTREATISES1";
				ThisAgent's "TASK_subIntentCurrent" = "IDTXT_INTENT_STUDYINGATWIZARDSGUILD";
				ThisAgent's "TASK_subActiveScriptCurrent" = $Use_Building_Packet;
				ThisAgent's "TASK_subVisitingScriptCurrent" = $wizards_guild_visited;
				ThisAgent's "TASK_subExitConditionCurrent" = $isdead;
				thisagent's "TASK_activeStatus" = "Ongoing";
			end
end
///////////////////////////////////////////////////////////////////////////////
function reset_tasks(agent thisagent)

declare

begin	
	$StopMoving (ThisAgent);

	$checktaskcompletion(thisagent);
		
	$clearlist(thisagent's "hostiles");
	thisagent's "activescript" = thisagent's "basicscript";
	thisagent's "backscript" = thisagent's "basicscript";
	thisagent's "target" = $Nullagent();

	$SetStringSafe(thisagent, "best_spell", "nothing");
	$SetAgentSafe(thisagent, "best_target", $Nullagent());
	$SetBooleanSafe(thisagent, "In_Combat", false);
end

function CheckTaskCompletion(agent thisagent)
declare
begin
	if ($getstringsafe(thisagent, "TASK_activeStatus") == "Ongoing")
		begin
			if (thisagent's "target" == thisagent's "TASK_subTargetCurrent")
				thisagent's "TASK_activeStatus" = "complete";
		end

end
///////////////////////////////////////////////////////////////////////////////
function NextTask (agent thisagent)

declare
begin

//	//$DebugOut("I'm deciding what to do!");
	if ($isdead(thisagent))
		begin
			thisagent's "activescript" = $be_dead;
			return;
		end
	
	$createeffector(thisagent,"thought_bubble_think",#think_bubble_time);
	$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_THINKING");

	if ($check_nearby(thisagent) == False)
	if ($Defend_home(thisagent) == False)
	//if ($Check_Rewards(thisagent,FALSE) == False)
	if ($rest(thisagent) == false)
	//if ($Open_Bank_Account(thisagent) == False)
	//if ($Defend_Building_Nearby(thisagent) == false)
	if ($pursueTask(thisagent) == false)
	if ($explore_map(thisagent, thisagent's "TASK_typeBaseChanceExplore") == false)
	if ($go_home(thisagent, thisagent's "TASK_typeBaseChanceIdle") == false)
		begin
			// do some immediate reactions while finding a long term plan
			
			$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_WANDERING");
			thisagent's "TASK_activeStatus" = "Searching";
			thisagent's "counter" = 0;
			thisagent's "activescript" = $hero_wander;
		end
end


function PursueTask(agent thisagent) is boolean
declare
	agent flag;
	list waypoints;
	integer waypointCount;
	function travelScript;
	string status;
begin
	status = thisagent's "TASK_activeStatus";

	if ($IsTaskValid(thisagent, "Current") == false)
		status = "Complete";

	if (status == "failed")
		begin
			$overridetasksequence(thisagent, "backup", "current");
			$overridetasksequence(thisagent, "current", "next");
			$overridetasksequence(thisagent, "next", "reserve");
			$overridetasksequence(thisagent, "reserve", "backup");
		end
	else if (Status == "Complete")
		begin
			$overridetasksequence(thisagent, "current", "next");
			$overridetasksequence(thisagent, "next", "reserve");
		end

	if ($IsTaskValid(thisagent, "Current") == true)
		begin
			thisagent's "Target" = thisagent's "TASK_subTargetCurrent";
			thisagent's "BackTarget" = thisagent's "TASK_subBackTargetCurrent";	
			thisagent's "ActiveScript" = thisagent's "TASK_subActiveScriptCurrent";
			thisagent's "BackScript" = thisagent's "TASK_subBackScriptCurrent";
			thisagent's "TaskName" = thisagent's "TASK_subTaskNameCurrent";
			thisagent's "VisitingScript" = thisagent's "TASK_subVisitingScriptCurrent";
			$SpecifyIntentString (ThisAgent, thisagent's "TASK_subIntentCurrent");

			flag = thisagent's "backtarget";
			if ($isvalidgamepiece(flag))
				if (flag's "type" == "rewardflag")
					begin
						$setparent(thisagent, flag);
						if ($agentinlist(thisagent, flag's "heroes") == false)
							flag's "heroes" << thisagent;
					end
			
			waypoints = thisagent's "TASK_subWaypointsCurrent";
			waypointCount = $listsize(waypoints);
			if (waypointCount > 0)
				begin
					thisagent's "Destination" = $listmember(waypoints, waypointCount);

					travelscript = thisagent's "TASK_subTravelScriptCurrent";
					if (travelScript == $movewaypoint)
						(travelscript)(thisagent, waypoints);
					else if (travelscript == $move)
						(travelscript)(thisagent, thisagent's "Destination");
				end
			
			thisagent's "TASK_activeStatus" = "Ongoing";
			return true;
		end
		
	thisagent's "TASK_activeStatus" = "Searching";
	return false;
end

function IsTaskValid(agent thisagent, string subset) is boolean
declare
	function condition;
	string _isValid, _condition, _target;

begin
	_isValid = "TASK_subIsValid"+subset;

	if (thisagent's _isValid == false)
		return false;
	
	_condition = "TASK_subExitCondition"+subset;
	_target = "TASK_subTarget"+subset;

	if ((thisagent's _condition)(thisagent's _target) == false)
		thisagent's _isValid = true;
	
	if (thisagent's _isvalid == false)
		$InvalidateTask(thisagent, subset);
	
	return thisagent's _isValid;
end

///////////////////////////////////////////////////////////////////////////////
function NotDuplicateTask (agent thisagent) is boolean
//Checks to see if the task is a duplicate of other ones

declare

	string targetsub, completetarget, othertarget, actionsub, completeaction, otheraction, index;
	
begin
	index = thisagent's "TASK_activeSubset";
	if (index == "Current")
		return true;
	
	targetsub = "TASK_subTarget";
	actionsub = "TASK_subActiveScript";
	completetarget = targetsub + index;
	completeaction = actionsub + index;

	// If Backup/Next/Reserve or any other index are duplicates of Current, then return false
	othertarget = targetsub + "Current";
	otheraction = actionsub + "Current";
	if ((thisagent's completetarget == thisagent's othertarget) && (thisagent's completeaction == thisagent's otheraction))
		begin
			return False;
		end

	if (index == "Reserve") //If Reserve is a duplicate of Backup or Next, then return false
		begin
			othertarget = targetsub + "Next";
			otheraction = actionsub + "Next";
			if ((thisagent's completetarget == thisagent's othertarget) && (thisagent's completeaction == thisagent's otheraction))
				begin
					return False;
				end
		end
		
	return true;
end

///////////////////////////////////////////////////////////////////////////////
function General_Task_Cycle (agent thisagent)
//This function cycles every few seconds to adjust the hero's task packets.
declare
	boolean flag, resting, in_combat;
	integer exhaustion, fear;
	string tasktype, _subset, _isValid;

begin
	exhaustion = thisagent's "Exhaustion";
	fear = thisagent's "Fear";
	
	if ($InsideBuilding(thisagent))
		begin
			Fear -= 5;
			Exhaustion -= 50;
		end
	else
		begin
			exhaustion += 5;
			if (thisagent's "In_Combat" == false)
				fear--;
		end

	
	if (Exhaustion < 0) Exhaustion = 0;
	thisagent's "Exhaustion" = exhaustion;
	
	if (Fear < 0) Fear = 0;
	thisagent's "Fear" = fear;
	
	$update_invalid_tasks(thisagent);
end

function update_invalid_tasks(agent thisagent)
declare
	string tasktype;

begin
	//Tasks should not update simultaneously. Current must update first. Then Next and Backup can update simultaneously following that. Reserve updates last.
	if ($IsTaskValid(thisagent, "Current") == false)
		begin
			//Dead tired, so do this asap
			tasktype = thisagent's "TASK_activeType";
			if (thisagent's "Exhaustion" >= 500)
				tasktype = "Idle";
			
			if ($Search_For_Task(thisagent, tasktype, "Current") == false)
				begin
					$overridetasksequence(thisagent, "current", "next");
					$overridetasksequence(thisagent, "next", "Reserve");
					return;
				end
		end
	
	// It can update simultaneously with Backup, since they don't directly conflict.
	if ($IsTaskValid(thisagent, "Next") == false)
		begin

			// use the ordered task type
			tasktype = thisagent's "TASK_activeType";

			//More tired, so look for a few places to sleep
			if (thisagent's "Exhaustion" >= 350)
				tasktype = "Idle";

			if ($Search_For_Task(thisagent, tasktype, "next") == false)
				begin
					$overridetasksequence(thisagent, "next", "Reserve");
					return;
				end
		end
	
	//Reserve must update at the end, and alone, not simultaneously with other tasks.
	if ($IsTaskValid(thisagent, "Reserve") == false)
		begin
			// use the ordered task type
			tasktype = thisagent's "TASK_activeType";

		 	//Tired, so start looking for a place to sleep
			if (thisagent's "Exhaustion" >= 200)
				tasktype = "Idle";

			$Search_For_Task(thisagent, tasktype, "Reserve");
		end
end

///////////////////////////////////////////////////////////////////////////////
function Search_For_Task (agent thisagent, string taskType, string subset) is boolean
//This function searches for new tasks for packets lacking one.
//This function should NOT have any setting for Primary/Current/Next/etc. Tasks
declare
	string _isValid, _type, _task;
	integer rand, guid, chance;
	list tasklist, guidlist, namelist, chancelist;
	function task;
	string taskname;

begin
	_isValid = "TASK_subIsValid" + subset;

	guidlist = thisagent's ("TASK_typeGuidList" + tasktype);
	namelist = thisagent's "TASK_globalNameList";
	chancelist = thisagent's "TASK_globalChanceList";
	tasklist = thisagent's "TASK_globalTaskList";

	if (thisagent's ("TASK_typeCount"+tasktype) >= $listsize(guidlist))
		begin
			if (thisagent's "TASK_activeType" == tasktype)
				begin
					taskType = $RerollTaskSet(thisagent, taskType);
					thisagent's "TASK_activeType" = tasktype;
				end
			thisagent's ("TASK_typeCount"+tasktype) = 0;
		end
	
	thisagent's ("TASK_typeCount"+tasktype)++;

	// gets referenced by the task evaluation functions to get supporting info
	if ($listsize(guidlist) > 0)
		begin
			rand = $RandomNumberNonZero($listsize(guidlist));
			guid = $listmember(guidlist, rand);
			task = $listmember(tasklist, guid);
			chance = $listmember(chancelist, guid);
			taskname = $listmember(namelist, guid);
			

			thisagent's "TASK_activeSubset" = subset;
			thisagent's "TASK_activeGuid" = guid;
			thisagent's "TASK_activeTaskName" = taskname;
			thisagent's "TASK_activeChance" = chance;
			thisagent's _isValid = (task)(thisagent);
		end
	return thisagent's _isValid;
end

function RerollTaskSet(agent thisagent, string tasktype) is string
declare
	string _baseChance;
	integer chance_total, chance;

begin
	if (tasktype != "general")
		return "general";
	_baseChance = "TASK_typeBaseChance";
	chance_total = $RandomNumber(thisagent's "TASK_typeBaseChancePrepare" + thisagent's "TASK_typeBaseChanceCombat" + thisagent's "TASK_typeBaseChanceExplore" + thisagent's "TASK_typeBaseChanceIdle");

	chance = thisagent's (_baseChance+"Prepare");
	if (chance >= chance_total)
		return "Prepare";
	
	chance_total -= chance;
	chance = thisagent's (_baseChance+"Combat");
	if (chance >= chance_total)
		return "Combat";	
	
	chance_total -= chance;
	chance = thisagent's (_baseChance+"Explore");
	if (chance >= chance_total)
		return "Explore";
	
	return "Idle";
end




///////////////////////////////////////////////////////////////////////////////
function Solarus_tree (agent thisagent)

declare

begin

//	//$DebugOut("I'm deciding what to do!");

	$createeffector(thisagent,"thought_bubble_think",#think_bubble_time);
	$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_THINKING");

	if ($check_nearby(thisagent) == False)

	if ($Check_Rewards(thisagent,FALSE) == False)

	if ($Defend_home(thisagent) == False)

	if ($defend_building(thisagent,"Marketplace") == FALSE)

	if ($rest(thisagent) == False)
	
	if ($Open_Bank_Account(thisagent) == False)

	if ($Purchase_equipment(thisagent) == False)

	if ($Purchase_bazaar(thisagent, 70) == False)

	if ($pursue_entertainment(thisagent) == False)

	if ($Visit_Building_Other(ThisAgent, "General_Housing_Lv3", 65) == False)
	
	if ($Hall_Champs_Check(thisagent, 40) == False)

	//if ($Raid_lair(thisagent,95) == False)

	if ($Check_Champion_Rewards (ThisAgent, 70) == False)

	//This covers both hidden and unhidden lairs
	if ($Find_Lair (ThisAgent, 95) == False)

	if ($Raid_enemy_building(thisagent,95) == False)

	//if ($patrol(thisagent, "guardhouse", 25) == FALSE)

	if ($Garrison_Check(ThisAgent, 50) == False)

	if ($explore_map(thisagent,75) == FALSE)

	if ($Visit_Building(ThisAgent, "Royal_gardens", 15) == False)

	if ($Visit_Building_Other(ThisAgent, "Shrine", 40) == False)
	
	if ($check_library(thisagent,15, "Train_magic_resist") == FALSE)

	if ($check_library(thisagent, 50,"Learn_generic_spell") == FALSE)

	if ($Go_home(thisagent,5) == False)

		begin
			$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_WANDERING");
			thisagent's "counter" = 0;
			thisagent's "activescript" = $hero_wander;
		end

end

///////////////////////////////////////////////////////////////////////////////
function warrior_tree (agent thisagent)

declare

begin

//	//$DebugOut("I'm deciding what to do!");
	$createeffector(thisagent,"thought_bubble_think",#think_bubble_time);
	$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_THINKING");

	if ($check_nearby(thisagent) == False)

	if ($Check_Rewards(thisagent,FALSE) == False)

	if ($Defend_home(thisagent) == False)

	if ($defend_building(thisagent,"temple_agrela") == FALSE)
	
	if ($rest(thisagent) == False)
	
	if ($Open_Bank_Account(thisagent) == False)

	if ($Purchase_equipment(thisagent) == False)

	if ($Purchase_bazaar(thisagent, 70) == False)

	if ($Hall_Champs_Check(thisagent, 40) == False)

	if ($pursue_entertainment(thisagent) == False)

	if ($Visit_Building_Other(ThisAgent, "General_Housing_Lv3", 50) == False)
	
//	if ($Guard_check(thisagent,"hero","caravan",90) == FALSE)

	if ($Raid_lair(thisagent,95) == False)

	if ($raid_enemy_building(thisagent,90) == False)

	if ($Combat_wandering(thisagent,95) == False)

	if ($combat_wandering_heroes(thisagent,95) == False)

	if ($Visit_Building(ThisAgent, "Inn", 50) == False)

	if ($check_library(thisagent,10, "Train_magic_resist") == FALSE)

	if ($check_library(thisagent, 10,"Learn_generic_spell") == FALSE)

	if ($Visit_Building_Other(ThisAgent, "Shrine", 30) == False)
	
	if ($collect_special_item (ThisAgent, 20) == False)

	if ($Go_home(thisagent,90) == False)

	if ($Visit_Building(ThisAgent, "Royal_gardens", 20) == False)

	if	($explore_map(thisagent,45) == FALSE)
		begin
			$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_WANDERING");
			thisagent's "counter" = 0;
			thisagent's "activescript" = $hero_wander;
		end

end

///////////////////////////////////////////////////////////////////////////////

function Wizard_tree (agent thisagent)

declare

begin

//	//$DebugOut("I'm deciding what to do!");
					
	$createeffector(thisagent,"thought_bubble_think",#think_bubble_time);
	$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_THINKING");

	if ($check_nearby(thisagent) == False)

	if ($Check_Rewards(thisagent,FALSE) == False)

	if ($Defend_home(thisagent) == False)

	if ($defend_building(thisagent,"Library") == FALSE)

	if ($defend_building(thisagent,"Marketplace") == FALSE)

	if ($rest(thisagent) == False)
	
	if ($Open_Bank_Account(thisagent) == False)

	if ($Purchase_equipment(thisagent) == False)

	if ($Purchase_bazaar(thisagent, 70) == False)

	if ($pursue_entertainment(thisagent) == False)

	if ($Visit_Building_Other(ThisAgent, "General_Housing_Lv3", 70) == False)
	
	if ($Collect_Resource (ThisAgent, "Magic_Crystals",90) == FALSE)

	if ($Check_Library(thisagent, 90,"Wizard_Spell") == False)

	if ($check_library(thisagent, 55,"Wizard_train_intel") == FALSE)

	if ($check_library(thisagent, 15,"Train_magic_resist") == FALSE)

	if ($Hall_Champs_Check(thisagent, 30) == False)

	if ($follow_support_check(thisagent,"barbarian",30) == FALSE)

	if ($follow_support_check(thisagent,"monk",20) == FALSE)

	if ($Raid_lair(thisagent,45) == False)

	if ($raid_enemy_building(thisagent,30) == False)

	if ($Combat_wandering(thisagent,65) == False)

	if ($combat_wandering_heroes(thisagent,60) == False)

	if ($Explore_Map(thisagent,50) == False)
	
	if ($Visit_Building_Other(ThisAgent, "Shrine", 25) == False)

	if ($Visit_Building(ThisAgent, "Royal_gardens", 5) == False)

	if ($Go_Home(thisagent,85) == False)

		begin
			$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_WANDERING");
			thisagent's "counter" = 0;
			thisagent's "activescript" = $hero_wander;
		end

end

///////////////////////////////////////////////////////////////////////////////
function Adept_Task_Packages (agent thisagent)
declare
	list flist;
begin	
	flist << $Check_rewards_Packet;
	$SetTaskParametersBasic(thisagent, "None", 100, "General");
	
	flist << $Defend_home_Packet;				//Defend
	$SetTaskParametersBasic(thisagent, "None", 100, "General");
	
	flist << $Defend_building_Packet;				//Defend
	$SetTaskParametersBasic(thisagent, "temple_agrela", 100, "General");

	flist << $Open_Bank_Account_Packet;			//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");

	flist << $Check_Marketplace_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");

	flist << $Check_Blacksmith_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Check_Library_Books_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 66, "Prepare");
	
	flist << $Purchase_bazaar_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 70, "Prepare");

	flist << $pursue_entertainment_Packet;		//Idle
	$SetTaskParametersBasic(thisagent, "None", 100, "Idle");

	flist << $Hall_Champs_Check_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 30, "Prepare");
	
	flist << $Combat_wandering_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 60, "Combat");

	flist << $Combat_wandering_heroes_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 55, "Combat");

	flist << $Patrol_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "building", 65, "Combat"); //"building" is not checked for anyway, can leave it as None, but leaving it as is just in case.

	flist << $Raid_enemy_building_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 80, "Combat");

	flist << $Visit_Building_Packet;	//Idle
	$SetTaskParametersBasic(thisagent, "Inn", 20, "Idle");

	flist << $Check_Champion_Rewards_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 85, "Combat");

	flist << $Visit_Building_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "Royal_gardens", 20, "Prepare");
	
	flist << $Visit_Building_Other_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "General_Housing_Lv3", 45, "Prepare");
	
	flist << $Visit_Building_Other_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "Shrine", 60, "Prepare");

	flist << $check_library_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "Train_magic_resist", 25, "Prepare");
	
	flist << $check_library_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "Learn_generic_spell", 40, "Prepare");

	flist << $Go_home_Packet;		//Idle
	$SetTaskParametersBasic(thisagent, "None", 95, "Idle");
	
	thisagent's "TASK_globalTaskList" = flist;
	$BuildTasks(thisagent);
end


///////////////////////////////////////////////////////////////////////////////
function eval_reaction(agent thisagent, agent new_target)

declare
	agent target;
	boolean flaggie;
	string intent;

begin

	// new enemy hit me, now im reconsidering the fight... stay or flee?
	// attack -> flee -> berserk

	if ($Berserk_check(thisagent) == 0)
		begin
			$Cleanse_Hostiles (ThisAgent);
			if ($should_I_Run(thisagent,thisagent's "Hostiles"))
				begin
					//$clearlist(thisagent's "Hostiles");
					return;
				end
		end
		
	if ($flee_check(thisagent) == 1)
		return;

	if (thisagent's "target" == new_target || $notvalid(new_target))
		return;
	
	flaggie = FALSE; // thisagent does not have a new target

	target = thisagent's "target";
	//new_target = $pick_closest(thisagent,thisagent's "Hostiles");

	// if thisagent's target is a building or lair,
	// they should just pick the closest enemy

	// if there is a target closer than thisagent's
	// current target - pick a new target
	if (($isvalidgamepiece(Target) == FALSE) || (Target == ThisAgent))
		flaggie = TRUE;
	else
		begin
			if ((target's "type" == "lair") || (target's "type" == "building"))
				flaggie = TRUE;
			if (($distanceBetweenAgents(thisagent,new_target) < $distanceBetweenAgents(thisagent,Target)))
				flaggie = TRUE;
		end

	if (flaggie)
		begin

			if ($Berserk_Check(thisagent) == 1)
				begin
					$Go_berserk(thisagent);
				end
			else
				begin		
					//$stopmoving(thisagent);	
					//Say See Hostile voice line if Target's "Type" is monster
					If (New_Target's "Type" == "Monster")
						$Say (ThisAgent, "VFX_See_Hostile");
					
					intent = "IDTXT_INTENT_ATTACKING" + $getintentext(New_Target);
					$SpecifyIntentString (ThisAgent, intent);
					thisagent's "ActiveScript" = $attack_object;
				end
			// do this after cuz berserk sets to null
			thisagent's "Target" = new_target;
		end
end

///////////////////////////////////////////////////////////////////////////////
function eval_enemies_nearby(agent thisagent) is Boolean

declare
	agent new_target,target;
	boolean flaggie;
	string intent;

begin

	$list_enemies(thisagent,1);

	if ($listsize(thisagent's "Hostiles") == 0) return FALSE;

	// add thisagent's target back onto the list, if neccessary????

	// decide whether to run or not
	if ($should_I_Run(thisagent,thisagent's "Hostiles") == FALSE)
		begin
			flaggie = FALSE; // thisagent does not have a new target

			target = thisagent's "target";
			new_target = $pick_closest(thisagent,thisagent's "Hostiles");

			// if thisagent's target is a building or lair,
			// they should just pick the closest enemy

			// if there is a target closer than thisagent's
			// current target - pick a new target
			if ($notvalid(Target))
				flaggie = TRUE;
			else if (Target == ThisAgent)
				flaggie = true;
			else
				begin
					if ((target's "type" == "lair") || (target's "type" == "building"))
						flaggie = TRUE;
					if (($distanceBetweenAgents(thisagent,new_target) < $distanceBetweenAgents(thisagent,Target)))
						flaggie = TRUE;
				end

			if (flaggie)
				begin
					$stopmoving(thisagent);
					thisagent's "Target" = new_target;

					//Say See Hostile voice line if Target's "Type" is monster
					If (New_Target's "Type" == "Monster")
						$Say (ThisAgent, "VFX_See_Hostile");

					intent = "IDTXT_INTENT_ATTACKING" + $getintentext(New_Target);
					$SpecifyIntentString (ThisAgent, intent);
					thisagent's "ActiveScript" = $attack_object;
				end

			return Flaggie;
		end
	else
		begin
			// hero has decided to run!

			// empty thisagent's Hostiles list
			$clearlist(thisagent's "Hostiles");
			return TRUE;
		end
end

///////////////////////////////////////////////////////////////////////////////
function target_eval( agent attacker, agent defender) is integer
/// this function
/// evaluates the desire of 'attacker' to
/// engage in combat with 'defender'
//

declare

	integer score;
	list thislist;

begin
	// first get a rough time estimate of how long it will take
	// attacker to kill defender

	// then modify it by distance
	// and attacker's combat variables, + intelligence

	thislist << defender;

	$list_eval_opt(attacker,thislist);
	score = attacker's "eval_best_score";

	// modify scores by distance between agents
	//score -= ($distancebetweenagents(attacker,defender) / 250);

	return score;
end

///////////////////////////////////////////////////////////////////////////////
function list_eval_opt(agent thisagent, list thislist) is agent

// this function should only ever be used by the unit type "hero"
// when they are evulating nearby hostiles of any type

declare
	agent hostile, best_target;
	float hmod_tohit;
	float ta_tohit_f,ta_avoid_f,htohit_f,havoid_f;
	float ta_mod_tohit;
	float enemy_total_strength,enemy_total_HP,enemy_HP,enemy_strength;
	integer distance,total_distance;
	integer hitstildead,hitstokill;
	integer total_range_difference,sum,dist1,hostile_range,attack_range,extra_shots;
	integer hostile_extra_range,thisagent_extra_range;
	integer spell_mod, dist_mod;

	integer current_score, best_score;
	integer best_hero_score, score_mod;

	integer hero_hp, hero_dmg, hero_armor, hero_speed;
	float self_est, enemy_est;

	boolean spellcaster;
	integer hostile_armor;
	// to make this work with towers:
	// make functions: $getattackrange, $getstrength, $getarmor
begin

	if ($listsize(thislist) == 0)
		begin
			$SetIntegerSafe(thisagent, "Eval_Best_Score", 0);
			return $NullAgent();
		end

	best_target = $NullAgent();
	enemy_est = thisagent's "enemy_estimation";
	self_est = thisagent's "self_estimation";
	best_score = 0;
	current_score = 0;
	total_range_difference = 0;
	hostile_extra_range = 0;
	
	spellcaster = $IsSpellCaster(thisagent);
	if (spellcaster)
		attack_range = thisagent's "castingrange";
	else
		attack_range = $GetAttribute(thisagent, #ATTRIB_MaxAttackRange);
	
	hero_armor = $hero_armor_value(thisagent);
	hero_dmg = $hero_damage(thisagent);
	
	hero_hp = $GetAttribute(thisagent, #ATTRIB_ResearchGoodGuard) * #Heal_Potion_Recovery;
	hero_hp += $getattribute(thisagent,#ATTRIB_HP);

	hero_speed = $Getattribute(thisagent, #ATTRIB_Speed);
	if (hero_speed < 1) hero_speed = 1;
	ta_tohit_f = $gettohit(thisagent);

	best_hero_score = self_est * hero_hp;

	foreach hostile in thislist do
		begin
			if ($NotValid(hostile) == false)
				begin
					// first determine if anyone has a range advantage
					dist1 = $distancebetweenagents(thisagent,hostile);
					dist_mod = ((dist1 / hero_speed) / #Extra_shot_mod);
					if ($CheckEffector(hostile, "Champion_Icon"))
						score_mod = #champs_mod;
					else
						score_mod = 0;
					// early out if distance makes them impossible to target
					if ((best_hero_score + score_mod) > (best_score + dist_mod))
						begin
							hostile_range = $Egetattackrange(hostile); //$getattribute(hostile,#ATTRIB_maxattackrange);
							thisagent_extra_range = 0;
							hostile_extra_range = 0;

							// longer stick gets small bonus
							if (hostile_range > attack_range)
								hostile_extra_range = hostile_range - attack_range;
							else if (attack_range < hostile_range)
								thisagent_extra_range = attack_range - hostile_range;

							htohit_f = $gettohit(hostile);
							ta_avoid_f = $gettoavoid(hostile,thisagent);
							havoid_f = $gettoavoid(thisagent,hostile);

							// these mods are the percentage below 1 (1/hmod..)
							// to modify the strength and HP by in order to estimate them
							// they are the fraction which represents how often a creature hits another
							// based on the first creatures to hit and the second creatures dodge/parry

							hmod_tohit = htohit_f * ((100.0 - ta_avoid_f) / 100.0);
							if (hmod_tohit == 0)
								hmod_tohit = 1;

							ta_mod_tohit = ta_tohit_f * ((100.0 - havoid_f) / 100.0);
							if (ta_mod_tohit == 0)
								ta_mod_tohit = 1;

							// a creature's actual HP is exaggerated to account for the
							// hero's chance of missing them
							// it is also exaggerated by the number of swings it would take the hero
							// to kill them times the hostiles armor value

							// adjust enemy HP upward for the chance of the hero missing them
							enemy_HP = $getattribute(hostile,#ATTRIB_HP);
							if (hostile's "type" == "hero")
								enemy_HP += $GetAttribute(thisagent, #ATTRIB_ResearchGoodGuard) * #Heal_Potion_Recovery;
							
							if (spellcaster)
								hostile_armor = $GetAttribute(hostile, #ATTRIB_MagicResistance);
							else
								hostile_armor = $getArmor(hostile);

							if (hostile_armor > 0)
								enemy_HP += ((enemy_HP*hostile_armor) / 100);

							enemy_HP *= (100.0 / ta_mod_tohit);
							hitstokill = enemy_HP / hero_dmg;
							hitstokill += (hostile_extra_range / #extra_shot_mod);
							hitstokill = enemy_est * hitstokill;


							// a creature's actual damage is underestimated to account for
							// the chance of them missing the hero
							// it is also underestimated by the hero's armor

							enemy_strength = $getstrength(hostile);
							enemy_strength -= hero_armor;
							if (enemy_strength < 1) enemy_strength = 1;

							enemy_total_strength = (enemy_strength / (100.0 / (hmod_tohit)) );
							if (enemy_total_strength < 1) enemy_total_strength = 1;

							hitstildead = hero_hp / enemy_total_strength;
							hitstildead += (thisagent_extra_range / #extra_shot_mod);
							hitstildead = self_est * hitstildead;

							current_score = hitstildead + score_mod;
							current_score -= (hitstokill + dist_mod);
							if (current_score > best_score)
								begin
									best_score = current_score;
									best_target = hostile;
								end
						end
				end
		end

	$SetIntegerSafe(thisagent, "Eval_Best_Score", best_score);
	return best_target;
end

///////////////////////////////////////////////////////////////////////////////
function list_eval(agent thisagent, list thislist) is integer

// this function should only ever be used by the unit type "hero"
// when they are evulating nearby hostiles of any type

declare
	agent hostile;
	float hmod_tohit;
	float ta_tohit_f,ta_avoid_f,htohit_f,havoid_f;
	float ta_mod_tohit;
	float enemy_total_strength,enemy_total_HP,enemy_HP,enemy_strength;
	integer distance,total_distance;
	integer hitstildead,hitstokill;
	integer total_range_difference,sum,dist1,hostile_range,attack_range,extra_shots;
	integer hostile_extra_range,thisagent_extra_range;
	integer spell_mod;
	boolean spellcaster;
	integer hero_armor, hero_damage, hostile_armor, hero_hp;
	list heroes;
	agent hero;
	integer friend_mod, friend_count;

	// to make this work with towers:
	// make functions: $getattackrange, $getstrength, $getarmor
begin
	if ($listsize(thislist) == 0)
		begin
			return 0;
		end

	total_range_difference = 0;
	hostile_extra_range = 0;
	
	spellcaster = $IsSpellCaster(thisagent);
	if (spellcaster)
		attack_range = thisagent's "castingrange";
	else
		attack_range = $GetAttribute(thisagent, #ATTRIB_MaxAttackRange);
	
	thisagent_extra_range = 1;
	ta_tohit_f = $gettohit(thisagent);
	hero_armor = $hero_armor_value(thisagent);
	hero_damage = $hero_damage(thisagent);
	
	hero_hp = $GetAttribute(thisagent, #ATTRIB_ResearchGoodGuard) * #Heal_Potion_Recovery;
	hero_hp += $getattribute(thisagent,#ATTRIB_HP);

	// count friendlies
	heroes = $list_heroes(thisagent);

	friend_mod = 0;
	friend_count = $listsize(heroes);
	if (friend_count > 0)
		foreach hero in heroes do
			begin
				if ($HasAttribute("eval_self", hero) == true)
					friend_mod += hero's "eval_self";
			end

	foreach hostile in thislist do
		begin
			dist1 = $distancebetweenagents(thisagent,hostile);
			hostile_range = $Egetattackrange(hostile); //$getattribute(hostile,#ATTRIB_maxattackrange);

			// if thisagent is in range of hostile, but hostile is not in range of
			// thisagent then thisagent has a range bonus
			// if any enemy is in range of thisagent, thisagent has no extra range
			if (thisagent_extra_range > 0)
				begin
					if (dist1 < hostile_range)
						thisagent_extra_range = 0;
					else 
						begin
							if (dist1 <= attack_range)
								thisagent_extra_range += (dist1 - hostile_range);
						end
				end
			
			// if hostile is in range of thisagent, but thisagent is not in range of
			// hostile then the hostiles have an advantage in range
			if (dist1 <= hostile_range)
				if (dist1 > attack_range)
					hostile_extra_range += (dist1 - attack_range);


			// these mods are the percentage below 1 (1/hmod..)
			// to modify the strength and HP by in order to estimate them
			// they are the fraction which represents how often a creature hits another
			// based on the first creatures to hit and the second creatures dodge/parry
		

			havoid_f = $gettoavoid(thisagent,hostile);
			ta_mod_tohit = ta_tohit_f * ((100.0 - havoid_f) / 100.0);
			if (ta_mod_tohit == 0)
				ta_mod_tohit = 1;

			// a creature's actual HP is exaggerated to account for the
			// hero's chance of missing them
			// it is also exaggerated by the number of swings it would take the hero
			// to kill them times the hostiles armor value

			// adjust for enemy armor
			enemy_HP = $getattribute(hostile,#ATTRIB_HP);
			if (hostile's "type" == "hero")
				enemy_HP += $GetAttribute(thisagent, #ATTRIB_ResearchGoodGuard) * #Heal_Potion_Recovery;
			
			if (spellcaster)
				hostile_armor = $GetAttribute(hostile, #ATTRIB_MagicResistance);
			else
				hostile_armor = $getArmor(hostile);
				
			if (hostile_armor > 0)
				enemy_HP += ((enemy_hp * hostile_armor)/100);

			// adjust enemy HP upward for the chance of the hero missing them
			enemy_total_HP += (enemy_HP * (100.0 / (ta_mod_tohit)) );

			// a creature's actual damage is underestimated to account for
			// the chance of them missing the hero
			// it is also underestimated by the hero's armor
			htohit_f = $gettohit(hostile);
			ta_avoid_f = $gettoavoid(hostile,thisagent);
			hmod_tohit = htohit_f * ((100.0 - ta_avoid_f) / 100.0);
			if (hmod_tohit == 0)
				hmod_tohit = 1;

			enemy_strength = $getstrength(hostile); //$getattribute(hostile,#ATTRIB_Strength);
			enemy_strength -= hero_armor;

			if (friend_count > 0)
				if (hostile's "target" != thisagent)
					enemy_strength = enemy_strength / friend_count;
					
			if (enemy_strength < 1)
				enemy_strength = 1;

			enemy_total_strength += (enemy_strength / (100.0 / hmod_tohit));
		end

	hitstokill = enemy_total_HP / (hero_damage + friend_mod);
	hitstokill += (hostile_extra_range - thisagent_extra_range) / #Extra_shot_mod;
	hitstokill = thisagent's "enemy_estimation" * hitstokill;

	if (enemy_total_strength < 1)
		enemy_total_strength = 1;
	
	hitstildead = hero_hp / enemy_total_strength;
	//hitstildead += thisagent_extra_range / #extra_shot_mod;
	hitstildead = (thisagent's "self_estimation") * hitstildead;
	
	$SetIntegerSafe(thisagent, "Eval_Friends", friend_mod);
	$SetIntegerSafe(thisagent, "Eval_Till_death", hitstildead);
	$SetIntegerSafe(thisagent, "Eval_To_Kill", 0 - hitstokill);
	$SetIntegerSafe(thisagent, "Eval_total", hitstildead - hitstokill);

	return thisagent's "eval_total";
end


///////////////////////////////////////////////////////////////////////////////
function Healer_Eval_Nearby (agent ThisAgent) is Boolean
Declare
	agent Healing_Target;
	string spell_name;
	list undead;
//	list	Friendlies;
//	agent Friendly;
//	agent Hostile;
//	agent target;

begin
	// first check if there is anyone nearby who needs healing
	// then see if anyone has attacked me. I only run if I am swung at!

	Healing_Target = $Eval_For_Healing (ThisAgent, thisagent's "castingrange");

	If (Healing_Target != $NullAgent ())
		begin
			spell_name = $Spell_List_Heal(thisagent,Healing_Target);
			if (spell_name != "nothing")
				$Cast (ThisAgent, spell_name, thisagent's "best_target", "");
		end
	
	If ($listsize(thisagent's "Hostiles") == 0)
		 return FALSE;

	$flee_packet(thisagent,"IDTXT_INTENT_FLEEING");

	// empty thisagent's Hostiles list
	$clearlist(thisagent's "Hostiles");

	return True;
end

///////////////////////////////////////////////////////////////////////////////
function support_eval_nearby(agent thisagent) is boolean

declare
	boolean flag;
	agent 	new_target;
	boolean should_support;
	string fuck_this_shit;

begin
	$Cleanse_Hostiles (ThisAgent);

	should_support = thisagent's "basicscript" == $follow_support || thisagent's "backscript" == $follow_support;

	if (should_support == false)
		begin	
			fuck_this_shit = "TASK_subBackScriptCurrent";
			if ($HasAttribute(fuck_this_shit, thisagent))
				should_support = thisagent's fuck_this_shit == $follow_support;
		end

	if (should_support == true)
		begin
			If ($listsize(thisagent's "Hostiles") == 0)
		 		return FALSE;
			else
				begin

					new_target = $Pick_Closest (thisagent,ThisAgent's "Hostiles");
					ThisAgent's "ActiveScript" = $Attack_Object;
					ThisAgent's "BackScript" = $Attack_Object;
					ThisAgent's "Target" = New_Target;

					$ClearList (ThisAgent's "Hostiles");

					return TRUE;

				end
		end
		
	return ($eval_enemies_nearby(thisagent) != FALSE);
end

///////////////////////////////////////////////////////////////////////////////
function wizard_eval_nearby(agent thisagent) is boolean

declare
	boolean danger_danger_flag,mirror_flag,flag;
	agent dude;

begin
	// check for targets with a high magic resistance
	// if there are none, go to regular eval, otherwise flee!
	$list_enemies(thisagent,1);
	danger_danger_flag = false;
	foreach dude in thisagent's "hostiles" do
		begin
			if (($getattribute(dude, #ATTRIB_HasEffectMagicMirror) == 1))
				begin
					mirror_flag = TRUE;
					danger_danger_flag = TRUE;
				end
		end

	if ($isvalidgamepiece(thisagent's "target") == true)
		if (($getattribute(thisagent's "target",#ATTRIB_magicresistance) > 60))
			danger_danger_flag = TRUE;

	if (danger_danger_flag == FALSE)
		begin
			return ($eval_enemies_nearby(thisagent) != FALSE);
		end
	else
		begin
			if (mirror_flag)
				$flee_absolute_packet(thisagent,"IDTXT_INTENT_FLEEING");
			else
				$flee_packet(thisagent,"IDTXT_INTENT_FLEEING");

			// empty thisagent's Hostiles list
			$clearlist(thisagent's "Hostiles");
			return TRUE;
		end
end

///////////////////////////////////////////////////////////////////////////////
function cultist_eval_nearby(agent thisagent) is boolean

declare
	agent charm_target;
	integer monster_limit;
	boolean flag;
	list animals;

begin
	monster_limit = (($getattribute(thisagent,#ATTRIB_experienceLevel) - 1) / 3) + 1;

	If (ThisAgent's "Num_Followers" < monster_limit)
		begin
			$listobjects (thisagent,"monster",thisagent's "castingrange",animals,#NotMyTeam, #CheckSubtypes, "Animal");
			animals = $listsubtypes(animals,"animal");

			if ($listsize(animals) > 0)
				charm_Target = $listmember(animals,1);

			If (charm_Target != $NullAgent ())
					if ($isspellavailable(thisagent,"charm_monster"))
						begin
							$Cast (ThisAgent, "charm_monster", charm_Target, "");
							return TRUE;
						end
		end

	return ($eval_enemies_nearby(thisagent) != false);
end

///////////////////////////////////////////////////////////////////////////////
function gnome_eval(agent thisagent) is boolean

declare

begin
	If ($listsize(thisagent's "Hostiles") == 0)
		 return FALSE;

	$flee_packet(thisagent,"IDTXT_INTENT_FLEEING");

	// empty thisagent's Hostiles list
	$clearlist(thisagent's "Hostiles");

	return True;
end

///////////////////////////////////////////////////////////////////////////////
function list_enemies(agent thisagent,integer mult)

// this function lists all dangerous enemies near thisagent,
// and exits the function with that list in thisagent's "hostiles"
declare
	list in_sight,in_sight2,newl,units,buildings,btowers,ghouses,wtowers,towers, settlements;
	//list forts, others;
	integer sightrange;
	agent unit;
	list hostiles;


begin
	//first add all enemies in sight of thisagent to thisagent's hostiles list
	sightrange = $getattribute(thisagent,#ATTRIB_sightrange) * mult;

	$ListObjects(thisagent,"monster",sightrange,in_sight,#NotMyTeam);
	$ListObjects(thisagent,"hero",sightrange,in_sight2,#NotMyTeam);
	$listobjects(thisagent,"building",sightrange,buildings,#ATTRIB_FirstStageBuilt, 1, #NotMyTeam);
	//buildings = $listcompleted(buildings);
	btowers = $removetitles(buildings,"ballista_Tower");
	settlements = $removetitles(buildings,"Dwarven_settlement");
	btowers = $addlists(btowers,settlements);

	//Enchanted wizard's towers
	wtowers = $removetitles(buildings,"wizards_tower");
	wtowers = $listenchanted(wtowers);

	//Guardhouses with arrows
	ghouses = $removetitles(buildings,"guardhouse");
	ghouses = $listarrowed(ghouses);

	towers = $addlists(btowers,ghouses);
	towers = $addlists(towers,wtowers);

	in_sight = $addlists(in_sight,in_sight2);

	in_sight = $addlists(in_sight,towers);

	//This takes all Friends off of In_Sight
	If (ThisAgent's "Friend" != "xx")
		$Cull_Subtypes (In_sight, ThisAgent's "Friend");
	if ($listsize(in_sight) > 0)
		begin
			foreach unit in in_sight do
				begin
					if ($notvalid(unit) == FALSE)
						newl << Unit;
				end
			in_sight = newl;
		end
	// make sure that there are no duplicates in hostiles and sight range
	hostiles = thisagent's "hostiles";
	if ($listsize(hostiles) > 0)
		foreach unit in hostiles do
			begin
				if ($notvalid(unit) == FALSE)
					if ($agentinlist(unit, in_sight) == false)
						Units << Unit;
			end
	units = $addlists(in_sight,units);
	units = $possibly_remove_target(thisagent,units);
	thisagent's "hostiles" = units;
end

///////////////////////////////////////////////////////////////////////////////
function should_I_run(agent thisagent, list thislist) is Boolean

// returns true if the guy wants to run, false if not

declare
	agent Speedy,hero;
	integer killorbekilled,friend_mod;
	list heroes;
	integer exhaustion;
	integer money;

begin
	// get the "numbers" for the list
	killorbekilled = $list_eval(thisagent, thislist);

	// see if the total of the targets is too dangerous
	if (killorbekilled < 1)
		begin
			// thisagent thinks it would be dead before it killed these guys
			// can thisagent outrun the fastest enemy?
			speedy = $pick_fastest(thisagent,thislist);

			if ($getattribute(thisagent,#ATTRIB_speed) >= $getspeed(speedy))
				begin
					// flight
//					//$DebugOut("I must flee!");
					$flee_packet(thisagent,"IDTXT_INTENT_FLEEING");
					return TRUE;

				end
			else
				begin
//					//$DebugOut("I can't flee. Oh Well!");
					$last_stand_packet(thisagent,"IDTXT_INTENT_FLEEING");
					return TRUE;
				end
		end
	
	return FALSE;
end


///////////////////////////////////////////////////////////////////////////////
function hero_damage(agent thisagent) is integer

declare
	integer value;

begin
	value = $getStrength(thisagent);
	value += $hero_weapon_value(thisagent);
	
	$SetIntegerSafe(thisagent, "eval_self", value);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function hero_weapon_value(agent thisagent) is integer

declare
	integer value;

begin
	value = $Spell_Extra_Value(thisagent);

	value += $getattribute(thisagent,#ATTRIB_weapon_struct_bonus);
	value += $getattribute(thisagent,#ATTRIB_weapon_magic_bonus);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function hero_armor_value(agent thisagent) is integer

declare
	integer value;

begin
	value = $getattribute(thisagent,#ATTRIB_armor_basic_damage);
	value += $getattribute(thisagent,#ATTRIB_armor_struct_bonus);
	value += $getattribute(thisagent,#ATTRIB_armor_magic_bonus);
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function getstrength(agent thisagent) is integer

declare
	integer value;

begin
	if ($GetBooleanSafe(thisagent, "attack_damage_based_on_weapon") == true)
		value = $GetAttribute(thisagent, #ATTRIB_Weapon_basic_damage);
	else 
		value = $GetIntegerSafe(thisagent, "Physical_Attack") + $GetIntegerSafe(thisagent, "Magical_attack");
	
	if (value > 0)
		begin
			if ($IsSpellCaster(thisagent))
				value += $GetAttribute(thisagent, #ATTRIB_Intelligence) / #Intelligence_div;
			else
				value += $getattribute(thisagent,#ATTRIB_Strength) / #strength_div;
		end
	else if ($isbuilding(thisagent))
		value = $GetIntegerSafe(thisagent, "strength");
	else
		value = $getattribute(thisagent, #ATTRIB_Strength);
	
	return value;
end

///////////////////////////////////////////////////////////////////////////////
function spell_extra_value(agent thisagent) is integer

declare
	integer value, level;

begin
	value = 0;
	if ($isspellavailable(thisagent,"energy_blast",1))
		value += 10;

	if ($isspellavailable(thisagent,"fire_blast",1))
		value += 10;

	if ($isspellavailable(thisagent,"fire_ball",1))
		value += 10;

	if ($isspellavailable(thisagent,"teleport",1))
		value += 10;

	if ($isspellavailable(thisagent,"resist_magic",1))
		value += 10;

	if ($isspellavailable(thisagent,"meteor_storm",1))
		value += 10;

	if ($isspellavailable(thisagent,"drain_life",1))
		value += 10;

	if ($isspellavailable(thisagent,"sun_scorch",1))
		value += 10;

	if (thisagent's "Title" == "Wizard")
		begin
			level = $GetAttribute(thisagent, #ATTRIB_experienceLevel);
			if (level > 10)
				level = 10;
			value += level * 10;
			if ($haslowMP(thisagent) == True)
				value /= 2;
		end
		
	return value;
end

///////////////////////////////////////////////////////////////////////////////
// This function looks for Special Items which can be EQuest Items or Treasure Chests
Function Eval_Items_Nearby (agent ThisAgent) is boolean
Declare
	list	Items, loot, equipment;
	agent	Item;
	boolean owned;
	string intentext;

Begin
	owned = false;
	//If I am fighting someone nearby, then don't even consider retrieving something
	If (ThisAgent's "ActiveScript" == $Attack_Object || ThisAgent's "BackScript" == $Attack_Object)
		begin
			If ($DistanceBetweenAgents (ThisAgent, ThisAgent's "Target") <= $GetAttribute (ThisAgent, #ATTRIB_SightRange))
				begin
					//Fight first
			  		return False;

				end
		end


	If (ThisAgent's "BackScript" != $Grab_Item)
		begin

			$ListObjects (ThisAgent, "Special_Item", $GetAttribute (ThisAgent, #ATTRIB_SightRange), Items);
			$ListObjects (ThisAgent, "Loot", $GetAttribute (ThisAgent, #ATTRIB_SightRange), Loot);
			$ListObjects (ThisAgent, "Equipment", $GetAttribute (ThisAgent, #ATTRIB_SightRange), Equipment);

			Items = $addlists(Items,Loot,Equipment);
			
			If ($ListSize (Items) > 0)
				begin
					Item = $ListMember (Items, 1);
					if ($HasAttribute("Owned", Item) == True)
						owned = Item's "Owned";

					//If someone on my team isn't already going for this item, then go get it
					If ($Is_Free_Task (ThisAgent, $Grab_Item, Item) && (owned == false))
						begin
							ThisAgent's "Target" = Item;

							ThisAgent's "ActiveScript" = $Grab_Item;
							ThisAgent's "BackScript" = $Grab_Item;

							//Specify either recovering item or Retrieving Treasure
							If (Item's "Title" == "Treasure_Chest")
								$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_RETRIEVINGTREASURE");
							Else if ($HasAttribute("IntenxtExt", Item))
								begin
									intentext = "IDTXT_INTENT_RECOVERINGITEM" + $getintentext(Item);
									$SpecifyIntentString (ThisAgent, intentext);
								end
							Else
								$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_RECOVERINGITEM");

							return True;
						end
				end

		end

	return False;
End

///////////////////////////////////////////////////////////////////////////////
Function Grab_Item (agent thisagent)
Declare
	agent 	target;
	integer	WhatItem;
	list pile;
	agent loot;
	boolean can_path;
	float cost;
	integer dist;

begin
	target = thisagent's "target";
	
	if ($isvalidgamepiece(target) == False)
		begin
			// all done
			$reset_tasks(thisagent);
			return;
		end

	if ($isadjacent(thisagent,target) == FALSE)
		// move towards target
		begin
			cost = $PathCost($LocationOf(thisagent), $LocationOf(target), "check_all_units", can_path, thisagent);
			dist = $DistanceBetweenAgents(thisagent, target);
			if (can_path || dist > 10)
				begin
					ThisAgent's "ActiveScript" = $Travel_To;
					thisagent's "destination" = $locationof(target);
					thisagent's "backScript" = $grab_item;
					$move(thisagent,target);
					return;
				end
		end

	If (Target's "Title" == "Treasure_Chest")
		begin
			$Open_Chest (ThisAgent, Target);
			return;
		end
		
	If ($pickup_stack (thisagent, Target) == false)
		begin
			$Reset_Tasks (ThisAgent);
			return;
		end
	$createeffector(ThisAgent,"got_item",0);
	$say (ThisAgent,"VFX_FIND_COOL");
end

function pickup_stack(agent thisagent, agent target) is boolean
declare
	list resources, loot, equipment;
	agent item;
	boolean took_anything;
	integer WhatItem;

begin
	took_anything = false;
	$ListObjects(target,"Special_Item", 1 ,resources );
	$ListObjects(target,"Loot", 1 ,loot );
	$ListObjects(target,"Equipment", 1 ,equipment );
	
	resources = $addlists(resources,loot,equipment);
	resources << target;

	foreach item in resources do
		begin
			// Else the Special Item is something we want to pick up
			WhatItem = -1;
			// Get what type of item it is from its inventory
			If ($AgentHasInventoryItem (WhatItem, item))
				begin
					$TransferInventoryItem (WhatItem, item, ThisAgent);
						
					// Call common code that will handle stat boosts for some Quest items
					$QItem_Stat_Boost (ThisAgent, WhatItem);
					// If the item has a transfer script call it.
					if ($HasAttribute("TransferScript", item))
						begin
							if ($validfunction(item's "TransferScript") == TRUE)
								(item's "TransferScript")(item, ThisAgent, WhatItem);
						end

					$DeleteGamePiece (item);
					took_anything = true;
				end
		end
	return took_anything;
end

///////////////////////////////////////////////////////////////////////////////
function collect_special_item (agent thisagent, integer chance) is Boolean

declare
	list resources, loot, equipment;
	agent this_resource;
	string intentext;

begin
//	//$DebugOut("Should I collect",resource,"?");

	if ($randomNumber(100) + 1 > chance)
		return FALSE;


	$ListObjects(thisagent,"Special_Item", -1 ,resources );
	$ListObjects(thisagent,"Loot", -1 ,loot );
	$ListObjects(thisagent,"Equipment", -1 ,equipment );
	
	resources = $addlists(resources,loot,equipment);

	if ($listsize(resources) > 0)
		begin

			This_resource = $ListMember (Resources, 1);
			//this_resource = $pick_closest(thisagent,resources);

		  	If ($Is_Free_Task (ThisAgent, $Grab_Item, This_resource))
			 	begin
					thisagent's "Activescript" = $Grab_Item;
					ThisAgent's "BackScript" = $Grab_Item;

					thisagent's "target" = this_resource;

					//Specify either recovering item or Retrieving Treasure
					If (This_resource's "Title" == "Treasure_Chest")
						$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_RETRIEVINGTREASURE");
					Else if ($HasAttribute("IntenxtExt", This_resource))
						begin
							intentext = "IDTXT_INTENT_RECOVERINGITEM" + $getintentext(This_resource);
							$SpecifyIntentString (ThisAgent, intentext);
						end
					Else
						$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_RECOVERINGITEM");

					return TRUE;
			  	end
		end

	return False;
end
///////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////
function collect_special_item_packet (agent thisagent) is Boolean

declare
	list resources, loot, equipment;
	agent this_resource;
	integer chance; 
	string actionsub, action2sub, intentsub, targetsub, taskindex, completeaction, completeaction2, completeintent, completetarget;
	string conditionsub, completecondition, intentext;

begin

//            //$DebugOut("Should I collect",resource,"?");
	chance = thisagent's "TASK_activeChance";

	if ($randomNumber(100) + 1 > chance)
		return FALSE;

	taskindex = thisagent's "TASK_activeSubset";
	actionsub = "TASK_subActiveScript";
	action2sub = "TASK_subBackScript";
	intentsub = "TASK_subIntent";
	targetsub = "TASK_subTarget";
	completeaction = actionsub + taskindex;
	completeaction2 = action2sub + taskindex;
	completeintent = intentsub + taskindex;
	completetarget = targetsub + taskindex;

	conditionsub = "TASK_subExitCondition";
	completecondition = conditionsub + taskindex;

	$ListObjects(thisagent,"Special_Item", -1 ,resources );
	$ListObjects(thisagent,"Loot", -1 ,loot );
	$ListObjects(thisagent,"Equipment", -1 ,equipment );
	
	resources = $addlists(resources,loot,equipment);
	
	if ($listsize(resources) > 0)
		begin

			This_resource = $ListMember (Resources, 1);
			//this_resource = $pick_closest(thisagent,resources);

			If ($Is_Free_Task (ThisAgent, $Grab_Item, This_resource))
				begin
					thisagent's completeaction = $Grab_Item;
					ThisAgent's completeaction2 = $Grab_Item; //Figure out what to do with this.

					thisagent's completetarget = this_resource;
					ThisAgent's completecondition = $notvalid;

					//Specify either recovering item or Retrieving Treasure
					If (This_resource's "Title" == "Treasure_Chest")
						thisagent's completeintent  = "IDTXT_INTENT_RETRIEVINGTREASURE";
					Else
						begin
							intentext = "IDTXT_INTENT_RECOVERINGITEM" + $getintentext(thisagent's completetarget);
							ThisAgent's completeintent = intentext;
						end

					return $NotDuplicateTask(thisagent);
				end
		end

	return False;
end

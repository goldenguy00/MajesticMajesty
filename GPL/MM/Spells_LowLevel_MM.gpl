/////////////////////////////////////////////////////////////////////////////////////////////////
function SpecialCastEnemyUnit_Transmute( agent thisagent, agent target, string spell_name ) is agent
// Return a viable allied target for support spell.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count, TargetHP, TargetMaxHP, Transmute_HP, stat_int;
	
begin
	unit_name = thisagent's "title";
	stat_int = $getattribute(thisagent, #ATTRIB_Intelligence);
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	targetrange = $distanceBetweenAgents(thisagent,target);
	TargetHP = $getattribute(target, #ATTRIB_HP);
	TargetMaxHP = $getattribute(target, #ATTRIB_MaxHP);
	Transmute_HP = $PercentOf(TargetMaxHP, (10 + (stat_int / 6)), FALSE);
	
	castrange = $CastRangeForSpell(castrange, spell_name);
	
	if ((TargetHP <= Transmute_HP) && (target's "Type" != "Building") && (target's "Type" != "Lair"))
		newtarget = target;
	else
		potential_targets = $compile_enemies(thisagent,castrange);

	if ($listsize(potential_targets) > 0)
		count = $listsize(potential_targets);
		if (count > 0)
			begin
				foreach picked in potential_targets do
					begin
						TargetHP = $getattribute(picked, #ATTRIB_HP);
						TargetMaxHP = $getattribute(picked, #ATTRIB_MaxHP);
						Transmute_HP = $PercentOf(TargetMaxHP, (10 + (stat_int / 6)), FALSE);
						if ((TargetHP <= Transmute_HP) && ($IsDead(picked) == false) && (target's "Type" != "Building") && (target's "Type" != "Lair"))
							begin
								if (picked != thisagent)
									spell_targets << picked;
							end
					end
				if ($listsize(spell_targets) > 0)
					begin
						newtarget = $listmember(spell_targets, 1);
					end
			end
		
	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function AdvancedCastCombatSupportAlly_hero( agent thisagent, agent target, string buff_name, string spell_name, integer required_mana ) is agent
// Return a viable allied target for support spell. This version prioritizes the caster's Mana in concern towards casting support spells on allies.
declare
	list potential_targets;
	
	agent new_target;
	
begin
	new_target = $NullAgent();

	if ($HasMPPercent(thisagent, required_mana) == false)
		return new_target;
	
	if ($Checkeffector(thisagent,buff_name) == false)
		return thisagent;

	$ListObjects(thisagent, "hero", thisagent's "castingrange", potential_targets, #MyPlayer);
	if ($ListSize(potential_targets) > 0)
		new_target = $FirstWithoutEffector(potential_targets, buff_name);
	
	return new_target;
end


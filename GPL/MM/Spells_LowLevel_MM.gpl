/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastHealAlly_hero( agent thisagent, agent target, string spell_name ) is agent
// Return a viable allied target for support spell.
declare
	agent newtarget, picked;
	list potential_targets;
	integer castrange, CurrentHP, MaxHP, MissingHP;
	integer most_hurt;
	
begin
	CurrentHP = $getattribute(thisagent, #ATTRIB_HP);
	MaxHP = $getattribute(thisagent, #ATTRIB_MaxHP);
	
	if (CurrentHP < MaxHP)
		return thisagent;
	
	newtarget = $NullAgent();
	castrange = thisagent's "castingrange";
	most_hurt = 0;
	$ListObjects(thisagent, "hero", castrange, potential_targets, #MyPlayer);
	if ($ListSize(potential_targets) > 0)
		foreach picked in potential_targets do
			begin
				if ($notvalid(picked) == false)
					begin
						CurrentHP = $getattribute(picked, #ATTRIB_HP);
						MaxHP = $getattribute(picked, #ATTRIB_MaxHP);
						MissingHP = (100 * (MaxHP - currentHP)) / MaxHP;
						if (most_hurt < missingHP)
							begin
								newtarget = picked;
								most_hurt = missingHP;
							end
					end
			end

	return newtarget;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastFollowAlly_hero( agent thisagent, agent target, string buff_name, string spell_name ) is agent
// Return a viable allied target for support spell while following and supporting another hero.
declare
	list potential_targets;
	agent new_target;
	
begin
	new_target = $NullAgent();

	if ($IsBuilding(target) == false && $Checkeffector(target,buff_name) == false)
		return target;

	if ($Checkeffector(thisagent, buff_name) == false)
		return thisagent;

	$ListObjects(thisagent, "hero", thisagent's "castingrange", potential_targets, #MyPlayer);
	if ($ListSize(potential_Targets) > 0)
		new_target = $FirstWithoutEffector(potential_targets, buff_name);
	
	return new_target;
end


function AdvancedCastCombatDebuffEnemy_hero( agent thisagent, agent target, string debuff_name, string spell_name, integer required_mana ) is agent
// Return a viable allied target for support spell.
declare
	list potential_targets;
	
	agent new_target;
	
begin
	new_target = $NullAgent();
	if ($HasMPPercent(thisagent, required_mana) == false)
		return new_target;
	
	if ($IsBuilding(target) == false && $Checkeffector(target,debuff_name) == false)
		return target;

	potential_targets = $compile_enemies(thisagent,thisagent's "castingrange");
	if ($Listsize(potential_targets) > 0)
		new_target = $FirstWithoutEffector(potential_targets, debuff_name);
	
	return new_target;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Heal( agent thisagent, agent target ) is string
// List of Healing spells to retrieve for a hero.
// Currently ignoring mana cost.

declare
	string new_spell;
	agent new_target;

begin
	$Reset_Best_Spell(thisagent);

	if ($isvalidgamepiece(target))
		if ($isbuilding(target))
			return "nothing";
	
	new_spell = "healer_heal";
	new_target = $CastableSpell_Heal(thisagent, target, new_spell);
	if ($TrySelectSpell(thisagent, new_target, new_spell))
		return new_spell;
	
	return "nothing";
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Follow( agent thisagent, agent target ) is string
// List of Healing spells to retrieve for a hero.
// Currently ignoring mana cost.

declare
	string new_spell;
	agent new_target;

begin
	$Reset_Best_Spell(thisagent);

	if ($isvalidgamepiece(target))
		if ($isbuilding(target))
			return "nothing";

	new_spell = "healer_heal";
	new_target = $CastableSpell_Heal(thisagent, target, new_spell);
	if ($TrySelectSpell(thisagent, new_target, new_spell))
		return new_spell;
	
	new_spell = "Meditation";
	new_target = $CastableSpell_Follow(thisagent, target, new_spell);
	if ($TrySelectSpell(thisagent, new_target, new_spell))
		return new_spell;
	
	new_spell = "generic_regenerate";
	new_target = $CastableSpell_Heal(thisagent, target, new_spell);
	if ($TrySelectSpell(thisagent, new_target, new_spell))
		return new_spell;
	
	return "nothing";
end


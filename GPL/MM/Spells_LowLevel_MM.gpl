function EffectDebuff( agent thisagent, agent target, integer effect ) is integer
// Batch code for debuff effect modifiers
//
declare
	integer new_effect;
begin
	new_effect = $WisdomDebuffEffect(thisagent, effect);
	new_effect = $WillpowerDebuffEffect(target, new_effect);
	return new_effect;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function EffectBuff_Thread( integer willpower, integer wisdom, integer effect ) is integer
// Batch code for buff effect modifiers
//
declare
	integer new_effect;
begin
	new_effect = $WisdomBuffEffect_Thread(wisdom, effect);
	new_effect = $WillpowerBuffEffect_Thread(willpower, new_effect);
	return new_effect;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function EffectDebuff_Thread( integer willpower, integer wisdom, integer effect ) is integer
// Batch code for debuff effect modifiers
//
declare
	integer new_effect;
begin
	new_effect = $WisdomDebuffEffect_Thread(wisdom, effect);
	new_effect = $WillpowerDebuffEffect_Thread(willpower, new_effect);
	return new_effect;
end

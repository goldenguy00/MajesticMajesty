/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellManaAvailable( agent thisagent, string spell_name ) is boolean
declare
begin
	if (thisagent's "type" != "hero")
		return true;
	if ($GetIntegerSafe(thisagent, "CurrentMana") >= $SpellManaCost(thisagent, spell_name))
		return TRUE;
	return FALSE;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellResourceAvailable( agent thisagent, string spell_name ) is boolean
// Checks for mana/stamina availability
// Currently only checks for mana
declare
begin
	if (thisagent's "type" != "hero")
		return true;
	if ($GetIntegerSafe(thisagent, "CurrentMana") >= $SpellManaCost(thisagent, spell_name))
		return TRUE;
	return FALSE;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellResourceCost( agent thisagent, string spell_name ) is integer
// List of spell costs of mana/stamina
//Currently only checks for mana
declare
	integer spell_level, mana_increase, total_cost;
	string mana_cost, mana_mult, mana_div;

begin
	if (thisagent's "type" != "hero")
		return 0;
	mana_cost = spell_name + "_Mana";
	mana_mult = spell_name + "_Mana_Mult";
	mana_div = spell_name + "_Mana_Div";

	spell_level =  $GetSpellRank(thisagent, spell_name);
	mana_increase = (((spell_level - 1) * thisagent's mana_mult) / thisagent's mana_div);
	total_cost = thisagent's mana_cost + mana_increase;
	
	return $WisdomManaReduction(thisagent, total_cost);
end

///////////////////////////////////////////////////////////////////////////////
function getattackrange(agent thisagent) is integer

declare
	integer arrivedist;

begin

	if ($getbestspell(thisagent,#List_attack) != "nothing")
		arrivedist = thisagent's "castingrange";
	else
		arrivedist = $HeroAttackRange(thisagent);

	return arrivedist;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IsSpellCaster( agent thisagent ) is boolean
declare
begin
	if (thisagent's "attacktype" == 3)
		return true;
	if ($hasattribute("attack_action", thisagent) == false)
		return false;
	return thisagent's "Attack_action" == "do_nothing";
end


/////////////////////////////////////////////////////////////////////////////////////////////////
function HeroAttackRange( agent thisagent ) is integer
// The distance at which a spellcaster will start casting spells.

declare
	
begin
	if ($IsSpellCaster(thisagent))
		return $PercentOf(thisagent's "castingRange", 67, false);
	
	// not casting
	return $GetAttribute(thisagent, #ATTRIB_Maxattackrange);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellManaCost( agent thisagent, string spell_name ) is integer
// List of spells to retrieve for a hero

declare
	integer base, mana_increase;

begin
	if (thisagent's "type" != "hero")
		return 0;
	////CULTIST
	if (spell_name == "camouflage")
		return $WisdomManaReduction(thisagent, 5);
	if (spell_name == "charm_monster")
		return $WisdomManaReduction(thisagent, 11);
	if (spell_name == "change_shape")
		return $WisdomManaReduction(thisagent, 16);

	////HEALER
	if (spell_name == "healer_heal")
		return $WisdomManaReduction(thisagent, 2);
	if (spell_name == "meditation")
		return $WisdomManaReduction(thisagent, 9);

	////MONK
	if (spell_name == "hands_of_steel")
		return $WisdomManaReduction(thisagent, 2);
	if (spell_name == "monk_stone_skin")
		return $WisdomManaReduction(thisagent, 5);
	if (spell_name == "iron_will")
		return $WisdomManaReduction(thisagent, 12);
	
	////PALADIN
	if (spell_name == "shield_of_light")
		return $WisdomManaReduction(thisagent, 6);
	
	////PRIESTESS
	if (spell_name == "drain_life")
		return $WisdomManaReduction(thisagent, 2);
	if (spell_name == "animate_skeleton")
		return $WisdomManaReduction(thisagent, 7);
	if (spell_name == "control_undead")
		return $WisdomManaReduction(thisagent, 9);
	if (spell_name == "priestess_wither")
		return $WisdomManaReduction(thisagent, 5);

	////SOLARUS
	if (spell_name == "sun_scorch")
		return $WisdomManaReduction(thisagent, 5);
	
	////WIZARD
	if (spell_name == "energy_blast")
		return $WisdomManaReduction(thisagent, 3);
	if (spell_name == "fire_shield")
		return $WisdomManaReduction(thisagent, 4);
	if (spell_name == "fire_blast")
		return $WisdomManaReduction(thisagent, 6);
	if (spell_name == "fire_ball")
		return $WisdomManaReduction(thisagent, 9);
	if (spell_name == "resist_magic")
		return $WisdomManaReduction(thisagent, 7);
	if (spell_name == "wizard_Transmute")
		return $WisdomManaReduction(thisagent, 10);
	if (spell_name == "meteor_storm")
		return $WisdomManaReduction(thisagent, 20);

	////GENERIC
	if (spell_name == "generic_regenerate")
		return $WisdomManaReduction(thisagent, 7);
	if (spell_name == "flame_shield")
		return $WisdomManaReduction(thisagent, 6);
	if (spell_name == "power_shock")
		return $WisdomManaReduction(thisagent, 4);

	////FIRE TREE
	if (spell_name == "firebolt")
		return $SpellResourceCost(thisagent, "firebolt");
	if (spell_name == "FireSurge")
		return $SpellResourceCost(thisagent, "FireSurge");
	if (spell_name == "Perdition_Barrage")
		return $SpellResourceCost(thisagent, "Perdition_Barrage");
	if (spell_name == "Incandescent_Ray")
		return $SpellResourceCost(thisagent, "Incandescent_Ray");
	if (spell_name == "Searing_Mantle")
		return $SpellResourceCost(thisagent, "Searing_Mantle");	
	if (spell_name == "Pyrelight")
		return $SpellResourceCost(thisagent, "Pyrelight");
	if (spell_name == "Ignite")
		return $SpellResourceCost(thisagent, "Ignite");

	return 5;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function CastRangeForSpell( integer cast_range, string spell_name ) is integer
// List of spells ranges to retrieve for a hero.
// This list determines the max cast range for each spell.

declare

begin
	////CULTIST
	if (spell_name == "camouflage")
		return $PercentOf(cast_range, 30, False);
	if (spell_name == "charm_monster")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "change_shape")
		return $PercentOf(cast_range, 30, False);
		
	////HEALER
	if (spell_name == "healer_heal")
		return $PercentOf(cast_range, 50, False);
		
	if (spell_name == "meditation")
		return $PercentOf(cast_range, 50, False);
		
	////MONK
	if (spell_name == "hands_of_steel")
		return $PercentOf(cast_range, 10, False);
		
	if (spell_name == "monk_stone_skin")
		return $PercentOf(cast_range, 50, False);
		
	if (spell_name == "iron_will")
		return $PercentOf(cast_range, 50, False);
		
	////PALADIN
	if (spell_name == "shield_of_light")
		return $PercentOf(cast_range, 50, False);
		
	////PRIESTESS
	if (spell_name == "drain_life")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "animate_skeleton")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "control_undead")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "priestess_wither")
		return $PercentOf(cast_range, 70, False);
		
	////SOLARUS
	if (spell_name == "sun_scorch")
		return $PercentOf(cast_range, 25, False);
		
	////WIZARD
	if (spell_name == "energy_blast")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_shield")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_blast")
		return $PercentOf(cast_range, 67, False);
	if (spell_name == "fire_ball")
		return $PercentOf(cast_range, 75, False);
	if (spell_name == "resist_magic")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "wizard_Transmute")
		return $PercentOf(cast_range, 67, False);
		
	////GENERIC
	if (spell_name == "generic_regenerate")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "flame_shield")
		return $PercentOf(cast_range, 50, False);
	if (spell_name == "power_shock")
		return $PercentOf(cast_range, 60, False);
		
	////GADGETS
	if (spell_name == "deploy_dart_sentry")
		return $PercentOf(cast_range, 60, False);
		
	////FIRE SKILL TREE
	if (spell_name == "firebolt")
		return $PercentOf(cast_range, 70, False);
	if (spell_name == "FireSurge")
		return $PercentOf(cast_range, 80, False);
	if (spell_name == "Perdition_Barrage")
		return $PercentOf(cast_range, 90, False);
	if (spell_name == "Incandescent_Ray")
		return $PercentOf(cast_range, 70, False);
	if (spell_name == "searing_mantle")
		return $PercentOf(cast_range, 60, False);
	if (spell_name == "Pyrelight")
		return $PercentOf(cast_range, 85, False);
	if (spell_name == "ignite")
		return $PercentOf(cast_range, 75, False);
		
	return cast_range;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////NEW SPELL FUNCTIONS/////////////////////////////////////////////////
function SpellTimeoutEffectAdvanced( agent source, string unit_name, agent target, function AScript, function DScript, string attach_effect, integer period, integer timeout, integer attribute, integer amount, integer level, integer attribute_2, integer amount_2, integer attribute_3, integer amount_3 )
// This will be used to allow scaling duration spells with an area of effect
//
declare
	agent dummy;
	coordinate Target_Loc;

begin
	Target_Loc = $LocationOf(target);
	dummy = $spawnunit(source, unit_name, Target_Loc);
	dummy's "ActiveScript" = AScript;
	dummy's "DeathScript" = DScript;
	$setparent(dummy, target);
	$SetDrawEffects( dummy, "none", 9 );
	
	$createeffector( dummy, attach_effect, timeout );
	$SetSpellUnitTimeout( dummy, timeout );
	
	$NewThread( dummy's "activeScript", period, dummy );
	
	if (attribute != 0)
		begin
			$setattribute(dummy, attribute, amount);
		end
	if (level != 0)
		begin
			$setattribute(dummy, #ATTRIB_Experience, level);
		end
	if (attribute_2 != 0)
		begin
			$setattribute(dummy, attribute_2, amount_2);
		end
	if (attribute_3 != 0)
		begin
			$setattribute(dummy, attribute_3, amount_3);
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellTimeoutEffect( agent target, function Script, integer timeout, integer attribute, integer amount, integer level, integer attribute_2, integer amount_2, integer attribute_3, integer amount_3 )
// This will be used to allow scaling duration spells
//
declare
	agent dummy;

begin
	dummy = $spawnunit(target, "spell_dummy_unit");
	dummy's "DeathScript" = Script;
	$setparent(dummy, target);
	$SetDrawEffects( dummy, "none", 9 );
	$SetSpellUnitTimeout( dummy, timeout );
	if (attribute != 0)
		begin
			$setattribute(dummy, attribute, amount);
		end
	if (level != 0)
		begin
			$setattribute(dummy, #ATTRIB_Experience, level);
		end
	if (attribute_2 != 0)
		begin
			$setattribute(dummy, attribute_2, amount_2);
		end
	if (attribute_3 != 0)
		begin
			$setattribute(dummy, attribute_3, amount_3);
		end
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ArtificeCooldownReduction_Magic( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of magic spells/abilities
//
declare
	integer stat_artifice, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_artifice = $getattribute(thisagent, #ATTRIB_Artifice);
	
	if (stat_artifice < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 133) * stat_artifice);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function ArtificeCooldownReduction_NonMagic( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of non-magic spells/abilities
//
declare
	integer stat_artifice, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_artifice = $getattribute(thisagent, #ATTRIB_Artifice);
	
	if (stat_artifice < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 100) * stat_artifice);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceCooldownReduction( agent thisagent, integer cooldown ) is integer
// The amount that Artifice reduces the cooldown of magic spells/abilities
//
declare
	integer stat_intelligence, cooldown_diff, new_cooldown;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return cooldown;
	
	cooldown_diff = ((cooldown / 200) * stat_intelligence);
	new_cooldown = (cooldown - cooldown_diff);
	
	if (new_cooldown < 300)
		new_cooldown = 300;
		
	return new_cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceDurationBuff( agent thisagent, integer duration ) is integer
// The amount that Intelligence affects the duration of buffs on the target
//
declare
	integer stat_intelligence, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return duration;
	
	duration_diff = ((duration / 125) * stat_intelligence);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function IntelligenceDurationDebuff( agent thisagent, integer duration ) is integer
// The amount that Intelligence affects the duration of buffs on the target
//
declare
	integer stat_intelligence, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_intelligence = $getattribute(thisagent, #ATTRIB_Intelligence);
	
	if (stat_intelligence < 1)
		return duration;
	
	duration_diff = ((duration / 125) * stat_intelligence);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomBuffEffect( agent thisagent, integer power ) is integer
// The amount that Wisdom affects the power of buffs
//
declare
	integer stat_wisdom, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
	
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	
	if (stat_wisdom < 1)
		return power;
	
	power_diff = ((power / 133) * stat_wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomDebuffEffect( agent thisagent, integer power ) is integer
// The amount that Wisdom affects the power of debuffs
// Right now its the same as WisdomBuffEffect
declare
	integer stat_wisdom, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
	
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	
	if (stat_wisdom < 1)
		return power;
		
	power_diff = ((power / 133) * stat_wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomManaReduction( agent thisagent, integer mana ) is integer
// The amount that Wisdom reduces the mana spent on spells
//
declare
	integer stat_wisdom, mana_diff, new_mana;

begin
	stat_wisdom = $GetBaseStatTotal(thisagent, "Wisdom");
	
	if (stat_wisdom > 0)
		begin
			mana_diff = ((mana * stat_wisdom) / 250);
			new_mana = (mana - mana_diff);
		end

	if (new_mana < 1)
		new_mana = 1;
		
	return new_mana;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerBuffEffect( agent thisagent, integer power ) is integer
// The amount that Willpower affects the power of buffs on this hero
//
declare
	integer stat_willpower, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return power;
	
	power_diff = ((power * stat_willpower) / 100);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDebuffEffect( agent thisagent, integer power ) is integer
// The amount that Willpower affects the power of debuffs on this hero
//
declare
	integer stat_willpower, power_diff, new_power;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return power;
		
	power_diff = ((power * stat_willpower) / 200);
	new_power = (power - power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerBuffEffect_Thread( integer willpower, integer power ) is integer
// The amount that Willpower affects the power of buffs on this hero
//
declare
	integer power_diff, new_power;

begin
	if (willpower < 1)
		return power;
	
	power_diff = ((power * willpower) / 100);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDebuffEffect_Thread( integer willpower, integer power ) is integer
// The amount that Willpower affects the power of debuffs on this hero
//
declare
	integer power_diff, new_power;

begin
	if (willpower < 1)
		return power;
		
	power_diff = ((power * willpower) / 200);
	new_power = (power - power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomBuffEffect_Thread( integer wisdom, integer power ) is integer
// The amount that Wisdom affects the power of buffs
//
declare
	integer power_diff, new_power;

begin
	if (wisdom < 1)
		return power;
	
	power_diff = ((power / 133) * wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WisdomDebuffEffect_Thread( integer wisdom, integer power ) is integer
// The amount that Wisdom affects the power of debuffs
// Right now its the same as WisdomBuffEffect
declare
	integer power_diff, new_power;

begin
	if (wisdom < 1)
		return power;
		
	power_diff = ((power / 133) * wisdom);
	new_power = (power + power_diff);
	
	if (new_power < 0)
		new_power = 0;
		
	return new_power;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDurationBuff( agent thisagent, integer duration ) is integer
// The amount that Willpower affects the duration of buffs
//
declare
	integer stat_willpower, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return duration;
	
	duration_diff = ((duration / 100) * stat_willpower);
	new_duration = (duration + duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function WillpowerDurationDebuff( agent thisagent, integer duration ) is integer
// The amount that Willpower affects the duration of debuffs
//
declare
	integer stat_willpower, duration_diff, new_duration;

begin
	if ($isvalidgamepiece(thisagent)!=TRUE)
		return;
		
	stat_willpower = $getattribute(thisagent, #ATTRIB_Willpower);
	
	if (stat_willpower < 1)
		return duration;
		
	duration_diff = ((duration / 200) * stat_willpower);
	new_duration = (duration - duration_diff);
	
	if (new_duration < 1000)
		new_duration = 1000;
		
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function DurationBuff( agent thisagent, agent target, integer duration ) is integer
// Batch code for buff duration modifiers
//
declare
	integer new_duration;
begin
	new_duration = $IntelligenceDurationBuff(thisagent, duration);
	new_duration = $WillpowerDurationBuff(target, new_duration);
	return new_duration;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function DurationDebuff( agent thisagent, agent target, integer duration ) is integer
// Batch code for debuff duration modifiers
//
declare
	integer new_duration;
begin
	new_duration = $IntelligenceDurationDebuff(thisagent, duration);
	new_duration = $WillpowerDurationDebuff(target, new_duration);
	return new_duration;
end


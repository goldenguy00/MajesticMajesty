function tower_blast_callback(agent thisagent,agent target)

declare
	integer stat, damagebonus;

begin
	stat = $getattribute(thisagent, #ATTRIB_Intelligence);
	if (stat > 0)
		damagebonus = (stat / 12);
	else
		damagebonus = 0;
		
	$createeffector( target, "Wizard_tower_effector", $GetSpellAttribute( "energy_blast", "effector_duration" ) );
	$spell_type_attack( thisagent, target, "Arcane", 8 + damagebonus, 12 + damagebonus );
end

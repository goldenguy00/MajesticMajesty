///////////////////////////////////////////////////////////////////////////////
prototype GuardHouse ()

declare
	string 	type;
	string 	subtype;
	string 	title;

	function Guard_Function;			//Guardhouse's version of an ActiveScript
										//This Holds the Guard script that the Building constantly runs

	function Guard_Spawn_Function;

	integer	Strength;
	integer	AttackType;
	integer	Ranged;


	boolean in_danger; 					// has the building been hit lately

	list Waiting_Guards;				//This list holds Guards that have suspended their threads
	list Guards;  						//List of this building's Guards

	list Occupants; 					//This holds all of the Heroes who are currently in the Guardhouse. For Use_Building.

	list Under_Const_In_Sight; 			//This is the list of all Buildings Under construction within sight

	integer	Max_Guards; 				//Holds the Maximum number of Guards a guardhouse can have
	integer	Num_Guards; 				//Keeps track of current number of Guards Guardhouse has or is spawning

 //	boolean	Hero_Guarded; 				//TRUE if the Guardhouse currently has a Hero Guard. FALSE if they don't.

	integer	Sleep_For; 					//This tells Heroes how long to stay IN the Guardhouse for.

	agent Target; 						//This holds the Guardhouse's target. It is for firing arrows.

	string	TaskName;

	string 	Enemytype;

	function RevenueScript; 			//This holds the script that either Auto Adds or Subracts money from the player's gold
	integer	Revenue_Amount; 			//Either Pos or Neg, this is the amount of gold the Revenue Script adds or subtracts
	integer	Revenue_Time; 				//This is how frequently a building executes its RevenueScript

	function Visited_Script; 			//This holds the script that Heroes call when they enter the Guardhouse

	function upgradescript;

	function birthScript;  				// This script will be called once, when the unit is created;
	function birthScript2;  			// This script will be called once, when the building is 'completed;
	function IGdeathScript; 			// This script will be called once, when the unit is ki  lled;
	function deathScript; 				// This script will be called once, when the unit is killed;
	
//////////////////////////////////////////Combat Attributes///////////////

	integer Experience_Value_Base;
	integer XPMultiplier;
	string IntentExt;
	
	integer Physical_Attack;
	string Physical_Attack_Type;
	
	integer Magical_Attack;
	string Magical_Attack_Type;
	
	integer Armor_Physical_Base;
	integer Armor_Physical_Total;
	
	integer Armor_Magical_Base;
	integer Armor_Magical_Total;

	/////////////////////////////////////////Misc Attributes///////////////
	list Upgrades;					//A list holding functions for upgrades applied to this unit on birth

	integer Max_City_Guard;
	integer Max_Archer;
	integer Num_City_Guard;
	integer Num_Archer;

	function Initial_Misc; //Any objects that are added to the Available Misc List on the birth of the structure.
	function Initial_Research; //Upgrades that are added to the Available Upgrade List on the birth of the structure.
	
	list Attachments;
	coordinate research_loc;
	integer level;
	integer max_level;

begin
end

///////////////////////////////////////////////////////////////////////////////

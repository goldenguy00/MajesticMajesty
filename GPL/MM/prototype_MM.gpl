///////////////////////////////////////////////////////////////////////////////
prototype Lair ()
Declare
	string 	type;
	string 	subtype;
	string 	title;

	integer	History_Modifier; 			//A counter that is incremented depending on a monster's strength. Used to adjust spawn_rate.

	// These are both used when a building is too close to a Lair. The lair become annoyed,
	// and sets the offending building as its target, which all of the Lairs spawned creatures querry.
	// boolean	Annoyed;
	
	agent		Target;

	integer	Dispersion_Range;
	
	function activescript;
	function Spawn_Function; 			// This Holds the agent's Spawning mechanism


	integer	Base_Spawn_Rate; 			// This is for lairs, it holds BaseLine interval between monster creations

	integer	difficulty; 				// this holds the relative difficulty of the lair for a character to undertake

	string Spawn_Type; 					// Holds the type of monster the lair spawns
	string Special_Spawn_Type; 			// Holds the "special" monster to spawn when the Lair is destroyed

	integer	Multi_Spawn_Num; 			// Number of spawns a lair will do when it dies if it uses Lair_Multispawn_Death
	integer  Stored_Spawns; 			// Number of spawns a lair has stored up to release when hit. Used only by Goblin fort.

	integer  Max_Simul_Spawns; 			// Currently Used by the Goblin Fortress. Max number of Gobs it spawns at a time.
	integer	Max_Stored_Spawns; 			// Currently used by the Goblin Fortress. Max number of spawns that the unit can store up
										// To dump on enemies that come up and whack it.

	boolean	Has_Special_Spawn; 			// This is set to TRUE if the lair wants to spawn its special spawn type instead of its
										// lairdata special spawn list

	//removed because now we only use inventory attribs
	//integer	Epic_Quest_Item; //This	holds and integer that corresponed to an entry in qitmes.txt (if applicable)

	function birthScript;  				// This script will be called once, when the unit is created;
	function IGdeathScript; 			// This script will be called once, when the unit is killed;
	function deathScript; 				// This script will be called once, when the unit is killed;
	
//////////////////////////////////////////Combat Attributes///////////////

	integer Experience_Value_Base;
	integer XPMultiplier;
	string IntentExt;
	
	integer Armor_Physical_Base;
	integer Armor_Physical_Total;
	
	integer Armor_Magical_Base;
	integer Armor_Magical_Total;

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Tower_Lair ()
// This is the prototype for a tower lair.  These are MX monster buildings that are capable of firing
// bolts as well as potentially spawning creatures.

Declare
	string type;
	string subtype;
	string title;

	integer	History_Modifier; 			//A counter that is incremented depending on a monster's strength. Used to adjust spawn_rate.

	// These are both used when a building is too close to a Lair. The lair become annoyed,
	// and sets the offending building as its target, which all of the Lairs spawned creatures querry.
	// boolean	Annoyed;
	
	agent Target;

	integer	Dispersion_Range;

	function activescript;
	function basicscript; 				// this holds the basic script the monster
										// always returns to when done with tasks
	function backscript;

	function Spawn_Function; 			//This Holds the agent's Spawning mechanism

	integer	Base_Spawn_Rate; 			//This is for lairs, it holds BaseLine interval between monster creations

	integer	difficulty; 				// this holds the relative difficulty of the lair for a character to undertake

	string Spawn_Type; 					// Holds the type of monster the lair spawns
	string Special_Spawn_Type; 			// Holds the "special" monster to spawn when the Lair is destroyed

	integer	Multi_Spawn_Num; 			//Number of spawns a lair will do when it dies if it uses Lair_Multispawn_Death

	boolean	Has_Special_Spawn; 			//This is set to TRUE if the lair wants to spawn its special spawn type instead of its
										//lairdata special spawn list

	integer  Max_Simul_Spawns; 			//Currently Used by the Spire. Max number of Gobs it spawns at a time.
	integer	Max_Stored_Spawns; 			//Currently used by the Spire. Max number of spawns that the unit can store up
										//To dump on enemies that come up and whack it.

	function birthScript;  				// This script will be called once, when the unit is created;
	function IGdeathScript; 			// This script will be called once, when the unit is killed;
	function deathScript; 				// This script will be called once, when the unit is killed;

	/////////////////////////////////////////////////////////////////////////
	// This stuff below was scavenged from the ballista tower to handle tower
	// weapon functions for the special MX guntower lairs.
	boolean in_danger;

	integer	Strength;
	integer	HtoH;
	integer	Ranged;
	integer	AttackType;

	string current_gun; 				// Used for spires of death only.

  	string attack_action;
	string EnemyType;
	//
	/////////////////////////////////////////////////////////////////////////

	list grovelist; 					// used by the Fortress of Ixmil only.
	
//////////////////////////////////////////Combat Attributes///////////////

	integer Experience_Value_Base;
	integer XPMultiplier;
	string IntentExt;
	
	integer Physical_Attack;
	string Physical_Attack_Type;
	
	integer Magical_Attack;
	string Magical_Attack_Type;
	
	integer Armor_Physical_Base;
	integer Armor_Physical_Total;
	
	integer Armor_Magical_Base;
	integer Armor_Magical_Total;

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype building ()

declare
	string type;
	string subtype;
	string title;

	boolean in_danger; 					// has the building been hit lately

	integer Level; 						//This is what Level this building is

	integer Sleep_For; 					//This holds how long a building holds Heroes for

	function visited_script; 			//holds the Building's visited function. Requested by Heroes.

	function ActiveScript; 				//For any buildings, like the TradingPost, that have ActiveScripts

	list Occupants;  					//List of all Occupants currently being held in this building

	function RevenueScript; 			//This holds the script that either Auto Adds or Subracts money from the player's gold
	integer	Revenue_Amount; 			//Either Pos or Neg, this is the amount of gold the Revenue Script adds or subtracts
	integer	Revenue_Time; 				//This is how frequently a building executes its RevenueScript

	integer Magical_Build_Rate; 		// Used to determine how fast magical buildings construct or upgrade.

	function spawn_1;  					// these are used if the building needs to spawn other buildings

	function birthScript;  				// This script will be called once, when the unit is created;
	function birthScript2;  			// This script will be called once, when the building is 'completed;
	function IGdeathScript; 			// This script will be called once, when the unit is killed;
	function deathScript; 				// This script will be called once, when the unit is killed;

	function upgradescript;
		
//////////////////////////////////////////Combat Attributes///////////////

	integer Experience_Value_Base;
	integer XPMultiplier;
	string IntentExt;
	
	integer Armor_Physical_Base;
	integer Armor_Physical_Total;
	
	integer Armor_Magical_Base;
	integer Armor_Magical_Total;

	/////////////////////////////////////////Misc Attributes///////////////
	function Initial_Misc; //Any objects that are added to the Available Misc List on the birth of the structure.
	function Initial_Research; //Upgrades that are added to the Available Upgrade List on the birth of the structure.

	list Attachments;
	coordinate research_loc;
	integer max_level;
begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Outpost ()

Declare
	string 	type;
	string 	subtype;
	string 	title;

	function activescript;
	integer level;

	agent Target;

	boolean in_danger;

	function Guard_Function;			//This Holds the Guard script that the Building constantly runs (after being set off by trigger)

	function Guard_Spawn_Function; 		//This holds the Spawn_Function for the Palace. It is on the agent because
										//it gets $RunThread-ed, so it needs to be persistent.

	list Waiting_Guards;				//This list holds Guards that have suspended their threads, and don't have targets
	list Guards;  						//List of this building's Guards

	list Waiting_Guardhouses; 			//This is a list of Guardhouses that are waiting for Guards.

	integer	Max_Guards; 				//Holds the Maximum number of Guards a palace can have
	integer	Num_Guards; 				//Keeps track of current number of Guards Palace has or is spawning

	integer	AttackType; 				//These are so the outpost can fire missiles.
	integer Ranged;
	integer	Strength;

	function Lived_In_Script; 			//Holds script that tells the character what to do here

	integer	Sleep_For;  				//This holds the duration a unit stays here for
	list Occupants;  					//List of all Occupants currently being held in this building

	list members; 						// all the current guild members
	// integer max_members;
	
	function spell_callback;			// special callback for spells (only used for supercharge for now)

	function tax_spawn;

	integer num_tax_collectors;
	integer max_tax_collectors;

	list tax_route;
	list tax_targets;

	list spawn_taxman_return_list; 		//These lists hold deadtax collectors tax attribs so
	list spawn_taxman_pickup_list; 		//that the next one gets spawned with the same Attribs

	integer tax_route_dead;

	function peasant_spawn;

	integer num_peasants;
	integer max_peasants;
	integer busy_peasants;

	list buildings_waiting;
	list buildings_under_construction;

	list Under_Const_In_Sight; 			//This is the list of all Buildings Under construction within sight

	integer	Vaporized_Gold; 			//Gold that has been vapoized when heroes spend money, etc.
	integer  troll_gold; 				// gold that is counting up to produce a troll somewhere in town

	agent Swarm_Target; 				//Holds the target that the Swarmers refer to/fill up when they want to combat wandering monsters

	function gnome_camp_spawner; 		// holds the function which spawns Gnome Camps

	Boolean Gambling_hall_building;
	boolean gazebo_building;

	integer Population_counter; 		// counts total # heroes recruited in town
	integer Waiting_population; 		// how much extras are waiting for housing

	integer num_deceased_heroes;

	integer total_buildings; 			// counts how many buildings have been built
	integer buildings_lately; 			// counts how many buildings have been built since the last sewer

	integer henchmen_dead_lately; 		//counts how many henchmen have died since last broken sewer main spawn

	integer fountain_buildings; 		// counts how many buildings towards a fountain have been built

	integer blacksmith_trips; 			// how many visits to the blacksmith?

	string  TaskName;

	integer heroes_to_upgrade; 			// how many heroes are needed to upgrade the palace

	integer num_resources;

	string 	Enemytype;

	function birthScript;  				// This script will be called once, when the unit is created;
	function IGdeathScript; 			// This script will be called once, when the unit is killed;
	function deathScript; 				// This script will be called once, when the unit is killed;

	function BirthScript2;

	function upgradescript;
	function upgradescript2;
	
//////////////////////////////////////////Combat Attributes///////////////

	integer Experience_Value_Base;
	integer XPMultiplier;
	string IntentExt;
	
	integer Armor_Physical_Base;
	integer Armor_Physical_Total;
	
	integer Armor_Magical_Base;
	integer Armor_Magical_Total;

	/////////////////////////////////////////Misc Attributes///////////////
	function Initial_Misc; //Any objects that are added to the Available Misc List on the birth of the structure.
	function Initial_Research; //Upgrades that are added to the Available Upgrade List on the birth of the structure.

	list Attachments;
	coordinate research_loc;
	integer max_level;
begin
end


end

///////////////////////////////////////////////////////////////////////////////
//Convert books that are used for reading into Services, not items
prototype Book_Item()
Declare
	boolean owned;
	
	string type;
	string subtype;
	string title;
	string IntentExt;

	integer gold_value;
	integer XP_value; //Experience gained from reading this book
	integer XPMultiplier; //The Level of experience gained from the book being read.

	function transferScript;  	// This script will be called when the item is transfered to its new owner.
	function birthScript;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Research()
Declare
	string type;
	string subtype;
	string title;
	string IntentExt;

	string ResearchStatus;		//Is it Complete(Green), Available(Blue), Unavailable(Red), Researching(Yellow)
	string ResearchDisplayName;		//The string name for the Research when applying specify name changes to reflect status
									//The string name must be set in a function, not in .dat
	
	string ResearchVoice;		//The advisor voice to use for this research
	
	string Service_Title;		//If a service is assosciated with the research, then it's title is used to spawn the service at the corresponding attachment. If no service_title is listed, then use "None"
	string Service_Type;		//Item or Unit (If an item, it becomes a part of the Service menu, if a unit like a City Guard, it is used as the guard spawn type
	
	integer gold_value;			//The gold cost of the Research
	integer Research_Time;		//The time it takes for the research to complete
	integer Level;				//The Level of Research if it can have multiple levels (Blacksmith equipment upgrades for example)
	integer Max_Level;			//The max Level a research can reach
	
	list Checklist;			//The list for all Research titles in the same structure that had this research as a Requirement to now check for.

	function birthScript;  	// This script is a dummy call, since you don't necessarily want it triggered right when it spawns
	function birthScript2;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;
	function DismissScript; 	// Function to call when the research is attempted (The Dismiss Hero button in this case)
	function ResearchCompleteScript;	//The function to call when the research is complete
	function ResearchCheck;
	
	string Increment;			//The attribute this research increments on completion
	integer Increment_Amount;			//The amount to increase by
	
	boolean Repeatable;			//Is the research repeatable, still requires passing it's ResearchCheck
	function RepeatableCheck;		//Determine if the research should be labelled as Complete or Unavailable depending on this check.
	
	agent Container;			//The container object for this Research item
	agent PrimaryStructure;		//The structure that holds the container object. The Primary Building that the research is occurring at
	
	agent ResearchText;		//The floating text research assosciated with this agent

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Service() //For available service agents available at structures (Potions in Marketplace)
					//Can NOT double as items!!!
					//Sequence of events: Hero checks shop -> Looks at Services -> Active script set to use_building, Task_Name given by Service looked at (for this case, it's the service "Title"
					//Hero enters building -> Task_Name correlates to Service in list from which hero determines duration at structure, gold costs, and items gained.
Declare
	string type;
	string subtype;
	string title;
	string IntentExt;
	
	string service_title;			//If an item service, this corresponds to the item's title

	string ServiceDisplayName;		//The string name for the Service when applying specify name changes to reflect status
									//The string name must be set in a function, not in .dat
	
	integer gold_value;					//The gold cost of the Service for heroes
	integer Service_Time;				//The time it takes for the service to be handled for the hero
	integer Service_Time_Increment;		//The additional time if the service has been multi-purchased (buying multiple potions instead of one)
	integer Level;						//The Level of the service if applicable
	
	list Requirements;					//The requirements for the Service in order for a hero to use it.
	list Hero_Preference;				//The heroes that prefer this service.

	function birthScript;  				//This script will be called once, when the unit is created;
	function birthScript2;  	// This script will be called once, when the unit is created;
	function deathScript; 				//This script will be called once, when the unit is killed;
	function IGDeathScript;
	function DismissScript; 			//Respawns the service if it ends up being dismissed
	function ServiceCheckScript;		//The function to call when the service is being checked for by the hero (the Conditions for the service to be used)
	
	agent Container;					//The container object for this Service
	agent PrimaryStructure;				//The structure that holds the container object. The Primary Building that the service is occurring at

begin
end

///////////////////////////////////////////////////////////////////////////////
prototype FloatingText()
Declare
	string type;
	string subtype;
	string title;

	string text;
	integer duration;			//The total amount of time needed to pass
	integer duration_current; 	//The amount of time currently passed
	integer update_counter;		//The counter for when to update the floating text display (should reset at 3, approximately 1500 miliseconds)
								//Update_Counter really only useful for Research % display
	list Research_Queue;			//The list for researches that are queued for this text
	
	integer gold_value;					//The gold cost for any research incurred for floating text
	
	function birthScript;  	// This script will be called once, when the unit is created
	function deathScript; 	// This script will be called once, when the unit is killed
	function textScript;  	// This script will periodically update the text for research
	function callbackScript; 	// This script will be called when the text duration ends
	
	agent research;			//The research that was dismissed to call the floating text if applicable
	
	agent target;			//The target agent for the floating text to use as a reference (The primary structure)
	coordinate loc;		//The location of the text if there is no target
	
	boolean target_linked;	//For whether the text relies on the target being valid in order to continue being run
	boolean target_locked;	//For whether the text updates and moves with the target while running

	boolean is_research;	//For whether the floating text is a Research text
begin
end

///////////////////////////////////////////////////////////////////////////////
prototype Equipment()
Declare
	string type;
	string subtype;
	string title;
	string subclass;
	integer gold_value;
	boolean owned;

	boolean armor_struct;
	boolean weapon_struct;
	
	integer num_enchant;
	integer num_upgrade;
	
	integer upgrade_level;
	
	string upgrade_equipment;
	string upgrade_increase;
	
	string Equip_Slot;

	integer Physical_Armor_Value;	
	integer Magical_Armor_Value;
	
	string Physical_Damage_Type;
	string Magical_Damage_Type;

	integer Physical_Damage;
	integer Magical_Damage;
	
	function transferScript;  	// This script will be called when the item is transfered to its new owner.
	function birthScript;  	// This script will be called once, when the unit is created;
	function deathScript; 	// This script will be called once, when the unit is killed;
	function IGDeathScript;

begin
end
///////////////////////////////////////////////////////////////////////////////
///////////////////////////////////////////////////////////////////////////////
prototype Flag()
// added the charm_percentage integer for zoo flags.
declare
	string type;
	string subtype;
	string title;

	function birthscript;
	function deathScript;
	function IGDeathScript;
	function activescript;
	
	boolean gavereward;
	list heroes;

// New MX stuff below this point //
	integer charm_percentage;
	
	agent Killing_Unit;
	
	list hostiles;
	agent target;
begin
end

///////////////////////////////////////////////////////////////////////////////
prototype map_goodie()
declare
	string 	type;
	string 	subtype;
	string 	title;
	function birthscript; 				// not used, but attribute must exist for $NewUnitInit()
	function deathScript; 				// not used, but attribute must exist for $UnitDelete()
	function activescript;

	function IGDeathScript; 			// not used, but attribute must exist for $Unit_Call_Deathscript()
	
	agent Container;			//The container object for this item.
	agent PrimaryStructure;		//The structure that holds the container object.
begin
end

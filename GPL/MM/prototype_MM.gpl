	integer Electric_Resistance_Flat;
	integer Poison_Resistance_Flat;
	integer Arcane_Resistance_Flat;
	integer Force_Resistance_Flat;
	integer Divine_Resistance_Flat;
	integer Necrotic_Resistance_Flat;
	integer Chaotic_Resistance_Flat;

	integer Crushing_Resistance_Flat;
	integer Piercing_Resistance_Flat;
	
	boolean Fire_Resistance_Flat_Neg;
	boolean Cold_Resistance_Flat_Neg; 
	boolean Electric_Resistance_Flat_Neg;
	boolean Poison_Resistance_Flat_Neg;
	boolean Arcane_Resistance_Flat_Neg;
	boolean Force_Resistance_Flat_Neg;
	boolean Divine_Resistance_Flat_Neg;
	boolean Necrotic_Resistance_Flat_Neg;
	boolean Chaotic_Resistance_Flat_Neg;
	boolean Slashing_Resistance_Flat_Neg;
	boolean Crushing_Resistance_Flat_Neg;
	boolean Piercing_Resistance_Flat_Neg;
	
	//////////////////////////////////////////General Attributes///////////////
	
	function TASK_StartingScript;
	function TASK_TaskScript;
	//////////////////////////
	//	Maybe thinking about it all wrong, instead of a Primary task with a conclusion, maybe just have the hero cycle through them?
	//	Prepare -> Combat -> Idle -> Explore but maybe randomize it or base it on hero with weighted preferences.
	//	Support task types are for things like Dwarfs and Gnomes aiding in construction, Adepts Patrolling, Solarus Garrisonning, Healers/Cultists seeding plants, etc.
	//	Quest tasks have their completed parts removed from the list and the next part added as part of the Quest tasks function to allow the hero to retroactively add it to their cycle.
	//	Maybe just stick to Current, Next, Backup, and Immediate
	//	Make the primary and conclusion taks for thing that need to be done in a process, like quests or other activities that simply can't be randomly sequenced
	//	Current Task -> The task from the que actively being carried out
	//	Next Task -> The task that comes next from the que. Must not be the same as the Current Task.
	//	Backup Task -> The task that comes in case the Current Task can't be accomplished. May be the same as the Current Task.
	//	Immediate Task -> The task that comes immediately after the Current Task has been attempted for emergencies (home under attack).
	//	Stored? Task -> Storage for the Current Task if it's overtaken by an Immediate Task. Maybe not if it overlaps with Next Task.
	//	Reserved? Task -> This task can be given to Next or Backup as the situation demands if either of those aren't available in time.
	//	Taskflow should change to Current -> Next, Next -> Search for task, Backup -> Search for Task. Current -> Backup, Backup -> Search for Task, Next remains unchanged.
	//////////////////////////
	integer TASK_activeGuid;
	string TASK_activeStatus; //The status of the Current task (Failed, Complete, Skip, Rereoll, Ongoing)
	string TASK_activeType; //What type the Task Packages are currently set to look for and are static (Combat, Prepare, Explore)
	string TASK_activeSubset; // The Index that determines it is for the Current, Next, Backup, Reserve task.
	integer TASK_activeChance;
	string TASK_activeTaskName;

	list TASK_globalNameList;
	list TASK_globalChanceList;
	list TASK_globalTypeList;
	list TASK_globalTaskList;

	integer TASK_typeBaseChancePrepare;
	integer TASK_typeBaseChanceCombat;

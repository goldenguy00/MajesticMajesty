	//flist << $rest;						//Idle //Need to adress this or it'll just trigger instantly instead of waiting in a task que
	//clist << $notvalid;					//Appears to be something that is determined on an immediate basis rather than something that is queued, probably have it be an action following each combat task?
	//$SetTaskParametersBasic(thisagent, "None", 100, "Idle");
	
	flist << $Check_Wizards_Guild_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 85, "Prepare");
	
	flist << $Check_Library_Books_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 75, "Prepare");
	
	flist << $Open_Bank_Account_Packet;			//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Check_Marketplace_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Check_Blacksmith_Packet;		//Prepare
	$SetTaskParametersBasic(thisagent, "None", 100, "Prepare");
	
	flist << $Purchase_bazaar_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 70, "Prepare");
	
	flist << $pursue_entertainment_Packet;		//Idle
	$SetTaskParametersBasic(thisagent, "None", 100, "Idle");
	
	flist << $Hall_Champs_Check_Packet;	//Prepare
	$SetTaskParametersBasic(thisagent, "None", 30, "Prepare");
	
	flist << $Raid_lair_Packet;			//Combat
	$SetTaskParametersBasic(thisagent, "None", 45, "Combat");
	
	flist << $raid_enemy_building_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 30, "Combat");
	
	flist << $Combat_wandering_packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 65, "Combat");
	
	flist << $combat_wandering_heroes_packet;	//Combat
	$SetTaskParametersBasic(thisagent, "None", 60, "Combat");
	
	flist << $Explore_Map_Packet;	//Explore
	$SetTaskParametersBasic(thisagent, "None", 50, "Explore");
	
	flist << $Go_Home_Packet;	//Idle
	$SetTaskParametersBasic(thisagent, "None", 85, "Idle");
	
	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Wizard_spell", 90, "Prepare");

	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Wizard_train_intel", 55, "Prepare");
	
	flist << $check_library_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Train_magic_resist", 15, "Prepare");
	
	flist << $defend_building_Packet;	//Defend
	$SetTaskParametersBasic(thisagent, "Library", 100, "Defend");
	
	flist << $defend_building_Packet;	//Defend
	$SetTaskParametersBasic(thisagent, "Marketplace", 100, "Defend");
	
	flist << $follow_support_check_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "barbarian", 30, "Combat");
	
	flist << $follow_support_check_Packet;	//Combat
	$SetTaskParametersBasic(thisagent, "monk", 20, "Combat");
	
	flist << $Visit_Building_Other_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "General_Housing_Lv3", 70, "Prepare");
	
	flist << $Visit_Building_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Royal_gardens", 5, "Prepare");
	
	flist << $Visit_Building_Other_Packet;	//Preapre
	$SetTaskParametersBasic(thisagent, "Shrine", 25, "Prepare");
	
	size = $ListSize(flist); // If an agent gets new tasks packets dynamically, the list part can be added in manually without the need for
	while (size > count) do			// another while/do action. This was to consolidate the total size of code for this part.
		begin
			count ++;
			string2 = string1 + $ListMember(thisagent's "TaskPackageTypeList", count); // For Example, "TaskPackageIndexList" + "Combat"
			string6 = string5 + $ListMember(thisagent's "TaskPackageTypeList", count); // For Example, "TaskPackageIndex" + "Combat"
			thisagent's string2 << $ListMember(flist, count); // Add functions to "TaskPackageIndexList"
			thisagent's string6 << count; 					  // Add the index itself, a numerical tracker for each task into "TaskPackageIndex";
			if ((($ListMember(thisagent's "TaskPackageTypeList", count)) == "Combat") || (($ListMember(thisagent's "TaskPackageTypeList", count)) == "Prepare")) //Update this, everything except "Defend" and "General" should have thresholds.
				begin
					string8 = string7 + $ListMember(thisagent's "TaskPackageTypeList", count);
					thisagent's string8 ++; // For Example, "TaskThreshold" + "Combat" //Threshold is the same as the list count of the amount of tasks in that task type.
				end
		end
	
	if (thisagent's "TaskPackageTargetActionCurrent" != $Use_Building_Packet)
		thisagent's "TaskPackageTargetActionCurrent" = $Search_For_Task;
	thisagent's "TaskPackageTargetActionNext" = $Search_For_Task;
	thisagent's "TaskPackageTargetActionBackup" = $Search_For_Task;

end

///////////////////////////////////////////////////////////////////////////////
function Wizard_Initial_Task (agent thisagent)
declare
	
begin
	if (thisagent's "Home" == $nullagent())
		thisagent's "activescript" = $Wizard_Tree;
	else if ($GetTitle(thisagent's "Home") == "Wizards_Guild")
		begin
			ThisAgent's "TaskPackageTargetCurrent" = thisagent's "Home";
			ThisAgent's "TaskPackageTaskNameCurrent" = "MAGICALTREATISES1";
			ThisAgent's "TaskPackageIntentCurrent" = "IDTXT_INTENT_STUDYINGATWIZARDSGUILD";
			ThisAgent's "TaskPackageTargetActionCurrent" = $Use_Building_Packet;
			ThisAgent's "TaskPackageVisitingScriptCurrent" = $wizards_guild_visited;
			ThisAgent's "TaskPackageTargetConditionCurrent" = $isdead;
			$reset_tasks(thisagent);
			thisagent's "TaskPackageStatus" = "Ongoing";
		end
	else
		thisagent's "activescript" = $Wizard_Tree;
end
///////////////////////////////////////////////////////////////////////////////
function reset_tasks(agent thisagent)

declare

begin
	if ($HasAttribute("TaskPackageStatus", thisagent))
		thisagent's "TaskPackageStatus" = "Complete";
	
	$StopMoving (ThisAgent);

	$clearlist(thisagent's "hostiles");

	thisagent's "activescript" = thisagent's "basicscript";
	thisagent's "backscript" = thisagent's "basicscript";
	thisagent's "target" = $Nullagent();

	$SetStringSafe(thisagent, "best_spell", "nothing");
	$SetAgentSafe(thisagent, "best_target", $Nullagent());
	$SetBooleanSafe(thisagent, "In_Combat", false);
end

///////////////////////////////////////////////////////////////////////////////
//This function is for the most basic types of actions a hero can be expected to execute if one is imminently required
function Generic_tree (agent thisagent)
declare
begin

//	//$DebugOut("I'm deciding what to do!");
					
	$createeffector(thisagent,"thought_bubble_think",#think_bubble_time);
	$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_THINKING");

	if ($check_nearby(thisagent) == False)

	if ($Check_Rewards(thisagent,FALSE) == False)

	if ($Defend_home(thisagent) == False)

	if ($rest(thisagent) == False)
	
	if ($Open_Bank_Account(thisagent) == False)

	if ($Explore_Map(thisagent,thisagent's "TaskChanceExplore") == False)

	if ($Defend_Building_Nearby(thisagent) == false)
	
	if ($Go_Home(thisagent,thisagent's "TaskChanceIdle") == False)

		begin
			$SpecifyIntentString (ThisAgent, "IDTXT_INTENT_WANDERING");
			thisagent's "counter" = 0;
			thisagent's "activescript" = $hero_wander;
		end

end

///////////////////////////////////////////////////////////////////////////////
function NextTask (agent thisagent)

declare

begin

//	//$DebugOut("I'm deciding what to do!");
	if ($isdead(thisagent))
		begin
			thisagent's "activescript" = $be_dead;
			return;
		end
	
	if ((thisagent's "TaskPackageTargetActionCurrent") != $Search_For_Task)
		begin
			if (thisagent's "TaskPackageStatus" == "Engaged")
				if ($ValidFunction(thisagent's "TaskPackageTargetConditionCurrent"))
					if ((thisagent's "TaskPackageTargetConditionCurrent")(thisagent's "TaskPackageTargetCurrent"))  // This is to check whether or not the target this hero attacked is dead after already engaging the target once in combat.
						begin																								//  By default, if it is, whether or not it died in the engagement with the hero, it will mark as complete
							thisagent's "TaskPackageStatus" = "Complete";
						end

			if (thisagent's "TaskPackageStatus" == "Ongoing")
				if ($ValidFunction(thisagent's "TaskPackageTargetConditionCurrent"))
					if ((thisagent's "TaskPackageTargetConditionCurrent")(thisagent's "TaskPackageTargetCurrent"))  // This is to check whether or not the target of the action is no longer valid.
						begin																								//  On this case, it will be marked as Retry for the Status
							thisagent's "TaskPackageStatus" = "Retry";
						end
		end

	if (thisagent's "TaskPackageStatus" == "Complete")
		begin
			thisagent's "TaskPackageStatus" = "Ongoing";
			thisagent's "TaskPackageFled" = 0;
			$NextTaskSequence(thisagent, "Current", "Next");
			$NextTaskSequence(thisagent, "Backup", "Reserve");
			thisagent's "TaskPackageTargetActionNext" = $Search_For_Task;
			thisagent's "TaskPackageTargetActionReserve" = $Search_For_Task;
		end
	else if (thisagent's "TaskPackageStatus" == "Retry")
		begin
			thisagent's "TaskPackageStatus" = "Ongoing";
			$NextTaskSequence(thisagent, "Current", "Backup");
			$NextTaskSequence(thisagent, "Backup", "Reserve"); //This makes it so if the agent Retries a second time, he invariably moves onto the Next Task anyway instead of looping forever on one type of task.
			thisagent's "TaskPackageTargetActionReserve" = $Search_For_Task;
		
		end
	else if (thisagent's "TaskPackageStatus" == "Failed") //Currently for if the agent has fled too many times while in pursuit of the task.
		begin											//Has the same effect as completing the task though... Need to remedy that// Change the task set to Preparation/Idle?
			thisagent's "TaskPackageStatus" = "Ongoing";
			$NextTaskSequence(thisagent, "Current", "Next");
			$NextTaskSequence(thisagent, "Backup", "Reserve");
			thisagent's "TaskPackageTargetActionNext" = $Search_For_Task;
			thisagent's "TaskPackageTargetActionReserve" = $Search_For_Task;
		end
	
	if ((thisagent's "TaskPackageTargetActionCurrent") != $Search_For_Task)
		begin
			thisagent's "Target" = thisagent's "TaskPackageTargetCurrent";
			thisagent's "BackTarget" = thisagent's "TaskPackageTarget2Current";
			thisagent's "ActiveScript" = thisagent's "TaskPackageTargetActionCurrent";
			thisagent's "BackScript" = thisagent's "TaskPackageTargetAction2Current";
			thisagent's "TaskName" = thisagent's "TaskPackageTaskNameCurrent";
			thisagent's "Destination" = thisagent's "TaskPackageDestinationCurrent";
			thisagent's "VisitingScript" = thisagent's "TaskPackageVisitingScriptCurrent";
			$SpecifyIntentString (ThisAgent, thisagent's "TaskPackageIntentCurrent");
			
			if (thisagent's "TaskPackageMoveCurrent" == $move)
				(thisagent's "TaskPackageMoveCurrent")(thisagent, thisagent's "TaskPackageDestinationCurrent");
				//(thisagent's "TaskPackageMoveCurrent")(thisagent, $listmember(thisagent's "TaskPackageMoveDestinationsCurrent", 1));
			else if (thisagent's "TaskPackageMoveCurrent" == $movewaypoint)
				(thisagent's "TaskPackageMoveCurrent")(thisagent, thisagent's "TaskPackageMoveDestinationsCurrent");
		end
	else
		begin
			thisagent's "ActiveScript" = $Generic_Tree;
			thisagent's "TaskPackageTargetActionBackup" = $Search_For_Task;
			thisagent's "TaskPackageVar" = thisagent's "TaskPackageSet"; //Tasks should not update simultaneously. Current must update first. Then Next and Backup can update simultaneously following that. Reserve updates last.
			thisagent's "TaskPackageTypeIndex" = "Current";				 //Otherwise the function that catches duplicates fails.
			$Search_For_Task(thisagent);
		end
end
///////////////////////////////////////////////////////////////////////////////
function NextTaskSequence (agent thisagent, string thistask, string nexttask)

declare

begin
	thisagent's ("TaskPackageTargetCondition" + thistask) = thisagent's ("TaskPackageTargetCondition" + nexttask);
	thisagent's ("TaskPackageDestination" + thistask) = thisagent's ("TaskPackageDestination" + nexttask);
	thisagent's ("TaskPackageTarget" + thistask) = thisagent's ("TaskPackageTarget" + nexttask);
	thisagent's ("TaskPackageTarget2" + thistask) = thisagent's ("TaskPackageTarget2" + nexttask);
	thisagent's ("TaskPackageTargetAction" + thistask) = thisagent's ("TaskPackageTargetAction" + nexttask);
	thisagent's ("TaskPackageTargetAction2" + thistask) = thisagent's ("TaskPackageTargetAction2" + nexttask);
	thisagent's ("TaskPackageTaskName" + thistask) = thisagent's ("TaskPackageTaskName" + nexttask);
	thisagent's ("TaskPackageIntent" + thistask) = thisagent's ("TaskPackageIntent" + nexttask);
	thisagent's ("TaskPackageMove" + thistask) = thisagent's ("TaskPackageMove" + nexttask);
	thisagent's ("TaskPackageMoveDestinations" + thistask) = thisagent's ("TaskPackageMoveDestinations" + nexttask);
	thisagent's ("TaskPackageMoveAgents" + thistask) = thisagent's ("TaskPackageMoveAgents" + nexttask);
	thisagent's ("TaskPackageVisitingScript" + thistask) = thisagent's ("TaskPackageVisitingScript" + nexttask);
			
end

///////////////////////////////////////////////////////////////////////////////
function NotDuplicateTask (agent thisagent, string index) is boolean
//Checks to see if the task is a duplicate of other ones

declare
	boolean flag;
	string targetsub, completetarget, othertarget, actionsub, completeaction, otheraction;
	
begin
	flag = TRUE;
	targetsub = "TaskPackageTarget";
	completetarget = targetsub + index;
	actionsub = "TaskPackageTargetAction";
	completeaction = actionsub + index;
		
	if (index != "Current") //If Backup/Next/Reserve or any other index are duplicates of Current, then return false
		begin
			othertarget = targetsub + "Current";
			otheraction = actionsub + "Current";
			if ((thisagent's completetarget == thisagent's othertarget) && (thisagent's completeaction == thisagent's otheraction))
				begin
					thisagent's completeaction = $Search_For_Task;
					return False;
				end
		
			if (index == "Reserve") //If Reserve is a duplicate of Backup or Next, then return false
				begin
					othertarget = targetsub + "Backup";
					otheraction = actionsub + "Backup";
					if ((thisagent's completetarget == thisagent's othertarget) && (thisagent's completeaction == thisagent's otheraction))
						begin
							thisagent's completeaction = $Search_For_Task;
							return False;
						end
						
					othertarget = targetsub + "Next";
					otheraction = actionsub + "Next";
					if ((thisagent's completetarget == thisagent's othertarget) && (thisagent's completeaction == thisagent's otheraction))
						begin
							thisagent's completeaction = $Search_For_Task;
							return False;
						end
				end
		end
		
	return true;
end

///////////////////////////////////////////////////////////////////////////////
function General_Task_Cycle (agent thisagent)
//This function cycles every few seconds to adjust the hero's task packets.
declare
	boolean flag, resting, in_combat;
	integer exhaustion, fear;

begin
	exhaustion = thisagent's "Exhaustion";
	fear = thisagent's "Fear";
	
	in_combat = thisagent's "In_Combat";
	resting = $InsideBuilding(thisagent);
	if (resting)
		begin
			thisagent's "Fear" = 0;
			if (exhaustion >= 50)
				thisagent's "Exhaustion" -= 50;
			else if (exhaustion != 0)
				thisagent's "Exhaustion" = 0;
		end
	else
		begin
			if (in_combat)
				thisagent's "exhaustion" += 5;
			else if ( thisagent's "fear" > 0)
				thisagent's "fear"--;
		end
		
	flag = true;

	if (thisagent's "TaskPackageTargetActionCurrent" == $Search_For_Task) //If Current needs to be updated, then so does Backup
		begin															//Current should only every go through this once, after that is switches to Next/Reserved/Backup instead of searching again.
			thisagent's "TaskPackageVar" = thisagent's "TaskPackageSet"; //Tasks should not update simultaneously. Current must update first. Then Next and Backup can update simultaneously following that. Reserve updates last.
			thisagent's "TaskPackageTypeIndex" = "Current";				 //Otherwise the function that catches duplicates fails.
			if (resting == false && thisagent's "Exhaustion" >= 500) //Dead tired, so do this asap
				thisagent's "TaskPackageVar" = "Idle";
			$Search_For_Task(thisagent);
			thisagent's "TaskPackageTargetActionBackup" = $Search_For_Task;
			flag = false;
		end
		
	if (flag == false)
		return; //Return here since Current needs to update by itself first to prevent duplicates with Next/Backup

	if (thisagent's "TaskPackageTargetActionNext" == $Search_For_Task)
		begin															//Next must not update simultaneously with Reserve. It can update simultaneously with Backup, since they don't directly conflict.
			thisagent's "TaskPackageVar" = thisagent's "TaskPackageSet";
			if (resting == false && thisagent's "Exhaustion" >= 350) //More tired, so look for a few places to sleep
				thisagent's "TaskPackageVar" = "Idle";
			thisagent's "TaskPackageTypeIndex" = "Next";
			$Search_For_Task(thisagent);
			flag = false;
		end

	if (flag == false)
		return; //Reserve must update at the end, and alone, not simultaneously with other tasks.

	// this can be chosen simultaneously with Next
	if (thisagent's "TaskPackageTargetActionBackup" == $Search_For_Task)
		begin
			thisagent's "TaskPackageVar" = thisagent's "TaskPackageSet";
			if (resting == false && thisagent's "Exhaustion" >= 350) //More tired, so look for a few places to sleep
				thisagent's "TaskPackageVar" = "Idle";
			thisagent's "TaskPackageTypeIndex" = "Backup";
			$Search_For_Task(thisagent);
			flag = false;
		end
		
	if (flag == false)
		return; //Reserve must update at the end, and alone, not simultaneously with other tasks.

	if (thisagent's "TaskPackageTargetActionReserve" == $Search_For_Task) 
		begin
			thisagent's "TaskPackageVar" = thisagent's "TaskPackageSet";
			if (resting == false && thisagent's "Exhaustion" >= 200) //Tired, so start looking for a place to sleep
				thisagent's "TaskPackageVar" = "Idle";
			thisagent's "TaskPackageTypeIndex" = "Reserve";
			$Search_For_Task(thisagent);
		end
end
///////////////////////////////////////////////////////////////////////////////
function Search_For_Task (agent thisagent)
//This function searches for new tasks for packets lacking one.
//This function should NOT have any setting for Primary/Current/Next/etc. Tasks
declare
	string taskindex, completetype, tasktype, subindex, index, orderindex;
	string type, indexlist, completeindex, threshold, subthresh, current, subcurrent;
	integer size, rand, chance_total;
	boolean flag;

begin
	flag = FALSE;
	indexlist =	"TaskPackageIndexList";
	subindex = "TaskPackageIndex";
	//tasktype = "TaskPackageType"; //This currently isn't being set anywhere, determine if it is obsolete by another field.
	//orderindex = thisagent's "TaskPackageTypeIndex"; // Is this for the Current/Backup/Next? //Isn't used here yet, obsolete?
	taskindex = thisagent's "TaskPackageVar";
	//completetype = tasktype + taskindex; // For Example, "TaskPackageType" + "Combat"
	index = subindex + taskindex; //This is "TaskPackageIndex" + "Combat"
	
	completeindex = indexlist + taskindex;
	
	if (taskindex == thisagent's "TaskPackageSet")
		begin
			flag = TRUE;
			subthresh = "TaskThreshold";
			subcurrent = "Task";
			threshold = subthresh + taskindex;//Right now current is the same as threshold, this results in the taskindex switching between prepare and combat each time.
			current = subcurrent + taskindex;
		end
	
	size = $listsize(thisagent's completeindex); //Is compiling as "TaskPackageIndexList" without the type included
	rand = $RandomNumberNonZero(size);
		
	thisagent's "TaskPackageListIndex" = $listmember(thisagent's index, rand); //This gives the index # for the task set for the agent. Needs to happen before the If/then
	
	if (($listmember((thisagent's completeindex),rand))(thisagent)) //Need an else for when a task is returning negative constantly.
		begin
			thisagent's "TaskSearch_Limit" = 0;
			if (flag)
				begin
					thisagent's current ++;
					if (thisagent's current >= thisagent's threshold)
						begin
							thisagent's current = 0;
							if (taskindex == "Prepare")
								begin
									chance_total = $RandomNumberNonZero(thisagent's "TaskChanceCombat" + thisagent's "TaskChanceExplore" + thisagent's "TaskChanceIdle");
									if (thisagent's "TaskChanceCombat" <= chance_total)
										thisagent's "TaskPackageSet" = "Combat";
									else if (thisagent's "TaskChanceCombat" +  thisagent's "TaskChanceExplore" <= chance_total)
										thisagent's "TaskPackageSet" = "Explore";
									else
										thisagent's "TaskPackageSet" = "Idle";
								end
							else
								begin
									thisagent's "TaskPackageSet" = "Prepare";
								end
						end
				end
		end
	else
		begin
			thisagent's "TaskSearch_Limit" ++;
			if (thisagent's "TaskSearch_Limit" > 20)
				begin
					thisagent's "TaskSearch_Limit" -= 10;
					if (taskindex == "Prepare")
						begin
							chance_total = $RandomNumberNonZero(thisagent's "TaskChanceCombat" + thisagent's "TaskChanceExplore" + thisagent's "TaskChanceIdle");
							if (thisagent's "TaskChanceCombat" <= chance_total)
								thisagent's "TaskPackageSet" = "Combat";
							else if (thisagent's "TaskChanceCombat" +  thisagent's "TaskChanceExplore" <= chance_total)
								thisagent's "TaskPackageSet" = "Explore";
							else
								thisagent's "TaskPackageSet" = "Idle";
						end
					else
						begin
							thisagent's "TaskPackageSet" = "Prepare";
						end
				end
		end
end
///////////////////////////////////////////////////////////////////////////////
function SetTaskParametersBasic (agent thisagent, string name, integer chance, string type)
//This function searches for new tasks for packets lacking one.

declare

begin
	thisagent's "TaskPackageCombineStringList" << name;
	thisagent's "TaskPackageCombineIntegerList" << chance;
	thisagent's "TaskPackageTypeList" << type;

end
///////////////////////////////////////////////////////////////////////////////
function SetTaskParametersExtended (agent thisagent, function Task, function Condition, string name, integer chance, string type)
//This function searches for new tasks for packets lacking one.

declare

begin
	thisagent's "TaskPackageCombineFunctionList" << Task;
	thisagent's "TaskPackageCombineConditionList" << Condition;
	thisagent's "TaskPackageCombineStringList" << name;
	thisagent's "TaskPackageCombineIntegerList" << chance;
	thisagent's "TaskPackageTypeList" << type;

end

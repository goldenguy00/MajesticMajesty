///////////////////////////////////////////////////////////////////////////////
Function SellLoot_Check_Packet (agent ThisAgent,list potentials) is boolean
Declare
	integer	Intel_Roll, Loot_Value, Loot_Mod, Intent_Mod; 
	string actionsub, intentsub, targetsub, tnamesub, taskindex, completeaction, completeintent, completetarget, completetname;
	string conditionsub, completecondition;


Begin
	//$DebugOut ("Should I sell my Loot?");
	
	Loot_Value = $Total_Loot_Value(thisagent);
	
	if (Loot_Value < 100)
		return false;
	
	taskindex = thisagent's "TaskPackageTypeIndex";
	actionsub = "TaskPackageTargetAction";
	intentsub = "TaskPackageIntent";
	targetsub = "TaskPackageTarget";
	tnamesub = "TaskPackageTaskName";
	completeaction = actionsub + taskindex;
	completeintent = intentsub + taskindex;
	completetarget = targetsub + taskindex;
	completetname = tnamesub + taskindex;

	conditionsub = "TaskPackageTargetCondition";
	completecondition = conditionsub + taskindex;
	
	Loot_Mod = (Loot_Value / 10);
	
	Intent_Mod = $RandomNumber (30);
	
	if (Loot_Mod > Intent_Mod)
		Loot_Mod = Intent_Mod;
	
	If ($ListSize (Potentials) == 0)
		begin
			//$DebugOut ("There either aren't any Potion Shops, or they aren't close enough to me!");
			return False;
		end

	Else
		begin
			Intel_Roll = Intent_Mod + 1 - Loot_Mod;
			If ($GetAttribute (ThisAgent, #ATTRIB_Intelligence) > Intel_Roll)
				begin
					ThisAgent's completetname = "Sell_Loot";
					ThisAgent's completetarget = $Loyalty_Mod_Pick_Closest (ThisAgent, Potentials);
					//$DebugOut ("Yes!");
					Thisagent's completeintent = "IDTXT_INTENT_SELLLOOT";
					return True;
				end
		end

	//$DebugOut ("No!");
	return False;

End


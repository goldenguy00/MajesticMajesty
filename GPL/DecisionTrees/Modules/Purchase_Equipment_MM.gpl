//	//Find all Markets that have researched the ring
//	Potentials = $listtitlesinRadius (ThisAgent, "Building", "MarketPlace", Search_Dist);

	Potentials = $List_Attribs (Potentials, #ATTRIB_ResearchRingsofProtection );

	If ($ListSize (Potentials) == 0)
		begin
			// //$DebugOut ("There either aren't any Markets that have researched Rings of Prot, or they aren't close enough!");
			return False;
		end

	Else
		begin
			Intel_Roll = $RandomNumber (30) + 1;
			If ($GetAttribute (ThisAgent, #ATTRIB_Intelligence) > Intel_Roll)
				begin
					ThisAgent's completetname = "Ring_Protection";
					ThisAgent's completetarget = $Loyalty_Mod_Pick_Closest (ThisAgent, Potentials);

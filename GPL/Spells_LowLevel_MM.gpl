/////////////////////////////////////////////////////////////////////////////////////////////////
function BasicCastFollowAlly_hero( agent thisagent, agent target, string buff_name, string spell_name ) is agent
// Return a viable allied target for support spell while following and supporting another hero.
declare
	agent newtarget, picked;
	list potential_targets, spell_targets;
	string unit_name;
	integer targetrange, attackrange, castrange, count;
	
begin
	unit_name = thisagent's "title";
	newtarget = $NullAgent();
	attackrange = $getattribute(thisagent, #ATTRIB_maxattackrange);
	castrange = (thisagent's "castingrange");
	
	castrange = $CastRangeForSpell(castrange, spell_name);
	
	if ((target's "Type" != "Building") && (target's "Type" != "Lair") && $Checkeffector(target,buff_name) != TRUE)
		newtarget = target;
	else
		begin
			$ListObjects(thisagent, "hero", castrange, potential_targets, #MyPlayer);
			count = $listsize(potential_targets);
			if (count > 0)
				begin
					foreach picked in potential_targets do
						begin
							if (($Checkeffector(picked,buff_name) != TRUE) && ($IsDead(picked) != TRUE) && (target's "Type" != "Building") && (target's "Type" != "Lair"))
								begin
									if (picked != thisagent)
										spell_targets << picked;
								end
						end
					if ($listsize(spell_targets) > 0)
						begin
							newtarget = $listmember(spell_targets, 1);
						end
				end
			else if ($Checkeffector(thisagent,buff_name) != TRUE)
				newtarget = thisagent;
		end
		
	return newtarget;
end


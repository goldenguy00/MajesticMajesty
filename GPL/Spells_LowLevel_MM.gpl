	targetrange = $distanceBetweenAgents(thisagent,target);
	
	castrange = $CastRangeForSpell(castrange, spell_name);
	
	if ((target's "Type" == "Building") || (target's "Type" == "Lair"))
		potential_targets = $compile_enemies(thisagent,castrange);
	else if ($Checkeffector(target,buff_name) != TRUE)
		newtarget = target;
	
	count = $listsize(potential_targets);
	if (count > 0)
		begin
			foreach picked in potential_targets do
				begin
					if (($Checkeffector(picked,buff_name) != TRUE) && ($IsDead(picked) != TRUE) && (target's "Type" != "Building") && (target's "Type" != "Lair"))
						begin
							if (picked != thisagent)
								spell_targets << picked;
						end
				end
			if ($listsize(spell_targets) > 0)
				begin
					newtarget = $listmember(spell_targets, 1);

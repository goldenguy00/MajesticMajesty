/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Support( agent thisagent) is string
// List of spells to retrieve for a hero
// Finally arranges on its own based on distance. Only concern would be whether the hero prioritizes other variables in spellcasting.

declare
	string new_spell, unit_name, original_name;
	integer attackrange, count;
	agent target;

begin
	unit_name = thisagent's "title";
	target = thisagent's "Target";
	new_spell = "nothing";
	
	if ($AddAttribute(thisagent, "Original_Title", "string", unit_name) == false)
		original_name = thisagent's "Original_Title";
	
	if ((unit_name == "cultist") || (original_name == "cultist"))
		begin
			if ($CastableSpell_hero(thisagent, target, "change_shape") == TRUE)
				return "change_shape";
		end
		
	else if (unit_name == "Healer")
		begin
			if ($CastableSpell_hero(thisagent, target, "meditation") == TRUE)
				return "meditation";
		end
		
	else if (unit_name == "Monk")
		begin
			if ($CastableSpell_hero(thisagent, target, "hands_of_steel") == TRUE)
				return "hands_of_steel";
			if ($CastableSpell_hero(thisagent, target, "monk_stone_skin") == TRUE)
				return "monk_stone_skin";
			if ($CastableSpell_hero(thisagent, target, "iron_will") == TRUE)
				return "iron_will";
		end
	
	else if (unit_name == "Paladin")
		begin
			if ($CastableSpell_hero(thisagent, target, "shield_of_light") == TRUE)
				return "shield_of_light";
		end
		
	else if ((unit_name == "priestess") || (original_name == "priestess"))
		begin
			if ($CastableSpell_hero(thisagent, target, "priestess_wither") == TRUE)
				return "priestess_wither";
		end
		
	else if (unit_name == "Solarus")
		begin
		end
		
	else if (unit_name == "Wizard")
		begin
			if ($CastableSpell_hero(thisagent, target, "fire_shield") == TRUE)
				return "fire_shield";
			if ($CastableSpell_hero(thisagent, target, "resist_magic") == TRUE)
				return "resist_magic";
			if ($CastableSpell_hero(thisagent, target, "wizard_transmute") == TRUE)
				return "wizard_Transmute";
			
			if ($CastableSpell_hero(thisagent, target, "Searing_Mantle") == TRUE)
				return "Searing_Mantle";
			if ($CastableSpell_hero(thisagent, target, "Pyrelight") == TRUE)
				return "Pyrelight";
			if ($CastableSpell_hero(thisagent, target, "Ignite") == TRUE)
				return "Ignite";
		end
		
	//GENERIC SPELLS
	if ($CastableSpell_hero(thisagent, target, "generic_regenerate") == TRUE)
		return "generic_regenerate";
		
	//GADGET SPELLS
	if ($CastableSpell_hero(thisagent, target, "deploy_dart_sentry") == TRUE)
		return "deploy_dart_sentry";
	
	return "nothing";
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function Spell_List_Attack( agent thisagent ) is string
//Use while instead of foreach as foreach for now
//Do not use return inside of a foreach struct
declare
	agent spell_target, new_target;
	string new_spell, spell_name, condition;

begin
	spell_name = "Nothing";
	new_spell = "Nothing";
	new_target = thisagent's "Target";
	
	if ($HasAttribute("SpellsAttack", thisagent))
	if ($ListSize(thisagent's "SpellsAttack") > 0)
		foreach spell_name in thisagent's "SpellsAttack" do
			if ($CanCast(thisagent, spell_name))
				begin
					spell_target = $EvaluateCondition(thisagent, spell_name);
					if (spell_target != $NullAgent())
						begin
							new_spell = spell_name;
							new_target = spell_target;			//Keep the new spell target consistent with the new spell, otherwise might get null agent targets with valid new spells
						end
				end
	if ($HasAttribute("Spell_Target", thisagent))
		thisagent's "Spell_Target" = new_target;
	return new_spell;
end


///////////////////////////////////////////////////////////////////////////////
function getattackrange(agent thisagent) is integer

declare
	string spell_name;
begin
	// pick a weapon to use - a spell or regular weapon
	spell_name = $Spell_List_Support(thisagent);
	if (spell_name != "nothing")
		return $MaxSpellRange(thisagent's "castingrange", spell_name);
	
	spell_name = $Spell_List_Attack(thisagent);
	if (spell_name != "nothing")
		return $GreatestAttackListRange(thisagent);

	if ($IsSpellCaster(thisagent))
		return $GreatestSpellRangeForHero(thisagent);

	spell_name = $getbestspell(thisagent,#list_attack);
	if (spell_name != "nothing")
		return $GreatestSpellRangeForHero(thisagent);
		
	return $getattribute(thisagent,#ATTRIB_maxattackrange);
		
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function GetSpellCooldown(agent thisagent, integer cooldown) is integer
declare
begin
	cooldown = $ArtificeCooldownReduction_Magic(thisagent, cooldown);
	cooldown = $IntelligenceCooldownReduction(thisagent, cooldown);
	return cooldown;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function HasCooldown(agent thisagent, string spell_name) is boolean
declare
	string cooldown_name;
begin
	cooldown_name = spell_name+"_cooldown";
	if ($HasAttribute(cooldown_name, thisagent))
		return $IsRunning (thisAgent's cooldown_name);
	return false;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function StartCooldown(agent thisagent, string spell_name, integer cooldown)
declare
	string cooldown_name;
begin
	cooldown_name = spell_name+"_cooldown";
	$AddAttribute(thisagent, cooldown_name, "function", $Cooldown_End);
	$NewThread(thisAgent's cooldown_name, cooldown, thisAgent, cooldown_name);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
// A simple cooldown function for various threads that require a simple timer.
function Cooldown_End( agent thisagent, string cooldown_name )
declare
begin
	$KillThread(thisagent's cooldown_name);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function GenericSpellCheck(agent thisagent, string spell_name) is integer
declare
begin
	if ($CanCast(thisagent, spell_name) == false)
		return 0;

	return 1;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function FireTreeCheck(agent thisagent, string spell_name) is integer
declare
begin
	if ($CanCast(thisagent, spell_name) == false)
		return 0;

	if ($EvaluateCondition(thisagent, spell_name) == $NullAgent())
		return 0;
	
	return 1;
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function EvaluateCondition(agent thisagent, string spell_name) is agent
declare
	string spell_condition;
begin
	spell_condition = spell_name+"_Condition";
	if ($HasAttribute(spell_condition, thisagent) == false)
		return $NullAgent();

	return (thisagent's spell_condition)(thisagent, spell_name);
end

/////////////////////////////////////////////////////////////////////////////////////////////////
function SpellDefaultAttackPass( agent thisagent, string spell_name) is agent //For this, return an agent as the pass condition for spells
//Basic fire tree attack spells currently all use this
declare

begin
	return $BasicCastTarget_hero(thisagent, thisagent's "Target", spell_name);
end
/////////////////////////////////////////////////////////////////////////////////////////////////
function CanCast(agent thisagent, string spell_name) is boolean
declare
begin
	if ($isspellAvailable(thisagent, spell_name))
		if ($HasCooldown(thisagent, spell_name) == false)
			return $SpellManaAvailable(thisagent, spell_name);
	return false;
end
/////////////////////////////////////////////////////////////////////////////////////////////////
